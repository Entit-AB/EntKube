# Copy this file to .env and fill in the values before running docker compose.

# --- Domain / TLS ---
# Public domain pointing at this server. Caddy will obtain a Let's Encrypt
# certificate automatically on first start. Port 80 and 443 must be reachable.
DOMAIN=entkube.example.com

# Email used for Let's Encrypt account registration and expiry notices.
ACME_EMAIL=admin@example.com

# --- Registry ---
# Registry to pull the entkube image from. entit.azurecr.io is public — pulls
# need no authentication and no `docker login`. Only override these if you host
# the image in your own registry.
REGISTRY=entit.azurecr.io
IMAGE_TAG=latest

# --- Postgres ---
# Password used by both the postgres service and the app connection string.
POSTGRES_PASSWORD=changeme

# --- Native telemetry / observability ---
# Password for the dedicated postgres-telemetry instance backing the native
# telemetry store (Logs / Traces / Metrics / Dashboards / RUM). Keep it distinct
# from POSTGRES_PASSWORD. If unset, the Telemetry connection stays enabled but
# the two DBs share nothing else. Telemetry__PublicIngestUrl is derived from DOMAIN
# in docker-compose.yml; override there if clusters reach this server on another URL.
TELEMETRY_POSTGRES_PASSWORD=changeme
# Days of telemetry to retain before old daily partitions are dropped.
TELEMETRY_RETENTION_DAYS=14

# --- Vault encryption ---
# 32-byte base64 key for secret encryption.
# Generate with: openssl rand -base64 32
VAULT__ROOTKEY=REPLACE_WITH_BASE64_32_BYTE_KEY
