{
  "DatabaseProvider": "Sqlite",
  "Auth": {
    "AllowRegistration": true
  },
  "Presence": {
    "//": "Live 'online now' backend for the admin users page. 'InMemory' (default) is process-local; set Provider to 'Redis' with ConnectionStrings:Redis for cross-instance presence.",
    "Provider": "InMemory",
    "StaleAfterSeconds": 30,
    "RefreshSeconds": 10
  },
  "ConnectionStrings": {
    "DefaultConnection": "DataSource=Data/app.db;Cache=Shared"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient.RouteHealth": "Warning"
    }
  },
  "AllowedHosts": "*"
}
