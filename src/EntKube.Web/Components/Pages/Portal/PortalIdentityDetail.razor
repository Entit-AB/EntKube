    // ── Portal mapper config helpers (avoids string literals inside HTML attribute quotes) ──

    private string PMapperUserAttr      { get => pNewMapperConfig.GetValueOrDefault("user.attribute", ""); set => pNewMapperConfig["user.attribute"] = value; }
    private string PMapperClaimName     { get => pNewMapperConfig.GetValueOrDefault("claim.name", ""); set => pNewMapperConfig["claim.name"] = value; }
    private string PMapperClaimValue    { get => pNewMapperConfig.GetValueOrDefault("claim.value", ""); set => pNewMapperConfig["claim.value"] = value; }
    private string PMapperJsonType      { get => pNewMapperConfig.GetValueOrDefault("jsonType.label", "String"); set => pNewMapperConfig["jsonType.label"] = value; }
    private string PMapperClientAudience { get => pNewMapperConfig.GetValueOrDefault("included.client.audience", ""); set => pNewMapperConfig["included.client.audience"] = value; }
    private bool   PMapperAccessToken   { get => pNewMapperConfig.GetValueOrDefault("access.token.claim", "true") != "false"; set => pNewMapperConfig["access.token.claim"] = value ? "true" : "false"; }
    private bool   PMapperIdToken       { get => pNewMapperConfig.GetValueOrDefault("id.token.claim", "true") != "false"; set => pNewMapperConfig["id.token.claim"] = value ? "true" : "false"; }
    private bool   PMapperUserinfoToken { get => pNewMapperConfig.GetValueOrDefault("userinfo.token.claim", "true") != "false"; set => pNewMapperConfig["userinfo.token.claim"] = value ? "true" : "false"; }
    private bool   PMapperFullPath      { get => pNewMapperConfig.GetValueOrDefault("full.path", "false") != "false"; set => pNewMapperConfig["full.path"] = value ? "true" : "false"; }

    private void ResetPortalMapper()
    {
        pNewMapperName = "";
        pNewMapperType = "oidc-usermodel-attribute-mapper";
        pNewMapperConfig = [];
        pNewMapperConfig["access.token.claim"] = "true";
        pNewMapperConfig["id.token.claim"] = "true";
        pNewMapperConfig["userinfo.token.claim"] = "true";
        pNewMapperConfig["jsonType.label"] = "String";
    }

    private void ResetPortalMapperConfig()
    {
        pNewMapperConfig = [];
        pNewMapperConfig["access.token.claim"] = "true";
        pNewMapperConfig["id.token.claim"] = "true";
        pNewMapperConfig["userinfo.token.claim"] = "true";
        if (pNewMapperType == "oidc-usermodel-attribute-mapper" || pNewMapperType == "oidc-hardcoded-claim-mapper")
            pNewMapperConfig["jsonType.label"] = "String";
        else if (pNewMapperType == "oidc-group-membership-mapper")
        {
            pNewMapperConfig["claim.name"] = "groups";
            pNewMapperConfig["full.path"] = "false";
        }
    }

    // ── Portal User Edit ─────────────────────────────────────────────────────

    private void OpenPortalUserEdit(KeycloakUserInfo user)
    {
        if (portalSelectedUserId == user.Id) { portalSelectedUserId = null; return; }
        portalSelectedUserId = user.Id;
        portalUserEditTab = "profile";
        portalUserEditError = null;
        portalProfileModel = new PortalUserProfileModel
        {
            FirstName = user.FirstName ?? "",
            LastName = user.LastName ?? "",
            Email = user.Email ?? "",
            Enabled = user.Enabled,
            EmailVerified = user.EmailVerified
        };
        portalPasswordModel = new PortalUserPasswordModel();
        portalEditAttributes = user.Attributes.ToDictionary(kv => kv.Key, kv => string.Join(", ", kv.Value));
        portalNewAttrKey = "";
        portalNewAttrValue = "";
    }

    private async Task SavePortalUserProfile(string userId)
    {
        portalSavingUser = true;
        portalUserEditError = null;
        try
        {
            Dictionary<string, List<string>> attrs = portalEditAttributes
                .Where(kv => !string.IsNullOrWhiteSpace(kv.Key))
                .ToDictionary(kv => kv.Key, kv => new List<string> { kv.Value });
            await KeycloakService.UpdateUserAsync(TenantId, Realm.Id, userId,
                portalProfileModel.FirstName, portalProfileModel.LastName, portalProfileModel.Email,
                portalProfileModel.Enabled, portalProfileModel.EmailVerified, attrs);
            users = await KeycloakService.GetUsersAsync(TenantId, Realm.Id);
        }
        catch (Exception ex) { portalUserEditError = ex.Message; }
        finally { portalSavingUser = false; }
    }

    private async Task SavePortalUserAttributes(string userId)
    {
        portalSavingUser = true;
        portalUserEditError = null;
        try
        {
            Dictionary<string, List<string>> attrs = portalEditAttributes
                .Where(kv => !string.IsNullOrWhiteSpace(kv.Key))
                .ToDictionary(kv => kv.Key, kv => new List<string> { kv.Value });
            await KeycloakService.UpdateUserAsync(TenantId, Realm.Id, userId,
                portalProfileModel.FirstName, portalProfileModel.LastName, portalProfileModel.Email,
                portalProfileModel.Enabled, portalProfileModel.EmailVerified, attrs);
            users = await KeycloakService.GetUsersAsync(TenantId, Realm.Id);
        }
        catch (Exception ex) { portalUserEditError = ex.Message; }
        finally { portalSavingUser = false; }
    }

    private async Task ResetPortalUserPassword(string userId)
    {
        if (string.IsNullOrWhiteSpace(portalPasswordModel.NewPassword)) return;
        portalSavingUser = true;
        portalUserEditError = null;
        try
        {
            await KeycloakService.ResetUserPasswordAsync(TenantId, Realm.Id, userId,
                portalPasswordModel.NewPassword, portalPasswordModel.Temporary);
            portalPasswordModel.NewPassword = "";
        }
        catch (Exception ex) { portalUserEditError = ex.Message; }
        finally { portalSavingUser = false; }
    }

    private void AddPortalUserAttribute()
    {
        if (string.IsNullOrWhiteSpace(portalNewAttrKey)) return;
        portalEditAttributes[portalNewAttrKey.Trim()] = portalNewAttrValue;
        portalNewAttrKey = "";
        portalNewAttrValue = "";
    }

    // ── Portal Clients ────────────────────────────────────────────────────────

    private async Task AddPortalClient()
    {
        pSavingClient = true;
        pClientError = null;
        try
        {
            await KeycloakService.CreateClientAsync(TenantId, Realm.Id, createClientModel.ClientId,
                createClientModel.Public == "true",
                string.IsNullOrWhiteSpace(createClientModel.Name) ? null : createClientModel.Name);
            pClients = await KeycloakService.GetClientsAsync(TenantId, Realm.Id);
            pShowAddClient = false;
            createClientModel = new CreateClientModel();
        }
        catch (Exception ex) { pClientError = ex.Message; }
        finally { pSavingClient = false; }
    }

    private async Task OpenPortalClientEdit(KeycloakClientInfo client)
    {
        if (pSelectedClientUuid == client.Id) { pSelectedClientUuid = null; pClientDetail = null; pClientMappers = null; return; }
        pSelectedClientUuid = client.Id;
        pClientEditTab = "settings";
        pClientEditError = null;
        pClientDetail = null;
        pClientMappers = null;
        pClientSecret = null;
        pShowClientSecret = false;
        try { pClientDetail = await KeycloakService.GetClientAsync(TenantId, Realm.Id, client.Id); }
        catch (Exception ex) { pClientEditError = ex.Message; }
    }

    private async Task SwitchPortalClientTab(string tab)
    {
        pClientEditTab = tab;
        pClientEditError = null;
        if (tab == "secret" && pClientSecret is null && pSelectedClientUuid is not null)
        {
            try { pClientSecret = await KeycloakService.GetClientSecretAsync(TenantId, Realm.Id, pSelectedClientUuid); }
            catch (Exception ex) { pClientEditError = ex.Message; }
        }
        else if (tab == "mappers" && pClientMappers is null && pSelectedClientUuid is not null)
        {
            pLoadingMappers = true;
            StateHasChanged();
            try
            {
                pClientMappers = await KeycloakService.GetClientMappersAsync(TenantId, Realm.Id, pSelectedClientUuid);
                ResetPortalMapper();
            }
            catch (Exception ex) { pClientEditError = ex.Message; }
            finally { pLoadingMappers = false; }
        }
    }

    private async Task SavePortalClientSettings()
    {
        if (pClientDetail is null) return;
        pSavingClient = true;
        pClientEditError = null;
        try
        {
            await KeycloakService.UpdateClientAsync(TenantId, Realm.Id, pClientDetail);
            pClients = await KeycloakService.GetClientsAsync(TenantId, Realm.Id);
        }
        catch (Exception ex) { pClientEditError = ex.Message; }
        finally { pSavingClient = false; }
    }

    private async Task DeletePortalClient(string clientUuid)
    {
        pClientError = null;
        try
        {
            await KeycloakService.DeleteClientAsync(TenantId, Realm.Id, clientUuid);
            if (pSelectedClientUuid == clientUuid) { pSelectedClientUuid = null; pClientDetail = null; }
            pClients = await KeycloakService.GetClientsAsync(TenantId, Realm.Id);
        }
        catch (Exception ex) { pClientError = ex.Message; }
    }

    private async Task RegeneratePortalSecret()
    {
        if (pSelectedClientUuid is null) return;
        pSavingClient = true;
        pClientEditError = null;
        try
        {
            pClientSecret = await KeycloakService.RegenerateClientSecretAsync(TenantId, Realm.Id, pSelectedClientUuid);
            pShowClientSecret = true;
        }
        catch (Exception ex) { pClientEditError = ex.Message; }
        finally { pSavingClient = false; }
    }

    private async Task AddPortalMapper()
    {
        if (pSelectedClientUuid is null || string.IsNullOrWhiteSpace(pNewMapperName)) return;
        pSavingMapper = true;
        pMapperError = null;
        pEditingMapperId = null;
        try
        {
            KeycloakProtocolMapper mapper = new()
            {
                Name = pNewMapperName,
                ProtocolMapper = pNewMapperType,
                Config = new Dictionary<string, string>(pNewMapperConfig)
            };
            await KeycloakService.CreateClientMapperAsync(TenantId, Realm.Id, pSelectedClientUuid, mapper);
            pClientMappers = await KeycloakService.GetClientMappersAsync(TenantId, Realm.Id, pSelectedClientUuid);
            pShowAddMapper = false;
            ResetPortalMapper();
        }
        catch (Exception ex) { pMapperError = ex.Message; }
        finally { pSavingMapper = false; }
    }

    private void OpenPortalMapperEdit(KeycloakProtocolMapper mapper)
    {
        if (pEditingMapperId == mapper.Id) { pEditingMapperId = null; return; }
        pEditingMapperId = mapper.Id;
        pShowAddMapper = false;
        pNewMapperName = mapper.Name;
        pNewMapperType = mapper.ProtocolMapper;
        pNewMapperConfig = new Dictionary<string, string>(mapper.Config);
        pMapperError = null;
    }

    private async Task SavePortalMapperEdit()
    {
        if (pSelectedClientUuid is null || pEditingMapperId is null) return;
        pSavingMapper = true;
        pMapperError = null;
        try
        {
            KeycloakProtocolMapper updated = new()
            {
                Id = pEditingMapperId,
                Name = pNewMapperName,
                ProtocolMapper = pNewMapperType,
                Config = new Dictionary<string, string>(pNewMapperConfig)
            };
            await KeycloakService.UpdateClientMapperAsync(TenantId, Realm.Id, pSelectedClientUuid, updated);
            pClientMappers = await KeycloakService.GetClientMappersAsync(TenantId, Realm.Id, pSelectedClientUuid);
            pEditingMapperId = null;
            ResetPortalMapper();
        }
        catch (Exception ex) { pMapperError = ex.Message; }
        finally { pSavingMapper = false; }
    }

    private async Task DeletePortalMapper(string mapperId)
    {
        if (pSelectedClientUuid is null) return;
        try
        {
            await KeycloakService.DeleteClientMapperAsync(TenantId, Realm.Id, pSelectedClientUuid, mapperId);
            pClientMappers = await KeycloakService.GetClientMappersAsync(TenantId, Realm.Id, pSelectedClientUuid);
        }
        catch (Exception ex) { pClientEditError = ex.Message; }
    }

    // ── Form models (DataAnnotations validation) ─────────────────────────────

    private sealed class CreateUserModel
    {
        [Required(ErrorMessage = "Username is required.")]
        public string Username { get; set; } = "";

        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = "";

        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Password { get; set; } = "";
    }

    private sealed class CreateClientModel
    {
        [Required(ErrorMessage = "Client ID is required.")]
        [RegularExpression(@"^\S+$", ErrorMessage = "Client ID cannot contain spaces.")]
        public string ClientId { get; set; } = "";

        public string Name { get; set; } = "";
        public string Public { get; set; } = "false";
    }

    private sealed class CreateIdpModel
    {
        [Required(ErrorMessage = "Alias is required.")]
        [RegularExpression(@"^\S+$", ErrorMessage = "Alias cannot contain spaces.")]
        public string Alias { get; set; } = "";

        public string ProviderId { get; set; } = "oidc";

        [Required(ErrorMessage = "Client ID is required.")]
        public string ClientId { get; set; } = "";

        [Required(ErrorMessage = "Client secret is required.")]
        public string ClientSecret { get; set; } = "";
    }

    private sealed class CreateGroupModel
    {
        [Required(ErrorMessage = "Group name is required.")]
        public string Name { get; set; } = "";
    }

    private sealed class CreateOrgModel
    {
        [Required(ErrorMessage = "Name is required.")]
        public string Name { get; set; } = "";

        public string Description { get; set; } = "";
    }

    private sealed class PortalUserProfileModel
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";

        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = "";

        public bool Enabled { get; set; }
        public bool EmailVerified { get; set; }
    }

    private sealed class PortalUserPasswordModel
    {
        [Required(ErrorMessage = "Enter a new password.")]
        public string NewPassword { get; set; } = "";

        public bool Temporary { get; set; }
    }

