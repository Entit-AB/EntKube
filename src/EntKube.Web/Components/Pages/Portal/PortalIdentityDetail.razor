@using System.ComponentModel.DataAnnotations
@using EntKube.Web.Data
@using EntKube.Web.Services
@inject KeycloakService KeycloakService

@* Realm management for customer portal — same as IdentityTab realm detail
   but without the ability to create realms or manage themes. *@

<div class="d-flex align-items-center justify-content-between mb-3">
    <div class="d-flex align-items-center gap-2">
        <i class="bi bi-shield-lock fs-4 text-primary"></i>
        <div>
            <h5 class="mb-0">@Realm.DisplayName</h5>
            <small class="text-muted font-monospace">@Realm.RealmName</small>
        </div>
    </div>
</div>

<ul class="nav nav-tabs mb-3 flex-wrap" role="tablist" aria-label="Realm sections">
    @foreach (string tab in new[] { "users", "clients", "idp", "groups", "orgs" })
    {
        string label = tab switch
        {
            "users" => "Users",
            "clients" => "Clients",
            "idp" => "Identity Providers",
            "groups" => "Groups",
            "orgs" => "Organizations",
            _ => tab
        };
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == tab ? "active" : "")"
                    role="tab" aria-selected="@(activeTab == tab)" tabindex="@(activeTab == tab ? 0 : -1)"
                    @onclick="() => SwitchTab(tab)">@label</button>
        </li>
    }
</ul>

@* ── Users ── *@
@if (activeTab == "users")
{
    <LoadingPanel Loading="@loadingUsers">
    @if (!loadingUsers)
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="text-muted small">@(users?.Count ?? 0) users</span>
            <button class="btn btn-sm btn-primary" @onclick="() => showAddUser = !showAddUser">
                <i class="bi bi-person-plus me-1"></i>Add User
            </button>
        </div>

        @if (showAddUser)
        {
            <div class="card mb-3 border-primary-subtle">
                <div class="card-body">
                    @if (userError is not null)
                    {
                        <div class="alert alert-danger py-2 small">@userError</div>
                    }
                    <EditForm Model="createUserModel" OnValidSubmit="AddUser">
                        <DataAnnotationsValidator />
                        <div class="row g-2">
                            <div class="col-md-4">
                                <InputText class="form-control form-control-sm" placeholder="Username" @bind-Value="createUserModel.Username" />
                                <ValidationMessage For="() => createUserModel.Username" class="text-danger small" />
                            </div>
                            <div class="col-md-4">
                                <InputText class="form-control form-control-sm" placeholder="Email" @bind-Value="createUserModel.Email" />
                                <ValidationMessage For="() => createUserModel.Email" class="text-danger small" />
                            </div>
                            <div class="col-md-2">
                                <InputText class="form-control form-control-sm" placeholder="First name" @bind-Value="createUserModel.FirstName" />
                            </div>
                            <div class="col-md-2">
                                <InputText class="form-control form-control-sm" placeholder="Last name" @bind-Value="createUserModel.LastName" />
                            </div>
                            <div class="col-md-4">
                                <InputText type="password" class="form-control form-control-sm" placeholder="Password (optional)" @bind-Value="createUserModel.Password" />
                            </div>
                        </div>
                        <div class="mt-2 d-flex gap-2">
                            <button type="submit" class="btn btn-sm btn-primary" disabled="@savingUser">
                                @if (savingUser) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Create
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => showAddUser = false">Cancel</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        }

        @if (users is not null)
        {
            <div class="list-group">
                @foreach (KeycloakUserInfo user in users)
                {
                    <div class="list-group-item py-2">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <strong>@user.Username</strong>
                                <span class="text-muted small ms-2">@user.Email</span>
                                @if (!user.Enabled)
                                {
                                    <span class="badge bg-secondary-subtle text-secondary ms-1 small">Disabled</span>
                                }
                                @if (!user.EmailVerified)
                                {
                                    <span class="badge bg-warning-subtle text-warning ms-1 small">Unverified</span>
                                }
                                @if (user.Attributes.Count > 0)
                                {
                                    <div class="mt-1 d-flex flex-wrap gap-1">
                                        @foreach (KeyValuePair<string, List<string>> attr in user.Attributes)
                                        {
                                            <span class="badge bg-light text-secondary border font-monospace"
                                                  style="font-size:0.7rem">
                                                @attr.Key: @string.Join(", ", attr.Value)
                                            </span>
                                        }
                                    </div>
                                }
                            </div>
                            <div class="d-flex gap-1 ms-2">
                                <button class="btn btn-sm btn-outline-secondary border-0"
                                        aria-label="@($"Edit user {user.Username}")"
                                        @onclick="() => OpenPortalUserEdit(user)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger border-0"
                                        aria-label="@($"Delete user {user.Username}")"
                                        @onclick="() => confirmDeleteUserId = user.Id">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                        @if (confirmDeleteUserId == user.Id)
                        {
                            <ConfirmDialog Visible="true"
                                           Message="@($"Delete user '{user.Username}'? This cannot be undone.")"
                                           ConfirmText="Delete"
                                           IsBusy="deletingItem"
                                           OnConfirm="() => DeleteUser(user.Id)"
                                           OnCancel="() => confirmDeleteUserId = null" />
                        }
                        @if (portalSelectedUserId == user.Id)
                        {
                            <div class="mt-2 p-3 bg-light border rounded">
                                @if (portalUserEditError is not null)
                                {
                                    <div class="alert alert-danger py-2 small mb-2">@portalUserEditError</div>
                                }
                                <ul class="nav nav-tabs mb-3 nav-sm" role="tablist" aria-label="User settings">
                                    @foreach (string ut in new[] { "profile", "attributes", "password" })
                                    {
                                        <li class="nav-item" role="presentation">
                                            <button class="nav-link py-1 px-2 small @(portalUserEditTab == ut ? "active" : "")"
                                                    role="tab" aria-selected="@(portalUserEditTab == ut)" tabindex="@(portalUserEditTab == ut ? 0 : -1)"
                                                    @onclick="() => portalUserEditTab = ut">
                                                @(ut switch { "profile" => "Profile", "attributes" => "Attributes", "password" => "Password", _ => ut })
                                            </button>
                                        </li>
                                    }
                                    <li class="ms-auto">
                                        <button class="btn btn-sm btn-link text-muted py-1"
                                                aria-label="Close"
                                                @onclick="() => portalSelectedUserId = null">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </li>
                                </ul>

                                @if (portalUserEditTab == "profile")
                                {
                                    <EditForm Model="portalProfileModel" OnValidSubmit="() => SavePortalUserProfile(user.Id)">
                                        <DataAnnotationsValidator />
                                        <div class="row g-2" style="max-width:520px">
                                            <div class="col-md-6">
                                                <label class="form-label small">First Name</label>
                                                <InputText class="form-control form-control-sm" @bind-Value="portalProfileModel.FirstName" />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">Last Name</label>
                                                <InputText class="form-control form-control-sm" @bind-Value="portalProfileModel.LastName" />
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label small">Email</label>
                                                <InputText class="form-control form-control-sm" type="email" @bind-Value="portalProfileModel.Email" />
                                                <ValidationMessage For="() => portalProfileModel.Email" class="text-danger small" />
                                            </div>
                                            <div class="col-12 d-flex gap-3">
                                                <div class="form-check">
                                                    <InputCheckbox class="form-check-input" id="@($"peEnabled_{user.Id}")" @bind-Value="portalProfileModel.Enabled" />
                                                    <label class="form-check-label small" for="peEnabled_@user.Id">Enabled</label>
                                                </div>
                                                <div class="form-check">
                                                    <InputCheckbox class="form-check-input" id="@($"peVerified_{user.Id}")" @bind-Value="portalProfileModel.EmailVerified" />
                                                    <label class="form-check-label small" for="peVerified_@user.Id">Email Verified</label>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <button type="submit" class="btn btn-sm btn-primary"
                                                        disabled="@portalSavingUser">
                                                    @if (portalSavingUser) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                    Save
                                                </button>
                                            </div>
                                        </div>
                                    </EditForm>
                                }

                                @if (portalUserEditTab == "attributes")
                                {
                                    <div style="max-width:520px">
                                        @foreach (KeyValuePair<string, string> attr in portalEditAttributes)
                                        {
                                            string attrKey = attr.Key;
                                            <div class="d-flex gap-2 mb-2 align-items-center">
                                                <input class="form-control form-control-sm font-monospace"
                                                       style="max-width:180px" value="@attr.Key" disabled />
                                                <input class="form-control form-control-sm"
                                                       value="@attr.Value"
                                                       @oninput="e => portalEditAttributes[attrKey] = e.Value?.ToString() ?? string.Empty" />
                                                <button class="btn btn-sm btn-outline-danger border-0"
                                                        aria-label="Remove attribute"
                                                        @onclick="() => portalEditAttributes.Remove(attrKey)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        }
                                        <div class="d-flex gap-2 mb-3 align-items-center">
                                            <input class="form-control form-control-sm font-monospace"
                                                   style="max-width:180px" placeholder="attribute key"
                                                   @bind="portalNewAttrKey" />
                                            <input class="form-control form-control-sm" placeholder="value"
                                                   @bind="portalNewAttrValue" />
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    aria-label="Add attribute"
                                                    @onclick="AddPortalUserAttribute"
                                                    disabled="@string.IsNullOrWhiteSpace(portalNewAttrKey)">
                                                <i class="bi bi-plus-lg"></i>
                                            </button>
                                        </div>
                                        <button class="btn btn-sm btn-primary" @onclick="() => SavePortalUserAttributes(user.Id)"
                                                disabled="@portalSavingUser">
                                            @if (portalSavingUser) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                            Save Attributes
                                        </button>
                                    </div>
                                }

                                @if (portalUserEditTab == "password")
                                {
                                    <EditForm Model="portalPasswordModel" OnValidSubmit="() => ResetPortalUserPassword(user.Id)">
                                        <DataAnnotationsValidator />
                                        <div class="row g-2" style="max-width:360px">
                                            <div class="col-12">
                                                <label class="form-label small">New Password</label>
                                                <InputText class="form-control form-control-sm" type="password" @bind-Value="portalPasswordModel.NewPassword" />
                                                <ValidationMessage For="() => portalPasswordModel.NewPassword" class="text-danger small" />
                                            </div>
                                            <div class="col-12">
                                                <div class="form-check">
                                                    <InputCheckbox class="form-check-input" id="@($"peTemp_{user.Id}")" @bind-Value="portalPasswordModel.Temporary" />
                                                    <label class="form-check-label small" for="peTemp_@user.Id">Temporary (user must change on next login)</label>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <button type="submit" class="btn btn-sm btn-primary"
                                                        disabled="@portalSavingUser">
                                                    @if (portalSavingUser) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                    Set Password
                                                </button>
                                            </div>
                                        </div>
                                    </EditForm>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }
    </LoadingPanel>
}

@* ── Clients ── *@
@if (activeTab == "clients")
{
    <LoadingPanel Loading="@pLoadingClients">
    @if (!pLoadingClients)
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="text-muted small">@(pClients?.Count ?? 0) clients</span>
            <button class="btn btn-sm btn-primary" @onclick="() => pShowAddClient = !pShowAddClient">
                <i class="bi bi-plus-circle me-1"></i>Add Client
            </button>
        </div>

        @if (pShowAddClient)
        {
            <div class="card mb-3 border-primary-subtle">
                <div class="card-body">
                    @if (pClientError is not null)
                    {
                        <div class="alert alert-danger py-2 small">@pClientError</div>
                    }
                    <EditForm Model="createClientModel" OnValidSubmit="AddPortalClient">
                        <DataAnnotationsValidator />
                        <div class="row g-2">
                            <div class="col-md-4">
                                <label class="form-label small">Client ID</label>
                                <InputText class="form-control form-control-sm font-monospace" placeholder="my-app" @bind-Value="createClientModel.ClientId" />
                                <ValidationMessage For="() => createClientModel.ClientId" class="text-danger small" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Name (optional)</label>
                                <InputText class="form-control form-control-sm" @bind-Value="createClientModel.Name" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Type</label>
                                <InputSelect class="form-select form-select-sm" @bind-Value="createClientModel.Public">
                                    <option value="false">Confidential (server-side app)</option>
                                    <option value="true">Public (SPA / mobile)</option>
                                </InputSelect>
                            </div>
                        </div>
                        <div class="mt-2 d-flex gap-2">
                            <button type="submit" class="btn btn-sm btn-primary" disabled="@pSavingClient">
                                @if (pSavingClient) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Create
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => pShowAddClient = false">Cancel</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        }

        @if (pClients is not null)
        {
            <div class="list-group">
                @foreach (KeycloakClientInfo client in pClients)
                {
                    bool isPClientExpanded = pSelectedClientUuid == client.Id;
                    <div class="list-group-item py-2">
                        <div class="d-flex justify-content-between align-items-center"
                             style="cursor:pointer" @onclick="() => OpenPortalClientEdit(client)">
                            <div>
                                <i class="bi bi-app me-2 text-muted"></i>
                                <strong>@client.ClientId</strong>
                                @if (!string.IsNullOrWhiteSpace(client.Name) && client.Name != client.ClientId)
                                {
                                    <span class="text-muted ms-2 small">@client.Name</span>
                                }
                                @if (client.PublicClient)
                                    { <span class="badge bg-info-subtle text-info ms-2 small">public</span> }
                                else if (client.BearerOnly)
                                    { <span class="badge bg-secondary-subtle text-secondary ms-2 small">bearer-only</span> }
                                else
                                    { <span class="badge bg-primary-subtle text-primary ms-2 small">confidential</span> }
                                @if (!client.Enabled)
                                {
                                    <span class="badge bg-secondary-subtle text-secondary ms-1 small">disabled</span>
                                }
                            </div>
                            <div class="d-flex gap-1" @onclick:stopPropagation>
                                <button class="btn btn-sm btn-outline-danger border-0"
                                        aria-label="@($"Delete client {client.ClientId}")"
                                        @onclick="() => DeletePortalClient(client.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>

                        @if (isPClientExpanded && pClientDetail is not null)
                        {
                            <div class="mt-2 border-top pt-2">
                                @if (pClientEditError is not null)
                                {
                                    <div class="alert alert-danger py-1 small mb-2">@pClientEditError</div>
                                }
                                <ul class="nav nav-tabs mb-3 nav-sm" role="tablist" aria-label="Client settings">
                                    @foreach (string ct in new[] { "settings", "secret", "mappers" }
                                        .Where(t => !(t == "secret" && pClientDetail!.PublicClient)))
                                    {
                                        <li class="nav-item" role="presentation">
                                            <button class="nav-link py-1 px-2 small @(pClientEditTab == ct ? "active" : "")"
                                                    role="tab" aria-selected="@(pClientEditTab == ct)" tabindex="@(pClientEditTab == ct ? 0 : -1)"
                                                    @onclick="() => SwitchPortalClientTab(ct)">
                                                @(ct switch { "settings" => "Settings", "secret" => "Credentials", "mappers" => "Mappers", _ => ct })
                                            </button>
                                        </li>
                                    }
                                </ul>

                                @if (pClientEditTab == "settings")
                                {
                                    <div class="row g-2" style="max-width:560px">
                                        <div class="col-md-6">
                                            <label class="form-label small">Name</label>
                                            <input class="form-control form-control-sm" @bind="pClientDetail.Name" />
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label small">Description</label>
                                            <input class="form-control form-control-sm" @bind="pClientDetail.Description" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small">Base URL</label>
                                            <input class="form-control form-control-sm font-monospace" @bind="pClientDetail.BaseUrl" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small">Root URL</label>
                                            <input class="form-control form-control-sm font-monospace" @bind="pClientDetail.RootUrl" />
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label small">Valid Redirect URIs <span class="text-muted">(one per line)</span></label>
                                            <textarea class="form-control form-control-sm font-monospace" rows="3"
                                                      value="@string.Join("\n", pClientDetail.RedirectUris)"
                                                      @oninput="e => pClientDetail.RedirectUris = (e.Value?.ToString() ?? string.Empty).Split('\n', StringSplitOptions.RemoveEmptyEntries).ToList()"></textarea>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label small">Web Origins <span class="text-muted">(one per line)</span></label>
                                            <textarea class="form-control form-control-sm font-monospace" rows="2"
                                                      value="@string.Join("\n", pClientDetail.WebOrigins)"
                                                      @oninput="e => pClientDetail.WebOrigins = (e.Value?.ToString() ?? string.Empty).Split('\n', StringSplitOptions.RemoveEmptyEntries).ToList()"></textarea>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label small d-block mb-1">Flows</label>
                                            <div class="d-flex flex-wrap gap-3">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" id="pStdFlow" @bind="pClientDetail.StandardFlowEnabled" />
                                                    <label class="form-check-label small" for="pStdFlow">Standard (Authorization Code)</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" id="pDirectAccess" @bind="pClientDetail.DirectAccessGrantsEnabled" />
                                                    <label class="form-check-label small" for="pDirectAccess">Direct Access Grants</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" id="pSvcAcct" @bind="pClientDetail.ServiceAccountsEnabled" />
                                                    <label class="form-check-label small" for="pSvcAcct">Service Accounts</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" id="pEnabled" @bind="pClientDetail.Enabled" />
                                                    <label class="form-check-label small" for="pEnabled">Enabled</label>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-12 mt-1">
                                            <button class="btn btn-sm btn-primary" @onclick="SavePortalClientSettings"
                                                    disabled="@pSavingClient">
                                                @if (pSavingClient) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                Save Settings
                                            </button>
                                        </div>
                                    </div>
                                }

                                @if (pClientEditTab == "secret")
                                {
                                    <div style="max-width:420px">
                                        <label class="form-label small">Client Secret</label>
                                        <div class="input-group input-group-sm mb-2">
                                            <input class="form-control form-control-sm font-monospace"
                                                   type="@(pShowClientSecret ? "text" : "password")"
                                                   value="@pClientSecret" readonly />
                                            <button class="btn btn-outline-secondary" aria-label="@(pShowClientSecret ? "Hide secret" : "Show secret")" @onclick="() => pShowClientSecret = !pShowClientSecret">
                                                <i class="bi bi-@(pShowClientSecret ? "eye-slash" : "eye")"></i>
                                            </button>
                                        </div>
                                        <button class="btn btn-sm btn-warning" @onclick="RegeneratePortalSecret"
                                                disabled="@pSavingClient">
                                            @if (pSavingClient) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                            Regenerate Secret
                                        </button>
                                    </div>
                                }

                                @if (pClientEditTab == "mappers")
                                {
                                    @if (pLoadingMappers)
                                    {
                                        <div class="spinner-border spinner-border-sm text-primary"></div>
                                    }
                                    else
                                    {
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <span class="text-muted small">@(pClientMappers?.Count ?? 0) mappers</span>
                                            <button class="btn btn-sm btn-outline-primary border-0"
                                                    @onclick="() => { pShowAddMapper = !pShowAddMapper; pEditingMapperId = null; ResetPortalMapper(); }">
                                                <i class="bi bi-plus-lg me-1"></i>Add Mapper
                                            </button>
                                        </div>

                                        @if (pShowAddMapper)
                                        {
                                            <div class="card mb-3 border-primary-subtle">
                                                <div class="card-body p-2">
                                                    @if (pMapperError is not null)
                                                    {
                                                        <div class="alert alert-danger py-1 small mb-2">@pMapperError</div>
                                                    }
                                                    <div class="row g-2">
                                                        <div class="col-md-5">
                                                            <label class="form-label small">Name</label>
                                                            <input class="form-control form-control-sm" @bind="pNewMapperName" />
                                                        </div>
                                                        <div class="col-md-7">
                                                            <label class="form-label small">Type</label>
                                                            <select class="form-select form-select-sm" @bind="pNewMapperType" @bind:after="ResetPortalMapperConfig">
                                                                <option value="oidc-usermodel-attribute-mapper">User Attribute → Claim</option>
                                                                <option value="oidc-usermodel-property-mapper">User Property → Claim</option>
                                                                <option value="oidc-group-membership-mapper">Group Membership → Claim</option>
                                                                <option value="oidc-hardcoded-claim-mapper">Hardcoded Claim</option>
                                                                <option value="oidc-audience-mapper">Audience</option>
                                                                <option value="oidc-full-name-mapper">Full Name</option>
                                                                <option value="oidc-role-name-mapper">Role Name</option>
                                                            </select>
                                                        </div>
                                                        @if (pNewMapperType == "oidc-usermodel-attribute-mapper")
                                                        {
                                                            <div class="col-md-6">
                                                                <label class="form-label small">User Attribute</label>
                                                                <input class="form-control form-control-sm font-monospace" @bind="PMapperUserAttr" />
                                                            </div>
                                                            <div class="col-md-6">
                                                                <label class="form-label small">Claim Name</label>
                                                                <input class="form-control form-control-sm font-monospace" @bind="PMapperClaimName" />
                                                            </div>
                                                            <div class="col-md-4">
                                                                <label class="form-label small">JSON Type</label>
                                                                <select class="form-select form-select-sm" @bind="PMapperJsonType">
                                                                    <option value="String">String</option>
                                                                    <option value="long">long</option>
                                                                    <option value="int">int</option>
                                                                    <option value="boolean">boolean</option>
