@using EntKube.Web.Data
@using EntKube.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject VaultService VaultService
@inject AppGovernanceService AppGovernanceService
@inject TenantService TenantService
@inject DeploymentService DeploymentService
@inject CnpgService CnpgService
@inject MongoService MongoService
@inject RedisService RedisService
@inject RabbitMQService RabbitMQService
@inject StorageService StorageService
@inject RegisteredPostgresService RegisteredPostgresService
@inject KeycloakService KeycloakService
@inject AuthenticationStateProvider AuthStateProvider
@using EntKube.Web.Components.Pages.Shared

@* ═══════════════════════════════════════════════════════════════════
   App Secrets — customer portal view for managing vault secrets and
   Docker registry credentials scoped to a single app.

   Tabs:
     App Secrets  — vault secrets tied directly to the app
     Registries   — Docker pull secrets

   Note: Database, Messaging, Cache, and Storage bindings are now
   top-level tabs in AppEnvironmentDetail.

   Access rules:
     Viewer+  — list and reveal values
     Admin    — add / update / delete secrets, trigger syncs
   ═══════════════════════════════════════════════════════════════════ *@


@if (!vaultInitialized)
{
    <div class="alert alert-warning py-2 small">
        <i class="bi bi-shield-exclamation me-1"></i>
        No vault has been set up for this tenant. Ask your platform administrator to initialize it.
    </div>
}
else
{
    @* ── Add Secret form (Admin only) ── *@
    @if (AccessRole >= CustomerAccessRole.Admin)
        {
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-white py-2">
                    <i class="bi bi-plus-circle me-1 text-primary"></i><strong>Add / Update Secret</strong>
                </div>
                <div class="card-body">
                    <div class="btn-group btn-group-sm mb-3">
                        <button type="button" class="btn @(addMode == "opaque" ? "btn-primary" : "btn-outline-primary")"
                                @onclick='() => addMode = "opaque"'>
                            <i class="bi bi-key me-1"></i>Opaque value
                        </button>
                        <button type="button" class="btn @(addMode == "certificate" ? "btn-primary" : "btn-outline-primary")"
                                @onclick='() => addMode = "certificate"'>
                            <i class="bi bi-patch-check me-1"></i>Certificate
                        </button>
                        <button type="button" class="btn @(addMode == "oauth" ? "btn-primary" : "btn-outline-primary")"
                                @onclick='() => addMode = "oauth"'>
                            <i class="bi bi-shield-lock me-1"></i>OAuth / OIDC
                        </button>
                    </div>

                    @if (addMode == "opaque")
                    {
                        <div class="row g-2 align-items-end">
                            <div class="col-md-4">
                                <label class="form-label small">Name</label>
                                <input type="text" class="form-control form-control-sm"
                                       placeholder="e.g. API_KEY, DB_PASSWORD"
                                       @bind="newSecretName" @bind:event="oninput" />
                            </div>
                            <div class="col-md-5">
                                <label class="form-label small">Value</label>
                                <input type="password" class="form-control form-control-sm"
                                       placeholder="Secret value"
                                       @bind="newSecretValue" @bind:event="oninput" />
                            </div>
                            <div class="col-auto">
                                <button class="btn btn-sm btn-primary" @onclick="AddSecret"
                                        disabled="@(string.IsNullOrWhiteSpace(newSecretName) || string.IsNullOrWhiteSpace(newSecretValue) || saving)">
                                    @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    <i class="bi bi-plus-lg me-1"></i>Set Secret
                                </button>
                            </div>
                        </div>
                    }
                    else if (addMode == "certificate")
                    {
                        <div class="row g-2 mb-2">
                            <div class="col-md-5">
                                <label class="form-label small">Name</label>
                                <input type="text" class="form-control form-control-sm"
                                       placeholder="e.g. PROD_TLS, ingress-cert"
                                       @bind="newSecretName" @bind:event="oninput" />
                            </div>
                        </div>
                        <CertificateFields Bundle="newCertBundle" />
                        <div class="mt-2">
                            <button class="btn btn-sm btn-primary" @onclick="AddCertificate"
                                    disabled="@(string.IsNullOrWhiteSpace(newSecretName) || string.IsNullOrWhiteSpace(newCertBundle.Certificate) || saving)">
                                @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                <i class="bi bi-plus-lg me-1"></i>Save Certificate
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="row g-2 mb-2">
                            <div class="col-md-5">
                                <label class="form-label small">Name</label>
                                <input type="text" class="form-control form-control-sm"
                                       placeholder="e.g. ENTRA_APP, google-oidc"
                                       @bind="newSecretName" @bind:event="oninput" />
                            </div>
                        </div>
                        <OAuthClientFields Bundle="newOAuthBundle" />
                        <div class="mt-2">
                            <button class="btn btn-sm btn-primary" @onclick="AddOAuthClient"
                                    disabled="@(string.IsNullOrWhiteSpace(newSecretName) || string.IsNullOrWhiteSpace(newOAuthBundle.ClientSecret) || saving)">
                                @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                <i class="bi bi-plus-lg me-1"></i>Save OAuth Client
                            </button>
                        </div>
                    }
                    @if (Environment is not null)
                    {
                        <div class="mt-2">
                            <label class="form-label small mb-1">Scope</label>
                            <div class="d-flex gap-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" id="scope-env"
                                           checked="@(!newSecretShared)" @onchange="() => newSecretShared = false" />
                                    <label class="form-check-label small" for="scope-env">
                                        <i class="bi bi-diagram-3 me-1"></i>This environment only (<strong>@Environment.Name</strong>)
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" id="scope-shared"
                                           checked="@newSecretShared" @onchange="() => newSecretShared = true" />
                                    <label class="form-check-label small" for="scope-shared">
                                        <i class="bi bi-globe me-1"></i>Shared across all environments
                                    </label>
                                </div>
                            </div>
                        </div>
                    }
                    <div class="form-text">
                        @if (Environment is not null && !newSecretShared)
                        {
                            <text>Stored only for the <strong>@Environment.Name</strong> environment — it will not be visible in, or synced to, other environments.</text>
                        }
                        else
                        {
                            <text>If a secret with this name already exists in this scope it will be updated in place.</text>
                        }
                    </div>
                    @if (errorMessage is not null)
                    {
                        <div class="alert alert-danger py-1 small mt-2 mb-0">
                            <i class="bi bi-exclamation-triangle me-1"></i>@errorMessage
                        </div>
                    }
                    @if (successMessage is not null)
                    {
                        <div class="alert alert-success py-1 small mt-2 mb-0">
                            <i class="bi bi-check-circle me-1"></i>@successMessage
                        </div>
                    }
                </div>
            </div>
        }

        @* ── Secrets list ── *@
        <div class="card shadow-sm">
            <div class="card-header bg-white py-2 d-flex align-items-center justify-content-between">
                <div>
                    <i class="bi bi-lock me-2 text-primary"></i>
                    <strong>Stored Secrets</strong>
                    @if (secrets is not null)
                    {
                        <span class="badge bg-secondary ms-1">@secrets.Count</span>
                    }
                </div>
                @if (AccessRole >= CustomerAccessRole.Admin && secrets?.Any(s => s.SyncToKubernetes) == true)
                {
                    <button class="btn btn-sm btn-outline-success" @onclick="SyncAllToKubernetes" disabled="@syncingSecrets">
                        @if (syncingSecrets) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        else { <i class="bi bi-cloud-arrow-up me-1"></i> }
                        Sync All to K8s
                    </button>
                }
            </div>
            <div class="card-body p-0">
                <LoadingPanel Loading="@(secrets is null)">
                @if (secrets is not null && secrets.Count == 0)
                {
                    <EmptyState Icon="bi-lock"
                                Message="@(AccessRole >= CustomerAccessRole.Admin ? "No secrets stored yet. Use the form above to add one." : "No secrets stored for this app yet.")" />
                }
                else if (secrets is not null)
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Name</th>
                                    <th>Scope</th>
                                    <th>K8s Sync</th>
                                    <th>K8s Secret</th>
                                    <th>Namespace</th>
                                    <th>Updated</th>
                                    <th class="text-end" style="min-width: 120px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (VaultSecret secret in secrets)
                                {
                                    <tr>
                                        <td>
                                            <code>@secret.Name</code>
                                            @if (secret.SecretType == VaultSecretType.Certificate)
                                            {
                                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle ms-1" title="TLS certificate">
                                                    <i class="bi bi-patch-check me-1"></i>TLS
                                                </span>
                                                <div class="mt-1">
                                                    <CertificateInfoDisplay Info="@certInfos.GetValueOrDefault(secret.Id)" Compact="true" />
                                                </div>
                                            }
                                            else if (secret.SecretType == VaultSecretType.OAuthClient)
                                            {
                                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle ms-1" title="OAuth / OIDC client">
                                                    <i class="bi bi-shield-lock me-1"></i>OAuth
                                                </span>
                                                <div class="mt-1">
                                                    <OAuthClientDisplay Info="@oauthInfos.GetValueOrDefault(secret.Id)" Compact="true" />
                                                </div>
                                            }
                                        </td>
                                        <td>
                                            @if (secret.EnvironmentId is null)
                                            {
                                                <span class="badge bg-light text-dark border" title="Visible in every environment of this app">
                                                    <i class="bi bi-globe me-1"></i>Shared
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle" title="Only visible and syncable in this environment">
                                                    <i class="bi bi-diagram-3 me-1"></i>@EnvironmentName(secret.EnvironmentId.Value)
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            @if (secret.SyncToKubernetes)
                                            {
                                                <span class="badge bg-success"><i class="bi bi-cloud-check me-1"></i>Enabled</span>
                                            }
                                            else if (IsClusterOwned(secret))
                                            {
                                                <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle"
                                                      title="Not controlled by EntKube — this secret is owned in the cluster. EntKube tracks it read-only and refreshes the vault copy whenever it changes in Kubernetes. Enable K8s sync to take ownership.">
                                                    <i class="bi bi-eye me-1"></i>Cluster-owned
                                                </span>
                                                <div class="text-muted mt-1" style="font-size:.72rem">
                                                    <i class="bi bi-arrow-repeat me-1"></i>
                                                    @(secret.LastRefreshedFromClusterAt is { } r
                                                        ? $"from cluster {r.ToString("MMM d, HH:mm")}"
                                                        : "not yet read")
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Off</span>
                                            }
                                        </td>
                                        <td><small class="text-muted">@(secret.KubernetesSecretName ?? "—")</small></td>
                                        <td><small class="text-muted">@(secret.KubernetesNamespace ?? "—")</small></td>
                                        <td><small class="text-muted">@secret.UpdatedAt.ToString("MMM d, HH:mm")</small></td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-secondary me-1"
                                                    @onclick="() => RevealSecret(secret)"
                                                    title="@(revealedSecretId == secret.Id ? "Hide value" : "Reveal value")"
                                                    aria-label="@(revealedSecretId == secret.Id ? "Hide value" : "Reveal value")">
                                                <i class="bi @(revealedSecretId == secret.Id ? "bi-eye-slash" : "bi-eye")"></i>
                                            </button>

                                            @if (AccessRole >= CustomerAccessRole.Admin)
                                            {
                                                <button class="btn btn-sm btn-outline-warning me-1"
                                                        @onclick="() => StartEdit(secret)" title="Update value" aria-label="Update value">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-primary me-1"
                                                        @onclick="() => StartScopeEdit(secret)" title="Change scope" aria-label="Change scope">
                                                    <i class="bi bi-diagram-3"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-secondary me-1"
                                                        @onclick="() => ToggleHistory(secret.Id)" title="Version history" aria-label="Version history">
                                                    <i class="bi bi-clock-history"></i>
                                                </button>
                                                @if (IsClusterOwned(secret))
                                                {
                                                    <button class="btn btn-sm btn-outline-secondary me-1"
                                                            @onclick="() => RefreshFromCluster(secret)"
                                                            disabled="@(refreshingSecretId == secret.Id)"
                                                            title="Refresh this secret from the live Kubernetes value now"
                                                            aria-label="Refresh from cluster">
                                                        <i class="bi @(refreshingSecretId == secret.Id ? "spinner-border spinner-border-sm" : "bi-arrow-repeat")"></i>
                                                    </button>
                                                }
                                                <button class="btn btn-sm btn-outline-info me-1"
                                                        @onclick="() => ToggleSync(secret)"
                                                        title="@(secret.SyncToKubernetes ? "Disable K8s sync" : "Configure K8s sync")"
                                                        aria-label="@(secret.SyncToKubernetes ? "Disable K8s sync" : "Configure K8s sync")">
                                                    <i class="bi @(secret.SyncToKubernetes ? "bi-cloud-slash" : "bi-cloud-arrow-up")"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger"
                                                        @onclick="() => confirmDeleteSecretId = secret.Id" title="Delete secret" aria-label="Delete secret">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        </td>
                                    </tr>

                                    @if (confirmDeleteSecretId == secret.Id)
                                    {
                                        <tr class="table-danger table-sm">
                                            <td colspan="7" class="px-3 py-2">
                                                <ConfirmDialog Visible="true"
                                                               Message="@($"Permanently delete secret '{secret.Name}'?")"
                                                               ConfirmText="Delete"
                                                               IsBusy="deletingSecret"
                                                               OnConfirm="() => DeleteSecret(secret.Id)"
                                                               OnCancel="() => confirmDeleteSecretId = null" />
                                            </td>
                                        </tr>
                                    }

                                    @if (revealedSecretId == secret.Id)
                                    {
                                        <tr class="table-light">
                                            <td colspan="7">
                                                @if (revealLoading)
                                                {
                                                    <div class="px-2 py-1">
                                                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                                    </div>
                                                }
                                                else if (secret.SecretType == VaultSecretType.Certificate && revealedBundle is not null)
                                                {
                                                    <div class="p-2">
                                                        <CertificateInfoDisplay Info="@certInfos.GetValueOrDefault(secret.Id)" />
                                                        <div class="mt-2">
                                                            <PemBlock Label="Certificate" Pem="@revealedBundle.Certificate" />
                                                            <PemBlock Label="Private key" Pem="@revealedBundle.PrivateKey" />
                                                            <PemBlock Label="CA certificate" Pem="@revealedBundle.CaCertificate" />
                                                            <PemBlock Label="Chain" Pem="@revealedBundle.Chain" />
                                                            <PemBlock Label="Full chain (synced as fullchain.crt)" Pem="@revealedBundle.FullChain" />
                                                        </div>
                                                    </div>
                                                }
                                                else if (secret.SecretType == VaultSecretType.OAuthClient && revealedOAuthBundle is not null)
                                                {
                                                    <div class="p-2">
                                                        <OAuthClientDisplay Info="@revealedOAuthBundle.ToInfo()" ClientSecret="@revealedOAuthBundle.ClientSecret" />
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="d-flex align-items-center px-2 py-1 gap-2">
                                                        <span class="text-muted small">Value:</span>
                                                        <code class="user-select-all">@revealedValue</code>
                                                    </div>
                                                }
                                            </td>
                                        </tr>
                                    }

                                    @if (editSecretId == secret.Id)
                                    {
                                        <tr class="table-light">
                                            <td colspan="7">
                                                @if (secret.SecretType == VaultSecretType.Certificate && editCertBundle is not null)
                                                {
                                                    <div class="p-2">
                                                        <CertificateFields Bundle="editCertBundle" />
                                                        <div class="mt-2">
                                                            <button class="btn btn-sm btn-success" @onclick="() => SaveCertEdit(secret)"
                                                                    disabled="@(string.IsNullOrWhiteSpace(editCertBundle.Certificate) || saving)">
                                                                @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                                <i class="bi bi-check-lg me-1"></i>Update Certificate
                                                            </button>
                                                            <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="CancelEdit">
                                                                Cancel
                                                            </button>
                                                        </div>
                                                    </div>
                                                }
                                                else if (secret.SecretType == VaultSecretType.OAuthClient && editOAuthBundle is not null)
                                                {
                                                    <div class="p-2">
                                                        <OAuthClientFields Bundle="editOAuthBundle" />
                                                        <div class="mt-2">
                                                            <button class="btn btn-sm btn-success" @onclick="() => SaveOAuthEdit(secret)"
                                                                    disabled="@(string.IsNullOrWhiteSpace(editOAuthBundle.ClientSecret) || saving)">
                                                                @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                                <i class="bi bi-check-lg me-1"></i>Update OAuth Client
                                                            </button>
                                                            <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="CancelEdit">
                                                                Cancel
                                                            </button>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="row g-2 p-2 align-items-center">
                                                        <div class="col-md-6">
                                                            <input type="password" class="form-control form-control-sm"
                                                                   placeholder="New secret value"
                                                                   @bind="editSecretValue" />
                                                        </div>
                                                        <div class="col-auto">
                                                            <button class="btn btn-sm btn-success" @onclick="SaveEdit"
                                                                    disabled="@(string.IsNullOrWhiteSpace(editSecretValue) || saving)">
                                                                @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                                <i class="bi bi-check-lg me-1"></i>Update
                                                            </button>
                                                            <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="CancelEdit">
                                                                Cancel
                                                            </button>
                                                        </div>
                                                    </div>
                                                }
                                            </td>
                                        </tr>
                                    }

                                    @if (scopeEditSecretId == secret.Id)
                                    {
                                        <tr class="table-light">
                                            <td colspan="7">
                                                <div class="row g-2 p-2 align-items-center">
                                                    <div class="col-auto">
                                                        <label class="form-label small mb-0">Scope</label>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <select class="form-select form-select-sm" @bind="scopeEditValue">
                                                            <option value="">Shared across all environments</option>
                                                            @foreach (KeyValuePair<Guid, string> env in AppEnvironmentOptions())
                                                            {
                                                                <option value="@env.Key">@env.Value (this environment only)</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="col-auto">
                                                        <button class="btn btn-sm btn-success" @onclick="() => SaveScopeEdit(secret)"
                                                                disabled="@savingScope">
                                                            @if (savingScope) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                            <i class="bi bi-check-lg me-1"></i>Save
                                                        </button>
                                                        <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="CancelScopeEdit">
                                                            Cancel
                                                        </button>
                                                    </div>
                                                </div>
                                                @if (secret.SyncToKubernetes)
                                                {
                                                    <div class="px-2 pb-1">
                                                        <small class="text-muted"><i class="bi bi-info-circle me-1"></i>If the new environment doesn't match this secret's sync target cluster, K8s sync will be turned off.</small>
                                                    </div>
                                                }
                                            </td>
                                        </tr>
                                    }

                                    @if (syncConfigSecretId == secret.Id)
                                    {
                                        bool nsLocked = syncClusterId != Guid.Empty && GetLockedNamespaceForCluster(syncClusterId) is not null;
                                        <tr class="table-light">
                                            <td colspan="7">
                                                <div class="row g-2 p-2 align-items-center">
                                                    <div class="col-md-3">
                                                        <select class="form-select form-select-sm"
                                                                value="@syncClusterId"
                                                                @onchange="OnSyncClusterChanged">
                                                            <option value="@Guid.Empty">Target cluster…</option>
                                                            @foreach (KubernetesCluster cluster in appEnvironmentClusters)
                                                            {
                                                                <option value="@cluster.Id">@cluster.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <input type="text" class="form-control form-control-sm"
                                                               placeholder="K8s Secret name"
                                                               @bind="syncSecretName" />
                                                    </div>
                                                    <div class="col-md-3">
                                                        <input type="text" class="form-control form-control-sm"
                                                               placeholder="Namespace"
                                                               @bind="syncNamespace"
                                                               disabled="@nsLocked"
                                                               title="@(nsLocked ? "Namespace is locked by governance policy" : null)" />
                                                    </div>
                                                    <div class="col-auto">
                                                        <button class="btn btn-sm btn-success" @onclick="SaveSync">
                                                            <i class="bi bi-check-lg me-1"></i>Save
                                                        </button>
                                                        <button class="btn btn-sm btn-outline-secondary ms-1"
                                                                @onclick="() => syncConfigSecretId = null">
                                                            Cancel
                                                        </button>
                                                    </div>
                                                </div>
                                                @if (nsLocked)
                                                {
                                                    <div class="px-2 pb-1">
                                                        <small class="text-muted"><i class="bi bi-shield-lock me-1"></i>Namespace locked by governance policy.</small>
                                                    </div>
                                                }
                                            </td>
                                        </tr>
                                    }

                                    @* Version history row *@
                                    @if (historySecretId == secret.Id)
                                    {
                                        <tr>
                                            <td colspan="7" class="bg-light p-0">
                                                <div class="p-3">
                                                    <div class="d-flex align-items-center mb-2">
                                                        <i class="bi bi-clock-history me-2 text-secondary"></i>
                                                        <strong class="small">Version History</strong>
                                                        <span class="badge bg-secondary ms-2">@(secretVersions?.Count ?? 0)</span>
                                                    </div>
                                                    @if (secretVersions is null)
                                                    {
                                                        <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
                                                    }
                                                    else if (secretVersions.Count == 0)
                                                    {
                                                        <p class="text-muted small mb-0">No previous versions recorded.</p>
                                                    }
                                                    else
                                                    {
                                                        <table class="table table-sm table-bordered mb-0">
                                                            <thead class="table-secondary">
                                                                <tr>
                                                                    <th style="width: 60px;">#</th>
                                                                    <th>Set by</th>
                                                                    <th>Date</th>
                                                                    <th class="text-end" style="width: 160px;">Actions</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (VaultSecretVersion ver in secretVersions)
                                                                {
                                                                    <tr>
                                                                        <td><span class="badge bg-secondary">v@ver.VersionNumber</span></td>
                                                                        <td><small class="text-muted">@(ver.CreatedBy ?? "—")</small></td>
                                                                        <td><small class="text-muted">@ver.CreatedAt.ToString("MMM d, HH:mm")</small></td>
                                                                        <td class="text-end">
                                                                            <button class="btn btn-xs btn-outline-secondary me-1"
                                                                                    @onclick="() => RevealVersion(secret.Id, ver)"
                                                                                    title="@(revealedVersionId == ver.Id ? "Hide" : "Reveal value")"
                                                                                    aria-label="@(revealedVersionId == ver.Id ? "Hide" : "Reveal value")">
                                                                                <i class="bi @(revealedVersionId == ver.Id ? "bi-eye-slash" : "bi-eye")"></i>
                                                                            </button>
                                                                            <button class="btn btn-xs btn-outline-warning"
                                                                                    @onclick="() => RollbackToVersion(secret.Id, ver.Id)"
                                                                                    title="Restore this value">
                                                                                <i class="bi bi-arrow-counterclockwise me-1"></i>Restore
                                                                            </button>
                                                                        </td>
                                                                    </tr>
                                                                    @if (revealedVersionId == ver.Id)
                                                                    {
                                                                        <tr class="table-light">
                                                                            <td colspan="4" class="px-2 py-1">
                                                                                <span class="text-muted small me-2">Value:</span>
                                                                                @if (versionRevealLoading)
                                                                                {
                                                                                    <span class="spinner-border spinner-border-sm"></span>
                                                                                }
                                                                                else
                                                                                {
                                                                                    <code class="user-select-all">@revealedVersionValue</code>
                                                                                }
                                                                            </td>
                                                                        </tr>
                                                                    }
                                                                }
                                                            </tbody>
                                                        </table>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
                </LoadingPanel>
                @if (syncOutput is not null)
                {
                    <div class="m-3 p-2 bg-dark text-white rounded font-monospace small" style="white-space: pre-wrap; max-height: 200px; overflow-y: auto;">@syncOutput</div>
                }
            </div>
        </div>
}

@code {
    [Parameter] public required Data.App App { get; set; }
    [Parameter] public Guid TenantId { get; set; }
    [Parameter] public CustomerAccessRole AccessRole { get; set; }
    [Parameter] public string InitialScope { get; set; } = "app";

    /// <summary>
    /// When set, this view is scoped to a single environment: only shared secrets
    /// and secrets bound to this environment are shown, created, and synced.
    /// When null, every app secret is shown (tenant-admin / cross-environment view).
    /// </summary>
    [Parameter] public Data.Environment? Environment { get; set; }

    private string activeScope = "app";
    private bool vaultInitialized;

    // ── App Secrets ──────────────────────────────────────────────────
    private List<VaultSecret>? secrets;
    private Dictionary<Guid, string?> environmentNamespaceLock = new();
    private Dictionary<Guid, string> environmentNames = new();
    private List<KubernetesCluster> appEnvironmentClusters = [];

    private string newSecretName = "";
    private string newSecretValue = "";
    // When in an environment context, new secrets default to that environment;
    // toggling this stores them as shared across all environments instead.
    private bool newSecretShared;
    private bool saving;

    // ── Add-form mode: "opaque" | "certificate" | "oauth" ────────────
    private string addMode = "opaque";

    // ── Certificate state ────────────────────────────────────────────
    private CertificateBundle newCertBundle = new();
    private CertificateBundle? revealedBundle;
    private CertificateBundle? editCertBundle;
    // Parsed metadata for the certificate rows currently listed (expiry badges).
    private Dictionary<Guid, CertificateInfo?> certInfos = new();

    // ── OAuth/OIDC client state ──────────────────────────────────────
    private OAuthClientBundle newOAuthBundle = new();
    private OAuthClientBundle? revealedOAuthBundle;
    private OAuthClientBundle? editOAuthBundle;
    // Non-secret metadata for OAuth rows currently listed (provider + expiry).
    private Dictionary<Guid, OAuthClientInfo?> oauthInfos = new();
    private string? errorMessage;
    private string? successMessage;

    private Guid? revealedSecretId;
    private string? revealedValue;
    private bool revealLoading;

    private Guid? editSecretId;
    private string editSecretValue = "";

    private Guid? confirmDeleteSecretId;
    private bool deletingSecret;

    // ── Scope edit state ─────────────────────────────────────────────
    private Guid? scopeEditSecretId;
    // Empty string = shared; otherwise the target environment id.
    private string scopeEditValue = "";
    private bool savingScope;

    private Guid? syncConfigSecretId;
    private string syncSecretName = "";
    private string syncNamespace = "";
    private Guid syncClusterId;
    private bool syncWasPreconfigured;

    private bool syncingSecrets;
    private string? syncOutput;

    // ── Version history state ────────────────────────────────────────
    private Guid? historySecretId;
    private List<VaultSecretVersion>? secretVersions;
    private Guid? revealedVersionId;
    private string? revealedVersionValue;
    private bool versionRevealLoading;

    // ── Shared binding state ─────────────────────────────────────────
    private List<AppDeployment>? deployments;

    private string? currentUserEmail;

    protected override async Task OnInitializedAsync()
    {
        activeScope = InitialScope;

        AuthenticationState authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUserEmail = authState.User.Identity?.Name;

        SecretVault? vault = await VaultService.GetVaultAsync(TenantId);
        vaultInitialized = vault is not null;

        await EnsureDeployments();
        List<AppEnvironment> appEnvs = await AppGovernanceService.GetAppEnvironmentsAsync(App.Id);
        environmentNamespaceLock = appEnvs.ToDictionary(ae => ae.EnvironmentId, ae => ae.Namespace);
        environmentNames = (await TenantService.GetEnvironmentsAsync(TenantId))
            .ToDictionary(e => e.Id, e => e.Name);

        HashSet<Guid> appEnvIds = appEnvs.Select(ae => ae.EnvironmentId).ToHashSet();
        appEnvironmentClusters = (await TenantService.GetClustersAsync(TenantId))
            // When scoped to a single environment, only that environment's clusters
            // are valid sync targets — prevents pointing a secret at another env.
            .Where(c => appEnvIds.Contains(c.EnvironmentId)
                && (Environment is null || c.EnvironmentId == Environment.Id))
            .ToList();

        if (!vaultInitialized) return;

        await LoadScopeData(activeScope);
    }

    private async Task SwitchScope(string scope)
    {
        activeScope = scope;
        await LoadScopeData(scope);
    }

    private async Task LoadScopeData(string scope)
    {
        if (secrets is null) await LoadSecrets();
    }

    private async Task EnsureDeployments()
    {
        if (deployments is null)
            deployments = await DeploymentService.GetDeploymentsAsync(App.Id);
    }

    // ── App Secrets: Add ─────────────────────────────────────────────

    private async Task LoadSecrets()
    {
        secrets = Environment is null
            ? await VaultService.GetAppSecretsAsync(TenantId, App.Id)
            : await VaultService.GetAppSecretsForEnvironmentAsync(TenantId, App.Id, Environment.Id);

        // Parse certificate rows so the list can show subject + expiry status.
        certInfos = new();
        foreach (VaultSecret cert in secrets.Where(s => s.SecretType == VaultSecretType.Certificate))
        {
            certInfos[cert.Id] = await VaultService.GetCertificateInfoByIdAsync(cert.Id);
        }

        // Load OAuth metadata so the list can show provider + expiry status.
        oauthInfos = new();
        foreach (VaultSecret oauth in secrets.Where(s => s.SecretType == VaultSecretType.OAuthClient))
        {
            oauthInfos[oauth.Id] = await VaultService.GetOAuthClientInfoByIdAsync(oauth.Id);
        }
    }

    private string EnvironmentName(Guid environmentId) =>
        environmentNames.GetValueOrDefault(environmentId, "Unknown env");

    private async Task ShowSuccessAsync(string message)
    {
        successMessage = message;
        StateHasChanged();
        await Task.Delay(3500);
        successMessage = null;
        StateHasChanged();
    }

    private async Task AddSecret()
    {
        errorMessage = null;
        successMessage = null;
        saving = true;

        try
        {
            string name = newSecretName.Trim();
            // In an environment context, bind to it unless the user chose "shared".
            Guid? environmentId = (Environment is not null && !newSecretShared) ? Environment.Id : null;
            await VaultService.SetAppSecretAsync(TenantId, App.Id, name, newSecretValue.Trim(), environmentId: environmentId);
            newSecretName = "";
            newSecretValue = "";
            await LoadSecrets();
            string scopeLabel = environmentId is null ? "shared" : Environment!.Name;
            _ = ShowSuccessAsync($"Secret '{name}' saved ({scopeLabel}).");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally { saving = false; }
    }

    // ── App Secrets: Add Certificate ─────────────────────────────────

    private async Task AddCertificate()
    {
        errorMessage = null;
        successMessage = null;
        saving = true;

        try
        {
            string name = newSecretName.Trim();
            Guid? environmentId = (Environment is not null && !newSecretShared) ? Environment.Id : null;
            (bool ok, string? error) = await VaultService.SetAppCertificateAsync(
                TenantId, App.Id, name, newCertBundle, environmentId, currentUserEmail);

            if (!ok)
            {
                errorMessage = error;
                return;
            }

            newSecretName = "";
            newCertBundle = new();
            await LoadSecrets();
            string scopeLabel = environmentId is null ? "shared" : Environment!.Name;
            _ = ShowSuccessAsync($"Certificate '{name}' saved ({scopeLabel}).");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally { saving = false; }
    }

    // ── App Secrets: Add OAuth/OIDC client ───────────────────────────

    private async Task AddOAuthClient()
    {
        errorMessage = null;
        successMessage = null;
        saving = true;

        try
        {
            string name = newSecretName.Trim();
            Guid? environmentId = (Environment is not null && !newSecretShared) ? Environment.Id : null;
            (bool ok, string? error) = await VaultService.SetAppOAuthClientAsync(
                TenantId, App.Id, name, newOAuthBundle, environmentId, currentUserEmail);

            if (!ok)
            {
                errorMessage = error;
                return;
            }

            newSecretName = "";
            newOAuthBundle = new();
            await LoadSecrets();
            string scopeLabel = environmentId is null ? "shared" : Environment!.Name;
            _ = ShowSuccessAsync($"OAuth client '{name}' saved ({scopeLabel}).");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally { saving = false; }
    }

    // ── App Secrets: Reveal ──────────────────────────────────────────

    private async Task RevealSecret(VaultSecret secret)
    {
        if (revealedSecretId == secret.Id)
        {
            revealedSecretId = null;
            revealedValue = null;
            revealedBundle = null;
            revealedOAuthBundle = null;
            return;
        }

        revealLoading = true;
        revealedSecretId = secret.Id;
        revealedValue = null;
        revealedBundle = null;
        revealedOAuthBundle = null;

        if (secret.SecretType == VaultSecretType.Certificate)
        {
            revealedBundle = await VaultService.GetCertificateBundleByIdAsync(secret.Id);
        }
        else if (secret.SecretType == VaultSecretType.OAuthClient)
        {
            revealedOAuthBundle = await VaultService.GetOAuthClientBundleByIdAsync(secret.Id);
        }
        else
        {
            revealedValue = await VaultService.GetSecretValueByIdAsync(secret.Id);
        }

        revealLoading = false;
    }

    // ── App Secrets: Edit ────────────────────────────────────────────

    private async Task StartEdit(VaultSecret secret)
    {
        editSecretId = secret.Id;
        editSecretValue = "";
        editCertBundle = null;
        editOAuthBundle = null;
        revealedSecretId = null;
        revealedValue = null;
        revealedBundle = null;
        revealedOAuthBundle = null;

        if (secret.SecretType == VaultSecretType.Certificate)
        {
            editCertBundle = await VaultService.GetCertificateBundleByIdAsync(secret.Id) ?? new CertificateBundle();
        }
        else if (secret.SecretType == VaultSecretType.OAuthClient)
        {
            editOAuthBundle = await VaultService.GetOAuthClientBundleByIdAsync(secret.Id) ?? new OAuthClientBundle();
        }
    }

    private void CancelEdit()
    {
        editSecretId = null;
        editSecretValue = "";
        editCertBundle = null;
        editOAuthBundle = null;
    }

    private async Task SaveOAuthEdit(VaultSecret secret)
    {
        if (editOAuthBundle is null || string.IsNullOrWhiteSpace(editOAuthBundle.ClientSecret)) return;

        saving = true;
        errorMessage = null;

        try
        {
            (bool ok, string? error) = await VaultService.SetAppOAuthClientAsync(
                TenantId, App.Id, secret.Name, editOAuthBundle, secret.EnvironmentId, currentUserEmail);

            if (ok)
            {
                editSecretId = null;
                editOAuthBundle = null;
                await LoadSecrets();
                _ = ShowSuccessAsync("OAuth client updated.");
            }
            else
            {
                errorMessage = error;
            }
        }
        finally { saving = false; }
    }

    private async Task SaveCertEdit(VaultSecret secret)
    {
        if (editCertBundle is null || string.IsNullOrWhiteSpace(editCertBundle.Certificate)) return;

        saving = true;
        errorMessage = null;

        try
        {
            (bool ok, string? error) = await VaultService.SetAppCertificateAsync(
                TenantId, App.Id, secret.Name, editCertBundle, secret.EnvironmentId, currentUserEmail);

            if (ok)
            {
                editSecretId = null;
                editCertBundle = null;
                await LoadSecrets();
                _ = ShowSuccessAsync("Certificate updated.");
            }
            else
            {
                errorMessage = error;
            }
        }
        finally { saving = false; }
    }

    private async Task SaveEdit()
    {
        if (editSecretId is null || string.IsNullOrWhiteSpace(editSecretValue)) return;

        saving = true;
        errorMessage = null;

        try
        {
            bool updated = await VaultService.UpdateSecretValueAsync(editSecretId.Value, editSecretValue.Trim(), currentUserEmail);
            if (updated)
                _ = ShowSuccessAsync("Secret value updated.");
            else
                errorMessage = "Failed to update secret.";
        }
        finally { saving = false; }

        editSecretId = null;
        editSecretValue = "";
        await LoadSecrets();
    }

    // ── App Secrets: Change scope ────────────────────────────────────

    /// <summary>
    /// The app's environments (id → name), ordered by name, used to populate the
    /// scope dropdown. Built from the app-environment bindings loaded at init.
    /// </summary>
    private IEnumerable<KeyValuePair<Guid, string>> AppEnvironmentOptions() =>
        environmentNamespaceLock.Keys
            .Select(id => new KeyValuePair<Guid, string>(id, EnvironmentName(id)))
            .OrderBy(kv => kv.Value);

    private void StartScopeEdit(VaultSecret secret)
    {
        scopeEditSecretId = secret.Id;
        scopeEditValue = secret.EnvironmentId?.ToString() ?? "";
        editSecretId = null;
        syncConfigSecretId = null;
        revealedSecretId = null;
        errorMessage = null;
    }

    private void CancelScopeEdit()
    {
        scopeEditSecretId = null;
        scopeEditValue = "";
    }

    private async Task SaveScopeEdit(VaultSecret secret)
    {
        errorMessage = null;
        savingScope = true;

        try
        {
            Guid? environmentId = Guid.TryParse(scopeEditValue, out Guid id) ? id : (Guid?)null;
            (bool ok, string? reason) = await VaultService.ChangeAppSecretScopeAsync(secret.Id, environmentId);
            if (ok)
            {
                scopeEditSecretId = null;
                await LoadSecrets();
                string scopeLabel = environmentId is null ? "shared" : EnvironmentName(environmentId.Value);
                _ = ShowSuccessAsync($"Secret '{secret.Name}' scope changed to {scopeLabel}.");
            }
            else
            {
                errorMessage = reason;
            }
        }
        finally { savingScope = false; }
    }

    // ── App Secrets: Delete ──────────────────────────────────────────

    private async Task DeleteSecret(Guid secretId)
    {
        errorMessage = null;
        deletingSecret = true;

        (bool canDelete, string? reason) = await VaultService.CanDeleteSecretAsync(secretId);
        if (!canDelete)
        {
            errorMessage = reason;
            deletingSecret = false;
            confirmDeleteSecretId = null;
            return;
        }

        await VaultService.DeleteSecretAsync(secretId);
        deletingSecret = false;
        confirmDeleteSecretId = null;
        revealedSecretId = null;
        editSecretId = null;
        await LoadSecrets();
    }

    // ── App Secrets: K8s sync ────────────────────────────────────────

    // Tracked but not pushed: a live k8s target is recorded (from deployment import) yet
    // sync is off, so the cluster owns the value and it's read back into the vault.
    private static bool IsClusterOwned(VaultSecret secret) =>
        !secret.SyncToKubernetes
        && secret.KubernetesClusterId is not null
        && !string.IsNullOrEmpty(secret.KubernetesSecretName);

    private Guid? refreshingSecretId;

    // Pull the live Kubernetes value into the vault on demand.
    private async Task RefreshFromCluster(VaultSecret secret)
    {
        refreshingSecretId = secret.Id;
        errorMessage = null;
        successMessage = null;
        try
        {
            VaultService.ClusterRefreshResult result = await VaultService.RefreshAppSecretFromClusterAsync(secret.Id);
            switch (result)
            {
                case VaultService.ClusterRefreshResult.Updated:
                    successMessage = $"'{secret.Name}' updated from the live cluster value.";
                    break;
                case VaultService.ClusterRefreshResult.Unchanged:
                    successMessage = $"'{secret.Name}' is already up to date with the cluster.";
                    break;
                case VaultService.ClusterRefreshResult.NotFound:
                    errorMessage = $"'{secret.Name}' could not be found in the cluster.";
                    break;
                default:
                    errorMessage = $"'{secret.Name}' has no live cluster target to refresh from.";
                    break;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to refresh from cluster: {ex.Message}";
        }
        finally
        {
            refreshingSecretId = null;
            await LoadSecrets();
        }
    }

    private void ToggleSync(VaultSecret secret)
    {
        if (secret.SyncToKubernetes)
        {
            _ = DisableSync(secret.Id);
        }
        else
        {
            syncConfigSecretId = secret.Id;
            syncSecretName = secret.KubernetesSecretName ?? "";
            syncNamespace = secret.KubernetesNamespace ?? "";
            syncClusterId = secret.KubernetesClusterId ?? Guid.Empty;
            // Imported/observed secrets already carry a target with sync disabled — for
            // those we re-read the live value on enable so we don't push a stale snapshot.
            syncWasPreconfigured = secret.KubernetesClusterId is not null
                && !string.IsNullOrEmpty(secret.KubernetesSecretName);

            // Auto-select cluster when only one exists across the app's environments
            if (syncClusterId == Guid.Empty && appEnvironmentClusters.Count == 1)
                syncClusterId = appEnvironmentClusters[0].Id;

            // Pre-fill namespace: governance lock takes precedence, then deployment namespace
            if (syncClusterId != Guid.Empty)
            {
                string? locked = GetLockedNamespaceForCluster(syncClusterId);
                if (locked is not null)
                    syncNamespace = locked;
                else if (string.IsNullOrEmpty(syncNamespace))
                    syncNamespace = GetDeploymentNamespaceForCluster(syncClusterId) ?? "";
            }
        }
    }

    private void OnSyncClusterChanged(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out Guid id))
        {
            syncClusterId = id;
            if (id != Guid.Empty)
            {
                string? locked = GetLockedNamespaceForCluster(id);
                if (locked is not null)
                    syncNamespace = locked;
                else
                    syncNamespace = GetDeploymentNamespaceForCluster(id) ?? syncNamespace;
            }
        }
    }

    private string? GetLockedNamespaceForCluster(Guid clusterId)
    {
        KubernetesCluster? cluster = appEnvironmentClusters.FirstOrDefault(c => c.Id == clusterId);
        if (cluster is null) return null;
        return environmentNamespaceLock.GetValueOrDefault(cluster.EnvironmentId);
    }

    private string? GetDeploymentNamespaceForCluster(Guid clusterId) =>
        deployments?.FirstOrDefault(d => d.ClusterId == clusterId)?.Namespace;

    private async Task DisableSync(Guid secretId)
    {
        await VaultService.ConfigureKubernetesSyncAsync(secretId, syncEnabled: false, secretName: null, ns: null);
        await LoadSecrets();
    }

    private async Task SaveSync()
    {
        if (syncConfigSecretId is null) return;

        Guid? clusterId = syncClusterId != Guid.Empty ? syncClusterId : (Guid?)null;

        await VaultService.ConfigureKubernetesSyncAsync(
            syncConfigSecretId.Value,
            syncEnabled: true,
            secretName: syncSecretName.Trim(),
            ns: syncNamespace.Trim(),
            clusterId: clusterId);

        // Taking ownership of an observed/imported secret: adopt the current live value
        // (e.g. what ArgoCD/Flux last set) so the next sync doesn't revert it.
        if (syncWasPreconfigured)
        {
            await VaultService.RefreshAppSecretFromClusterAsync(syncConfigSecretId.Value);
        }

        syncConfigSecretId = null;
        syncWasPreconfigured = false;
        await LoadSecrets();
    }

    private async Task SyncAllToKubernetes()
    {
        syncingSecrets = true;
        syncOutput = null;
        List<string> results = [];

        try
        {
            // App vault secrets (scoped to this environment when in env context)
            HelmExecutionResult vaultResult = await VaultService.SyncAppSecretsToKubernetesAsync(TenantId, App.Id, environmentId: Environment?.Id);
            if (!string.IsNullOrEmpty(vaultResult.Output))
                results.Add(vaultResult.Output);

            // Service bindings for all deployments of this app
            List<AppDeployment> deployments = await DeploymentService.GetDeploymentsAsync(App.Id);

            foreach (AppDeployment deployment in deployments)
            {
                await SyncDeploymentBindingsAsync(deployment, results);
            }
        }
        catch (Exception ex)
        {
            results.Add($"✗ Sync failed: {ex.Message}");
        }
        finally
        {
            syncOutput = string.Join("\n", results);
            syncingSecrets = false;
        }
    }

    private async Task SyncDeploymentBindingsAsync(AppDeployment deployment, List<string> results)
    {
        // DB bindings (CNPG / MongoDB / registered Postgres)
        try
        {
            List<DatabaseBinding> dbBindings = await CnpgService.GetDatabaseBindingsAsync(deployment.Id);
            foreach (DatabaseBinding binding in dbBindings.Where(b => b.SyncEnabled))
            {
                try
                {
                    if (binding.CnpgDatabaseId.HasValue)
                        await CnpgService.SyncDatabaseCredentialsToK8sAsync(
                            TenantId, binding.CnpgDatabase!.CnpgClusterId, binding.CnpgDatabaseId.Value);
                    else if (binding.MongoDatabaseId.HasValue)
                        await MongoService.SyncDatabaseCredentialsToK8sAsync(
                            TenantId, binding.MongoDatabase!.MongoClusterId, binding.MongoDatabaseId.Value);
                    else if (binding.RegisteredPostgresDatabaseId.HasValue)
                        await RegisteredPostgresService.SyncCredentialsToK8sAsync(
                            TenantId, binding.RegisteredPostgresDatabase!.RegisteredPostgresInstanceId,
                            binding.RegisteredPostgresDatabaseId.Value);

                    results.Add($"✓ db/{binding.KubernetesSecretName}");
                }
                catch (Exception ex) { results.Add($"✗ db/{binding.KubernetesSecretName}: {ex.Message}"); }
            }
        }
        catch (Exception ex) { results.Add($"✗ db (load failed): {ex.Message}"); }

        // Cache bindings (Redis)
        try
        {
            List<CacheBinding> cacheBindings = await RedisService.GetCacheBindingsForDeploymentAsync(deployment.Id);
            foreach (CacheBinding binding in cacheBindings.Where(b => b.SyncEnabled))
            {
                try
                {
                    await RedisService.SyncCacheBindingAsync(TenantId, binding.Id);
                    results.Add($"✓ cache/{binding.KubernetesSecretName}");
                }
                catch (Exception ex) { results.Add($"✗ cache/{binding.KubernetesSecretName}: {ex.Message}"); }
            }
        }
        catch (Exception ex) { results.Add($"✗ cache (load failed): {ex.Message}"); }

        // Messaging bindings (RabbitMQ)
        try
        {
            List<MessagingBinding> messagingBindings = await RabbitMQService.GetMessagingBindingsForDeploymentAsync(deployment.Id);
            foreach (MessagingBinding binding in messagingBindings.Where(b => b.SyncEnabled))
            {
                try
                {
                    await RabbitMQService.SyncMessagingBindingAsync(TenantId, binding.Id);
                    results.Add($"✓ messaging/{binding.KubernetesSecretName}");
                }
                catch (Exception ex) { results.Add($"✗ messaging/{binding.KubernetesSecretName}: {ex.Message}"); }
            }
        }
        catch (Exception ex) { results.Add($"✗ messaging (load failed): {ex.Message}"); }

        // Storage bindings
        try
        {
            List<StorageBinding> storageBindings = await StorageService.GetBindingsForDeploymentAsync(deployment.Id);
            foreach (StorageBinding binding in storageBindings.Where(b => b.SyncEnabled))
            {
                try
                {
                    await StorageService.SyncStorageBindingAsync(TenantId, binding.Id);
                    results.Add($"✓ storage/{binding.KubernetesSecretName}");
                }
                catch (Exception ex) { results.Add($"✗ storage/{binding.KubernetesSecretName}: {ex.Message}"); }
            }
        }
        catch (Exception ex) { results.Add($"✗ storage (load failed): {ex.Message}"); }

        // Identity bindings (Keycloak OIDC)
        try
        {
            List<IdentityBinding> identityBindings = await KeycloakService.GetIdentityBindingsForDeploymentAsync(deployment.Id);
            foreach (IdentityBinding binding in identityBindings.Where(b => b.SyncEnabled))
            {
                try
                {
                    await KeycloakService.SyncIdentityBindingAsync(TenantId, binding.Id);
                    results.Add($"✓ identity/{binding.KubernetesSecretName}");
                }
                catch (Exception ex) { results.Add($"✗ identity/{binding.KubernetesSecretName}: {ex.Message}"); }
            }
        }
        catch (Exception ex) { results.Add($"✗ identity (load failed): {ex.Message}"); }
    }

    // ── Version history ──────────────────────────────────────────────

    private async Task ToggleHistory(Guid secretId)
    {
        if (historySecretId == secretId)
        {
            historySecretId = null;
            secretVersions = null;
            revealedVersionId = null;
            revealedVersionValue = null;
            return;
        }

        historySecretId = secretId;
        revealedVersionId = null;
        revealedVersionValue = null;
        secretVersions = null;
        secretVersions = await VaultService.GetSecretVersionsAsync(secretId);
    }

    private async Task RevealVersion(Guid secretId, VaultSecretVersion version)
    {
        if (revealedVersionId == version.Id)
        {
            revealedVersionId = null;
            revealedVersionValue = null;
            return;
        }

        versionRevealLoading = true;
        revealedVersionId = version.Id;
        revealedVersionValue = null;
        revealedVersionValue = await VaultService.GetSecretVersionValueAsync(secretId, version.Id);
        versionRevealLoading = false;
    }

    private async Task RollbackToVersion(Guid secretId, Guid versionId)
    {
        errorMessage = null;
        bool ok = await VaultService.RollbackToVersionAsync(secretId, versionId, currentUserEmail);

        if (ok)
        {
            historySecretId = null;
            secretVersions = null;
            revealedVersionId = null;
            revealedVersionValue = null;
            await LoadSecrets();
            _ = ShowSuccessAsync("Secret restored to selected version.");
        }
        else
        {
            errorMessage = "Failed to restore version.";
        }
    }

}
