@page "/portal"
@using EntKube.Web.Data
@using EntKube.Web.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize]
@rendermode InteractiveServer
@inject CustomerAccessService CustomerAccessService
@inject DeploymentService DeploymentService
@inject TenantService TenantService
@inject KubernetesOperationsService K8sOps
@inject KeycloakService KeycloakService
@inject HarborService HarborService
@inject VaultService VaultService
@inject IncidentService IncidentService
@inject CustomerGitService CustomerGitService
@inject AppRouteService AppRouteService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Customer Portal</PageTitle>

@* ═══════════════════════════════════════════════════════════════════
   Customer Portal — a scoped view where a user sees only the customers
   they've been granted access to. A left-hand resource tree (matching
   the tenant explorer) drills Customer → App → Environments + Services,
   plus per-customer Operations; the right pane reuses the existing
   detail components. Selection deep-links via the URL.
   ═══════════════════════════════════════════════════════════════════ *@

@if (loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="text-muted mt-2">Loading portal...</p>
    </div>
}
else if (customers is null || customers.Count == 0)
{
    <EmptyState Icon="bi-shield-lock"
                Title="No access granted"
                Message="You don't have access to any customers yet. Ask a tenant administrator to grant you access." />
}
else
{
    <div class="explorer">
        <aside class="tree-side">
            <div class="tree-head">
                <div class="tree-tenant"><i class="bi bi-grid"></i> Customer Portal</div>
                <div class="tree-filter">
                    <i class="bi bi-search text-muted small" aria-hidden="true"></i>
                    <input type="search" placeholder="Filter…" aria-label="Filter customers and apps"
                           value="@filter" @oninput="OnFilterInput" />
                </div>
            </div>

            <div class="tree-scroll" role="tree" aria-label="Customer resources">
                @foreach (IGrouping<Guid, Customer> tenantGroup in customers
                    .GroupBy(c => c.TenantId)
                    .OrderBy(g => g.First().Tenant?.Name))
                {
                    List<Customer> visibleCustomers = VisibleCustomers(tenantGroup);
                    if (visibleCustomers.Count == 0) { continue; }

                    <div class="tree-section-head">
                        <span class="tree-section-label">@(tenantGroup.First().Tenant?.Name ?? "Tenant")</span>
                    </div>

                    @foreach (Customer c in visibleCustomers)
                    {
                        bool copen = CustomerOpen(c);
                        <button type="button" class="node group indent-1 @(CustomerNodeSelected(c) ? "selected" : "")"
                                @onclick="() => ToggleCustomer(c)" aria-expanded="@copen">
                            <span class="caret">@(copen ? "▾" : "▸")</span>
                            <i class="ico bi bi-people" aria-hidden="true"></i>
                            <span class="label">@c.Name</span>
                            <span class="badge-count">@c.Apps.Count</span>
                        </button>

                        @if (copen && selectedCustomer?.Id == c.Id && !loadingCustomer)
                        {
                            @* ── Apps ── *@
                            <div class="tree-sub indent-2">Apps</div>
                            @if (VisibleApps(c).Count == 0)
                            {
                                <div class="tree-empty" style="padding-left:1.5rem">@(HasFilter ? "No matches" : "No apps")</div>
                            }
                            @foreach (Data.App app in VisibleApps(c))
                            {
                                bool aopen = AppOpen(app);
                                int envCount = appLinkedEnvironments.TryGetValue(app.Id, out List<Data.Environment>? le) ? le.Count : 0;
                                <button type="button" class="node group indent-2 @(AppNodeSelected(app) ? "selected" : "")"
                                        @onclick="() => ToggleApp(app)" aria-expanded="@aopen">
                                    <span class="caret">@(aopen ? "▾" : "▸")</span>
                                    <i class="ico bi bi-box-seam" aria-hidden="true"></i>
                                    <span class="label">@app.Name</span>
                                    <span class="badge-count">@envCount</span>
                                </button>

                                @if (aopen)
                                {
                                    @* Environments *@
                                    <div class="tree-sub indent-3">Environments</div>
                                    @if (VisibleEnvs(app).Count == 0)
                                    {
                                        <div class="tree-empty" style="padding-left:2.4rem">@(HasFilter ? "—" : "No environments")</div>
                                    }
                                    @foreach (Data.Environment env in VisibleEnvs(app))
                                    {
                                        <button type="button" class="node leaf indent-3 @(EnvNodeSelected(app, env) ? "selected" : "")"
                                                @onclick="() => SelectEnv(app, env)">
                                            <span class="caret"></span>
                                            <i class="ico bi bi-layers" aria-hidden="true"></i>
                                            <span class="label">@env.Name</span>
                                        </button>
                                    }

                                    @* Services *@
                                    <div class="tree-sub indent-3">Services</div>
                                    @foreach ((string Key, string Label, string Icon) svc in VisibleAppServices(app))
                                    {
                                        <button type="button" class="node leaf indent-3 @(AppServiceSelected(app, svc.Key) ? "selected" : "")"
                                                @onclick="() => SelectAppService(app, svc.Key)">
                                            <span class="caret"></span>
                                            <i class="ico bi @svc.Icon" aria-hidden="true"></i>
                                            <span class="label">@svc.Label</span>
                                        </button>
                                    }
                                }
                            }

                            @* ── Operations (customer-wide) ── *@
                            <div class="tree-sub indent-2">Operations</div>
                            @foreach ((string Key, string Label, string Icon) op in VisibleOps())
                            {
                                <button type="button" class="node leaf indent-2 @(selectedCustomerOp == op.Key ? "selected" : "")"
                                        @onclick="() => SelectOp(op.Key)">
                                    <span class="caret"></span>
                                    <i class="ico bi @op.Icon" aria-hidden="true"></i>
                                    <span class="label">@op.Label</span>
                                </button>
                            }
                        }
                    }
                }
            </div>
        </aside>

        <section class="detail-pane">
            @if (selectedCustomer is null)
            {
                <div class="pane-placeholder">
                    <i class="bi bi-people" aria-hidden="true"></i>
                    <div class="fw-semibold">Select a customer</div>
                    <div class="small">Open a customer to see its apps, environments and operations.</div>
                </div>
            }
            else if (loadingCustomer)
            {
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-people fs-3 me-2 text-primary"></i>
                    <h2 class="mb-0">@selectedCustomer.Name</h2>
                </div>
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="text-muted small mt-2 mb-0">Loading apps...</p>
                </div>
            }
            else if (selectedPortalEnvironment is not null && selectedPortalApp is not null)
            {
                @* App-level actions stay reachable above the environment's deployments so you
                   don't have to leave the deployment view to rename or delete the app. *@
                @if (currentAccessRole >= CustomerAccessRole.Admin)
                {
                    <div class="d-flex align-items-center gap-2 flex-wrap mb-2">
                        <span class="text-muted small"><i class="bi bi-app-indicator me-1"></i>@selectedPortalApp.Name</span>
                        @if (editingAppId == selectedPortalApp.Id)
                        {
                            <input class="form-control form-control-sm" style="max-width:240px"
                                   @bind="editAppName" @bind:event="oninput" @onkeyup="OnEditAppNameKeyUp" />
                            <button class="btn btn-sm btn-primary" @onclick="SaveAppName" disabled="@savingAppName">
                                @if (savingAppName) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Save
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEditApp" disabled="@savingAppName">Cancel</button>
                        }
                        else if (deletingAppId != selectedPortalApp.Id)
                        {
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartEditApp(selectedPortalApp)">
                                <i class="bi bi-pencil me-1"></i>Rename
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => StartDeleteApp(selectedPortalApp)">
                                <i class="bi bi-trash me-1"></i>Delete
                            </button>
                        }
                    </div>
                    @if (deletingAppId == selectedPortalApp.Id)
                    {
                        @if (deleteAppError is not null)
                        {
                            <div class="alert alert-danger py-1 small mb-2"><i class="bi bi-exclamation-triangle me-1"></i>@deleteAppError</div>
                        }
                        <ConfirmDialog Visible="true"
                                       Message="@($"Permanently delete {selectedPortalApp.Name} and all its deployments and cluster resources?")"
                                       ConfirmText="Yes, delete"
                                       IsBusy="deletingApp"
                                       OnConfirm="() => ConfirmDeleteApp(selectedPortalApp.Id)"
                                       OnCancel="CancelDeleteApp" />
                    }
                }
                <AppEnvironmentDetail App="selectedPortalApp"
                                      Environment="selectedPortalEnvironment"
                                      TenantId="selectedCustomer.TenantId"
                                      IsPortalView="true"
                                      AccessRole="currentAccessRole"
                                      InitialDeploymentId="pendingPortalDeploymentId"
                                      OnBack="BackFromEnv"
                                      ShowBackLink="false"
                                      @key="(selectedPortalApp.Id, selectedPortalEnvironment.Id)" />
            }
            else if (selectedIdentityRealm is not null)
            {
                <PortalIdentityDetail Realm="selectedIdentityRealm" TenantId="selectedCustomer.TenantId" />
            }
            else if (selectedSecrets is not null)
            {
                <PortalSecretsDetail
                    @key="(selectedSecrets.App.Id, selectedSecrets.Scope)"
                    App="selectedSecrets.App"
                    TenantId="selectedCustomer.TenantId"
                    AccessRole="currentAccessRole"
                    InitialScope="@selectedSecrets.Scope" />
            }
            else if (selectedRegistryProject is not null)
            {
                <PortalRegistryDetail Project="selectedRegistryProject" TenantId="selectedCustomer.TenantId" AccessRole="currentAccessRole" />
            }
            else if (selectedRoutesApp is not null)
            {
                <PortalAppRoutesPanel App="selectedRoutesApp" AccessRole="currentAccessRole" />
            }
            else if (selectedCustomerOp == "monitoring")
            {
                <div class="d-flex align-items-center mb-3">
                    <span class="bi bi-heart-pulse fs-4 me-2 text-primary"></span>
                    <h4 class="mb-0">Monitoring — @selectedCustomer.Name</h4>
                </div>
                <div class="mb-4">
                    <h6 class="text-muted small mb-2"><span class="bi bi-grid-1x2 me-1"></span>Health &amp; Uptime Dashboard</h6>
                    <CustomerStatusDashboard Customer="selectedCustomer" />
                </div>
                <div class="mb-4">
                    <h6 class="text-muted small mb-2"><span class="bi bi-shield-check me-1"></span>SLA &amp; Uptime</h6>
                    @if (AllCustomerDeployments.Count > 0)
                    {
                        <CustomerSlaReport Deployments="AllCustomerDeployments" CustomerId="selectedCustomer.Id" TenantId="selectedCustomer.TenantId" />
                    }
                    else { <div class="text-muted small">No deployments yet.</div> }
                </div>
                <div>
                    <h6 class="text-muted small mb-2"><span class="bi bi-clock-history me-1"></span>Incident History (30 days)</h6>
                    @if (AllCustomerDeployments.Count > 0)
                    {
                        <CustomerIncidentHistory Deployments="AllCustomerDeployments" WindowDays="30" />
                    }
                    else { <div class="text-muted small">No deployments yet.</div> }
                </div>
            }
            else if (selectedCustomerOp == "logs")
            {
                <div class="d-flex align-items-center mb-3">
                    <span class="bi bi-journal-text fs-4 me-2 text-primary"></span>
                    <h4 class="mb-0">Logs — @selectedCustomer.Name</h4>
                </div>
                <CustomerLogBrowser Customer="selectedCustomer" OnNavigateToDeployment="NavigateToDeploymentFromLogs" />
            }
            else if (selectedCustomerOp == "observability" && currentAccessRole >= CustomerAccessRole.Operator)
            {
                <div class="d-flex align-items-center mb-3">
                    <span class="bi bi-graph-up fs-4 me-2 text-primary"></span>
                    <h4 class="mb-0">Traces, Metrics &amp; RUM — @selectedCustomer.Name</h4>
                </div>
                <CustomerObservability Customer="selectedCustomer" />
            }
            else if (selectedCustomerOp == "notifications")
            {
                <PortalNotifications
                    TenantId="selectedCustomer.TenantId"
                    CustomerId="selectedCustomer.Id"
                    CustomerName="selectedCustomer.Name"
                    AccessRole="currentAccessRole" />
            }
            else
            {
                @* ── Customer home (all apps) or single-app overview ── *@
                @if (selectedOverviewApp is not null)
                {
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-box-seam fs-3 me-2 text-primary"></i>
                        <h2 class="mb-0">@selectedOverviewApp.Name</h2>
                    </div>
                }
                else
                {
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-people fs-3 me-2 text-primary"></i>
                        <div>
                            <h2 class="mb-0">@selectedCustomer.Name</h2>
                            <small class="text-muted">@selectedCustomer.Apps.Count app@(selectedCustomer.Apps.Count != 1 ? "s" : "")</small>
                        </div>
                    </div>
                    <CustomerMaintenanceNotice TenantId="selectedCustomer.TenantId" ClusterIds="AllCustomerClusterIds" />
                }

                @if (!PaneApps.Any())
                {
                    <EmptyState Icon="bi-app-indicator" Message="No apps configured for this customer yet." />
                }
                else
                {
                    @foreach (Data.App app in PaneApps)
                    {
                        <div class="card shadow-sm mb-3">
                            <div class="card-header bg-white py-2">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-app-indicator me-2 text-primary"></i>
                                        <strong>@app.Name</strong>
                                    </div>
                                    @if (currentAccessRole >= CustomerAccessRole.Admin)
                                    {
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                                    data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="bi bi-three-dots me-1"></i>Manage
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <button class="dropdown-item" @onclick="() => StartEditApp(app)">
                                                        <i class="bi bi-pencil me-2"></i>Rename
                                                    </button>
                                                </li>
                                                <li>
                                                    <button class="dropdown-item text-danger" @onclick="() => StartDeleteApp(app)">
                                                        <i class="bi bi-trash me-2"></i>Delete App
                                                    </button>
                                                </li>
                                            </ul>
                                        </div>
                                    }
                                </div>
                            </div>
                            @if (editingAppId == app.Id)
                            {
                                <div class="px-3 py-2 border-top">
                                    <div class="d-flex gap-2 align-items-center flex-wrap">
                                        <input class="form-control form-control-sm" style="max-width:280px"
                                               @bind="editAppName" @bind:event="oninput"
                                               @onkeyup="OnEditAppNameKeyUp" />
                                        <button class="btn btn-sm btn-primary" @onclick="SaveAppName" disabled="@savingAppName">
                                            @if (savingAppName) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                            Save
                                        </button>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEditApp" disabled="@savingAppName">Cancel</button>
                                    </div>
                                </div>
                            }
                            @if (deletingAppId == app.Id)
                            {
                                <div class="px-3 py-2 border-top">
                                    @if (deleteAppError is not null)
                                    {
                                        <div class="alert alert-danger py-1 small mb-2">
                                            <i class="bi bi-exclamation-triangle me-1"></i>@deleteAppError
                                        </div>
                                    }
                                    <ConfirmDialog Visible="true"
                                                   Message="@($"Permanently delete {app.Name} and all its deployments and cluster resources?")"
                                                   ConfirmText="Yes, delete"
                                                   IsBusy="deletingApp"
                                                   OnConfirm="() => ConfirmDeleteApp(app.Id)"
                                                   OnCancel="CancelDeleteApp" />
                                </div>
                            }
                            <div class="card-body">
                                @* ── Environment cards ── *@
                                @if (appLinkedEnvironments.TryGetValue(app.Id, out List<Data.Environment>? linkedEnvs) && linkedEnvs.Count > 0)
                                {
                                    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-2">
                                        @foreach (Data.Environment env in linkedEnvs)
                                        {
                                            int deployCount = appDeployments.TryGetValue(app.Id, out List<AppDeployment>? deploys2)
                                                ? deploys2.Count(d => d.EnvironmentId == env.Id)
                                                : 0;
                                            <div class="col">
                                                <div class="card border-light h-100 portal-env-card" role="button" style="cursor: pointer;"
                                                     @onclick="() => SelectEnv(app, env)">
                                                    <div class="card-body py-2">
                                                        <div class="d-flex align-items-center justify-content-between mb-1">
                                                            <span class="fw-medium">
                                                                <i class="bi bi-layers me-1 text-primary"></i>@env.Name
                                                            </span>
                                                            <i class="bi bi-chevron-right text-muted small"></i>
                                                        </div>
                                                        <div class="small text-muted">
                                                            @if (deployCount > 0)
                                                            {
                                                                <span><i class="bi bi-rocket-takeoff me-1"></i>@deployCount deployment@(deployCount == 1 ? "" : "s")</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="fst-italic">No deployments</span>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <EmptyState Icon="bi-layers" Message="No environments linked to this app yet." />
                                }

                                @* ── External URLs ── *@
                                @if (appRoutes.TryGetValue(app.Id, out List<AppRoute>? routes) && routes.Count > 0)
                                {
                                    <div class="mt-3 pt-2 border-top">
                                        <div class="small text-muted mb-1">
                                            <i class="bi bi-globe me-1"></i>External URLs
                                        </div>
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (AppRoute route in routes.Where(r => r.IsEnabled))
                                            {
                                                string href = $"https://{route.Hostname}";
                                                bool allUp = route.DeploymentRoutes.Any() && route.DeploymentRoutes.All(dr => dr.IsReachable == true);
                                                bool anyDown = route.DeploymentRoutes.Any(dr => dr.IsReachable == false);
                                                string statusClass = allUp ? "text-success" : anyDown ? "text-danger" : "text-muted";
                                                string statusIcon = allUp ? "bi-check-circle-fill" : anyDown ? "bi-x-circle-fill" : "bi-circle";
                                                string tlsTitle = route.TlsMode == TlsMode.ClusterIssuer
                                                    ? $"TLS: auto ({route.ClusterIssuerName})"
                                                    : "TLS: manual certificate";

                                                <div class="d-flex align-items-center gap-1 border rounded px-2 py-1 bg-light" title="@tlsTitle">
                                                    <i class="bi @statusIcon @statusClass small"></i>
                                                    <a href="@href" target="_blank" rel="noopener noreferrer"
                                                       class="small text-decoration-none fw-medium">@route.Hostname</a>
                                                    <i class="bi bi-lock-fill text-success small" title="@tlsTitle"></i>
                                                    @if (route.DeploymentRoutes.Count(dr => dr.IsEnabled) > 1)
                                                    {
                                                        <span class="badge bg-secondary bg-opacity-50 small" title="Multiple deployment paths">
                                                            @route.DeploymentRoutes.Count(dr => dr.IsEnabled)
                                                        </span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            }
        </section>
    </div>
}

@code {
    private bool loading = true;
    private bool loadingCustomer;
    private string? currentUserId;
    private CustomerAccessRole currentAccessRole;

    private List<Customer>? customers;
    private Customer? selectedCustomer;

    // ── Deep-link query parameters ──
    [SupplyParameterFromQuery(Name = "customer")] private Guid? CustomerParam { get; set; }
    [SupplyParameterFromQuery(Name = "app")] private Guid? AppParam { get; set; }
    [SupplyParameterFromQuery(Name = "env")] private Guid? EnvParam { get; set; }
    [SupplyParameterFromQuery(Name = "section")] private string? SectionParam { get; set; }
    private (Guid?, Guid?, Guid?, string?)? _appliedQuery;

    // ── Tree expansion state ──
    // Only one customer's subtree is loaded at a time, so the loaded customer is the expanded one.
    private Guid? expandedCustomerId;
    private readonly HashSet<Guid> expandedApps = [];
    private string filter = "";
    private bool HasFilter => !string.IsNullOrWhiteSpace(filter);

    // ── Right-pane selection (mutually exclusive) ──
    private Data.App? selectedOverviewApp;          // single-app overview
    private Data.App? selectedPortalApp;            // env detail: app
    private Data.Environment? selectedPortalEnvironment;
    private Guid? pendingPortalDeploymentId;
    private KeycloakRealm? selectedIdentityRealm;
    private HarborProject? selectedRegistryProject;
    private Data.App? selectedRoutesApp;
    private string? selectedCustomerOp;             // "monitoring" | "logs" | "observability" | "notifications"
    private Guid? activeAppId;                       // app whose service leaf is active (for tree highlight)
    private string? activeAppServiceKey;

    private sealed record SecretsNav(Data.App App, string Scope);
    private SecretsNav? selectedSecrets;

    // ── Per-customer loaded data (keyed by app id) ──
    private Dictionary<Guid, List<Data.Environment>> appLinkedEnvironments = new();
    private Dictionary<Guid, List<AppDeployment>> appDeployments = new();
    private Dictionary<Guid, KeycloakRealm> appRealms = new();
    private Dictionary<Guid, HarborProject> appHarborProjects = new();
    private Dictionary<Guid, List<AppRoute>> appRoutes = new();
    private List<Data.Environment> tenantEnvironments = [];

    private List<AppDeployment> AllCustomerDeployments => appDeployments.Values.SelectMany(d => d).ToList();
    private HashSet<Guid> AllCustomerClusterIds => AllCustomerDeployments.Select(d => d.ClusterId).ToHashSet();

    // Apps shown in the right pane: the single selected app, else all of the customer's apps.
    private IEnumerable<Data.App> PaneApps =>
        selectedOverviewApp is not null
            ? new[] { selectedOverviewApp }
            : selectedCustomer?.Apps.OrderBy(a => a.Name) ?? Enumerable.Empty<Data.App>();

    // ── App edit/delete state ──
    private Guid? editingAppId;
    private string editAppName = "";
    private bool savingAppName;
    private Guid? deletingAppId;
    private bool deletingApp;
    private string? deleteAppError;

    protected override async Task OnInitializedAsync()
    {
        AuthenticationState authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrEmpty(currentUserId))
        {
            loading = false;
            return;
        }

        customers = await CustomerAccessService.GetAccessibleCustomersAsync(currentUserId);
        loading = false;
    }

    // Re-derive the open pane from the query string whenever it changes (deep links + mega-menu).
    protected override async Task OnParametersSetAsync()
    {
        if (loading || customers is null) return;

        (Guid?, Guid?, Guid?, string?) sig = (CustomerParam, AppParam, EnvParam, SectionParam);
        if (_appliedQuery is { } applied && applied == sig) return;
        _appliedQuery = sig;
        await RestoreSelectionFromQuery();
    }

    private async Task RestoreSelectionFromQuery()
    {
        // Ensure the requested customer is the loaded one.
        if (CustomerParam is Guid cid)
        {
            if (selectedCustomer?.Id != cid)
            {
                Customer? match = customers!.FirstOrDefault(x => x.Id == cid);
                if (match is not null) await LoadCustomerAsync(match);
            }
            if (selectedCustomer?.Id != cid) { return; }       // not accessible
            expandedCustomerId = cid;
        }
        else
        {
            ClearPaneSelection();
            selectedCustomer = null;
            expandedCustomerId = null;
            return;
        }

        // Rebuild the deeper selection from scratch.
        ClearPaneSelection();

        Data.App? app = AppParam is Guid aid ? selectedCustomer!.Apps.FirstOrDefault(a => a.Id == aid) : null;
        if (app is not null) expandedApps.Add(app.Id);

        if (app is not null && EnvParam is Guid eid)
        {
            Data.Environment? env = appLinkedEnvironments.GetValueOrDefault(app.Id)?.FirstOrDefault(e => e.Id == eid);
            if (env is not null) { selectedPortalApp = app; selectedPortalEnvironment = env; }
        }
        else if (app is not null && !string.IsNullOrEmpty(SectionParam))
        {
            ApplyAppService(app, SectionParam);
        }
        else if (app is not null)
        {
            selectedOverviewApp = app;
        }
        else if (SectionParam is "monitoring" or "logs" or "observability" or "notifications")
        {
            selectedCustomerOp = SectionParam;
        }
    }

    // ── Customer load ──
    private async Task LoadCustomerAsync(Customer customer)
    {
        selectedCustomer = customer;
        loadingCustomer = true;
        ClearPaneSelection();
        expandedApps.Clear();
        StateHasChanged();

        CustomerAccess? access = await CustomerAccessService.GetAccessAsync(currentUserId!, customer.Id);
        currentAccessRole = access?.Role ?? CustomerAccessRole.Viewer;

        appDeployments.Clear();
        appRealms.Clear();
        appHarborProjects.Clear();
        appRoutes.Clear();
        appLinkedEnvironments.Clear();

        foreach (Data.App app in customer.Apps)
        {
            appDeployments[app.Id] = await DeploymentService.GetDeploymentsAsync(app.Id);

            KeycloakRealm? realm = await KeycloakService.GetRealmForAppAsync(customer.TenantId, app.Id);
            if (realm is not null) appRealms[app.Id] = realm;

            HarborProject? harborProject = await HarborService.GetProjectForAppAsync(customer.TenantId, app.Id);
            if (harborProject is not null) appHarborProjects[app.Id] = harborProject;

            try
            {
                List<AppRoute> routes = await AppRouteService.GetRoutesForAppAsync(app.Id);
                if (routes.Count > 0) appRoutes[app.Id] = routes;
            }
            catch
            {
                // Routes table may not exist if a migration is pending; skip silently.
            }
        }

        tenantEnvironments = await TenantService.GetEnvironmentsAsync(customer.TenantId);
        foreach (Data.App app in customer.Apps)
        {
            appLinkedEnvironments[app.Id] = tenantEnvironments
                .Where(e => app.AppEnvironments.Any(ae => ae.EnvironmentId == e.Id))
                .ToList();
        }

        loadingCustomer = false;
    }

    // ── Tree node handlers ──
    private async Task ToggleCustomer(Customer c)
    {
        if (expandedCustomerId == c.Id)
        {
            // Collapse but keep it loaded so the pane persists.
            expandedCustomerId = null;
            return;
        }
        await LoadCustomerAsync(c);
        expandedCustomerId = c.Id;
        ClearPaneSelection();
        UpdateUrl();
    }

    private void ToggleApp(Data.App app)
    {
        if (!expandedApps.Remove(app.Id)) expandedApps.Add(app.Id);
        ClearPaneSelection();
        selectedOverviewApp = app;
        UpdateUrl(app: app.Id);
    }

    private void SelectEnv(Data.App app, Data.Environment env)
    {
        ClearPaneSelection();
        selectedPortalApp = app;
        selectedPortalEnvironment = env;
        expandedApps.Add(app.Id);
        UpdateUrl(app: app.Id, env: env.Id);
    }

    private void SelectAppService(Data.App app, string key)
    {
        ClearPaneSelection();
        expandedApps.Add(app.Id);
        ApplyAppService(app, key);
        UpdateUrl(app: app.Id, section: key);
    }

    // Maps a service key onto the concrete pane selection (shared by clicks and deep-link restore).
    private void ApplyAppService(Data.App app, string key)
    {
        activeAppId = app.Id;
        activeAppServiceKey = key;
        switch (key)
        {
            case "secrets": selectedSecrets = new(app, "app"); break;
            case "identity":
                if (appRealms.TryGetValue(app.Id, out KeycloakRealm? realm)) selectedIdentityRealm = realm;
                break;
            case "registry":
                if (appHarborProjects.TryGetValue(app.Id, out HarborProject? project)) selectedRegistryProject = project;
                break;
            case "urls": selectedRoutesApp = app; break;
        }
    }

    private void SelectOp(string key)
    {
        ClearPaneSelection();
        selectedCustomerOp = key;
        UpdateUrl(section: key);
    }

    private void BackFromEnv()
    {
        Data.App? app = selectedPortalApp;
        ClearPaneSelection();
        selectedOverviewApp = app;
        UpdateUrl(app: app?.Id);
    }

    // Jump from a clicked log row to its deployment (lands on the per-deployment env view).
    private void NavigateToDeploymentFromLogs(Guid deploymentId)
    {
        AppDeployment? deploy = appDeployments.Values.SelectMany(d => d).FirstOrDefault(d => d.Id == deploymentId);
        if (deploy is null) return;

        Data.App? app = selectedCustomer?.Apps.FirstOrDefault(a => a.Id == deploy.AppId);
        Data.Environment? env = tenantEnvironments.FirstOrDefault(e => e.Id == deploy.EnvironmentId);
        if (app is null || env is null) return;

        ClearPaneSelection();
        selectedPortalApp = app;
        selectedPortalEnvironment = env;
        pendingPortalDeploymentId = deploymentId;
        expandedApps.Add(app.Id);
        UpdateUrl(app: app.Id, env: env.Id);
    }

    private void ClearPaneSelection()
    {
        selectedOverviewApp = null;
        selectedPortalApp = null;
        selectedPortalEnvironment = null;
        pendingPortalDeploymentId = null;
        selectedSecrets = null;
        selectedIdentityRealm = null;
        selectedRegistryProject = null;
        selectedRoutesApp = null;
        selectedCustomerOp = null;
        activeAppId = null;
        activeAppServiceKey = null;
    }

    private void UpdateUrl(Guid? app = null, Guid? env = null, string? section = null)
    {
        string uri = Navigation.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["customer"] = selectedCustomer?.Id,
            ["app"] = app,
            ["env"] = env,
            ["section"] = section,
        });
        // Keep the applied-query signature in sync so the resulting navigation is a no-op re-render.
        _appliedQuery = (selectedCustomer?.Id, app, env, section);
        Navigation.NavigateTo(uri, forceLoad: false, replace: true);
    }

    // ── Tree data / selection helpers ──
    private bool Match(string? s) => s is not null && s.Contains(filter.Trim(), StringComparison.OrdinalIgnoreCase);

    private List<Customer> VisibleCustomers(IEnumerable<Customer> group)
    {
        List<Customer> ordered = group.OrderBy(c => c.Name).ToList();
        if (!HasFilter) return ordered;
        return ordered.Where(c => Match(c.Name) || c.Apps.Any(a => Match(a.Name))).ToList();
    }

    private bool CustomerOpen(Customer c) => expandedCustomerId == c.Id;

    private bool CustomerNodeSelected(Customer c) =>
        selectedCustomer?.Id == c.Id
        && selectedOverviewApp is null && selectedPortalEnvironment is null
        && selectedSecrets is null && selectedIdentityRealm is null && selectedRegistryProject is null
        && selectedRoutesApp is null && selectedCustomerOp is null;

    private List<Data.App> VisibleApps(Customer c)
    {
        List<Data.App> apps = c.Apps.OrderBy(a => a.Name).ToList();
        if (!HasFilter || Match(c.Name)) return apps;
        return apps.Where(a => Match(a.Name)).ToList();
    }

    private bool AppOpen(Data.App app) => expandedApps.Contains(app.Id);
    private bool AppNodeSelected(Data.App app) => selectedOverviewApp?.Id == app.Id;

    private List<Data.Environment> VisibleEnvs(Data.App app)
    {
        List<Data.Environment> envs = appLinkedEnvironments.GetValueOrDefault(app.Id) ?? [];
        if (!HasFilter || Match(app.Name)) return envs;
        return envs.Where(e => Match(e.Name)).ToList();
    }

    private bool EnvNodeSelected(Data.App app, Data.Environment env) =>
        selectedPortalApp?.Id == app.Id && selectedPortalEnvironment?.Id == env.Id;

    // Per-app service leaves; Identity/Registry only when the app has one linked.
    // Databases/Messaging/Cache live as tabs under each Environment (see AppEnvironmentDetail),
    // so they are not repeated here — only app-level services belong in this flat group.
    private List<(string Key, string Label, string Icon)> AppServiceItems(Data.App app)
    {
        var items = new List<(string Key, string Label, string Icon)>
        {
            ("secrets", "App Secrets", "bi-key"),
        };
        if (appRealms.ContainsKey(app.Id)) items.Add(("identity", "Identity", "bi-shield-lock"));
        if (appHarborProjects.ContainsKey(app.Id)) items.Add(("registry", "Registry", "bi-archive"));
        items.Add(("urls", "URLs", "bi-globe"));
        return items;
    }

    private List<(string Key, string Label, string Icon)> VisibleAppServices(Data.App app)
    {
        List<(string Key, string Label, string Icon)> items = AppServiceItems(app);
        if (!HasFilter || Match(app.Name)) return items;
        return items.Where(i => Match(i.Label)).ToList();
    }

    private bool AppServiceSelected(Data.App app, string key) =>
        activeAppId == app.Id && activeAppServiceKey == key;

    private List<(string Key, string Label, string Icon)> VisibleOps()
    {
        var items = new List<(string Key, string Label, string Icon)>
        {
            ("monitoring", "Monitoring", "bi-heart-pulse"),
            ("logs", "Logs", "bi-journal-text"),
        };
        if (currentAccessRole >= CustomerAccessRole.Operator)
            items.Add(("observability", "Traces & Metrics", "bi-graph-up"));
        items.Add(("notifications", "Notifications", "bi-bell"));

        if (!HasFilter) return items;
        return items.Where(i => Match(i.Label)).ToList();
    }

    private void OnFilterInput(ChangeEventArgs e) => filter = e.Value?.ToString() ?? "";

    // ── App edit ──
    private void StartEditApp(Data.App app)
    {
        editingAppId = app.Id;
        editAppName = app.Name;
        deletingAppId = null;
    }

    private void CancelEditApp()
    {
        editingAppId = null;
        editAppName = "";
    }

    private async Task OnEditAppNameKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SaveAppName();
    }

    private async Task SaveAppName()
    {
        if (editingAppId is null || string.IsNullOrWhiteSpace(editAppName)) return;

        savingAppName = true;
        await TenantService.RenameAppAsync(editingAppId.Value, editAppName);

        Data.App? appInList = selectedCustomer!.Apps.FirstOrDefault(a => a.Id == editingAppId.Value);
        if (appInList is not null) appInList.Name = editAppName.Trim();

        editingAppId = null;
        editAppName = "";
        savingAppName = false;
    }

    // ── App delete ──
    private void StartDeleteApp(Data.App app)
    {
        deletingAppId = app.Id;
        deleteAppError = null;
        editingAppId = null;
    }

    private void CancelDeleteApp()
    {
        deletingAppId = null;
        deleteAppError = null;
    }

    private async Task ConfirmDeleteApp(Guid appId)
    {
        deletingApp = true;
        deleteAppError = null;

        await K8sOps.DeleteAppFromClusterAsync(appId, currentUserId);
        await TenantService.DeleteAppAsync(appId);

        Data.App? appToRemove = selectedCustomer!.Apps.FirstOrDefault(a => a.Id == appId);
        if (appToRemove is not null) selectedCustomer.Apps.Remove(appToRemove);
        appDeployments.Remove(appId);
        appRealms.Remove(appId);
        appHarborProjects.Remove(appId);
        appLinkedEnvironments.Remove(appId);
        expandedApps.Remove(appId);
        // If we were viewing the deleted app (overview or one of its environments), drop back to the customer home.
        if (selectedOverviewApp?.Id == appId || selectedPortalApp?.Id == appId) ClearPaneSelection();

        deletingApp = false;
        deletingAppId = null;
    }
}
