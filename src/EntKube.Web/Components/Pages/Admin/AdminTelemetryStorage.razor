@page "/admin/telemetry"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using EntKube.Web.Data
@using EntKube.Web.Services
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]

@inject TelemetryStorageSettingService StorageSettings
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthState
@inject ToastService Toasts

<PageTitle>Telemetry Storage</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="mb-0"><i class="bi bi-hdd-network me-2 text-primary"></i>Telemetry Storage</h1>
        <p class="text-muted small mb-0 mt-1">
            Where the telemetry segment engine stores sealed logs / traces / RUM segments (object storage).
        </p>
    </div>
</div>

@if (loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body">
            <p class="text-muted small">
                Choose a registered <strong>storage link</strong> (AWS S3 / Cleura S3 / MinIO — credentials stored
                in the vault) to hold sealed telemetry segments. This is one store shared by all tenants. Leave it
                unset to use the flat <code>Telemetry:ObjectStorage</code> config, or local disk if neither is set.
            </p>

            <div class="mb-3" style="max-width: 640px;">
                <label class="form-label small text-muted mb-1">Storage link</label>
                <select class="form-select" @bind="selectedLinkId" disabled="@saving">
                    <option value="">— None (flat config / local disk) —</option>
                    @foreach (StorageLink l in links)
                    {
                        <option value="@l.Id">
                            @(l.Tenant?.Name ?? "?") / @l.Name — @l.Provider@(string.IsNullOrEmpty(l.BucketName) ? "" : $" ({l.BucketName})")
                        </option>
                    }
                </select>
            </div>

            @if (links.Count == 0)
            {
                <div class="alert alert-light border small py-2">
                    No storage links are registered yet. Add one from a tenant's <strong>Storage</strong> tab, then select it here.
                </div>
            }

            <div class="alert alert-warning border small py-2">
                <i class="bi bi-exclamation-triangle me-1"></i>
                Changing the storage link applies to <strong>newly sealed</strong> segments. Segments already written to
                the previous store stay there until retention ages them out — switch deliberately.
            </div>

            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@saving">
                @if (saving)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                Save
            </button>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private bool saving;
    private List<StorageLink> links = [];
    private string selectedLinkId = "";

    protected override async Task OnInitializedAsync()
    {
        await using ApplicationDbContext db = await DbFactory.CreateDbContextAsync();
        links = await db.StorageLinks.Include(l => l.Tenant).AsNoTracking()
            .OrderBy(l => l.Tenant.Name).ThenBy(l => l.Name)
            .ToListAsync();

        Guid? current = await StorageSettings.GetStorageLinkIdAsync();
        selectedLinkId = current?.ToString() ?? "";
        loading = false;
    }

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            Guid? id = Guid.TryParse(selectedLinkId, out Guid g) ? g : null;
            AuthenticationState authState = await AuthState.GetAuthenticationStateAsync();
            string? userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            await StorageSettings.SetStorageLinkIdAsync(id, userId);
            Toasts.Success(id is null
                ? "Telemetry storage set to flat config / local disk."
                : "Telemetry storage link saved.");
        }
        catch (Exception ex)
        {
            Toasts.Error($"Failed to save telemetry storage: {ex.Message}");
        }
        finally
        {
            saving = false;
        }
    }
}
