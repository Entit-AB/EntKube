@page "/admin/users/{UserId}"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using EntKube.Web.Data
@using EntKube.Web.Services
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]

@inject UserManagementService UserManagement
@inject NavigationManager NavigationManager
@inject ToastService Toasts

<PageTitle>@(user?.Email ?? "User")</PageTitle>

@if (user is null && loaded)
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>User not found.</div>
}
else if (user is not null)
{
    <div class="d-flex align-items-center mb-1">
        <a href="/admin/users" class="btn btn-sm btn-outline-secondary me-3">
            <i class="bi bi-arrow-left me-1"></i>Users
        </a>
        <h1 class="mb-0 fs-3"><i class="bi bi-person-circle me-2 text-primary"></i>@user.Email</h1>
        @if (user.EmailConfirmed)
        {
            <span class="badge bg-success-subtle text-success border border-success-subtle ms-3">Confirmed</span>
        }
        else
        {
            <span class="badge bg-warning-subtle text-warning border border-warning-subtle ms-3">Unconfirmed</span>
        }
    </div>
    <p class="text-muted small mb-4">ID: @user.Id</p>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible py-2" role="alert">
            <i class="bi bi-exclamation-triangle me-1"></i>@errorMessage
            <button type="button" class="btn-close btn-close-sm" @onclick="() => errorMessage = null"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success py-2 small" role="alert">
            <i class="bi bi-check-circle me-1"></i>@successMessage
        </div>
    }

    <div class="row g-4">

        @* ── Security & Access ── *@
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3"><i class="bi bi-shield-lock me-2 text-primary"></i>Security &amp; Access</h5>
                    <div class="row g-3">
                        <div class="col-6 col-md-3">
                            <div class="text-muted small mb-1">Session</div>
                            @if (security?.IsOnline == true)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle">
                                    <i class="bi bi-circle-fill me-1" style="font-size:.5rem;vertical-align:middle"></i>Online now
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">Offline</span>
                            }
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted small mb-1">Multi-factor auth</div>
                            @if (security?.TwoFactorEnabled == true)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle">
                                    <i class="bi bi-shield-check me-1"></i>Enabled
                                </span>
                            }
                            else if (security?.MfaSetupIncomplete == true)
                            {
                                <span class="badge bg-warning-subtle text-warning border border-warning-subtle"
                                      title="An authenticator key exists from an unfinished setup, but two-factor was never turned on. This is why the user's own page says 'configured' while this flag reads off — use 'Reset & disable MFA' below to clear it.">
                                    <i class="bi bi-shield-exclamation me-1"></i>Setup incomplete
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">
                                    <i class="bi bi-shield-x me-1"></i>Not enabled
                                </span>
                            }
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted small mb-1">Passkeys</div>
                            @if (security is { PasskeyCount: > 0 })
                            {
                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle">
                                    <i class="bi bi-key me-1"></i>@security.PasskeyCount registered
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">None registered</span>
                            }
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted small mb-1">Last login</div>
                            <span class="fw-semibold">
                                @(user.LastLoginAt is { } t ? t.ToString("MMM d, yyyy HH:mm 'UTC'") : "Never")
                            </span>
                        </div>
                    </div>

                    @* ── Reset multi-factor auth (works in any half-finished state) ── *@
                    <hr class="my-3" />
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <div class="me-auto">
                            <div class="fw-semibold small">Reset multi-factor auth</div>
                            <div class="text-muted small">
                                Disables two-factor and deletes the authenticator app + recovery codes — whatever
                                half-finished state it's in — then signs the user out so they can enroll again cleanly.
                            </div>
                        </div>
                        @if (!confirmResetMfa)
                        {
                            <button class="btn btn-sm btn-outline-warning" @onclick="() => confirmResetMfa = true">
                                <i class="bi bi-shield-slash me-1"></i>Reset &amp; disable MFA
                            </button>
                        }
                    </div>
                    @if (confirmResetMfa)
                    {
                        <div class="border border-warning-subtle bg-warning-subtle rounded p-3 mt-2">
                            <div class="small mb-2">
                                Reset MFA for <strong>@user.Email</strong>? This disables two-factor, deletes their
                                authenticator key and recovery codes, and rotates their security stamp — any active
                                sessions and remembered-browser 2FA are invalidated.
                            </div>
                            @if (security is { PasskeyCount: > 0 })
                            {
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" id="alsoPasskeys" @bind="alsoRemovePasskeys" />
                                    <label class="form-check-label small" for="alsoPasskeys">
                                        Also remove this user's @security.PasskeyCount passkey(s). They'll lose passwordless
                                        sign-in and must re-register. Leave unchecked to reset only the authenticator/2FA.
                                    </label>
                                </div>
                            }
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-warning" @onclick="ResetMfa" disabled="@resettingMfa">
                                    @if (resettingMfa) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    Reset MFA
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="CancelResetMfa" disabled="@resettingMfa">Cancel</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ── Global Roles ── *@
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3"><i class="bi bi-shield-lock me-2 text-primary"></i>Global Roles</h5>
                    @if (allRoles.Count == 0)
                    {
                        <p class="text-muted small mb-0">No global roles defined.</p>
                    }
                    else
                    {
                        <div class="d-flex flex-wrap gap-3">
                            @foreach (IdentityRole role in allRoles)
                            {
                                bool hasRole = userRoles.Contains(role.Name ?? "");
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" role="switch"
                                           id="role-@role.Id"
                                           checked="@hasRole"
                                           @onchange="e => ToggleRole(role.Name!, (bool)(e.Value ?? false))" />
                                    <label class="form-check-label fw-semibold" for="role-@role.Id">
                                        @role.Name
                                    </label>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ── Tenant Memberships ── *@
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3"><i class="bi bi-building me-2 text-primary"></i>Tenant Memberships</h5>

                    @if (tenantMemberships.Count > 0)
                    {
                        <div class="table-responsive mb-3">
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Tenant</th>
                                        <th>Role</th>
                                        <th>Joined</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (TenantMembership m in tenantMemberships)
                                    {
                                        <tr>
                                            <td class="align-middle">@m.Tenant.Name</td>
                                            <td class="align-middle">
                                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle">@m.Role.Name</span>
                                            </td>
                                            <td class="align-middle text-muted small">@m.JoinedAt.ToString("MMM d, yyyy")</td>
                                            <td class="align-middle text-end">
                                                <button class="btn btn-sm btn-outline-danger"
                                                        @onclick="() => confirmRemoveTenantId = m.TenantId">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                        @if (confirmRemoveTenantId == m.TenantId)
                                        {
                                            <tr class="table-danger table-sm">
                                                <td colspan="4" class="px-3 py-2">
                                                    <ConfirmDialog Visible="true"
                                                                   Message="@($"Remove {user!.Email} from tenant '{m.Tenant.Name}'?")"
                                                                   ConfirmText="Remove"
                                                                   IsBusy="removingMembership"
                                                                   OnConfirm="() => RemoveTenantMembership(m.TenantId)"
                                                                   OnCancel="() => confirmRemoveTenantId = null" />
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    @* Add tenant form *@
                    @if (availableTenants.Count > 0)
                    {
                        <EditForm Model="addTenantForm" OnValidSubmit="AddTenantMembership">
                            <DataAnnotationsValidator />
                            <div class="d-flex gap-2 align-items-end flex-wrap">
                                <div>
                                    <label class="form-label small text-muted mb-1">Tenant</label>
                                    <InputSelect class="form-select form-select-sm" style="min-width:180px"
                                                 @bind-Value="addTenantForm.TenantId" @bind-Value:after="OnAddTenantChanged">
                                        <option value="">Select tenant…</option>
                                        @foreach (Tenant t in availableTenants)
                                        {
                                            <option value="@t.Id">@t.Name</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="() => addTenantForm.TenantId" class="text-danger small" />
                                </div>
                                <div>
                                    <label class="form-label small text-muted mb-1">Role</label>
                                    @if (addTenantForm.TenantId is not null && !rolesForSelectedTenant.Any())
                                    {
                                        <div class="text-muted small">
                                            <i class="bi bi-exclamation-circle me-1"></i>No roles defined for this tenant.
                                            <a href="/admin/roles">Create roles first</a>.
                                        </div>
                                    }
                                    else
                                    {
                                        <InputSelect class="form-select form-select-sm" style="min-width:150px"
                                                     @bind-Value="addTenantForm.RoleId">
                                            <option value="">Select role…</option>
                                            @foreach (TenantRole r in rolesForSelectedTenant)
                                            {
                                                <option value="@r.Id">@r.Name</option>
                                            }
                                        </InputSelect>
                                        <ValidationMessage For="() => addTenantForm.RoleId" class="text-danger small" />
                                    }
                                </div>
                                <button type="submit" class="btn btn-sm btn-primary">
                                    <i class="bi bi-plus-lg me-1"></i>Add
                                </button>
                            </div>
                        </EditForm>
                    }
                    else if (tenantMemberships.Count == 0)
                    {
                        <p class="text-muted small mb-0">No tenants available to assign.</p>
                    }
                </div>
            </div>
        </div>

        @* ── Group Memberships ── *@
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3"><i class="bi bi-diagram-3 me-2 text-primary"></i>Group Memberships</h5>

                    @if (groupMemberships.Count > 0)
                    {
                        <div class="table-responsive mb-3">
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Group</th>
                                        <th>Tenant</th>
                                        <th>Joined</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (GroupMembership gm in groupMemberships)
                                    {
                                        <tr>
                                            <td class="align-middle">@gm.Group.Name</td>
                                            <td class="align-middle text-muted small">@gm.Group.Tenant.Name</td>
                                            <td class="align-middle text-muted small">@gm.JoinedAt.ToString("MMM d, yyyy")</td>
                                            <td class="align-middle text-end">
                                                <button class="btn btn-sm btn-outline-danger"
                                                        @onclick="() => confirmRemoveGroupId = gm.GroupId">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                        @if (confirmRemoveGroupId == gm.GroupId)
                                        {
                                            <tr class="table-danger table-sm">
                                                <td colspan="4" class="px-3 py-2">
                                                    <ConfirmDialog Visible="true"
                                                                   Message="@($"Remove {user!.Email} from group '{gm.Group.Name}'?")"
                                                                   ConfirmText="Remove"
                                                                   IsBusy="removingMembership"
                                                                   OnConfirm="() => RemoveGroupMembership(gm.GroupId)"
                                                                   OnCancel="() => confirmRemoveGroupId = null" />
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    @* Add group form — only tenants this user is a member of have groups *@
                    @if (tenantMemberships.Count > 0)
                    {
                        <EditForm Model="addGroupForm" OnValidSubmit="AddGroupMembership">
                            <DataAnnotationsValidator />
                            <div class="d-flex gap-2 align-items-end flex-wrap">
                                <div>
                                    <label class="form-label small text-muted mb-1">Tenant</label>
                                    <InputSelect class="form-select form-select-sm" style="min-width:180px"
                                                 @bind-Value="addGroupForm.TenantId" @bind-Value:after="OnAddGroupTenantChanged">
                                        <option value="">Select tenant…</option>
                                        @foreach (TenantMembership m in tenantMemberships)
                                        {
                                            <option value="@m.TenantId">@m.Tenant.Name</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div>
                                    <label class="form-label small text-muted mb-1">Group</label>
                                    <InputSelect class="form-select form-select-sm" style="min-width:180px"
                                                 @bind-Value="addGroupForm.GroupId">
                                        <option value="">Select group…</option>
                                        @foreach (Group g in availableGroupsForTenant)
                                        {
                                            <option value="@g.Id">@g.Name</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="() => addGroupForm.GroupId" class="text-danger small" />
                                </div>
                                <button type="submit" class="btn btn-sm btn-primary">
                                    <i class="bi bi-plus-lg me-1"></i>Add
                                </button>
                            </div>
                        </EditForm>
                    }
                    else if (groupMemberships.Count == 0)
                    {
                        <p class="text-muted small mb-0">Add the user to a tenant first, then assign groups.</p>
                    }
                </div>
            </div>
        </div>

        @* ── Danger Zone ── *@
        <div class="col-12">
            <div class="card border-danger border-opacity-50 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-danger mb-1"><i class="bi bi-exclamation-triangle me-2"></i>Danger Zone</h5>
                    <p class="text-muted small mb-3">Permanently delete this user account. All tenant and group memberships are removed. This cannot be undone.</p>
                    <button class="btn btn-outline-danger" @onclick="() => confirmDelete = true"
                            hidden="@confirmDelete">
                        <i class="bi bi-trash me-1"></i>Delete User
                    </button>
                    <ConfirmDialog Visible="confirmDelete"
                                   Message="@($"Permanently delete {user.Email}? All memberships are removed and this cannot be undone.")"
                                   ConfirmText="Delete Permanently"
                                   IsBusy="deletingUser"
                                   OnConfirm="DeleteUser"
                                   OnCancel="() => confirmDelete = false" />
                </div>
            </div>
        </div>

    </div>
}

@code {
    [Parameter] public string UserId { get; set; } = null!;

    private ApplicationUser? user;
    private UserSecurityInfo? security;
    private bool loaded;
    private string? errorMessage;

    private List<IdentityRole> allRoles = [];
    private IList<string> userRoles = [];

    private List<TenantMembership> tenantMemberships = [];
    private List<Tenant> allTenants = [];
    private List<Tenant> availableTenants = [];

    // Add-tenant form state
    private AddTenantForm addTenantForm = new();
    private IEnumerable<TenantRole> rolesForSelectedTenant =>
        allTenants.FirstOrDefault(t => t.Id == addTenantForm.TenantId)?.Roles ?? [];

    private void OnAddTenantChanged()
    {
        // Switching tenant invalidates the previously chosen role.
        addTenantForm.RoleId = null;
    }

    private List<GroupMembership> groupMemberships = [];

    // Add-group form state
    private AddGroupForm addGroupForm = new();
    private List<Group> availableGroupsForTenant = [];

    private async Task OnAddGroupTenantChanged()
    {
        // Switching tenant clears the chosen group and reloads the group options.
        addGroupForm.GroupId = null;
        await LoadGroupsForSelectedTenant();
    }

    private Guid? confirmRemoveTenantId;
    private Guid? confirmRemoveGroupId;
    private bool confirmDelete;
    private bool removingMembership;
    private bool deletingUser;
    private bool confirmResetMfa;
    private bool alsoRemovePasskeys;
    private bool resettingMfa;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        user = await UserManagement.GetUserByIdAsync(UserId);
        loaded = true;
        if (user is null) return;

        security = await UserManagement.GetUserSecurityAsync(UserId);

        // UserManager and RoleManager share the scoped DbContext — run sequentially.
        // The IDbContextFactory-based calls each create their own instance and are safe.
        allRoles = await UserManagement.GetAllRolesAsync();
        userRoles = await UserManagement.GetUserRolesAsync(UserId);
        tenantMemberships = await UserManagement.GetUserTenantMembershipsAsync(UserId);
        groupMemberships = await UserManagement.GetUserGroupMembershipsAsync(UserId);
        allTenants = await UserManagement.GetAllTenantsAsync();

        RefreshAvailableTenants();
    }

    private void RefreshAvailableTenants()
    {
        HashSet<Guid> joined = tenantMemberships.Select(m => m.TenantId).ToHashSet();
        availableTenants = allTenants.Where(t => !joined.Contains(t.Id)).ToList();
        if (addTenantForm.TenantId is { } selected && availableTenants.All(t => t.Id != selected))
        {
            addTenantForm.TenantId = null;
            addTenantForm.RoleId = null;
        }
    }

    private async Task LoadGroupsForSelectedTenant()
    {
        if (addGroupForm.TenantId is not { } tenantId)
        {
            availableGroupsForTenant = [];
            return;
        }
        List<Group> all = await UserManagement.GetGroupsForTenantAsync(tenantId);
        HashSet<Guid> joined = groupMemberships.Select(gm => gm.GroupId).ToHashSet();
        availableGroupsForTenant = all.Where(g => !joined.Contains(g.Id)).ToList();
        StateHasChanged();
    }

    private async Task ToggleRole(string role, bool grant)
    {
        errorMessage = null;
        IdentityResult result = grant
            ? await UserManagement.AddToRoleAsync(UserId, role)
            : await UserManagement.RemoveFromRoleAsync(UserId, role);

        if (!result.Succeeded)
        {
            errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
            return;
        }

        userRoles = await UserManagement.GetUserRolesAsync(UserId);
    }

    private async Task AddTenantMembership()
    {
        errorMessage = null;

        try
        {
            await UserManagement.AddTenantMembershipAsync(UserId, addTenantForm.TenantId!.Value, addTenantForm.RoleId!.Value);
            addTenantForm = new AddTenantForm();
            tenantMemberships = await UserManagement.GetUserTenantMembershipsAsync(UserId);
            RefreshAvailableTenants();
            Toasts.Success("Tenant membership added.");
        }
        catch (Exception ex)
        {
            string msg = $"Failed to add tenant membership: {ex.Message}";
            errorMessage = msg;
            Toasts.Error(msg);
        }
    }

    private async Task ShowSuccessAsync(string message)
    {
        successMessage = message;
        StateHasChanged();
        await Task.Delay(3500);
        successMessage = null;
        StateHasChanged();
    }

    private async Task RemoveTenantMembership(Guid tenantId)
    {
        removingMembership = true;
        errorMessage = null;
        string? tenantName = tenantMemberships.FirstOrDefault(m => m.TenantId == tenantId)?.Tenant.Name;

        await UserManagement.RemoveTenantMembershipAsync(UserId, tenantId);
        tenantMemberships = await UserManagement.GetUserTenantMembershipsAsync(UserId);
        RefreshAvailableTenants();
        removingMembership = false;
        confirmRemoveTenantId = null;
        if (tenantName is not null) _ = ShowSuccessAsync($"Removed from tenant '{tenantName}'.");
    }

    private async Task AddGroupMembership()
    {
        errorMessage = null;

        try
        {
            await UserManagement.AddGroupMembershipAsync(UserId, addGroupForm.GroupId!.Value);
            addGroupForm.GroupId = null;
            groupMemberships = await UserManagement.GetUserGroupMembershipsAsync(UserId);
            await LoadGroupsForSelectedTenant();
            Toasts.Success("Group membership added.");
        }
        catch (Exception ex)
        {
            string msg = $"Failed to add group membership: {ex.Message}";
            errorMessage = msg;
            Toasts.Error(msg);
        }
    }

    private async Task RemoveGroupMembership(Guid groupId)
    {
        removingMembership = true;
        errorMessage = null;
        string? groupName = groupMemberships.FirstOrDefault(gm => gm.GroupId == groupId)?.Group.Name;

        await UserManagement.RemoveGroupMembershipAsync(UserId, groupId);
        groupMemberships = await UserManagement.GetUserGroupMembershipsAsync(UserId);
        await LoadGroupsForSelectedTenant();
        removingMembership = false;
        confirmRemoveGroupId = null;
        if (groupName is not null) _ = ShowSuccessAsync($"Removed from group '{groupName}'.");
    }

    private void CancelResetMfa()
    {
        confirmResetMfa = false;
        alsoRemovePasskeys = false;
    }

    private async Task ResetMfa()
    {
        resettingMfa = true;
        errorMessage = null;
        (bool ok, string? error, int passkeysRemoved) =
            await UserManagement.ResetAndDisableMfaAsync(UserId, alsoRemovePasskeys);
        resettingMfa = false;
        confirmResetMfa = false;

        if (!ok)
        {
            errorMessage = error ?? "Failed to reset MFA.";
            Toasts.Error(errorMessage);
            alsoRemovePasskeys = false;
            return;
        }

        // Reload so the badges reflect the cleared state immediately.
        security = await UserManagement.GetUserSecurityAsync(UserId);
        string extra = passkeysRemoved > 0 ? $" and removed {passkeysRemoved} passkey(s)" : "";
        Toasts.Success($"Reset MFA for {user!.Email}{extra}. They have been signed out and can re-enroll.");
        alsoRemovePasskeys = false;
    }

    private async Task DeleteUser()
    {
        deletingUser = true;
        IdentityResult result = await UserManagement.DeleteUserAsync(UserId);
        deletingUser = false;

        if (!result.Succeeded)
        {
            errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
            confirmDelete = false;
            return;
        }
        NavigationManager.NavigateTo("/admin/users");
    }

    private sealed class AddTenantForm
    {
        [Required(ErrorMessage = "Select a tenant.")]
        public Guid? TenantId { get; set; }

        [Required(ErrorMessage = "Select a role.")]
        public Guid? RoleId { get; set; }
    }

    private sealed class AddGroupForm
    {
        // Filters the group list only; not itself submitted, so not required.
        public Guid? TenantId { get; set; }

        [Required(ErrorMessage = "Select a group.")]
        public Guid? GroupId { get; set; }
    }
}
