@using EntKube.Web.Services

@* ═══════════════════════════════════════════════════════════════════
   Editor for an OAuth/OIDC client credential. A provider selector adapts
   which fields are shown; everything is stored in the one OAuthClientBundle
   passed in (mutated in place, read back by the parent on save).
   ═══════════════════════════════════════════════════════════════════ *@

<div class="row g-2">
    <div class="col-md-4">
        <label class="form-label small mb-1">Provider</label>
        <select class="form-select form-select-sm" @bind="Bundle.Provider">
            <option value="@OAuthProvider.Entra">Microsoft Entra</option>
            <option value="@OAuthProvider.Google">Google</option>
            <option value="@OAuthProvider.AwsCognito">AWS Cognito</option>
            <option value="@OAuthProvider.GenericOidc">Generic OIDC</option>
        </select>
    </div>

    <div class="col-md-8">
        <label class="form-label small mb-1">Client ID</label>
        <input type="text" class="form-control form-control-sm font-monospace"
               placeholder="application / client id" @bind="Bundle.ClientId" />
    </div>

    <div class="col-12">
        <label class="form-label small mb-1">Client secret <span class="text-danger">*</span></label>
        <input type="password" class="form-control form-control-sm"
               placeholder="client secret value" @bind="Bundle.ClientSecret" />
    </div>

    @if (Bundle.Provider == OAuthProvider.Entra)
    {
        <div class="col-md-6">
            <label class="form-label small mb-1">Tenant ID <span class="text-danger">*</span></label>
            <input type="text" class="form-control form-control-sm font-monospace"
                   placeholder="directory (tenant) id" @bind="Bundle.TenantId" />
        </div>
        <div class="col-md-6">
            <label class="form-label small mb-1">Authority</label>
            <input type="text" class="form-control form-control-sm"
                   placeholder="https://login.microsoftonline.com/{tenant}/v2.0" @bind="Bundle.Issuer" />
        </div>
    }
    else if (Bundle.Provider == OAuthProvider.AwsCognito)
    {
        <div class="col-md-4">
            <label class="form-label small mb-1">Region</label>
            <input type="text" class="form-control form-control-sm"
                   placeholder="eu-north-1" @bind="Bundle.Region" />
        </div>
        <div class="col-md-4">
            <label class="form-label small mb-1">User Pool ID</label>
            <input type="text" class="form-control form-control-sm font-monospace"
                   placeholder="eu-north-1_xxxxxxxxx" @bind="Bundle.UserPoolId" />
        </div>
        <div class="col-md-4">
            <label class="form-label small mb-1">Issuer override</label>
            <input type="text" class="form-control form-control-sm"
                   placeholder="@DerivedCognitoIssuer()" @bind="Bundle.Issuer" />
        </div>
    }
    else
    {
        <div class="col-12">
            <label class="form-label small mb-1">Issuer</label>
            <input type="text" class="form-control form-control-sm"
                   placeholder="@(Bundle.Provider == OAuthProvider.Google ? "https://accounts.google.com" : "https://issuer.example.com")"
                   @bind="Bundle.Issuer" />
        </div>
    }

    <div class="col-md-8">
        <label class="form-label small mb-1">Scopes <span class="text-muted">— optional, space-separated</span></label>
        <input type="text" class="form-control form-control-sm"
               placeholder="openid profile email" @bind="Bundle.Scopes" />
    </div>

    <div class="col-md-4">
        <label class="form-label small mb-1">Secret expires</label>
        <input type="date" class="form-control form-control-sm" @bind="Bundle.ExpiresAt" />
    </div>

    <div class="col-12">
        <div class="form-text">
            Providers report when a client secret expires at creation time — enter it here to get expiry warnings.
            <span class="ms-1"><ExpiryBadge ExpiresAt="Bundle.ExpiresAt" /></span>
        </div>
    </div>
</div>

@code {
    /// <summary>The bundle being edited. Mutated in place; the parent reads it back on save.</summary>
    [Parameter] public required OAuthClientBundle Bundle { get; set; }

    private string DerivedCognitoIssuer() =>
        !string.IsNullOrWhiteSpace(Bundle.Region) && !string.IsNullOrWhiteSpace(Bundle.UserPoolId)
            ? $"https://cognito-idp.{Bundle.Region.Trim()}.amazonaws.com/{Bundle.UserPoolId.Trim()}"
            : "auto from region + user pool";
}
