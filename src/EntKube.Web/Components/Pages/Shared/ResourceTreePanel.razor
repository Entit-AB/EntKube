@using EntKube.Web.Data
@using EntKube.Web.Services
@inject KubernetesOperationsService K8sOps
@inject LogQueryService Logs
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ToastService Toasts
@implements IAsyncDisposable

@* ═══════════════════════════════════════════════════════════════════
   ResourceTreePanel — proper ArgoCD-style graph.

   Layout:  horizontal tree, each depth level is a column.
            Subtrees are centred over their children using a two-pass
            layout algorithm.
   Lines:   SVG cubic bezier curves drawn on an absolute-positioned
            overlay that covers the whole graph container.
   Cards:   absolute-positioned; left-border colour = health status;
            kind icon, name, status, health badge and action buttons.
   Actions: floating panel positioned under (or above) the active card.
   ═══════════════════════════════════════════════════════════════════ *@

<style>
    .rg-wrap {
        display: flex;
        flex-direction: column;
        flex: 1;
        min-height: 0;
    }

    .rg-outer {
        overflow-x: auto;
        overflow-y: auto;
        flex: 1;
        min-height: 0;
        background: #f6f8fa;
        border-radius: 8px;
        border: 1px solid #e9ecef;
    }

    .rg-fs {
        position: fixed;
        inset: 0;
        z-index: 1055;
        background: white;
        display: flex;
        flex-direction: column;
        padding: 12px 16px;
        box-shadow: 0 0 0 100vmax rgba(0,0,0,.4);
    }

    .rg-fs .rg-outer {
        flex: 1;
        min-height: 0;
        max-height: none;
    }
    .rg-canvas {
        position: relative;
        /* width/height set inline from C# layout */
    }

    /* ── Node card ── */
    .rg-card {
        position: absolute;
        width: 204px;
        box-sizing: border-box;
        background: var(--hc-bg, white);
        border: 1px solid #dee2e6;
        border-left: 7px solid var(--hc, #adb5bd);
        border-radius: 8px;
        box-shadow: 0 1px 4px rgba(0,0,0,.07);
        overflow: hidden;
        cursor: default;
        transition: box-shadow .12s;
        font-size: .82rem;
    }
    .rg-card:hover { box-shadow: 0 3px 10px rgba(0,0,0,.13); }
    .rg-card.rg-active { border-color: #6ea8fe; box-shadow: 0 0 0 2px rgba(13,110,253,.15); }

    .rg-card-body { padding: 7px 10px 5px; }

    .rg-card-top {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 3px;
    }
    .rg-kind-badge {
        font-size: .62rem;
        font-weight: 700;
        letter-spacing: .04em;
        text-transform: uppercase;
        background: #f1f3f5;
        border: 1px solid #dee2e6;
        border-radius: 3px;
        padding: 1px 5px;
        color: #495057;
        flex-shrink: 0;
    }
    .rg-health-badge {
        margin-left: auto;
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: .64rem;
        font-weight: 700;
        letter-spacing: .03em;
        text-transform: uppercase;
        color: #fff;
        background: var(--hc, #adb5bd);
        border-radius: 10px;
        padding: 1px 7px 1px 6px;
        line-height: 1.45;
    }
    .rg-health-badge::before {
        content: "";
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: rgba(255,255,255,.9);
        flex-shrink: 0;
    }

    .rg-card-name {
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-size: .82rem;
        color: #212529;
        margin-bottom: 2px;
    }
    .rg-card-status {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: .71rem;
        color: #6c757d;
    }
    .rg-status-msg {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .rg-age {
        margin-left: auto;
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        gap: 3px;
        color: #868e96;
        font-variant-numeric: tabular-nums;
    }

    /* ── Card action bar ── */
    .rg-actions {
        padding: 4px 8px;
        border-top: 1px solid #f0f2f4;
        background: #f8f9fa;
        display: flex;
        gap: 3px;
    }
    .rg-btn {
        background: none;
        border: 1px solid transparent;
        border-radius: 4px;
        padding: 2px 5px;
        font-size: .7rem;
        color: #6c757d;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 3px;
        transition: background .1s, color .1s;
    }
    .rg-btn:hover { background: #e9ecef; color: #212529; border-color: #dee2e6; }
    .rg-btn.active { background: #e7f1ff; color: #0d6efd; border-color: #b6d4fe; }
    .rg-btn.active-warn { background: #fff3cd; color: #664d03; border-color: #ffd666; }
    .rg-btn.active-danger { background: #f8d7da; color: #842029; border-color: #f5c2c7; }

    /* ── Floating action panel ── */
    .rg-panel {
        position: absolute;
        z-index: 200;
        width: 700px;
        background: #1e1e2e;
        border: 1px solid #3a3a4e;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(0,0,0,.35);
    }
    .rg-panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 5px 10px;
        background: #2a2a3e;
        border-bottom: 1px solid #3a3a4e;
        color: white;
        font-size: .8rem;
        font-weight: 500;
    }
    .rg-panel-body { padding: 10px; }

    /* ── Roomy log/events/yaml modal ── */
    .rg-log-modal { max-width: 92vw; }
    .rg-log-modal .modal-content {
        background: #1e1e2e;
        border: 1px solid #3a3a4e;
        height: 88vh;
    }
    .rg-log-toolbar {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        gap: 10px;
        padding: 8px 12px;
        background: #2a2a3e;
        border-bottom: 1px solid #3a3a4e;
    }
    .rg-log-toolbar .form-label { color: #9aa0b4; font-size: .66rem; margin-bottom: 2px; }
    .rg-log-toolbar .form-select,
    .rg-log-toolbar .form-control {
        background: #1e1e2e;
        border-color: #3a3a4e;
        color: #e6e6ef;
        font-size: .74rem;
    }
    .rg-log-lines {
        flex: 1;
        min-height: 0;
        overflow-y: auto;
        background: #181820;
        font-family: var(--bs-font-monospace, monospace);
    }
    .rg-log-row {
        display: flex;
        gap: 10px;
        align-items: baseline;
        padding: 1px 14px;
        border-bottom: 1px solid #23232e;
        line-height: 1.45;
    }
    .rg-log-ts { color: #7a7a8c; font-size: .68rem; flex-shrink: 0; user-select: none; }
    .rg-log-src {
        font-size: .55rem;
        text-transform: uppercase;
        letter-spacing: .04em;
        border-radius: 3px;
        padding: 0 4px;
        flex-shrink: 0;
        user-select: none;
    }
    .rg-log-src.live { background: #14361f; color: #57d98a; }
    .rg-log-src.ingested { background: #2a2136; color: #b98be0; }
    .rg-log-msg { font-size: .76rem; white-space: pre-wrap; word-break: break-all; }
    .rg-log-restart {
        text-align: center;
        color: #8a8a9c;
        font-size: .66rem;
        padding: 3px 0;
        border-bottom: 1px solid #23232e;
        background: #201a24;
    }

    /* ── Global feedback bar ── */
    .rg-feedback {
        margin-bottom: 8px;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: .82rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
</style>

<div class="@(_fullscreen ? "rg-fs" : "rg-wrap")">
<div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
    @if (!string.IsNullOrEmpty(Namespace))
    {
        <span class="badge bg-light border text-muted font-monospace small">
            <i class="bi bi-box me-1"></i>@Namespace
        </span>
    }
    @if (!Loading && Resources is not null)
    {
        <span class="text-muted small">@_nodes.Count resources</span>
    }
    @if (LastRefreshed.HasValue && !Loading)
    {
        <span class="text-muted small ms-auto">
            <i class="bi bi-clock me-1"></i>@LastRefreshed.Value.ToLocalTime().ToString("HH:mm:ss")
        </span>
    }
    @if (OnRefresh.HasDelegate)
    {
        <button class="btn btn-sm btn-outline-secondary @(LastRefreshed.HasValue ? "" : "ms-auto")"
                @onclick="OnRefresh" disabled="@Loading">
            <i class="bi bi-arrow-clockwise me-1"></i>Refresh
        </button>
    }
    <button class="btn btn-sm @(_hideCompleted ? "btn-outline-secondary" : "btn-secondary")"
            title="@(_hideCompleted ? "Showing condensed view — click to show completed jobs & old ReplicaSets" : "Click to hide completed jobs & old ReplicaSets")"
            aria-label="@(_hideCompleted ? "Show completed jobs and old ReplicaSets" : "Hide completed jobs and old ReplicaSets")"
            @onclick="ToggleHideCompleted">
        <i class="bi @(_hideCompleted ? "bi-funnel-fill" : "bi-funnel")"></i>
    </button>
    <button class="btn btn-sm btn-outline-secondary @(!LastRefreshed.HasValue && !OnRefresh.HasDelegate ? "ms-auto" : "")"
            title="@(_fullscreen ? "Exit fullscreen" : "Fullscreen")"
            aria-label="@(_fullscreen ? "Exit fullscreen" : "Enter fullscreen")"
            @onclick="ToggleFullscreen">
        <i class="bi @(_fullscreen ? "bi-fullscreen-exit" : "bi-arrows-fullscreen")"></i>
    </button>
</div>

<LoadingPanel Loading="@Loading" LoadingText="Querying cluster…" Error="@Error">
@if (!Loading && Error is null && (Resources is null || Resources.Count == 0))
{
    <EmptyState Icon="bi-diagram-3"
                Message="@($"No resources tracked for this deployment in namespace {Namespace}.")" />
}
else if (!Loading && Error is null && Resources is not null && Resources.Count > 0)
{
    @if (_feedback is not null)
    {
        <div class="rg-feedback @(_feedbackOk ? "alert-success" : "alert-danger") alert">
            <span><i class="bi @(_feedbackOk ? "bi-check-circle" : "bi-x-circle") me-1"></i>@_feedback</span>
            <button class="btn-close btn-close-sm" @onclick="() => _feedback = null"></button>
        </div>
    }

    <div class="rg-outer">
        <div class="rg-canvas" style="width: @(_graphW + 24)px; min-height: @(_graphH + 24)px; padding: 12px;">

            @* ── SVG bezier connectors ── *@
            <svg style="position:absolute;inset:0;width:@(_graphW + 24)px;height:@(_graphH + 24)px;pointer-events:none;overflow:visible;">
                @foreach (SvgLine ln in _lines)
                {
                    <path d="@BezierPath(ln)" stroke="#ced4da" stroke-width="1.5" fill="none" />
                }
            </svg>

            @* ── Node cards ── *@
            @foreach (NodeLayout nd in _nodes)
            {
                var cx = nd.Col * ColW + 12;
                var cy = nd.Y + 12;
                var hc = HealthColor(nd.Node.HealthStatus);
                var isActive = _activePanelNodeId == nd.Node.Id;

                <div class="rg-card @(isActive ? "rg-active" : "")"
                     style="left:@(cx)px;top:@(cy)px;--hc:@hc;--hc-bg:@HealthTint(nd.Node.HealthStatus);">

                    <div class="rg-card-body">
                        <div class="rg-card-top">
                            <i class="bi @KindIcon(nd.Node.Kind) @KindColor(nd.Node.Kind)"
                               style="font-size:.95rem;flex-shrink:0;"></i>
                            <span class="rg-kind-badge">@nd.Node.Kind</span>
                            <span class="rg-health-badge" style="background:@hc;"
                                  title="@HealthLabel(nd.Node.HealthStatus)">@HealthLabel(nd.Node.HealthStatus)</span>
                        </div>

                        <div class="rg-card-name" title="@nd.Node.Name">@nd.Node.Name</div>

                        @if (!string.IsNullOrEmpty(nd.Node.StatusMessage) || nd.Node.KubernetesCreatedAt is not null)
                        {
                            <div class="rg-card-status">
                                <span class="rg-status-msg">@nd.Node.StatusMessage</span>
                                @if (nd.Node.KubernetesCreatedAt is not null)
                                {
                                    <span class="rg-age" title="Alive since @nd.Node.KubernetesCreatedAt.Value.ToLocalTime().ToString("g")">
                                        <i class="bi bi-clock-history"></i> @FormatAge(nd.Node.KubernetesCreatedAt.Value)
                                    </span>
                                }
                            </div>
                        }
                    </div>

                    @* ── Action buttons ── *@
                    <div class="rg-actions">
                        @if (nd.Node.Kind == "Pod" && CanLogs)
                        {
                            <button class="rg-btn @(IsPanel(nd.Node.Id, "logs") ? "active" : "")"
                                    title="Logs" @onclick="() => PanelLogs(nd.Node)">
                                <i class="bi bi-terminal"></i> Logs
                            </button>
                        }
                        @if (CanEvents)
                        {
                            <button class="rg-btn @(IsPanel(nd.Node.Id, "events") ? "active" : "")"
                                    title="Events" @onclick="() => PanelEvents(nd.Node)">
                                <i class="bi bi-list-ul"></i> Events
                            </button>
                        }
                        @if (CanEvents)
                        {
                            <button class="rg-btn @(IsPanel(nd.Node.Id, "yaml") ? "active" : "")"
                                    title="YAML" aria-label="@($"View YAML for {nd.Node.Name}")" @onclick="() => PanelYaml(nd.Node)">
                                <i class="bi bi-file-code"></i>
                            </button>
                        }
                        @if (nd.Node.Kind == "CronJob" && CanRestart)
                        {
                            bool cronSuspended = nd.Node.HealthStatus == HealthStatus.Suspended;
                            <button class="rg-btn @(IsPanel(nd.Node.Id, "trigger") ? "active-warn" : "")"
                                    title="Trigger manual run" aria-label="@($"Trigger manual run of {nd.Node.Name}")" @onclick="() => PanelTrigger(nd.Node)">
                                <i class="bi bi-lightning"></i>
                            </button>
                            <button class="rg-btn" disabled="@_opBusy"
                                    title="@(cronSuspended ? "Resume schedule" : "Suspend schedule")"
                                    aria-label="@($"{(cronSuspended ? "Resume" : "Suspend")} schedule for {nd.Node.Name}")"
                                    @onclick="() => _ = ToggleSuspendCronJobAsync(nd.Node)">
                                <i class="bi @(cronSuspended ? "bi-play-fill" : "bi-pause-fill")"></i>
                            </button>
                        }
                        @if ((nd.Node.Kind is "Deployment" or "StatefulSet" or "DaemonSet") && CanRestart)
                        {
                            <button class="rg-btn @(IsPanel(nd.Node.Id, "restart") ? "active-warn" : "")"
                                    title="Restart" aria-label="@($"Restart {nd.Node.Name}")" @onclick="() => PanelRestart(nd.Node)">
                                <i class="bi bi-arrow-repeat"></i>
                            </button>
                        }
                        @if ((nd.Node.Kind is "Deployment" or "StatefulSet" or "ReplicaSet") && CanScale)
                        {
                            <button class="rg-btn @(IsPanel(nd.Node.Id, "scale") ? "active" : "")"
                                    title="Scale" aria-label="@($"Scale {nd.Node.Name}")" @onclick="() => PanelScale(nd.Node)">
                                <i class="bi bi-sliders"></i>
                            </button>
                        }
                        @if (nd.Node.Kind == "ReplicaSet" && ParseDesiredReplicas(nd.Node.StatusMessage) == 0 && CanDelete)
                        {
                            <button class="rg-btn @(IsPanel(nd.Node.Id, "delete") ? "active-danger" : "")"
                                    title="Delete old ReplicaSet" aria-label="@($"Delete old ReplicaSet {nd.Node.Name}")" @onclick="() => PanelDelete(nd.Node)">
                                <i class="bi bi-trash"></i>
                            </button>
                        }
                        @if ((nd.Node.Kind == "Pod" || nd.Node.Kind == "Job") && CanDelete)
                        {
                            <button class="rg-btn @(IsPanel(nd.Node.Id, "delete") ? "active-danger" : "")"
                                    title="Delete" aria-label="@($"Delete {nd.Node.Kind} {nd.Node.Name}")" @onclick="() => PanelDelete(nd.Node)">
                                <i class="bi bi-trash"></i>
                            </button>
                        }
                        @if (_hideCompleted && _hiddenJobCounts.TryGetValue(nd.Node.Id, out int hj) && hj > 0)
                        {
                            <span class="rg-btn ms-auto" style="cursor:default;opacity:.7;"
                                  title="@hj completed job(s) hidden — click the funnel to show">
                                <i class="bi bi-clock"></i> @hj
                            </span>
                        }
                        @if (_hideCompleted && _hiddenRsCounts.TryGetValue(nd.Node.Id, out int hr) && hr > 0)
                        {
                            <span class="rg-btn @(_hiddenJobCounts.ContainsKey(nd.Node.Id) ? "" : "ms-auto")"
                                  style="cursor:default;opacity:.7;"
                                  title="@hr old ReplicaSet(s) hidden — click the funnel to show">
                                <i class="bi bi-files"></i> @hr
                            </span>
                        }
                    </div>
                </div>

                @* ── Floating action panel (small confirmations) for this node ── *@
                @if (isActive && _panelMode is "scale" or "restart" or "delete" or "trigger")
                {
                    @RenderPanel(nd.Node, ClampPanelX(cx), PanelY(cy))
                }
            }
        </div>
    </div>
}
</LoadingPanel>
</div>

@* ── Roomy modal for text-heavy views: Logs / Events / YAML ── *@
@if (_activePanelNode is not null && _panelMode is "logs" or "events" or "yaml")
{
    @RenderResourceModal(_activePanelNode)
}

@code {
    [Parameter] public bool Loading { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public List<DeploymentResource>? Resources { get; set; }
    [Parameter] public string? Namespace { get; set; }
    [Parameter] public Guid DeploymentId { get; set; }
    [Parameter] public CustomerAccessRole? AccessRole { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public DateTime? LastRefreshed { get; set; }

    /// <summary>
    /// When true, ingested log lines that carry a trace id render a clickable badge that deep-links
    /// to the cluster's Traces tab. Only enable in hosts whose page reads the tab/cluster/trace
    /// query params (the tenant ops explorer) — left off in the customer portal.
    /// </summary>
    [Parameter] public bool EnableTraceLinks { get; set; }

    // ── Access gates ────────────────────────────────────────────────────────

    private bool CanLogs    => AccessRole is null || AccessRole >= CustomerAccessRole.Viewer;
    private bool CanEvents  => AccessRole is null || AccessRole >= CustomerAccessRole.Viewer;
    private bool CanRestart => AccessRole is null || AccessRole >= CustomerAccessRole.Operator;
    private bool CanDelete  => AccessRole is null || AccessRole >= CustomerAccessRole.Operator;
    private bool CanScale   => AccessRole is null || AccessRole >= CustomerAccessRole.Admin;

    // ── Layout constants ─────────────────────────────────────────────────────

    private const double CardW = 204;
    private const double CardH = 86;   // body + action bar
    private const double ColGap = 72;  // horizontal gap between columns (lines travel here)
    private const double RowGap = 28;
    private const double ColW = CardW + ColGap;
    private const double RowH = CardH + RowGap;

    // ── Layout state ─────────────────────────────────────────────────────────

    private record NodeLayout(DeploymentResource Node, int Col, double Y, Guid? ParentId);
    private record SvgLine(double X1, double Y1, double X2, double Y2);

    private List<NodeLayout> _nodes = [];
    private List<SvgLine> _lines = [];
    private double _graphW;
    private double _graphH;

    // ── Panel state ──────────────────────────────────────────────────────────

    private Guid? _activePanelNodeId;
    private DeploymentResource? _activePanelNode;
    private string? _panelMode;

    private bool _panelLoading;
    private string? _panelText;
    private string? _panelError;
    private List<string> _containers = [];
    private string? _selectedContainer;
    private int _scaleValue = 1;
    private bool _opBusy;

    // ── Log modal state (unified live pod + ingested backfill) ───────────────
    private record LogRow(DateTime Timestamp, string Line, LogLevel Level, bool Live, string? TraceId);

    private List<LogRow> _logRows = [];
    private List<LogHistogramBucket> _logHistogram = [];
    private Guid? _resolvedClusterId;
    private bool _logIngestedAvailable;
    private bool _logIncludeIngested = true;
    private string _logLevelFilter = "";     // "", Info, Warn, Error
    private string _logTextFilter = "";
    private int _logRangeMinutes = 60;        // ingested backfill window
    private bool _logFollow;
    private CancellationTokenSource? _logFollowCts;

    private string? _feedback;
    private bool _feedbackOk;
    private bool _fullscreen;
    private bool _hideCompleted = true;
    private Dictionary<Guid, int> _hiddenJobCounts = new();
    private Dictionary<Guid, int> _hiddenRsCounts  = new();

    // ── Lifecycle ────────────────────────────────────────────────────────────

    private Guid _lastDeploymentId;

    protected override void OnParametersSet()
    {
        // Reset the cached cluster/backend probe when the panel is reused for a different
        // deployment, so ingested backfill targets the right cluster.
        if (DeploymentId != _lastDeploymentId)
        {
            _lastDeploymentId = DeploymentId;
            _resolvedClusterId = null;
            _logIngestedAvailable = false;
        }
        ComputeLayout();
    }

    // ── Layout engine ────────────────────────────────────────────────────────

    private void ComputeLayout()
    {
        _nodes.Clear();
        _lines.Clear();
        _hiddenJobCounts.Clear();
        _hiddenRsCounts.Clear();
        if (Resources is null || Resources.Count == 0) return;

        double y = 0;

        void Layout(DeploymentResource node, int col, Guid? parentId)
        {
            double top = y;

            List<DeploymentResource> kids = node.ChildResources is { Count: > 0 } c ? new(c) : [];

            if (_hideCompleted)
            {
                // Completed Jobs owned by a CronJob are history — hide them, show count on parent
                if (node.Kind == "CronJob")
                {
                    List<DeploymentResource> done = kids
                        .Where(k => k.Kind == "Job" && k.HealthStatus != HealthStatus.Progressing)
                        .ToList();
                    if (done.Count > 0)
                    {
                        _hiddenJobCounts[node.Id] = done.Count;
                        kids = kids.Except(done).ToList();
                    }
                }

                // Completed standalone Jobs: keep the Job card but collapse its pod children
                if (node.Kind == "Job" && node.HealthStatus != HealthStatus.Progressing)
                    kids = [];

                // Zero-replica ReplicaSets are inactive rollback history — hide them
                List<DeploymentResource> zeroRs = kids
                    .Where(k => k.Kind == "ReplicaSet" && ParseDesiredReplicas(k.StatusMessage) == 0)
                    .ToList();
                if (zeroRs.Count > 0)
                {
                    _hiddenRsCounts[node.Id] = zeroRs.Count;
                    kids = kids.Except(zeroRs).ToList();
                }
            }

            if (kids.Count > 0)
                foreach (DeploymentResource kid in kids)
                    Layout(kid, col + 1, node.Id);
            else
                y += RowH;

            double centerY = (top + y) / 2 - CardH / 2;
            _nodes.Add(new NodeLayout(node, col, centerY, parentId));
        }

        foreach (DeploymentResource root in Resources)
            Layout(root, 0, null);

        Dictionary<Guid, NodeLayout> byId = _nodes.ToDictionary(n => n.Node.Id);

        foreach (NodeLayout n in _nodes.Where(n => n.ParentId.HasValue))
        {
            if (byId.TryGetValue(n.ParentId!.Value, out NodeLayout? p))
            {
                _lines.Add(new SvgLine(
                    p.Col * ColW + CardW + 12,   // parent right edge (+ canvas padding)
                    p.Y + CardH / 2 + 12,         // parent vertical centre
                    n.Col * ColW + 12,             // child left edge
                    n.Y + CardH / 2 + 12           // child vertical centre
                ));
            }
        }

        int maxCol = _nodes.Count > 0 ? _nodes.Max(n => n.Col) : 0;
        _graphW = (maxCol + 1) * ColW;
        _graphH = y;
    }

    private static string BezierPath(SvgLine l)
    {
        double dx = Math.Abs(l.X2 - l.X1) * 0.55;
        return FormattableString.Invariant(
            $"M {l.X1:F1} {l.Y1:F1} C {l.X1 + dx:F1} {l.Y1:F1} {l.X2 - dx:F1} {l.Y2:F1} {l.X2:F1} {l.Y2:F1}");
    }

    // ── Panel helpers ────────────────────────────────────────────────────────

    private bool IsPanel(Guid id, string mode) =>
        _activePanelNodeId == id && _panelMode == mode;

    // String-literal-safe wrappers — avoids embedding "string" inside @onclick="..." attributes.
    private void PanelLogs(DeploymentResource n)    => TogglePanel(n.Id, n, "logs");
    private void PanelEvents(DeploymentResource n)  => TogglePanel(n.Id, n, "events");
    private void PanelYaml(DeploymentResource n)    => TogglePanel(n.Id, n, "yaml");
    private void PanelTrigger(DeploymentResource n) => TogglePanel(n.Id, n, "trigger");
    private void PanelRestart(DeploymentResource n) => TogglePanel(n.Id, n, "restart");
    private void PanelScale(DeploymentResource n)   => TogglePanel(n.Id, n, "scale");
    private void PanelDelete(DeploymentResource n)  => TogglePanel(n.Id, n, "delete");

    private void TogglePanel(Guid id, DeploymentResource node, string mode)
    {
        if (_activePanelNodeId == id && _panelMode == mode)
        {
            ClosePanel(); return;
        }
        ClosePanel();
        _activePanelNodeId = id;
        _activePanelNode   = node;
        _panelMode         = mode;

        if (mode == "logs")    _ = LoadLogsAsync(node);
        if (mode == "events")  _ = LoadEventsAsync(node);
        if (mode == "yaml")    _ = LoadYamlAsync(node);
        if (mode == "scale")   _scaleValue = ParseDesiredReplicas(node.StatusMessage) ?? 1;
    }

    private void ClosePanel()
    {
        StopLogFollow();
        _activePanelNodeId = null;
        _activePanelNode   = null;
        _panelMode         = null;
        _panelText         = null;
        _panelError        = null;
        _containers        = [];
        _selectedContainer = null;
        _logRows           = [];
        _logHistogram      = [];
    }

    // Deep-links a log line to its distributed trace: switches the tenant explorer to the Traces
    // section with this cluster + trace preselected. Clears the app/cluster pane params so the
    // section branch renders, and uses `tcluster` (not `cluster`, which would select a cluster
    // pane instead). Only reachable when EnableTraceLinks is set by a host whose page reads these
    // query params (the tenant ops explorer).
    private void OpenTrace(string? traceId)
    {
        if (string.IsNullOrEmpty(traceId) || _resolvedClusterId is not Guid cid) return;
        Nav.NavigateTo(Nav.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["app"] = null,
            ["env"] = null,
            ["cluster"] = null,
            ["tab"] = null,
            ["section"] = "traces",
            ["tcluster"] = cid.ToString(),
            ["trace"] = traceId
        }));
    }

    // ── Async operations (fire-and-forget from sync context) ─────────────────

    private async Task LoadLogsAsync(DeploymentResource node)
    {
        _panelLoading = true; _logRows = []; _panelError = null;
        StateHasChanged();

        // Resolve the deployment's cluster once, and probe whether an ingested log
        // backend (native telemetry or Loki) is available to backfill history.
        if (_resolvedClusterId is null)
        {
            AppDeployment? dep = await K8sOps.GetDeploymentWithClusterAsync(DeploymentId);
            _resolvedClusterId = dep?.Cluster?.Id;
            if (_resolvedClusterId is Guid cid)
            {
                try
                {
                    (bool native, bool loki) = await Logs.ProbeBackendsAsync(cid);
                    _logIngestedAvailable = native || loki;
                }
                catch { _logIngestedAvailable = false; }
            }
        }

        var cr = await K8sOps.GetPodContainersAsync(DeploymentId, node.Name);
        if (!cr.IsSuccess) { _panelError = cr.Error; _panelLoading = false; StateHasChanged(); return; }

        _containers = cr.Data ?? [];
        _selectedContainer = _containers.FirstOrDefault();
        await FetchLogsAsync(node.Name);
    }

    private int _panelTailLines = 500;
    private ElementReference _logPreRef;
    private bool _pendingLogScroll;

    // Fetches the live pod tail (primary) and, when enabled, ingested history, then merges
    // them into one timeline: ingested lines older than the live tail become backfill; lines
    // present in both prefer the live copy.
    private async Task FetchLogsAsync(string podName)
    {
        _panelLoading = true; _panelError = null;
        StateHasChanged();

        var live = await K8sOps.GetPodLogEntriesAsync(DeploymentId, podName, _selectedContainer, _panelTailLines);
        if (!live.IsSuccess)
        {
            _panelError = live.Error; _panelLoading = false; StateHasChanged();
            return;
        }

        List<LogRow> liveRows = (live.Data ?? [])
            .Select(e => new LogRow(e.Timestamp, e.Line, e.DetectedLevel, true, e.TraceId))
            .ToList();

        List<LogRow> ingestedRows = [];
        List<LogHistogramBucket> histogram = [];
        if (_logIncludeIngested && _logIngestedAvailable && _resolvedClusterId is Guid cid)
        {
            DateTime to = DateTime.UtcNow;
            DateTime from = to.AddMinutes(-_logRangeMinutes);
            LogQueryFilter filter = BuildLogFilter(podName);
            try
            {
                // Log page and volume histogram are independent queries over the same filter —
                // issue them concurrently so the fetch waits on the slower, not the sum.
                var queryTask = Logs.QueryAsync(cid, filter, from, to, Math.Max(_panelTailLines, 500));
                var histTask = Logs.GetHistogramAsync(cid, filter, from, to);
                await Task.WhenAll(queryTask, histTask);

                if (queryTask.Result.IsSuccess && queryTask.Result.Data is not null)
                    ingestedRows = queryTask.Result.Data
                        .SelectMany(s => s.Entries)
                        .Select(e => new LogRow(e.Timestamp, e.Line, e.DetectedLevel, false, e.TraceId))
                        .ToList();

                if (histTask.Result.IsSuccess && histTask.Result.Data is not null)
                    histogram = histTask.Result.Data;
            }
            catch { /* ingested backfill is best-effort — never block the live tail */ }
        }

        _logRows = MergeLogRows(liveRows, ingestedRows);
        _logHistogram = histogram;
        _panelLoading = false;
        _pendingLogScroll = true;
        StateHasChanged();
    }

    private LogQueryFilter BuildLogFilter(string podName) => new()
    {
        Namespaces = [Namespace ?? ""],
        Pod = podName,
        Container = string.IsNullOrEmpty(_selectedContainer) ? null : _selectedContainer,
        Text = string.IsNullOrEmpty(_logTextFilter) ? null : _logTextFilter,
        MinLevel = LogMinLevel
    };

    // Live pod logs are primary. Keep every live row; add ingested rows that are either older
    // than the live window (true backfill) or not already present in the live tail (deduped by
    // second + text). Result is ordered oldest→newest so backfill leads into the live stream.
    private static List<LogRow> MergeLogRows(List<LogRow> live, List<LogRow> ingested)
    {
        if (ingested.Count == 0)
            return live.OrderBy(r => r.Timestamp).ToList();

        DateTime liveMin = live.Count > 0 ? live.Min(r => r.Timestamp) : DateTime.MaxValue;
        HashSet<string> liveSigs = live.Select(Sig).ToHashSet();

        List<LogRow> merged = new(live);
        foreach (LogRow r in ingested)
            if (r.Timestamp < liveMin || !liveSigs.Contains(Sig(r)))
                merged.Add(r);

        return merged.OrderBy(r => r.Timestamp).ToList();

        static string Sig(LogRow r) => $"{r.Timestamp:yyyyMMddHHmmss}|{r.Line}";
    }

    private LogLevel LogMinLevel => _logLevelFilter switch
    {
        "Error" => LogLevel.Error,
        "Warn"  => LogLevel.Warn,
        "Info"  => LogLevel.Info,
        _ => LogLevel.None
    };

    // Client-side severity/text filter, applied uniformly to live and ingested rows so the
    // toolbar behaves the same regardless of source (ingested queries also push these down).
    private IEnumerable<LogRow> FilteredLogRows => _logRows.Where(r =>
        (LogMinLevel == LogLevel.None || r.Level >= LogMinLevel) &&
        (string.IsNullOrEmpty(_logTextFilter) ||
         r.Line.Contains(_logTextFilter, StringComparison.OrdinalIgnoreCase)));

    private static string LogLineStyle(LogLevel level) => level switch
    {
        LogLevel.Fatal or LogLevel.Error => "color:#f48771",
        LogLevel.Warn  => "color:#cca700",
        LogLevel.Info  => "color:#9cdcfe",
        LogLevel.Debug => "color:#808080",
        _ => "color:#d4d4d4"
    };

    private async Task ToggleIngested(string podName)
    {
        _logIncludeIngested = !_logIncludeIngested;
        await FetchLogsAsync(podName);
    }

    private void ToggleLogFollow(string podName)
    {
        _logFollow = !_logFollow;
        if (_logFollow)
        {
            _logFollowCts = new CancellationTokenSource();
            _ = LogFollowLoopAsync(podName, _logFollowCts.Token);
        }
        else
        {
            StopLogFollow();
        }
    }

    private void StopLogFollow()
    {
        _logFollow = false;
        _logFollowCts?.Cancel();
        _logFollowCts?.Dispose();
        _logFollowCts = null;
    }

    // Re-fetch the live tail (and ingested backfill) on a fixed cadence. Re-merging the whole
    // window each tick keeps the timeline correct without tracking append cursors across sources.
    private async Task LogFollowLoopAsync(string podName, CancellationToken ct)
    {
        try
        {
            using PeriodicTimer timer = new(TimeSpan.FromSeconds(3));
            while (await timer.WaitForNextTickAsync(ct))
            {
                await FetchLogsAsync(podName);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { /* stopped */ }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingLogScroll)
        {
            _pendingLogScroll = false;
            try { await JS.InvokeVoidAsync("scrollToBottom", _logPreRef); } catch { }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_logFollowCts is not null)
        {
            await _logFollowCts.CancelAsync();
            _logFollowCts.Dispose();
        }
    }

    private async Task LoadYamlAsync(DeploymentResource node)
    {
        _panelLoading = true; _panelText = null; _panelError = null;
        StateHasChanged();
        var r = await K8sOps.GetResourceYamlAsync(DeploymentId, node.Kind, node.Name);
        _panelLoading = false;
        if (r.IsSuccess)
        {
            _panelText = node.Kind == "Secret"
                ? RedactSecretData(r.Data ?? "(empty)")
                : r.Data ?? "(empty)";
        }
        else
            _panelError = r.Error;
        StateHasChanged();
    }

    private static string RedactSecretData(string yaml)
    {
        bool inDataSection = false;
        var sb = new System.Text.StringBuilder();
        foreach (string raw in yaml.Split('\n'))
        {
            string line = raw.TrimEnd('\r');
            string trimmed = line.TrimEnd();
            if (trimmed is "data:" or "binaryData:" or "stringData:")
            {
                inDataSection = true;
                sb.Append(line).Append('\n');
            }
            else if (inDataSection && line.Length > 0 && (line[0] == ' ' || line[0] == '\t'))
            {
                int colon = line.IndexOf(':');
                sb.Append(colon >= 0 ? line[..(colon + 1)] + " [REDACTED]" : line).Append('\n');
            }
            else
            {
                if (line.Length > 0 && line[0] != ' ' && line[0] != '\t')
                    inDataSection = false;
                sb.Append(line).Append('\n');
            }
        }
        return sb.ToString();
    }

    private async Task LoadEventsAsync(DeploymentResource node)
    {
        _panelLoading = true; _panelText = null; _panelError = null;
        StateHasChanged();
        var r = await K8sOps.GetResourceEventsAsync(DeploymentId, node.Kind, node.Name);
        _panelLoading = false;
        if (r.IsSuccess)
            _panelText = r.Data is { Count: > 0 } l ? string.Join("\n", l) : "(no events)";
        else _panelError = r.Error;
        StateHasChanged();
    }

    private void SwitchContainer(string podName, string container)
    {
        _selectedContainer = container;
        _ = FetchLogsAsync(podName);
    }

    private async Task ApplyScaleAsync(DeploymentResource node)
    {
        _opBusy = true; StateHasChanged();
        var r = await K8sOps.ScaleWorkloadAsync(DeploymentId, node.Kind, node.Name, _scaleValue);
        _opBusy = false; ClosePanel();
        SetFeedback(r.IsSuccess, r.IsSuccess
            ? $"{node.Kind} {node.Name} scaled to {_scaleValue}."
            : r.Error ?? "Scale failed.");
    }

    private async Task ApplyRestartAsync(DeploymentResource node)
    {
        _opBusy = true; StateHasChanged();
        var r = await K8sOps.RestartWorkloadAsync(DeploymentId, node.Kind, node.Name);
        _opBusy = false; ClosePanel();
        SetFeedback(r.IsSuccess, r.IsSuccess
            ? $"Rolling restart triggered for {node.Name}."
            : r.Error ?? "Restart failed.");
    }

    private async Task ApplyTriggerAsync(DeploymentResource node)
    {
        _opBusy = true; StateHasChanged();
        var r = await K8sOps.TriggerCronJobAsync(DeploymentId, node.Name);
        _opBusy = false; ClosePanel();
        SetFeedback(r.IsSuccess, r.IsSuccess
            ? r.Data ?? "Job created."
            : r.Error ?? "Trigger failed.");
        if (r.IsSuccess && OnRefresh.HasDelegate)
            await OnRefresh.InvokeAsync();
    }

    private async Task ToggleSuspendCronJobAsync(DeploymentResource node)
    {
        if (_opBusy) return;
        _opBusy = true;
        StateHasChanged();
        bool wasSuspended = node.HealthStatus == HealthStatus.Suspended;
        var r = await K8sOps.SetCronJobSuspendedAsync(DeploymentId, node.Name, !wasSuspended);
        _opBusy = false;
        SetFeedback(r.IsSuccess, r.IsSuccess
            ? $"CronJob {node.Name} {(!wasSuspended ? "suspended" : "resumed")}."
            : r.Error ?? "Operation failed.");
        if (r.IsSuccess && OnRefresh.HasDelegate)
            await OnRefresh.InvokeAsync();
    }

    private async Task ApplyDeleteAsync(DeploymentResource node)
    {
        _opBusy = true; StateHasChanged();
        var r = await K8sOps.DeleteResourceAsync(DeploymentId, node.Kind, node.Name);
        _opBusy = false; ClosePanel();
        SetFeedback(r.IsSuccess, r.IsSuccess
            ? $"{node.Kind} {node.Name} deleted."
            : r.Error ?? "Delete failed.");
        if (r.IsSuccess)
            Toasts.Success($"Deleted {node.Kind} {node.Name}.");
        else
            Toasts.Error($"Failed to delete {node.Kind} {node.Name}: {r.Error}");
        if (r.IsSuccess && OnRefresh.HasDelegate)
            await OnRefresh.InvokeAsync();
    }

    private Task RefreshPanel(DeploymentResource node) => _panelMode switch
    {
        "logs"   => FetchLogsAsync(node.Name),
        "events" => LoadEventsAsync(node),
        "yaml"   => LoadYamlAsync(node),
        _        => Task.CompletedTask
    };

    private void SetFeedback(bool ok, string msg)
    {
        _feedbackOk = ok; _feedback = msg; StateHasChanged();
    }

    private void ToggleFullscreen() => _fullscreen = !_fullscreen;

    private void ToggleHideCompleted()
    {
        _hideCompleted = !_hideCompleted;
        ComputeLayout();
    }

    private double ClampPanelX(double cardX)
    {
        const double PanelW = 700;
        double canvasW = _graphW + 24;
        return Math.Max(0, Math.Min(cardX, canvasW - PanelW));
    }

    private static double EstimatedPanelHeight(string? mode) => mode switch
    {
        "scale"   => 120,
        "trigger" => 90,
        _         => 70      // restart / delete
    };

    private double PanelY(double cardY)
    {
        double below = cardY + CardH + 6;
        double panelH = EstimatedPanelHeight(_panelMode);
        // Flip above the card when the panel would extend past the canvas bottom.
        return below + panelH > _graphH ? Math.Max(0, cardY - panelH - 6) : below;
    }

    // ── Floating panel renderer ──────────────────────────────────────────────

    private RenderFragment RenderPanel(DeploymentResource node, double px, double py) => __builder =>
    {
        <div class="rg-panel" style="left:@(px.ToString("F0", System.Globalization.CultureInfo.InvariantCulture))px;top:@(py.ToString("F0", System.Globalization.CultureInfo.InvariantCulture))px;">
            <div class="rg-panel-header">
                <span>
                    @if (_panelMode == "scale")
                    {
                        <i class="bi bi-sliders me-1"></i><text>Scale — @node.Name</text>
                    }
                    else if (_panelMode == "restart")
                    {
                        <i class="bi bi-arrow-repeat me-1"></i><text>Restart — @node.Name</text>
                    }
                    else if (_panelMode == "trigger")
                    {
                        <i class="bi bi-lightning me-1"></i><text>Trigger — @node.Name</text>
                    }
                    else if (_panelMode == "delete")
                    {
                        <i class="bi bi-trash me-1"></i><text>Delete — @node.Name</text>
                    }
                </span>
                <div class="d-flex align-items-center gap-1">
                    <button class="btn btn-sm btn-link text-white py-0 px-1" aria-label="Close panel" @onclick="ClosePanel">
                        <i class="bi bi-x-lg" style="font-size:.75rem;"></i>
                    </button>
                </div>
            </div>

            @if (_panelMode == "scale")
            {
                var current = ParseDesiredReplicas(node.StatusMessage);
                <div class="rg-panel-body">
                    @if (current.HasValue)
                    {
                        <div class="text-muted small mb-2">
                            Current: <strong class="text-light">@current</strong> replica@(current == 1 ? "" : "s")
                        </div>
                    }
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <div class="d-flex align-items-center gap-1">
                            <button class="btn btn-sm py-0 px-2" style="color:#ccc;border:1px solid #555;border-radius:4px;background:none;"
                                    @onclick="() => _scaleValue = Math.Max(0, _scaleValue - 1)" disabled="@_opBusy">
                                <i class="bi bi-dash"></i>
                            </button>
                            <input type="number" class="form-control form-control-sm text-center"
                                   style="width:60px;background:#2a2a3e;border-color:#555;color:white;"
                                   min="0" max="99" @bind="_scaleValue" />
                            <button class="btn btn-sm py-0 px-2" style="color:#ccc;border:1px solid #555;border-radius:4px;background:none;"
                                    @onclick="() => _scaleValue++" disabled="@_opBusy">
                                <i class="bi bi-plus"></i>
                            </button>
                        </div>
                        <button class="btn btn-sm btn-primary" disabled="@_opBusy" @onclick="() => ApplyScaleAsync(node)">
                            @if (_opBusy) { <span class="spinner-border spinner-border-sm me-1"></span> } Apply
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="ClosePanel">Cancel</button>
                    </div>
                </div>
            }

            @if (_panelMode == "restart")
            {
                <div class="rg-panel-body d-flex align-items-center gap-2">
                    <span class="text-light small">Rolling restart <strong>@node.Name</strong>?</span>
                    <button class="btn btn-sm btn-warning" disabled="@_opBusy" @onclick="() => ApplyRestartAsync(node)">
                        @if (_opBusy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-arrow-repeat me-1"></i>Restart
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ClosePanel">Cancel</button>
                </div>
            }

            @if (_panelMode == "delete")
            {
                <div class="rg-panel-body d-flex align-items-center gap-2">
                    <span class="text-light small">
                        Delete <strong>@node.Kind @node.Name</strong>?
                        @if (node.Kind == "Pod") { <span class="text-muted"> K8s will restart it.</span> }
                        @if (node.Kind == "ReplicaSet") { <span class="text-muted"> Old revision, safe to remove.</span> }
                    </span>
                    <button class="btn btn-sm btn-danger" disabled="@_opBusy" @onclick="() => ApplyDeleteAsync(node)">
                        @if (_opBusy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ClosePanel">Cancel</button>
                </div>
            }

            @if (_panelMode == "trigger")
            {
                <div class="rg-panel-body">
                    <div class="text-light small mb-2">
                        Create a manual Job from <strong>@node.Name</strong>?
                        @if (!string.IsNullOrEmpty(node.StatusMessage))
                        {
                            <span class="text-muted ms-1">(@node.StatusMessage)</span>
                        }
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-sm btn-warning" disabled="@_opBusy" @onclick="() => ApplyTriggerAsync(node)">
                            @if (_opBusy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            <i class="bi bi-lightning me-1"></i>Run Job
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="ClosePanel">Cancel</button>
                    </div>
                </div>
            }
        </div>
    };

    // ── Roomy modal renderer (logs / events / yaml) ──────────────────────────

