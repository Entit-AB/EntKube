                        @bind="_logLevelFilter" @bind:after="() => _ = FetchLogsAsync(node.Name)">
                    <option value="">All levels</option>
                    <option value="Info">Info+</option>
                    <option value="Warn">Warn+</option>
                    <option value="Error">Error + Fatal</option>
                </select>
            </div>
            <div>
                <label class="form-label d-block">Ingested history</label>
                <select class="form-select form-select-sm" style="width:auto;"
                        @bind="_logRangeMinutes" @bind:after="() => _ = FetchLogsAsync(node.Name)"
                        disabled="@(!_logIncludeIngested || !_logIngestedAvailable)">
                    <option value="15">Last 15 min</option>
                    <option value="60">Last 1 hour</option>
                    <option value="180">Last 3 hours</option>
                    <option value="720">Last 12 hours</option>
                    <option value="1440">Last 24 hours</option>
                </select>
            </div>
            <div>
                <label class="form-label d-block">Tail (live)</label>
                <select class="form-select form-select-sm" style="width:auto;"
                        @bind="_panelTailLines" @bind:after="() => _ = FetchLogsAsync(node.Name)">
                    <option value="100">100</option>
                    <option value="500">500</option>
                    <option value="1000">1000</option>
                </select>
            </div>
            <div class="flex-fill" style="min-width:160px;">
                <label class="form-label d-block">Filter text</label>
                <input class="form-control form-control-sm" placeholder="e.g. error, timeout"
                       @bind="_logTextFilter" @bind:after="() => _ = FetchLogsAsync(node.Name)" />
            </div>
            <div class="d-flex align-items-center gap-2">
                @if (_logIngestedAvailable)
                {
                    <button class="btn btn-sm @(_logIncludeIngested ? "btn-primary" : "btn-outline-secondary")"
                            title="Complete live pod logs with ingested telemetry history"
                            @onclick="() => ToggleIngested(node.Name)">
                        <i class="bi bi-hdd-network me-1"></i>Ingested
                    </button>
                }
                <button class="btn btn-sm @(_logFollow ? "btn-success" : "btn-outline-secondary")"
                        title="Live-tail new log lines" @onclick="() => ToggleLogFollow(node.Name)">
                    <i class="bi @(_logFollow ? "bi-pause-fill" : "bi-play-fill") me-1"></i>@(_logFollow ? "Following" : "Follow")
                </button>
            </div>
        </div>

        @if (!_logIngestedAvailable)
        {
            <div class="px-3 py-1 small" style="color:#8a8a9c;background:#201a24;border-bottom:1px solid #23232e;">
                <i class="bi bi-info-circle me-1"></i>No ingested log backend on this cluster — showing live pod logs only.
            </div>
        }

        @* Log-volume histogram over the ingested window: one bar per bucket, height ∝ count,
           error+fatal portion in red. Only present when an ingested backend returned buckets. *@
        @if (_logHistogram.Count > 0)
        {
            <div class="d-flex align-items-end gap-1 px-3 py-2" style="height:52px;background:#181820;border-bottom:1px solid #23232e;">
                @{ long maxTotal = _logHistogram.Max(b => b.Total); }
                @foreach (LogHistogramBucket b in _logHistogram)
                {
                    int barPx = maxTotal > 0 ? (int)Math.Round(b.Total * 40.0 / maxTotal) : 0;
                    int errPx = b.Total > 0 ? (int)Math.Round(b.Errors * (double)barPx / b.Total) : 0;
                    <div style="flex:1 1 0;display:flex;flex-direction:column;justify-content:flex-end;height:40px;"
                         title="@b.Start.ToLocalTime().ToString("HH:mm:ss") · @b.Total logs (@b.Errors err)">
                        <div style="background:#f48771;height:@(errPx)px;"></div>
                        <div style="background:#4a90d9;height:@(barPx - errPx)px;"></div>
                    </div>
                }
            </div>
        }

        @if (_panelError is not null)
        {
            <div class="alert alert-warning m-3 py-2 small">@_panelError</div>
        }
        else if (_panelLoading && _logRows.Count == 0)
        {
            <div class="text-center py-4"><div class="spinner-border text-light"></div></div>
        }
        else
        {
            <div @ref="_logPreRef" class="rg-log-lines">
                @{ var rows = FilteredLogRows.ToList(); }
                @if (rows.Count == 0)
                {
                    <div class="text-center py-5" style="color:#8a8a9c;">
                        <i class="bi bi-journal d-block mb-2" style="font-size:1.6rem;"></i>
                        No log lines match the current filters.
                    </div>
                }
                else
                {
                    bool prevLive = rows[0].Live;
                    bool first = true;
                    @foreach (LogRow row in rows)
                    {
                        @if (!first && row.Live && !prevLive)
                        {
                            <div class="rg-log-restart"><i class="bi bi-arrow-repeat me-1"></i>live pod stream</div>
                        }
                        first = false;
                        prevLive = row.Live;
                        <div class="rg-log-row">
                            <span class="rg-log-ts">@row.Timestamp.ToLocalTime().ToString("HH:mm:ss.fff")</span>
                            <span class="rg-log-src @(row.Live ? "live" : "ingested")">@(row.Live ? "live" : "ing")</span>
                            <span class="rg-log-msg" style="@LogLineStyle(row.Level)">@row.Line</span>
                            @if (EnableTraceLinks && !string.IsNullOrEmpty(row.TraceId))
                            {
                                <a class="badge bg-primary text-decoration-none ms-1" style="font-size:.55rem;cursor:pointer;flex-shrink:0;"
                                   title="Open trace @row.TraceId" @onclick="() => OpenTrace(row.TraceId)">trace</a>
                            }
                        </div>
                    }
                }
            </div>
            <div class="px-3 py-1 small d-flex justify-content-between" style="color:#8a8a9c;background:#2a2a3e;border-top:1px solid #3a3a4e;">
                <span>@FilteredLogRows.Count() lines · @_logRows.Count(r => r.Live) live · @_logRows.Count(r => !r.Live) ingested</span>
                @if (_panelLoading) { <span><span class="spinner-border spinner-border-sm me-1" style="width:.7rem;height:.7rem;"></span>refreshing…</span> }
            </div>
        }
    };

    // ── Visual helpers ───────────────────────────────────────────────────────

    private static string HealthColor(HealthStatus h) => h switch
    {
        HealthStatus.Healthy     => "#198754",
        HealthStatus.Progressing => "#0d6efd",
        HealthStatus.Degraded    => "#fd7e14",
        HealthStatus.Missing     => "#dc3545",
        HealthStatus.Suspended   => "#6c757d",
        _                        => "#adb5bd",
    };

    // Very light card-background tint per health status, so the whole card reads
    // its status at a glance — healthy stays subtle, problems pop.
    private static string HealthTint(HealthStatus h) => h switch
    {
        HealthStatus.Healthy     => "#f1faf5",
        HealthStatus.Progressing => "#eef4ff",
        HealthStatus.Degraded    => "#fff6ee",
        HealthStatus.Missing     => "#fdeff1",
        HealthStatus.Suspended   => "#f5f6f7",
        _                        => "#ffffff",
    };

    private static string HealthLabel(HealthStatus h) => h switch
    {
        HealthStatus.Healthy     => "Healthy",
        HealthStatus.Progressing => "Progressing",
        HealthStatus.Degraded    => "Degraded",
        HealthStatus.Missing     => "Missing",
        HealthStatus.Suspended   => "Suspended",
        _                        => "Unknown",
    };

    private static string KindIcon(string kind) => kind switch
    {
        "Deployment"            => "bi-layers",
        "StatefulSet"           => "bi-database",
        "DaemonSet"             => "bi-broadcast",
        "ReplicaSet"            => "bi-files",
        "Pod"                   => "bi-cpu",
        "Service"               => "bi-share",
        "Ingress"               => "bi-globe",
        "HTTPRoute"             => "bi-signpost-split",
        "PersistentVolumeClaim" => "bi-hdd",
        "ConfigMap"             => "bi-file-code",
        "Secret"                => "bi-key",
        "Job"                   => "bi-lightning",
        "CronJob"               => "bi-clock",
        _                       => "bi-box",
    };

    private static string KindColor(string kind) => kind switch
    {
        "Deployment" or "StatefulSet" or "DaemonSet" => "text-primary",
        "ReplicaSet"                                  => "text-secondary",
        "Pod"                                         => "text-success",
        "Service" or "Ingress" or "HTTPRoute"         => "text-info",
        "Job" or "CronJob"                            => "text-warning",
        "PersistentVolumeClaim"                       => "text-danger",
        _                                             => "text-muted",
    };

    private static int? ParseDesiredReplicas(string? s)
    {
        if (string.IsNullOrEmpty(s)) return null;
        int slash = s.IndexOf('/');
        if (slash < 0) return null;
        return int.TryParse(s[(slash + 1)..].Split(' ')[0], out int n) ? n : null;
    }

    // Compact "how long has it lived" age, matching kubectl's AGE column style.
    private static string FormatAge(DateTime dt)
    {
        TimeSpan age = DateTime.UtcNow - dt.ToUniversalTime();
        if (age < TimeSpan.Zero) age = TimeSpan.Zero;
        if (age.TotalDays  >= 1) return $"{(int)age.TotalDays}d";
        if (age.TotalHours >= 1) return $"{(int)age.TotalHours}h";
        if (age.TotalMinutes >= 1) return $"{(int)age.TotalMinutes}m";
        return $"{(int)age.TotalSeconds}s";
    }
}
