@* Colored expiry badge driven by a manually-tracked expiry date (e.g. an OAuth
   client secret). Renders a neutral badge when no expiry is set. *@

@if (ExpiresAt is null)
{
    <span class="badge bg-light text-dark border" title="No expiry recorded">
        <i class="bi bi-infinity me-1"></i>No expiry
    </span>
}
else
{
    int days = (int)Math.Floor((ExpiresAt.Value.ToUniversalTime() - DateTime.UtcNow).TotalDays);
    bool expired = DateTime.UtcNow > ExpiresAt.Value.ToUniversalTime();
    bool soon = !expired && days <= ThresholdDays;

    string cls = expired ? "bg-danger" : soon ? "bg-warning text-dark" : "bg-success";
    string icon = expired ? "bi-x-octagon" : soon ? "bi-exclamation-triangle" : "bi-check-circle";
    string text = expired ? $"Expired {-days}d ago" : soon ? $"Expires in {days}d" : $"Valid · {days}d left";

    <span class="badge @cls" title="@($"Expires {ExpiresAt.Value:yyyy-MM-dd}")">
        <i class="bi @icon me-1"></i>@text
    </span>
}

@code {
    [Parameter] public DateTime? ExpiresAt { get; set; }

    /// <summary>Days-until-expiry at or below which the badge turns amber.</summary>
    [Parameter] public int ThresholdDays { get; set; } = 30;
}
