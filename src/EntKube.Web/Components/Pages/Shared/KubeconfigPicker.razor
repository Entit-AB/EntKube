@using EntKube.Web.Services
@using Microsoft.AspNetCore.Components.Forms

@* Reusable kubeconfig chooser: paste YAML or upload a file, auto-detect contexts, and pick one
   when there is more than one. Raises OnSelectionChanged with the chosen context (or null when
   the selection is cleared). Used by both cluster registration and kubeconfig updates so the two
   flows offer the same experience. *@

<div>
    @if (parsedContexts is null || parsedContexts.Count == 0)
    {
        <p class="text-muted small mb-2">Paste your kubeconfig YAML or upload a file to auto-detect contexts and API server URLs.</p>

        <YamlEditor @bind-Value="yaml" />

        <div class="d-flex align-items-center gap-2 mt-1">
            <label class="btn btn-sm btn-outline-secondary mb-0">
                <i class="bi bi-upload me-1"></i>Upload file
                <InputFile OnChange="HandleFileUpload" class="d-none" accept=".yaml,.yml,.conf,.config" />
            </label>
            <button class="btn btn-sm btn-primary" @onclick="Parse" disabled="@string.IsNullOrWhiteSpace(yaml)">
                <i class="bi bi-search me-1"></i>Parse Contexts
            </button>
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="text-danger small mt-1">@error</div>
        }
    }
    else
    {
        <p class="text-muted small mb-2">
            @(parsedContexts.Count == 1 ? "Found 1 context:" : $"Found {parsedContexts.Count} contexts. Select one to use:")
        </p>

        <div class="list-group mb-2">
            @foreach (KubeconfigContext ctx in parsedContexts)
            {
                <label class="list-group-item list-group-item-action d-flex align-items-center gap-2 py-2 @(selectedContext == ctx.Name ? "active" : "")">
                    <input class="form-check-input mt-0" type="radio" name="@radioName"
                           checked="@(selectedContext == ctx.Name)"
                           @onchange="() => Select(ctx)" />
                    <div class="flex-grow-1">
                        <span class="fw-medium @(selectedContext == ctx.Name ? "text-white" : "")">@ctx.Name</span>
                        <br />
                        <small class="@(selectedContext == ctx.Name ? "text-white-50" : "text-muted")">@ctx.ClusterServer</small>
                    </div>
                    @if (ctx.IsCurrent)
                    {
                        <span class="badge @(selectedContext == ctx.Name ? "bg-white text-primary" : "bg-info")">current</span>
                    }
                </label>
            }
        </div>

        <button class="btn btn-sm btn-outline-secondary" @onclick="Clear">
            <i class="bi bi-arrow-counterclockwise me-1"></i>Choose a different kubeconfig
        </button>
    }
</div>

@code {
    /// <summary>Raised whenever a context is selected, or null when the selection is cleared.</summary>
    [Parameter] public EventCallback<KubeconfigSelection?> OnSelectionChanged { get; set; }

    // A unique radio-group name so multiple pickers on one page don't share selection state.
    private readonly string radioName = "kubeconfig-ctx-" + Guid.NewGuid().ToString("N");

    private string yaml = "";
    private List<KubeconfigContext>? parsedContexts;
    private string? selectedContext;
    private string? error;

    private void Parse()
    {
        error = null;
        List<KubeconfigContext> contexts = KubeconfigParser.ParseContexts(yaml);

        if (contexts.Count == 0)
        {
            error = "No valid contexts found in the kubeconfig. Check the YAML format.";
            parsedContexts = null;
            return;
        }

        parsedContexts = contexts;
        KubeconfigContext defaultCtx = contexts.FirstOrDefault(c => c.IsCurrent) ?? contexts.First();
        _ = Select(defaultCtx);
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        error = null;
        IBrowserFile file = e.File;

        if (file.Size > 1_048_576)
        {
            error = "File too large. Kubeconfig files should be under 1 MB.";
            return;
        }

        using StreamReader reader = new(file.OpenReadStream(maxAllowedSize: 1_048_576));
        yaml = await reader.ReadToEndAsync();
        Parse();
    }

    private async Task Select(KubeconfigContext ctx)
    {
        selectedContext = ctx.Name;
        await OnSelectionChanged.InvokeAsync(new KubeconfigSelection(yaml, ctx.Name, ctx.ClusterServer));
    }

    private async Task Clear()
    {
        parsedContexts = null;
        selectedContext = null;
        await OnSelectionChanged.InvokeAsync(null);
    }

    /// <summary>Resets the picker to its empty state (e.g. after a successful save).</summary>
    public void Reset()
    {
        yaml = "";
        parsedContexts = null;
        selectedContext = null;
        error = null;
    }
}
