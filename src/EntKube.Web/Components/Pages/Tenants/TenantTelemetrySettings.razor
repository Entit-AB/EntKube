@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using EntKube.Web.Data
@using EntKube.Web.Services
@rendermode InteractiveServer

@inject TelemetryStorageSettingService StorageSettings
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthState
@inject ToastService Toasts

<div class="card">
    <div class="card-body" style="max-width: 720px;">
        <h5 class="card-title"><i class="bi bi-hdd-network me-2 text-primary"></i>Telemetry storage</h5>
        <p class="text-muted small">
            Where this tenant's telemetry segments (logs / traces / RUM) are stored. Telemetry is
            tenant-scoped — this tenant's data is written to its own object storage and never mixed with
            another tenant's. Choose one of this tenant's registered storage links (AWS S3 / Cleura S3 /
            MinIO); leave it unset to fall back to a per-tenant prefix on the shared/local store.
        </p>

        @if (loading)
        {
            <div class="d-flex py-3"><div class="spinner-border spinner-border-sm text-primary"></div></div>
        }
        else
        {
            <div class="mb-3">
                <label class="form-label small text-muted mb-1">Storage link</label>
                <select class="form-select" @bind="selectedLinkId" disabled="@saving">
                    <option value="">— None (shared/local fallback) —</option>
                    @foreach (StorageLink l in links)
                    {
                        <option value="@l.Id">@l.Name — @l.Provider@(string.IsNullOrEmpty(l.BucketName) ? "" : $" ({l.BucketName})")</option>
                    }
                </select>
            </div>

            @if (links.Count == 0)
            {
                <div class="alert alert-light border small py-2">
                    This tenant has no storage links yet. Add one on the <strong>Storage</strong> tab, then select it here.
                </div>
            }

            <div class="alert alert-warning border small py-2">
                <i class="bi bi-exclamation-triangle me-1"></i>
                Changing the storage link applies to <strong>newly sealed</strong> segments. Data already written to
                the previous store stays there until retention ages it out.
            </div>

            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@saving">
                @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                Save
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public Guid TenantId { get; set; }

    private bool loading = true;
    private bool saving;
    private List<StorageLink> links = [];
    private string selectedLinkId = "";

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        await using ApplicationDbContext db = await DbFactory.CreateDbContextAsync();
        links = await db.StorageLinks.AsNoTracking()
            .Where(l => l.TenantId == TenantId)
            .OrderBy(l => l.Name)
            .ToListAsync();

        Guid? current = await StorageSettings.GetStorageLinkIdAsync(TenantId);
        selectedLinkId = current?.ToString() ?? "";
        loading = false;
    }

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            Guid? id = Guid.TryParse(selectedLinkId, out Guid g) ? g : null;
            // Guard: never accept another tenant's link.
            if (id is Guid picked && links.All(l => l.Id != picked))
            {
                Toasts.Error("That storage link does not belong to this tenant.");
                return;
            }
            AuthenticationState authState = await AuthState.GetAuthenticationStateAsync();
            string? userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            await StorageSettings.SetStorageLinkIdAsync(TenantId, id, userId);
            Toasts.Success(id is null ? "Telemetry storage set to the shared/local fallback." : "Telemetry storage link saved.");
        }
        catch (Exception ex)
        {
            Toasts.Error($"Failed to save telemetry storage: {ex.Message}");
        }
        finally
        {
            saving = false;
        }
    }
}
