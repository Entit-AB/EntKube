            return;
        }

        selectedUserId = user.Id;
        userEditTab = "profile";
        userEditError = null;
        editUserFirstName = user.FirstName ?? "";
        editUserLastName = user.LastName ?? "";
        editUserEmail = user.Email ?? "";
        editUserEnabled = user.Enabled;
        editUserEmailVerified = user.EmailVerified;
        editUserNewPassword = "";
        editUserPasswordTemporary = false;
        editUserAttributes = user.Attributes.ToDictionary(
            kv => kv.Key, kv => string.Join(", ", kv.Value));
        newAttrKey = "";
        newAttrValue = "";
        userRoles = null;
        userGroupMemberships = null;
        addRoleToUserId = "";
        addGroupToUserId = "";
    }

    private void CloseUserEdit()
    {
        selectedUserId = null;
        userRoles = null;
        userGroupMemberships = null;
        userEditError = null;
    }

    private async Task SwitchUserEditTab(string tab, KeycloakUserInfo user)
    {
        userEditTab = tab;
        userEditError = null;

        if (tab == "roles")
        {
            if (roles is null)
            {
                loadingRoles = true;
                StateHasChanged();
                try { roles = await KeycloakService.GetRealmRolesAsync(TenantId, selectedRealm!.Id); }
                catch (Exception ex) { userEditError = ex.Message; }
                finally { loadingRoles = false; }
            }
            if (userRoles is null)
            {
                loadingUserRoles = true;
                StateHasChanged();
                try { userRoles = await KeycloakService.GetUserRoleMappingsAsync(TenantId, selectedRealm!.Id, user.Id); }
                catch (Exception ex) { userEditError = ex.Message; }
                finally { loadingUserRoles = false; }
            }
        }
        else if (tab == "groups")
        {
            if (groups is null)
            {
                loadingGroups = true;
                StateHasChanged();
                try { groups = await KeycloakService.GetGroupsAsync(TenantId, selectedRealm!.Id); }
                catch (Exception ex) { userEditError = ex.Message; }
                finally { loadingGroups = false; }
            }
            if (userGroupMemberships is null)
            {
                loadingUserGroups = true;
                StateHasChanged();
                try { userGroupMemberships = await KeycloakService.GetUserGroupsAsync(TenantId, selectedRealm!.Id, user.Id); }
                catch (Exception ex) { userEditError = ex.Message; }
                finally { loadingUserGroups = false; }
            }
        }
    }

    private async Task SaveUserProfile(string userId)
    {
        if (selectedRealm is null) return;

        savingUserEdit = true;
        userEditError = null;

        try
        {
            Dictionary<string, List<string>> attrs = editUserAttributes
                .Where(kv => !string.IsNullOrWhiteSpace(kv.Key))
                .ToDictionary(kv => kv.Key, kv => new List<string> { kv.Value });

            await KeycloakService.UpdateUserAsync(
                TenantId, selectedRealm.Id, userId,
                editUserFirstName, editUserLastName, editUserEmail,
                editUserEnabled, editUserEmailVerified, attrs);

            users = await KeycloakService.GetUsersAsync(TenantId, selectedRealm.Id);
            KeycloakUserInfo? updated = users.FirstOrDefault(u => u.Id == userId);
            if (updated is not null)
            {
                editUserFirstName = updated.FirstName ?? "";
                editUserLastName = updated.LastName ?? "";
                editUserEmail = updated.Email ?? "";
                editUserEnabled = updated.Enabled;
                editUserEmailVerified = updated.EmailVerified;
            }
        }
        catch (Exception ex) { userEditError = ex.Message; }
        finally { savingUserEdit = false; }
    }

    private async Task SaveUserAttributes(string userId)
    {
        if (selectedRealm is null) return;

        savingUserEdit = true;
        userEditError = null;

        try
        {
            Dictionary<string, List<string>> attrs = editUserAttributes
                .Where(kv => !string.IsNullOrWhiteSpace(kv.Key))
