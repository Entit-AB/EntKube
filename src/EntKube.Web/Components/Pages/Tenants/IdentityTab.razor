@code {
    [Parameter] public Guid TenantId { get; set; }

    /// <summary>
    /// When set, this tab is scoped to a single environment: only Keycloak instances
    /// whose backing cluster belongs to this environment are shown/selectable, and the
    /// "Register External Keycloak" flow (which has no cluster/environment) is hidden.
    /// When null, behaviour is unchanged — every detected instance is shown.
    /// </summary>
    [Parameter] public Guid? EnvironmentId { get; set; }

    /// <summary>
    /// Loads the tenant's detected Keycloak instances and, when <see cref="EnvironmentId"/>
    /// is set, restricts them to instances whose managed ClusterComponent's cluster is in
    /// that environment (linkage: Component.Cluster.EnvironmentId). External instances
    /// (Component null) have no cluster and are excluded from an env-scoped view.
    /// </summary>
    private async Task<List<DetectedKeycloak>> LoadDetectedKeycloaksAsync()
    {
        List<DetectedKeycloak> all = await KeycloakService.GetDetectedKeycloaksAsync(TenantId);
