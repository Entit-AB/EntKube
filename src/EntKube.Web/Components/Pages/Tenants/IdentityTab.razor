    private string newIdpProviderId = "oidc";
    private string newIdpClientId = "";
    private string newIdpClientSecret = "";

    // ── Group form ────────────────────────────────────────────────────────────
    private bool showAddGroup;
    private bool savingGroup;
    private string? groupError;
    private string newGroupName = "";

    // ── Org form ─────────────────────────────────────────────────────────────
    private bool showAddOrg;
    private bool savingOrg;
    private string? orgError;
    private string newOrgName = "";
    private string newOrgDescription = "";

    // ── Realm theme form ──────────────────────────────────────────────────────
    private bool savingThemes;
    private bool applyingNamedTheme;
    private string? realmThemeError;
    private string editLoginTheme = "";
    private string editAccountTheme = "";
    private Guid? editRealmNamedThemeId;

    // ── Backup form ───────────────────────────────────────────────────────────
    private bool creatingBackup;
    private string? backupError;
    private Guid backupStorageLinkId;

    // ── Portal form ───────────────────────────────────────────────────────────
    private string? portalError;
    private Guid linkAppId;

    // ── Register external Keycloak form ───────────────────────────────────────
    private bool showRegisterExternal;
    private bool registeringExternal;
    private string? registerExternalError;
    private string registerExternalDisplayName = "";
    private string registerExternalAdminUrl = "";
    private string registerExternalUsername = "admin";
    private string registerExternalPassword = "";

    // ── Migrate tab ───────────────────────────────────────────────────────────
    private Guid migrateSourceKcId;
    private List<KeycloakRealm>? migrateSourceRealms;
    private bool loadingMigrateSourceRealms;
    private Guid migrateSourceRealmId;
    private Guid migrateTargetRealmId;
    private bool migrateCopyUsers = true;
    private bool migrateCopyThemeCss;
    private bool migrating;
    private CopyResult? migrateResult;
    private int migrateCssCopied;
    private string? migrateError;

    protected override async Task OnInitializedAsync()
    {
        detectedKeycloaks = await KeycloakService.GetDetectedKeycloaksAsync(TenantId);
        loading = false;
    }

    private async Task SelectKeycloak(DetectedKeycloak kc)
    {
        selectedKeycloak = kc;
        realms = null;
        availableDatabases = null;
        availableRegPgDatabases = null;
        setupError = null;
        setupDatabaseId = Guid.Empty;
        setupDatabaseSelection = "";
        setupAdminUrl = kc.SuggestedAdminUrl ?? "";
        setupPassword = "";
        instanceTab = "realms";
        availableThemes = null;
        namedThemes = [];
        selectedNamedTheme = null;
        showCreateTheme = false;
        themeCss = null;
        themeSaved = false;
        themeError = null;
        realmSyncError = null;

        if (kc.IsConfigured)
        {
            try
            {
                realms = await KeycloakService.SyncRealmsFromKeycloakAsync(TenantId, kc.Config!.Id);
            }
            catch (Exception ex)
            {
                realmSyncError = ex.Message;
                realms = await KeycloakService.GetRealmsForConfigAsync(TenantId, kc.Config!.Id);
            }
            storageLinks ??= await StorageService.GetStorageLinksAsync(TenantId);
            apps ??= await KeycloakService.GetAppsAsync(TenantId);
        }
        else
        {
            if (kc.Component is not null)
            {
                var dbTask = KeycloakService.GetDatabasesForComponentAsync(TenantId, kc.Component.Id);
                var regPgTask = KeycloakService.GetRegisteredPostgresDatabasesForComponentAsync(TenantId, kc.Component.Id);
                await Task.WhenAll(dbTask, regPgTask);
                availableDatabases = dbTask.Result;
                availableRegPgDatabases = regPgTask.Result;
            }
            else
            {
                availableDatabases = [];
                availableRegPgDatabases = await KeycloakService.GetAllRegisteredPostgresDatabasesAsync(TenantId);
            }
        }

        if (kc.Config is not null)
        {
            editAdminUrl = kc.Config.AdminUrl ?? "";
            editAdminUsername = kc.Config.AdminUsername;
        }
    }

    private async Task SwitchInstanceTab(string tab)
    {
        instanceTab = tab;
        themeSaved = false;
        themeError = null;

        if (tab == "themes" && selectedKeycloak?.Config is not null)
        {
            await LoadThemesTab();
        }
        else if (tab == "migrate")
        {
            migrateResult = null;
            migrateError = null;
            migrateSourceKcId = Guid.Empty;
            migrateSourceRealms = null;
            migrateSourceRealmId = Guid.Empty;
            migrateTargetRealmId = Guid.Empty;
        }
    }

    private async Task SwitchThemeType(string type)
    {
        themeType = type;
        themeSaved = false;
        themeError = null;
        await LoadThemeCss();
    }

    private async Task LoadThemesTab()
    {
        if (selectedKeycloak?.Config is null) return;

        loadingThemes = true;
        StateHasChanged();

        try
        {
            availableThemes = await KeycloakService.GetAvailableThemesAsync(TenantId, selectedKeycloak.Config.Id);
            namedThemes = await KeycloakService.GetNamedThemesAsync(TenantId, selectedKeycloak.Config.Id);

            // Re-select the same named theme if it still exists after a reload.
            if (selectedNamedTheme is not null)
            {
                selectedNamedTheme = namedThemes.FirstOrDefault(t => t.Id == selectedNamedTheme.Id);
                if (selectedNamedTheme is not null)
                    await LoadThemeCss();
                else
                    themeCss = null;
            }
        }
        catch
        {
            availableThemes = [];
            namedThemes = [];
        }
        finally
        {
            loadingThemes = false;
        }
    }

    private async Task LoadThemeCss()
    {
        if (selectedKeycloak is null || selectedNamedTheme is null) { themeCss = null; return; }
        themeCss = await KeycloakService.GetNamedThemeCssAsync(
            TenantId, selectedKeycloak.ComponentId, selectedNamedTheme.Id, themeType);
    }

    private async Task SelectNamedTheme(KeycloakTheme theme)
    {
        selectedNamedTheme = theme;
        editThemeName = theme.Name;
        editThemeLoginTheme = theme.LoginTheme ?? "";
        editThemeAccountTheme = theme.AccountTheme ?? "";
        themeType = "login";
        themeSaved = false;
        themeError = null;
        themeMetaSaved = false;
        themeMetaError = null;
        showCreateTheme = false;
        await LoadThemeCss();
    }

    private async Task CreateNamedTheme()
    {
        if (selectedKeycloak?.Config is null || string.IsNullOrWhiteSpace(newThemeName)) return;

        creatingTheme = true;
        createThemeError = null;

        try
        {
            KeycloakTheme created = await KeycloakService.CreateNamedThemeAsync(
                TenantId, selectedKeycloak.Config.Id,
                newThemeName,
                string.IsNullOrWhiteSpace(newThemeLoginTheme) ? null : newThemeLoginTheme,
                string.IsNullOrWhiteSpace(newThemeAccountTheme) ? null : newThemeAccountTheme);

            namedThemes = await KeycloakService.GetNamedThemesAsync(TenantId, selectedKeycloak.Config.Id);
            showCreateTheme = false;
            newThemeName = "";
            newThemeLoginTheme = "";
            newThemeAccountTheme = "";
            await SelectNamedTheme(created);
        }
        catch (Exception ex)
        {
            createThemeError = ex.Message;
        }
        finally
        {
            creatingTheme = false;
        }
    }

    private async Task SaveNamedThemeMeta()
    {
        if (selectedNamedTheme is null || string.IsNullOrWhiteSpace(editThemeName)) return;

        savingThemeMeta = true;
        themeMetaSaved = false;
        themeMetaError = null;

        try
        {
            await KeycloakService.UpdateNamedThemeAsync(
                TenantId, selectedNamedTheme.Id, editThemeName,
                string.IsNullOrWhiteSpace(editThemeLoginTheme) ? null : editThemeLoginTheme,
                string.IsNullOrWhiteSpace(editThemeAccountTheme) ? null : editThemeAccountTheme);

            namedThemes = await KeycloakService.GetNamedThemesAsync(TenantId, selectedKeycloak!.Config!.Id);
            selectedNamedTheme = namedThemes.FirstOrDefault(t => t.Id == selectedNamedTheme.Id) ?? selectedNamedTheme;
            themeMetaSaved = true;
        }
        catch (Exception ex)
        {
            themeMetaError = ex.Message;
        }
        finally
        {
            savingThemeMeta = false;
        }
    }

    private async Task SaveNamedThemeCss()
    {
        if (selectedKeycloak is null || selectedNamedTheme is null) return;

        savingTheme = true;
        themeSaved = false;
        themeError = null;

        try
        {
            await KeycloakService.SaveNamedThemeCssAsync(
                TenantId, selectedKeycloak.ComponentId, selectedNamedTheme.Id, themeType, themeCss ?? "");
            themeSaved = true;
        }
        catch (Exception ex)
        {
            themeError = ex.Message;
        }
        finally
        {
            savingTheme = false;
        }
    }

    private async Task DeleteNamedTheme()
    {
        if (selectedKeycloak is null || selectedNamedTheme is null) return;

        deletingTheme = true;
        themeMetaError = null;

        try
        {
            await KeycloakService.DeleteNamedThemeAsync(
                TenantId, selectedNamedTheme.Id, selectedKeycloak.ComponentId);

            namedThemes = await KeycloakService.GetNamedThemesAsync(TenantId, selectedKeycloak.Config!.Id);
            selectedNamedTheme = null;
            themeCss = null;
        }
        catch (Exception ex)
        {
            themeMetaError = ex.Message;
        }
        finally
        {
            deletingTheme = false;
        }
    }

    private Task SaveThemeCss() => SaveNamedThemeCss();

    // ── Register external ─────────────────────────────────────────────────────

    private async Task RegisterExternal()
    {
        registeringExternal = true;
        registerExternalError = null;

        try
        {
            KeycloakComponentConfig config = await KeycloakService.RegisterExternalAsync(
                TenantId,
                registerExternalDisplayName,
                registerExternalAdminUrl,
                registerExternalUsername,
                registerExternalPassword);

            await KeycloakService.SyncRealmsFromKeycloakAsync(TenantId, config.Id);

            detectedKeycloaks = await KeycloakService.GetDetectedKeycloaksAsync(TenantId);
            showRegisterExternal = false;
            registerExternalDisplayName = "";
            registerExternalAdminUrl = "";
            registerExternalPassword = "";
        }
        catch (Exception ex)
        {
            registerExternalError = ex.Message;
        }
        finally
        {
            registeringExternal = false;
        }
    }

    // ── Migrate ───────────────────────────────────────────────────────────────

    private async Task OnMigrateSourceKcChanged()
    {
        migrateSourceRealms = null;
        migrateSourceRealmId = Guid.Empty;
        migrateError = null;

        if (migrateSourceKcId == Guid.Empty) return;

        DetectedKeycloak? sourceKc = detectedKeycloaks?.FirstOrDefault(k => k.ComponentId == migrateSourceKcId);
        if (sourceKc?.Config is null) return;

        loadingMigrateSourceRealms = true;
        StateHasChanged();

        try
        {
            migrateSourceRealms = await KeycloakService.GetRealmsForConfigAsync(TenantId, sourceKc.Config.Id);
        }
        catch (Exception ex)
        {
            migrateError = ex.Message;
        }
        finally
        {
            loadingMigrateSourceRealms = false;
        }
    }

    private async Task ExecuteMigrate()
    {
        if (selectedKeycloak is null || migrateSourceKcId == Guid.Empty) return;

        migrating = true;
        migrateResult = null;
        migrateCssCopied = 0;
        migrateError = null;

        try
        {
            CopyResult combined = new();

            if (migrateCopyUsers && migrateSourceRealmId != Guid.Empty && migrateTargetRealmId != Guid.Empty)
            {
                CopyResult r = await KeycloakService.CopyUsersAsync(
                    TenantId, migrateSourceRealmId, migrateTargetRealmId);
                combined.Copied += r.Copied;
                combined.Skipped += r.Skipped;
                combined.Errors.AddRange(r.Errors);
            }

            if (migrateCopyThemeCss)
            {
                migrateCssCopied = await KeycloakService.CopyThemeCssAsync(
                    TenantId, migrateSourceKcId, selectedKeycloak.ComponentId);
            }

            migrateResult = combined;
        }
        catch (Exception ex)
        {
            migrateError = ex.Message;
        }
        finally
        {
            migrating = false;
        }
    }

    private void BackToList()
    {
        selectedKeycloak = null;
        selectedRealm = null;
        realms = null;
    }

    private async Task OpenRealm(KeycloakRealm realm)
    {
        selectedRealm = realm;
        realmTab = "users";
        users = null;
        idps = null;
        groups = null;
        orgs = null;
        backups = null;
        realmDetails = null;
        await SwitchRealmTab("users");
    }

    private void BackToRealms()
    {
        selectedRealm = null;
        users = null;
        idps = null;
        groups = null;
        orgs = null;
        backups = null;
        realmDetails = null;
    }

    private async Task SwitchRealmTab(string tab)
    {
        realmTab = tab;

        if (selectedRealm is null) return;

        switch (tab)
        {
            case "users" when users is null:
                loadingUsers = true;
                StateHasChanged();
                try { users = await KeycloakService.GetUsersAsync(TenantId, selectedRealm.Id); }
                catch (Exception ex) { userError = ex.Message; }
                finally { loadingUsers = false; }
                break;

            case "idp" when idps is null:
                loadingIdps = true;
                StateHasChanged();
                try { idps = await KeycloakService.GetIdpsAsync(TenantId, selectedRealm.Id); }
                catch (Exception ex) { idpError = ex.Message; }
                finally { loadingIdps = false; }
                break;

            case "groups" when groups is null:
                loadingGroups = true;
                StateHasChanged();
                try { groups = await KeycloakService.GetGroupsAsync(TenantId, selectedRealm.Id); }
                catch (Exception ex) { groupError = ex.Message; }
                finally { loadingGroups = false; }
                break;

            case "orgs" when orgs is null:
                loadingOrgs = true;
                StateHasChanged();
                try { orgs = await KeycloakService.GetOrganizationsAsync(TenantId, selectedRealm.Id); }
                catch (Exception ex) { orgError = ex.Message; }
                finally { loadingOrgs = false; }
                break;

            case "themes" when realmDetails is null:
                StateHasChanged();
                try
                {
                    realmDetails = await KeycloakService.GetRealmDetailsAsync(TenantId, selectedRealm.Id);
                    editLoginTheme = realmDetails.LoginTheme ?? "";
                    editAccountTheme = realmDetails.AccountTheme ?? "";
                    editRealmNamedThemeId = selectedRealm.KeycloakThemeId;

                    if (namedThemes.Count == 0 && selectedKeycloak?.Config is not null)
                        namedThemes = await KeycloakService.GetNamedThemesAsync(TenantId, selectedKeycloak.Config.Id);
                }
                catch (Exception ex) { realmThemeError = ex.Message; }
                break;

            case "backup" when backups is null:
                loadingBackups = true;
                storageLinks ??= await StorageService.GetStorageLinksAsync(TenantId);
                StateHasChanged();
                try { backups = await KeycloakService.GetBackupsAsync(TenantId, selectedRealm.Id); }
                catch (Exception ex) { backupError = ex.Message; }
                finally { loadingBackups = false; }
                break;

            case "portal":
                apps ??= await KeycloakService.GetAppsAsync(TenantId);
                break;
        }
    }

    // ── Setup ─────────────────────────────────────────────────────────────────

    private void UseSuggestedUrl()
    {
        setupAdminUrl = selectedKeycloak?.SuggestedAdminUrl ?? "";
    }

    private async Task ConfigureKeycloak()
    {
        if (selectedKeycloak is null) return;

        configuringKeycloak = true;
        setupError = null;

        try
        {
            Guid? cnpgDbId = null;
            Guid? regPgDbId = null;

            if (setupDatabaseSelection.StartsWith("cnpg:") && Guid.TryParse(setupDatabaseSelection[5..], out Guid parsedCnpg))
                cnpgDbId = parsedCnpg;
            else if (setupDatabaseSelection.StartsWith("regpg:") && Guid.TryParse(setupDatabaseSelection[6..], out Guid parsedRegPg))
                regPgDbId = parsedRegPg;

            KeycloakComponentConfig config = await KeycloakService.ConfigureAsync(
                TenantId,
                selectedKeycloak.Component!.Id,
                cnpgDbId,
                setupUsername,
                setupPassword,
                setupAdminUrl,
                registeredPostgresDatabaseId: regPgDbId);

            // Sync the credentials to the K8s secret immediately so the pod can start.
            await LifecycleService.SyncComponentSecretsAsync(selectedKeycloak.Component!.Id);

            // Import any realms that already exist in this Keycloak instance.
            await KeycloakService.SyncRealmsFromKeycloakAsync(TenantId, config.Id);

            // Refresh detection list and re-select the now-configured keycloak.
            detectedKeycloaks = await KeycloakService.GetDetectedKeycloaksAsync(TenantId);
            Guid originalId = selectedKeycloak.ComponentId;
            DetectedKeycloak? updated = detectedKeycloaks.FirstOrDefault(
                k => k.ComponentId == originalId);

            if (updated is not null)
            {
                await SelectKeycloak(updated);
            }
        }
        catch (Exception ex)
        {
            setupError = ex.Message;
        }
        finally
        {
            configuringKeycloak = false;
        }
    }

    private async Task SaveConfig()
    {
        if (selectedKeycloak?.Config is null) return;

        savingConfig = true;
        configError = null;

        try
        {
            await KeycloakService.UpdateConfigAsync(
                TenantId, selectedKeycloak.Config.Id,
                editAdminUrl, editAdminUsername,
                string.IsNullOrWhiteSpace(editAdminPassword) ? null : editAdminPassword);

            showEditConfig = false;
            detectedKeycloaks = await KeycloakService.GetDetectedKeycloaksAsync(TenantId);
            Guid originalId = selectedKeycloak.ComponentId;
            DetectedKeycloak? updated = detectedKeycloaks.FirstOrDefault(k => k.ComponentId == originalId);
            if (updated is not null) selectedKeycloak = updated;
        }
        catch (Exception ex)
        {
            configError = ex.Message;
        }
        finally
        {
            savingConfig = false;
        }
    }

