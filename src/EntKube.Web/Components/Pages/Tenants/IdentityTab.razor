            // Re-select the same named theme if it still exists after a reload.
            if (selectedNamedTheme is not null)
            {
                selectedNamedTheme = namedThemes.FirstOrDefault(t => t.Id == selectedNamedTheme.Id);
                if (selectedNamedTheme is not null)
                    await LoadThemeCss();
                else
                    themeCss = null;
