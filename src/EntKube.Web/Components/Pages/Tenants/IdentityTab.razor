    private void OnMapperTypeChanged()
    {
        newMapperConfig = [];
        newMapperConfig["access.token.claim"] = "true";
        newMapperConfig["id.token.claim"] = "true";
        newMapperConfig["userinfo.token.claim"] = "true";

        if (newMapperType == "oidc-usermodel-attribute-mapper" || newMapperType == "oidc-usermodel-property-mapper")
            newMapperConfig["jsonType.label"] = "String";
        else if (newMapperType == "oidc-group-membership-mapper")
        {
            newMapperConfig["claim.name"] = "groups";
            newMapperConfig["full.path"] = "false";
        }
        else if (newMapperType == "oidc-hardcoded-claim-mapper")
            newMapperConfig["jsonType.label"] = "String";
    }

    private void ResetAddMapper()
    {
        newMapperName = "";
        newMapperType = "oidc-usermodel-attribute-mapper";
        newMapperConfig = [];
        newMapperConfig["access.token.claim"] = "true";
        newMapperConfig["id.token.claim"] = "true";
        newMapperConfig["userinfo.token.claim"] = "true";
        newMapperConfig["jsonType.label"] = "String";
    }

