            loadingMigrateSourceRealms = false;
        }
    }

    private async Task ExecuteMigrate()
    {
        if (selectedKeycloak is null || migrateSourceKcId == Guid.Empty) return;

        migrating = true;
        migrateResult = null;
        migrateCssCopied = 0;
        migrateError = null;

        try
        {
            CopyResult combined = new();

            if (migrateCopyUsers && migrateSourceRealmId != Guid.Empty && migrateTargetRealmId != Guid.Empty)
            {
                CopyResult r = await KeycloakService.CopyUsersAsync(
                    TenantId, migrateSourceRealmId, migrateTargetRealmId);
                combined.Copied += r.Copied;
                combined.Skipped += r.Skipped;
                combined.Errors.AddRange(r.Errors);
            }

            if (migrateCopyThemeCss)
            {
                migrateCssCopied = await KeycloakService.CopyThemeCssAsync(
                    TenantId, migrateSourceKcId, selectedKeycloak.ComponentId);
            }

            migrateResult = combined;
        }
        catch (Exception ex)
        {
            migrateError = ex.Message;
        }
        finally
        {
            migrating = false;
        }
    }

