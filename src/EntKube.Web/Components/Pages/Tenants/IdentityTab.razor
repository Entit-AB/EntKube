                TenantId, selectedRealm.Id, editRealmNamedThemeId == Guid.Empty ? null : editRealmNamedThemeId);

            // Refresh the realm list so the FK and theme labels are up-to-date.
            realms = await KeycloakService.GetRealmsForConfigAsync(TenantId, selectedKeycloak!.Config!.Id);
            selectedRealm = realms.FirstOrDefault(r => r.Id == selectedRealm.Id) ?? selectedRealm;

            if (realmDetails is not null)
            {
                // Refresh realm details from Keycloak so editLoginTheme reflects the slug that
                // AssignNamedThemeToRealmAsync just wrote. Without this, editLoginTheme keeps the
                // stale in-memory value (e.g. "theme-salesdata") and a subsequent Save click
                // reverts the realm back to the wrong slug.
                realmDetails = await KeycloakService.GetRealmDetailsAsync(TenantId, selectedRealm.Id);
                editLoginTheme = realmDetails.LoginTheme ?? "";
                editAccountTheme = realmDetails.AccountTheme ?? "";
            }
        }
        catch (Exception ex)
