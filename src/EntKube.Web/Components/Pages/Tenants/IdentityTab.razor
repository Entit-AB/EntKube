@using System.ComponentModel.DataAnnotations
@using EntKube.Web.Data
@using EntKube.Web.Services
@inject KeycloakService KeycloakService
@inject StorageService StorageService
@inject ComponentLifecycleService LifecycleService
@inject RegisteredPostgresService RegisteredPostgresService
@inject ToastService Toasts

<LoadingPanel Loading="@loading" LoadingText="Scanning for Keycloak instances…">
<ConfirmDialog Visible="@(pendingConfirm is not null)"
               Message="@(pendingConfirm?.Message ?? "")"
               ConfirmText="@(pendingConfirm?.ConfirmText ?? "Delete")"
               IsBusy="confirmBusy"
               OnConfirm="RunPendingConfirmAsync"
               OnCancel="() => pendingConfirm = null" />
@if (selectedRealm is not null && selectedKeycloak is not null)
{
    @* ── Level 3: Realm detail ── *@
    <nav class="mb-3">
        <button class="btn btn-sm btn-link text-decoration-none p-0" @onclick="BackToRealms">
            <i class="bi bi-arrow-left me-1"></i>Back to Realms
        </button>
    </nav>

    <div class="d-flex align-items-center justify-content-between mb-3">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-shield-lock fs-4 text-primary"></i>
            <div>
                <h5 class="mb-0">@selectedRealm.DisplayName</h5>
                <small class="text-muted font-monospace">@selectedRealm.RealmName</small>
            </div>
        </div>
        @if (selectedRealm.LinkedApp is not null)
        {
            <span class="badge bg-primary-subtle text-primary border border-primary-subtle small">
                <i class="bi bi-link-45deg me-1"></i>@selectedRealm.LinkedApp.Customer.Name / @selectedRealm.LinkedApp.Name
            </span>
        }
    </div>

    <ul class="nav nav-tabs mb-3 flex-wrap" role="tablist" aria-label="Realm sections">
        @foreach (string tab in new[] { "users", "roles", "clients", "idp", "groups", "orgs", "themes", "settings", "backup", "portal" })
        {
            string label = tab switch
            {
                "users" => "Users",
                "roles" => "Roles",
                "clients" => "Clients",
                "idp" => "Identity Providers",
                "groups" => "Groups",
                "orgs" => "Organizations",
                "themes" => "Themes",
                "settings" => "Settings",
                "backup" => "Backup & Restore",
                "portal" => "Customer Portal",
                _ => tab
            };
            <li class="nav-item" role="presentation">
                <button class="nav-link @(realmTab == tab ? "active" : "")"
                        role="tab"
                        aria-selected="@(realmTab == tab)"
                        tabindex="@(realmTab == tab ? 0 : -1)"
                        @onclick="() => SwitchRealmTab(tab)">@label</button>
            </li>
        }
    </ul>

    @* ── Users ── *@
    @if (realmTab == "users")
    {
        @if (loadingUsers)
        {
            <div class="spinner-border spinner-border-sm text-primary"></div>
        }
        else
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted small">@(users?.Count ?? 0) users</span>
                <button class="btn btn-sm btn-primary" @onclick="() => showAddUser = !showAddUser">
                    <i class="bi bi-person-plus me-1"></i>Add User
                </button>
            </div>

            @if (showAddUser)
            {
                <div class="card mb-3 border-primary-subtle">
                    <div class="card-body">
                        @if (userError is not null)
                        {
                            <div class="alert alert-danger py-2 small">@userError</div>
                        }
                        <EditForm Model="addUserForm" OnValidSubmit="AddUser">
                            <DataAnnotationsValidator />
                            <div class="row g-2">
                                <div class="col-md-4">
                                    <InputText class="form-control form-control-sm" placeholder="Username" @bind-Value="addUserForm.Username" />
                                    <ValidationMessage For="() => addUserForm.Username" class="text-danger small" />
                                </div>
                                <div class="col-md-4">
                                    <InputText class="form-control form-control-sm" placeholder="Email" @bind-Value="addUserForm.Email" />
                                    <ValidationMessage For="() => addUserForm.Email" class="text-danger small" />
                                </div>
                                <div class="col-md-2">
                                    <InputText class="form-control form-control-sm" placeholder="First name" @bind-Value="addUserForm.FirstName" />
                                </div>
                                <div class="col-md-2">
                                    <InputText class="form-control form-control-sm" placeholder="Last name" @bind-Value="addUserForm.LastName" />
                                </div>
                                <div class="col-md-4">
                                    <InputText type="password" class="form-control form-control-sm" placeholder="Password (optional)" @bind-Value="addUserForm.Password" />
                                </div>
                            </div>
                            <div class="mt-2 d-flex gap-2">
                                <button type="submit" class="btn btn-sm btn-primary" disabled="@savingUser">
                                    @if (savingUser) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    Create
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => showAddUser = false">Cancel</button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            }

            @if (users is not null)
            {
                <div class="list-group">
                    @foreach (KeycloakUserInfo user in users)
                    {
                        bool isEditingThisUser = selectedUserId == user.Id;
                        <div class="list-group-item py-2">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <strong>@user.Username</strong>
                                    <span class="text-muted small ms-2">@user.Email</span>
                                    @if (!user.Enabled)
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary ms-1 small">Disabled</span>
                                    }
                                    @if (!user.EmailVerified)
                                    {
                                        <span class="badge bg-warning-subtle text-warning ms-1 small">Unverified</span>
                                    }
                                    @if (user.Attributes.Count > 0)
                                    {
                                        <div class="mt-1 d-flex flex-wrap gap-1">
                                            @foreach (KeyValuePair<string, List<string>> attr in user.Attributes)
                                            {
                                                <span class="badge bg-light text-secondary border font-monospace"
                                                      style="font-size:0.7rem">
                                                    @attr.Key: @string.Join(", ", attr.Value)
                                                </span>
                                            }
                                        </div>
                                    }
                                </div>
                                <div class="d-flex gap-1">
                                    <button class="btn btn-sm btn-outline-secondary border-0"
                                            @onclick="() => OpenUserEdit(user)"
                                            aria-label="@($"Edit user {user.Username}")">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger border-0"
                                            @onclick='() => pendingConfirm = new PendingConfirm($"Delete user \"{user.Username}\"? This cannot be undone.", "Delete", () => DeleteUser(user.Id))'
                                            aria-label="@($"Delete user {user.Username}")">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>

                            @if (isEditingThisUser)
                            {
                                <div class="mt-2 p-3 bg-light border rounded">
                                    @if (userEditError is not null)
                                    {
                                        <div class="alert alert-danger py-2 small mb-2">@userEditError</div>
                                    }
                                    <ul class="nav nav-tabs mb-3 nav-sm" role="tablist" aria-label="User settings">
                                        @foreach (string ut in new[] { "profile", "roles", "groups", "password", "attributes" })
                                        {
                                            <li class="nav-item" role="presentation">
                                                <button class="nav-link py-1 px-2 small @(userEditTab == ut ? "active" : "")"
                                                        role="tab"
                                                        aria-selected="@(userEditTab == ut)"
                                                        tabindex="@(userEditTab == ut ? 0 : -1)"
                                                        @onclick="() => SwitchUserEditTab(ut, user)">
                                                    @(ut switch { "profile" => "Profile", "roles" => "Roles", "groups" => "Groups", "password" => "Password", "attributes" => "Attributes", _ => ut })
                                                </button>
                                            </li>
                                        }
                                        <li class="ms-auto">
                                            <button class="btn btn-sm btn-link text-muted py-1"
                                                    @onclick="CloseUserEdit">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </li>
                                    </ul>

                                    @* ── Profile sub-tab ── *@
                                    @if (userEditTab == "profile")
                                    {
                                        <div class="row g-2" style="max-width:520px">
                                            <div class="col-md-6">
                                                <label class="form-label small">First Name</label>
                                                <input class="form-control form-control-sm" @bind="editUserFirstName" />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">Last Name</label>
                                                <input class="form-control form-control-sm" @bind="editUserLastName" />
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label small">Email</label>
                                                <input class="form-control form-control-sm" type="email" @bind="editUserEmail" />
                                            </div>
                                            <div class="col-12 d-flex gap-3">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" id="editUserEnabled_@user.Id" @bind="editUserEnabled" />
                                                    <label class="form-check-label small" for="editUserEnabled_@user.Id">Enabled</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" id="editUserVerified_@user.Id" @bind="editUserEmailVerified" />
                                                    <label class="form-check-label small" for="editUserVerified_@user.Id">Email Verified</label>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <button class="btn btn-sm btn-primary" @onclick="() => SaveUserProfile(user.Id)"
                                                        disabled="@savingUserEdit">
                                                    @if (savingUserEdit) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                    Save
                                                </button>
                                            </div>
                                        </div>
                                    }

                                    @* ── Roles sub-tab ── *@
                                    @if (userEditTab == "roles")
                                    {
                                        @if (loadingUserRoles)
                                        {
                                            <div class="spinner-border spinner-border-sm text-primary"></div>
                                        }
                                        else
                                        {
                                            @if (userRoles is not null && userRoles.Count > 0)
                                            {
                                                <div class="d-flex flex-wrap gap-1 mb-2">
                                                    @foreach (KeycloakRole role in userRoles)
                                                    {
                                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle d-flex align-items-center gap-1">
                                                            @role.Name
                                                            <button class="btn-close btn-close-sm ms-1" style="font-size:0.6rem"
                                                                    @onclick="() => RemoveUserRole(user.Id, role)"></button>
                                                        </span>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <EmptyState Icon="bi-shield-lock" Title="No roles" Message="No roles assigned." />
                                            }
                                            @if (roles is not null)
                                            {
                                                HashSet<string> assignedRoleIds = [.. (userRoles ?? []).Select(r => r.Id)];
                                                List<KeycloakRole> availableToAdd = roles.Where(r => !assignedRoleIds.Contains(r.Id)).ToList();
                                                @if (availableToAdd.Count > 0)
                                                {
                                                    <div class="d-flex gap-2 align-items-center" style="max-width:320px">
                                                        <select class="form-select form-select-sm" @bind="addRoleToUserId">
                                                            <option value="">Add role…</option>
                                                            @foreach (KeycloakRole r in availableToAdd)
                                                            {
                                                                <option value="@r.Id">@r.Name</option>
                                                            }
                                                        </select>
                                                        <button class="btn btn-sm btn-primary" @onclick="() => AddRoleToUser(user.Id)"
                                                                disabled="@(string.IsNullOrEmpty(addRoleToUserId))">
                                                            Add
                                                        </button>
                                                    </div>
                                                }
                                            }
                                        }
                                    }

                                    @* ── Groups sub-tab ── *@
                                    @if (userEditTab == "groups")
                                    {
                                        @if (loadingUserGroups)
                                        {
                                            <div class="spinner-border spinner-border-sm text-primary"></div>
                                        }
                                        else
                                        {
                                            @if (userGroupMemberships is not null && userGroupMemberships.Count > 0)
                                            {
                                                <div class="d-flex flex-wrap gap-1 mb-2">
                                                    @foreach (KeycloakGroupInfo g in userGroupMemberships)
                                                    {
                                                        <span class="badge bg-secondary-subtle text-secondary border d-flex align-items-center gap-1">
                                                            <i class="bi bi-people me-1"></i>@g.Name
                                                            <button class="btn-close btn-close-sm ms-1" style="font-size:0.6rem"
                                                                    @onclick="() => RemoveUserFromGroup(user.Id, g.Id)"></button>
                                                        </span>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <EmptyState Icon="bi-people" Title="No groups" Message="Not a member of any group." />
                                            }
                                            @if (groups is not null)
                                            {
                                                HashSet<string> memberGroupIds = [.. (userGroupMemberships ?? []).Select(g => g.Id)];
                                                List<KeycloakGroupInfo> availableGroups = groups.Where(g => !memberGroupIds.Contains(g.Id)).ToList();
                                                @if (availableGroups.Count > 0)
                                                {
                                                    <div class="d-flex gap-2 align-items-center" style="max-width:320px">
                                                        <select class="form-select form-select-sm" @bind="addGroupToUserId">
                                                            <option value="">Add to group…</option>
                                                            @foreach (KeycloakGroupInfo g in availableGroups)
                                                            {
                                                                <option value="@g.Id">@g.Name</option>
                                                            }
                                                        </select>
                                                        <button class="btn btn-sm btn-primary" @onclick="() => AddUserToGroup(user.Id)"
                                                                disabled="@(string.IsNullOrEmpty(addGroupToUserId))">
                                                            Add
                                                        </button>
                                                    </div>
                                                }
                                            }
                                        }
                                    }

                                    @* ── Password sub-tab ── *@
                                    @if (userEditTab == "password")
                                    {
                                        <div class="row g-2" style="max-width:360px">
                                            <div class="col-12">
                                                <label class="form-label small">New Password</label>
                                                <input type="password" class="form-control form-control-sm"
                                                       @bind="editUserNewPassword" />
                                            </div>
                                            <div class="col-12">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" id="pwdTemp_@user.Id"
                                                           @bind="editUserPasswordTemporary" />
                                                    <label class="form-check-label small" for="pwdTemp_@user.Id">
                                                        Temporary (user must change on next login)
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <button class="btn btn-sm btn-warning" @onclick="() => ResetUserPassword(user.Id)"
                                                        disabled="@(savingUserEdit || string.IsNullOrWhiteSpace(editUserNewPassword))">
                                                    @if (savingUserEdit) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                    Reset Password
                                                </button>
                                            </div>
                                        </div>
                                    }

                                    @* ── Attributes sub-tab ── *@
                                    @if (userEditTab == "attributes")
                                    {
                                        <div style="max-width:520px">
                                            @foreach (KeyValuePair<string, string> attr in editUserAttributes)
                                            {
                                                string attrKey = attr.Key;
                                                <div class="d-flex gap-2 mb-2 align-items-center">
                                                    <input class="form-control form-control-sm font-monospace"
                                                           style="max-width:180px" value="@attr.Key" disabled />
                                                    <input class="form-control form-control-sm"
                                                           value="@attr.Value"
                                                           @oninput="e => editUserAttributes[attrKey] = e.Value?.ToString() ?? string.Empty" />
                                                    <button class="btn btn-sm btn-outline-danger border-0"
                                                            @onclick="() => editUserAttributes.Remove(attrKey)">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            }
                                            <div class="d-flex gap-2 mb-3 align-items-center">
                                                <input class="form-control form-control-sm font-monospace"
                                                       style="max-width:180px" placeholder="attribute key"
                                                       @bind="newAttrKey" />
                                                <input class="form-control form-control-sm" placeholder="value"
                                                       @bind="newAttrValue" />
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        @onclick="AddUserAttribute"
                                                        disabled="@string.IsNullOrWhiteSpace(newAttrKey)">
                                                    <i class="bi bi-plus-lg"></i>
                                                </button>
                                            </div>
                                            <button class="btn btn-sm btn-primary" @onclick="() => SaveUserAttributes(user.Id)"
                                                    disabled="@savingUserEdit">
                                                @if (savingUserEdit) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                Save Attributes
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        }
    }

    @* ── Identity Providers ── *@
    @if (realmTab == "idp")
    {
        @if (loadingIdps)
        {
            <div class="spinner-border spinner-border-sm text-primary"></div>
        }
        else
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted small">@(idps?.Count ?? 0) providers</span>
                <button class="btn btn-sm btn-primary" @onclick="() => showAddIdp = !showAddIdp">
                    <i class="bi bi-plus-circle me-1"></i>Add Provider
                </button>
            </div>

            @if (showAddIdp)
            {
                <div class="card mb-3 border-primary-subtle">
                    <div class="card-body">
                        @if (idpError is not null)
                        {
                            <div class="alert alert-danger py-2 small">@idpError</div>
                        }
                        <EditForm Model="addIdpForm" OnValidSubmit="AddIdp">
                            <DataAnnotationsValidator />
                            <div class="row g-2">
                                <div class="col-md-3">
                                    <InputText class="form-control form-control-sm" placeholder="Alias (e.g. google)" @bind-Value="addIdpForm.Alias" />
                                    <ValidationMessage For="() => addIdpForm.Alias" class="text-danger small" />
                                </div>
                                <div class="col-md-3">
                                    <InputSelect class="form-select form-select-sm" @bind-Value="addIdpForm.ProviderId">
                                        <option value="oidc">OpenID Connect</option>
                                        <option value="saml">SAML</option>
                                        <option value="google">Google</option>
                                        <option value="github">GitHub</option>
                                        <option value="microsoft">Microsoft</option>
                                    </InputSelect>
                                </div>
                                <div class="col-md-3">
                                    <InputText class="form-control form-control-sm" placeholder="Client ID" @bind-Value="addIdpForm.ClientId" />
                                </div>
                                <div class="col-md-3">
                                    <InputText type="password" class="form-control form-control-sm" placeholder="Client Secret" @bind-Value="addIdpForm.ClientSecret" />
                                </div>
                            </div>
                            <div class="mt-2 d-flex gap-2">
                                <button type="submit" class="btn btn-sm btn-primary" disabled="@savingIdp">
                                    @if (savingIdp) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    Add
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => showAddIdp = false">Cancel</button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            }

            @if (idps is not null)
            {
                <div class="list-group">
                    @foreach (KeycloakIdpInfo idp in idps)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center py-2">
                            <div>
                                <i class="bi bi-box-arrow-in-right me-2 text-muted"></i>
                                <strong>@idp.Alias</strong>
                                <span class="badge bg-secondary-subtle text-secondary ms-2 small">@idp.ProviderId</span>
                                @if (!idp.Enabled)
                                {
                                    <span class="badge bg-secondary-subtle text-secondary ms-1 small">Disabled</span>
                                }
                            </div>
                            <button class="btn btn-sm btn-outline-danger border-0"
                                    @onclick='() => pendingConfirm = new PendingConfirm($"Delete identity provider \"{idp.Alias}\"? Users will no longer be able to log in through it. This cannot be undone.", "Delete", () => DeleteIdp(idp.Alias))'
                                    aria-label="@($"Delete identity provider {idp.Alias}")">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    }
                </div>
            }
        }
    }

    @* ── Groups ── *@
    @if (realmTab == "groups")
    {
        @if (loadingGroups)
        {
            <div class="spinner-border spinner-border-sm text-primary"></div>
        }
        else
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted small">@(groups?.Count ?? 0) groups</span>
                <button class="btn btn-sm btn-primary" @onclick="() => showAddGroup = !showAddGroup">
                    <i class="bi bi-people me-1"></i>Add Group
                </button>
            </div>

            @if (showAddGroup)
            {
                <EditForm Model="addGroupForm" OnValidSubmit="AddGroup" class="mb-3">
                    <DataAnnotationsValidator />
                    <div class="d-flex gap-2">
                        <InputText class="form-control form-control-sm" placeholder="Group name" @bind-Value="addGroupForm.Name" />
                        <button type="submit" class="btn btn-sm btn-primary" disabled="@savingGroup">
                            @if (savingGroup) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Create
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => showAddGroup = false">Cancel</button>
                    </div>
                    <ValidationMessage For="() => addGroupForm.Name" class="text-danger small" />
                </EditForm>
                @if (groupError is not null)
                {
                    <div class="alert alert-danger py-2 small mb-3">@groupError</div>
                }
            }

            @if (groups is not null)
            {
                <div class="list-group">
                    @foreach (KeycloakGroupInfo g in groups)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center py-2">
                            <span><i class="bi bi-people me-2 text-muted"></i>@g.Name <span class="text-muted small">@g.Path</span></span>
                            <button class="btn btn-sm btn-outline-danger border-0"
                                    @onclick='() => pendingConfirm = new PendingConfirm($"Delete group \"{g.Name}\"? This cannot be undone.", "Delete", () => DeleteGroup(g.Id))'
                                    aria-label="@($"Delete group {g.Name}")">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    }
                </div>
            }
        }
    }

    @* ── Organizations ── *@
    @if (realmTab == "orgs")
    {
        @if (loadingOrgs)
        {
            <div class="spinner-border spinner-border-sm text-primary"></div>
        }
        else
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted small">@(orgs?.Count ?? 0) organizations (Keycloak 26+)</span>
                <button class="btn btn-sm btn-primary" @onclick="() => showAddOrg = !showAddOrg">
                    <i class="bi bi-building me-1"></i>Add Organization
                </button>
            </div>

            @if (showAddOrg)
            {
                <div class="card mb-3 border-primary-subtle">
                    <div class="card-body">
                        @if (orgError is not null)
                        {
                            <div class="alert alert-danger py-2 small">@orgError</div>
                        }
                        <EditForm Model="addOrgForm" OnValidSubmit="AddOrg">
                            <DataAnnotationsValidator />
                            <div class="row g-2">
                                <div class="col-md-4">
                                    <InputText class="form-control form-control-sm" placeholder="Name" @bind-Value="addOrgForm.Name" />
                                    <ValidationMessage For="() => addOrgForm.Name" class="text-danger small" />
                                </div>
                                <div class="col-md-8">
                                    <InputText class="form-control form-control-sm" placeholder="Description (optional)" @bind-Value="addOrgForm.Description" />
                                </div>
                            </div>
                            <div class="mt-2 d-flex gap-2">
                                <button type="submit" class="btn btn-sm btn-primary" disabled="@savingOrg">
                                    @if (savingOrg) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    Create
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => showAddOrg = false">Cancel</button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            }

            @if (orgs is not null)
            {
                <div class="list-group">
                    @foreach (KeycloakOrganizationInfo org in orgs)
                    {
                        <div class="list-group-item py-2">
                            <strong>@org.Name</strong>
                            @if (!string.IsNullOrWhiteSpace(org.Description))
                            {
                                <span class="text-muted small ms-2">@org.Description</span>
                            }
                            @if (!org.Enabled)
                            {
                                <span class="badge bg-secondary-subtle text-secondary ms-1 small">Disabled</span>
                            }
                        </div>
                    }
                </div>
            }
        }
    }

    @* ── Themes ── *@
    @if (realmTab == "themes")
    {
        @if (realmDetails is null)
        {
            <div class="spinner-border spinner-border-sm text-primary"></div>
        }
        else
        {
            @if (realmThemeError is not null)
            {
                <div class="alert alert-danger py-2 small mb-3">@realmThemeError</div>
            }

            @* ── Named theme section ── *@
            @if (namedThemes.Count > 0)
            {
                <div class="mb-4" style="max-width:480px">
                    <label class="form-label small fw-semibold">EntKube Theme</label>
                    <div class="form-text mb-2">
                        Applies a named theme bundle — sets the Keycloak login/account provider automatically.
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                        <select class="form-select form-select-sm"
                                @bind="editRealmNamedThemeId">
                            <option value="">— none —</option>
                            @foreach (KeycloakTheme nt in namedThemes)
                            {
                                <option value="@nt.Id">@nt.Name
                                    @if (!string.IsNullOrEmpty(nt.LoginTheme) || !string.IsNullOrEmpty(nt.AccountTheme))
                                    {
                                        <text> (@(nt.LoginTheme ?? "default") / @(nt.AccountTheme ?? "default"))</text>
                                    }
                                </option>
                            }
                        </select>
                        <button class="btn btn-sm btn-primary" @onclick="ApplyNamedThemeToRealm"
                                disabled="@applyingNamedTheme">
                            @if (applyingNamedTheme) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Apply
                        </button>
                    </div>
                    @if (selectedRealm?.KeycloakThemeId is not null)
                    {
                        KeycloakTheme? applied = namedThemes.FirstOrDefault(t => t.Id == selectedRealm.KeycloakThemeId);
                        @if (applied is not null)
                        {
                            <div class="form-text mt-1">
                                <i class="bi bi-check-circle text-success me-1"></i>Applied: <strong>@applied.Name</strong>
                                @if (!string.IsNullOrEmpty(applied.LoginTheme))
                                {
                                    <span class="ms-1 badge bg-secondary-subtle text-secondary border small">login: @applied.LoginTheme</span>
                                }
                                @if (!string.IsNullOrEmpty(applied.AccountTheme))
                                {
                                    <span class="ms-1 badge bg-secondary-subtle text-secondary border small">account: @applied.AccountTheme</span>
                                }
                            </div>
                        }
                    }
                </div>
                <hr class="my-3" />
            }

            @* ── Manual Keycloak theme overrides ── *@
            <div class="row g-3" style="max-width:480px">
                <div class="col-12">
                    <label class="form-label small fw-semibold">Login Theme</label>
                    <select class="form-select form-select-sm" @bind="editLoginTheme">
                        <option value="">(default)</option>
                        @foreach (string t in realmDetails.Themes)
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label small fw-semibold">Account Console Theme</label>
                    <select class="form-select form-select-sm" @bind="editAccountTheme">
                        <option value="">(default)</option>
                        @foreach (string t in (realmDetails.AccountThemes.Count > 0 ? realmDetails.AccountThemes : realmDetails.Themes))
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div class="col-12">
                    <button class="btn btn-sm btn-primary" @onclick="SaveThemes" disabled="@savingThemes">
                        @if (savingThemes) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Save
                    </button>
                </div>
            </div>
        }
    }

    @* ── Backup & Restore ── *@
    @if (realmTab == "backup")
    {
        @if (loadingBackups)
        {
            <div class="spinner-border spinner-border-sm text-primary"></div>
        }
        else
        {
            @if (backupError is not null)
            {
                <div class="alert alert-danger py-2 small mb-3">@backupError</div>
            }

            <div class="card mb-4">
                <div class="card-body">
                    <h6 class="card-title">Create Backup</h6>
                    <div class="row g-2 align-items-end" style="max-width:400px">
                        <div class="col">
                            <label class="form-label small">Storage Bucket</label>
                            <select class="form-select form-select-sm" @bind="backupStorageLinkId">
                                <option value="@Guid.Empty">Select bucket...</option>
                                @if (storageLinks is not null)
                                {
                                    @foreach (StorageLink link in storageLinks)
                                    {
                                        <option value="@link.Id">@link.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-auto">
                            <button class="btn btn-sm btn-primary" @onclick="CreateBackup"
                                    disabled="@(creatingBackup || backupStorageLinkId == Guid.Empty)">
                                @if (creatingBackup) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Backup Now
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-body">
                    <h6 class="card-title">Scheduled Backups</h6>
                    <p class="text-muted small mb-2">
                        Automatically export this realm on a cron schedule. Leave the schedule blank for on-demand only.
                    </p>
                    @if (scheduleError is not null)
                    {
                        <div class="alert alert-danger py-2 small mb-2">@scheduleError</div>
                    }
                    <div class="row g-2 align-items-end" style="max-width:620px">
                        <div class="col">
                            <label class="form-label small">Cron schedule (UTC)</label>
                            <input class="form-control form-control-sm font-monospace" placeholder="0 3 * * *" @bind="scheduleCron" />
                        </div>
                        <div class="col">
                            <label class="form-label small">Storage Bucket</label>
                            <select class="form-select form-select-sm" @bind="scheduleStorageLinkId">
                                <option value="@Guid.Empty">Select bucket...</option>
                                @if (storageLinks is not null)
                                {
                                    @foreach (StorageLink link in storageLinks)
                                    {
                                        <option value="@link.Id">@link.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-auto">
                            <button class="btn btn-sm btn-outline-primary" @onclick="SaveSchedule" disabled="@savingSchedule">
                                @if (savingSchedule) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Save
                            </button>
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(selectedRealm?.BackupSchedule))
                    {
                        <div class="small text-success mt-2">
                            <i class="bi bi-clock-history me-1"></i>Automated backups active:
                            <span class="font-monospace">@selectedRealm.BackupSchedule</span>
                        </div>
                    }
                    <div class="form-text">
                        5-field cron: <span class="font-monospace">min hour day month weekday</span>.
                        Example: <span class="font-monospace">0 3 * * *</span> = daily at 03:00 UTC.
                    </div>
                </div>
            </div>

            @if (backups is not null && backups.Count > 0)
            {
                <h6>Backups</h6>
                <div class="list-group">
                    @foreach (KeycloakBackup b in backups)
                    {
                        <div class="list-group-item py-2">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <span class="font-monospace small">@b.RealmName</span>
                                    <span class="text-muted small ms-2">@b.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                                    @if (b.Status == KeycloakBackupStatus.Ready)
                                    {
                                        <span class="badge bg-success-subtle text-success ms-1 small">Ready</span>
                                        <span class="text-muted small ms-1">@FormatSize(b.SizeBytes)</span>
                                    }
                                    else if (b.Status == KeycloakBackupStatus.Failed)
                                    {
                                        <span class="badge bg-danger-subtle text-danger ms-1 small">Failed</span>
                                        <span class="text-muted small ms-1">@b.LastError</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary ms-1 small">Creating</span>
                                    }
                                </div>
                                @if (b.Status == KeycloakBackupStatus.Ready)
                                {
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-outline-primary border-0"
                                                @onclick='() => pendingConfirm = new PendingConfirm($"Restore backup of realm \"{b.RealmName}\" from {b.CreatedAt:yyyy-MM-dd HH:mm}? This overwrites the current realm state and cannot be undone.", "Restore", () => RestoreBackup(b.Id))'>
                                            <i class="bi bi-arrow-counterclockwise me-1"></i>Restore
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger border-0"
                                                @onclick='() => pendingConfirm = new PendingConfirm($"Delete backup of realm \"{b.RealmName}\" from {b.CreatedAt:yyyy-MM-dd HH:mm}? This cannot be undone.", "Delete", () => DeleteBackup(b.Id))'
                                                aria-label="@($"Delete backup of {b.RealmName} from {b.CreatedAt:yyyy-MM-dd HH:mm}")">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        }
    }

    @* ── Roles ── *@
    @if (realmTab == "roles")
    {
        @if (loadingRoles)
        {
            <div class="spinner-border spinner-border-sm text-primary"></div>
        }
        else
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted small">@(roles?.Count ?? 0) roles</span>
                <button class="btn btn-sm btn-primary" @onclick="() => showAddRole = !showAddRole">
                    <i class="bi bi-plus-circle me-1"></i>Add Role
                </button>
            </div>

            @if (showAddRole)
            {
                <div class="card mb-3 border-primary-subtle">
                    <div class="card-body">
                        @if (roleError is not null)
                        {
                            <div class="alert alert-danger py-2 small">@roleError</div>
                        }
                        <EditForm Model="addRoleForm" OnValidSubmit="AddRole">
                            <DataAnnotationsValidator />
                            <div class="row g-2" style="max-width:480px">
                                <div class="col-md-5">
                                    <label class="form-label small">Role Name</label>
                                    <InputText class="form-control form-control-sm" placeholder="e.g. app-admin" @bind-Value="addRoleForm.RoleName" />
                                    <ValidationMessage For="() => addRoleForm.RoleName" class="text-danger small" />
                                </div>
                                <div class="col-md-7">
                                    <label class="form-label small">Description <span class="text-muted">(optional)</span></label>
                                    <InputText class="form-control form-control-sm" @bind-Value="addRoleForm.Description" />
                                </div>
                            </div>
                            <div class="mt-2 d-flex gap-2">
                                <button type="submit" class="btn btn-sm btn-primary" disabled="@savingRole">
                                    @if (savingRole) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    Create
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => showAddRole = false">Cancel</button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            }

            @if (roles is not null)
            {
                <div class="list-group">
                    @foreach (KeycloakRole role in roles)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center py-2">
                            <div>
                                <strong>@role.Name</strong>
                                @if (!string.IsNullOrWhiteSpace(role.Description))
                                {
                                    <span class="text-muted small ms-2">@role.Description</span>
                                }
                                @if (role.Composite)
                                {
                                    <span class="badge bg-info-subtle text-info ms-1 small">composite</span>
                                }
                            </div>
                            <button class="btn btn-sm btn-outline-danger border-0"
                                    @onclick='() => pendingConfirm = new PendingConfirm($"Delete role \"{role.Name}\"? It will be removed from all users and groups. This cannot be undone.", "Delete", () => DeleteRole(role.Name))'
                                    aria-label="@($"Delete role {role.Name}")">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    }
                </div>
            }
        }
    }

    @* ── Clients ── *@
    @if (realmTab == "clients")
    {
        @if (loadingClients)
        {
            <div class="spinner-border spinner-border-sm text-primary"></div>
        }
        else
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted small">@(clients?.Count ?? 0) clients</span>
                <button class="btn btn-sm btn-primary" @onclick="() => showAddClient = !showAddClient">
                    <i class="bi bi-plus-circle me-1"></i>Add Client
                </button>
            </div>

            @if (showAddClient)
            {
                <div class="card mb-3 border-primary-subtle">
                    <div class="card-body">
                        @if (clientError is not null)
                        {
                            <div class="alert alert-danger py-2 small">@clientError</div>
                        }
                        <EditForm Model="addClientForm" OnValidSubmit="AddClient">
                            <DataAnnotationsValidator />
                            <div class="row g-2" style="max-width:520px">
                                <div class="col-md-5">
                                    <label class="form-label small">Client ID</label>
                                    <InputText class="form-control form-control-sm font-monospace" placeholder="my-app" @bind-Value="addClientForm.ClientId" />
                                    <ValidationMessage For="() => addClientForm.ClientId" class="text-danger small" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small">Name <span class="text-muted">(optional)</span></label>
                                    <InputText class="form-control form-control-sm" @bind-Value="addClientForm.Name" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small">Access Type</label>
                                    <InputSelect class="form-select form-select-sm" @bind-Value="addClientForm.Public">
                                        <option value="false">Confidential</option>
                                        <option value="true">Public</option>
                                    </InputSelect>
                                </div>
                            </div>
                            <div class="mt-2 d-flex gap-2">
                                <button type="submit" class="btn btn-sm btn-primary" disabled="@savingClient">
                                    @if (savingClient) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    Create
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => showAddClient = false">Cancel</button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            }

            @if (clients is not null)
            {
                <div class="list-group">
                    @foreach (KeycloakClientInfo client in clients)
                    {
                        bool isEditingClient = selectedClientUuid == client.Id;
                        <div class="list-group-item py-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <strong class="font-monospace">@client.ClientId</strong>
                                    @if (!string.IsNullOrWhiteSpace(client.Name) && client.Name != client.ClientId)
                                    {
                                        <span class="text-muted small ms-2">@client.Name</span>
                                    }
                                    @if (!client.Enabled)
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary ms-1 small">Disabled</span>
                                    }
                                    @if (client.PublicClient)
                                    {
                                        <span class="badge bg-info-subtle text-info ms-1 small">public</span>
                                    }
                                    else if (client.BearerOnly)
                                    {
                                        <span class="badge bg-warning-subtle text-warning ms-1 small">bearer-only</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success-subtle text-success ms-1 small">confidential</span>
                                    }
                                </div>
                                <div class="d-flex gap-1">
                                    <button class="btn btn-sm btn-outline-secondary border-0"
                                            @onclick="() => OpenClientEdit(client)"
                                            aria-label="@($"Edit client {client.ClientId}")">
                                        <i class="bi @(isEditingClient ? "bi-chevron-up" : "bi-pencil")"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger border-0"
                                            @onclick='() => pendingConfirm = new PendingConfirm($"Delete client \"{client.ClientId}\"? Applications using this client will stop working. This cannot be undone.", "Delete", () => DeleteClient(client.Id))'
                                            aria-label="@($"Delete client {client.ClientId}")">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>

                            @if (isEditingClient && clientDetail is not null)
                            {
                                <div class="mt-2 p-3 bg-light border rounded">
                                    @if (clientEditError is not null)
                                    {
                                        <div class="alert alert-danger py-2 small mb-2">@clientEditError</div>
                                    }
                                    <ul class="nav nav-tabs mb-3 nav-sm" role="tablist" aria-label="Client settings">
                                        @foreach (string ct2 in new[] { "settings", "secret", "mappers" }
                                            .Where(t => !(t == "secret" && clientDetail.PublicClient)))
                                        {
                                            <li class="nav-item" role="presentation">
                                                <button class="nav-link py-1 px-2 small @(clientEditTab == ct2 ? "active" : "")"
                                                        role="tab"
                                                        aria-selected="@(clientEditTab == ct2)"
                                                        tabindex="@(clientEditTab == ct2 ? 0 : -1)"
                                                        @onclick="() => SwitchClientTab(ct2)">
                                                    @(ct2 switch { "settings" => "Settings", "secret" => "Credentials", "mappers" => "Mappers", _ => ct2 })
                                                </button>
                                            </li>
                                        }
                                    </ul>

                                    @* ── Client Settings ── *@
                                    @if (clientEditTab == "settings")
                                    {
                                        <div class="row g-2" style="max-width:560px">
                                            <div class="col-md-6">
                                                <label class="form-label small">Name</label>
                                                <input class="form-control form-control-sm" @bind="clientDetail.Name" />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">Description</label>
                                                <input class="form-control form-control-sm" @bind="clientDetail.Description" />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">Base URL</label>
                                                <input class="form-control form-control-sm" @bind="clientDetail.BaseUrl" />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">Root URL</label>
                                                <input class="form-control form-control-sm" @bind="clientDetail.RootUrl" />
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label small">Valid Redirect URIs <span class="text-muted">(one per line)</span></label>
                                                <textarea class="form-control form-control-sm font-monospace" rows="3"
                                                          value="@string.Join("\n", clientDetail.RedirectUris)"
                                                          @oninput="e => clientDetail.RedirectUris = (e.Value?.ToString() ?? string.Empty).Split('\n', StringSplitOptions.RemoveEmptyEntries).ToList()"></textarea>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label small">Web Origins <span class="text-muted">(one per line)</span></label>
                                                <textarea class="form-control form-control-sm font-monospace" rows="2"
                                                          value="@string.Join("\n", clientDetail.WebOrigins)"
                                                          @oninput="e => clientDetail.WebOrigins = (e.Value?.ToString() ?? string.Empty).Split('\n', StringSplitOptions.RemoveEmptyEntries).ToList()"></textarea>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label small d-block mb-1">Flows</label>
                                                <div class="d-flex flex-wrap gap-3">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" id="sfe_@client.Id" @bind="clientDetail.StandardFlowEnabled" />
                                                        <label class="form-check-label small" for="sfe_@client.Id">Standard Flow</label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" id="dage_@client.Id" @bind="clientDetail.DirectAccessGrantsEnabled" />
                                                        <label class="form-check-label small" for="dage_@client.Id">Direct Access Grants</label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" id="ife_@client.Id" @bind="clientDetail.ImplicitFlowEnabled" />
                                                        <label class="form-check-label small" for="ife_@client.Id">Implicit Flow</label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" id="sae_@client.Id" @bind="clientDetail.ServiceAccountsEnabled" />
                                                        <label class="form-check-label small" for="sae_@client.Id">Service Accounts</label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" id="clientEnabled_@client.Id" @bind="clientDetail.Enabled" />
                                                        <label class="form-check-label small" for="clientEnabled_@client.Id">Enabled</label>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <button class="btn btn-sm btn-primary" @onclick="SaveClientSettings"
                                                        disabled="@savingClient">
                                                    @if (savingClient) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                    Save
                                                </button>
                                            </div>
                                        </div>
                                    }

                                    @* ── Client Secret ── *@
                                    @if (clientEditTab == "secret")
                                    {
                                        <div style="max-width:480px">
                                            @if (clientSecret is not null)
                                            {
                                                <div class="input-group input-group-sm mb-2">
                                                    <span class="input-group-text"><i class="bi bi-key"></i></span>
                                                    <input type="@(showClientSecret ? "text" : "password")"
                                                           class="form-control font-monospace"
                                                           value="@clientSecret" readonly />
                                                    <button class="btn btn-outline-secondary" type="button"
                                                            @onclick="() => showClientSecret = !showClientSecret">
                                                        <i class="bi bi-@(showClientSecret ? "eye-slash" : "eye")"></i>
                                                    </button>
                                                </div>
                                            }
                                            <button class="btn btn-sm btn-warning"
                                                    @onclick='() => pendingConfirm = new PendingConfirm("Regenerate the client secret? The current secret stops working immediately and every integration using it must be updated. This cannot be undone.", "Regenerate", RegenerateSecret)'
                                                    disabled="@savingClient">
                                                @if (savingClient) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                <i class="bi bi-arrow-clockwise me-1"></i>Regenerate Secret
                                            </button>
                                        </div>
                                    }

                                    @* ── Protocol Mappers ── *@
                                    @if (clientEditTab == "mappers")
                                    {
                                        @if (loadingMappers)
                                        {
                                            <div class="spinner-border spinner-border-sm text-primary"></div>
                                        }
                                        else
                                        {
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <span class="text-muted small">@(clientMappers?.Count ?? 0) mappers</span>
                                                <button class="btn btn-sm btn-primary" @onclick="() => showAddMapper = !showAddMapper">
                                                    <i class="bi bi-plus-circle me-1"></i>Add Mapper
                                                </button>
                                            </div>

                                            @if (showAddMapper)
                                            {
                                                <div class="card mb-3 border-primary-subtle">
                                                    <div class="card-body">
                                                        @if (mapperError is not null)
                                                        {
                                                            <div class="alert alert-danger py-2 small">@mapperError</div>
                                                        }
                                                        <div class="row g-2" style="max-width:560px">
                                                            <div class="col-md-5">
                                                                <label class="form-label small">Mapper Name</label>
                                                                <input class="form-control form-control-sm" @bind="newMapperName" />
                                                            </div>
                                                            <div class="col-md-7">
                                                                <label class="form-label small">Mapper Type</label>
                                                                <select class="form-select form-select-sm" @bind="newMapperType"
                                                                        @bind:after="OnMapperTypeChanged">
                                                                    <option value="oidc-usermodel-attribute-mapper">User Attribute → Claim</option>
                                                                    <option value="oidc-usermodel-property-mapper">User Property → Claim</option>
                                                                    <option value="oidc-group-membership-mapper">Group Membership → Claim</option>
                                                                    <option value="oidc-hardcoded-claim-mapper">Hardcoded Claim</option>
                                                                    <option value="oidc-audience-mapper">Audience</option>
                                                                    <option value="oidc-full-name-mapper">Full Name</option>
                                                                    <option value="oidc-role-name-mapper">Role Name</option>
                                                                </select>
                                                            </div>

                                                            @* User Attribute mapper fields *@
                                                            @if (newMapperType == "oidc-usermodel-attribute-mapper")
                                                            {
                                                                <div class="col-md-6">
                                                                    <label class="form-label small">User Attribute</label>
                                                                    <input class="form-control form-control-sm font-monospace" placeholder="e.g. department"
                                                                           @bind="MapperUserAttr" />
                                                                </div>
                                                                <div class="col-md-6">
                                                                    <label class="form-label small">Token Claim Name</label>
                                                                    <input class="form-control form-control-sm font-monospace" placeholder="e.g. department"
                                                                           @bind="MapperClaimName" />
                                                                </div>
                                                                <div class="col-md-4">
                                                                    <label class="form-label small">Claim JSON Type</label>
                                                                    <select class="form-select form-select-sm" @bind="MapperJsonType">
                                                                        <option value="String">String</option>
                                                                        <option value="long">long</option>
                                                                        <option value="int">int</option>
                                                                        <option value="boolean">boolean</option>
                                                                        <option value="JSON">JSON</option>
                                                                    </select>
                                                                </div>
                                                                <div class="col-12 d-flex flex-wrap gap-3">
                                                                    <div class="form-check">
                                                                        <input class="form-check-input" type="checkbox" id="atc1" @bind="MapperAccessToken" />
                                                                        <label class="form-check-label small" for="atc1">Access token</label>
                                                                    </div>
                                                                    <div class="form-check">
                                                                        <input class="form-check-input" type="checkbox" id="itc1" @bind="MapperIdToken" />
                                                                        <label class="form-check-label small" for="itc1">ID token</label>
                                                                    </div>
                                                                    <div class="form-check">
                                                                        <input class="form-check-input" type="checkbox" id="uic1" @bind="MapperUserinfoToken" />
                                                                        <label class="form-check-label small" for="uic1">Userinfo</label>
                                                                    </div>
                                                                </div>
                                                            }

                                                            @* User Property mapper fields *@
                                                            @if (newMapperType == "oidc-usermodel-property-mapper")
                                                            {
                                                                <div class="col-md-6">
                                                                    <label class="form-label small">User Property</label>
                                                                    <select class="form-select form-select-sm" @bind="MapperUserAttr">
                                                                        <option value="username">username</option>
                                                                        <option value="email">email</option>
                                                                        <option value="firstName">firstName</option>
                                                                        <option value="lastName">lastName</option>
                                                                    </select>
                                                                </div>
                                                                <div class="col-md-6">
                                                                    <label class="form-label small">Token Claim Name</label>
                                                                    <input class="form-control form-control-sm font-monospace"
                                                                           @bind="MapperClaimName" />
                                                                </div>
                                                                <div class="col-12 d-flex flex-wrap gap-3">
                                                                    <div class="form-check">
                                                                        <input class="form-check-input" type="checkbox" id="atc2" @bind="MapperAccessToken" />
                                                                        <label class="form-check-label small" for="atc2">Access token</label>
                                                                    </div>
                                                                    <div class="form-check">
                                                                        <input class="form-check-input" type="checkbox" id="itc2" @bind="MapperIdToken" />
                                                                        <label class="form-check-label small" for="itc2">ID token</label>
                                                                    </div>
                                                                    <div class="form-check">
                                                                        <input class="form-check-input" type="checkbox" id="uic2" @bind="MapperUserinfoToken" />
                                                                        <label class="form-check-label small" for="uic2">Userinfo</label>
                                                                    </div>
                                                                </div>
                                                            }

                                                            @* Group membership mapper fields *@
                                                            @if (newMapperType == "oidc-group-membership-mapper")
                                                            {
                                                                <div class="col-md-6">
                                                                    <label class="form-label small">Token Claim Name</label>
                                                                    <input class="form-control form-control-sm font-monospace" placeholder="groups"
                                                                           @bind="MapperClaimName" />
                                                                </div>
                                                                <div class="col-md-6 d-flex align-items-end pb-1">
                                                                    <div class="form-check">
                                                                        <input class="form-check-input" type="checkbox" id="fullPath" @bind="MapperFullPath" />
                                                                        <label class="form-check-label small" for="fullPath">Full group path</label>
                                                                    </div>
                                                                </div>
                                                                <div class="col-12 d-flex flex-wrap gap-3">
                                                                    <div class="form-check">
                                                                        <input class="form-check-input" type="checkbox" id="atc3" @bind="MapperAccessToken" />
                                                                        <label class="form-check-label small" for="atc3">Access token</label>
                                                                    </div>
                                                                    <div class="form-check">
                                                                        <input class="form-check-input" type="checkbox" id="itc3" @bind="MapperIdToken" />
                                                                        <label class="form-check-label small" for="itc3">ID token</label>
                                                                    </div>
                                                                    <div class="form-check">
                                                                        <input class="form-check-input" type="checkbox" id="uic3" @bind="MapperUserinfoToken" />
                                                                        <label class="form-check-label small" for="uic3">Userinfo</label>
                                                                    </div>
                                                                </div>
                                                            }

                                                            @* Hardcoded claim mapper *@
                                                            @if (newMapperType == "oidc-hardcoded-claim-mapper")
                                                            {
                                                                <div class="col-md-6">
                                                                    <label class="form-label small">Token Claim Name</label>
                                                                    <input class="form-control form-control-sm font-monospace"
                                                                           @bind="MapperClaimName" />
                                                                </div>
                                                                <div class="col-md-6">
                                                                    <label class="form-label small">Claim Value</label>
                                                                    <input class="form-control form-control-sm"
                                                                           @bind="MapperClaimValue" />
                                                                </div>
                                                                <div class="col-md-4">
                                                                    <label class="form-label small">JSON Type</label>
                                                                    <select class="form-select form-select-sm" @bind="MapperJsonType">
                                                                        <option value="String">String</option>
                                                                        <option value="boolean">boolean</option>
                                                                        <option value="int">int</option>
                                                                        <option value="JSON">JSON</option>
                                                                    </select>
                                                                </div>
                                                                <div class="col-12 d-flex flex-wrap gap-3">
                                                                    <div class="form-check">
                                                                        <input class="form-check-input" type="checkbox" id="atc4" @bind="MapperAccessToken" />
                                                                        <label class="form-check-label small" for="atc4">Access token</label>
                                                                    </div>
                                                                    <div class="form-check">
                                                                        <input class="form-check-input" type="checkbox" id="itc4" @bind="MapperIdToken" />
                                                                        <label class="form-check-label small" for="itc4">ID token</label>
                                                                    </div>
                                                                    <div class="form-check">
                                                                        <input class="form-check-input" type="checkbox" id="uic4" @bind="MapperUserinfoToken" />
                                                                        <label class="form-check-label small" for="uic4">Userinfo</label>
                                                                    </div>
                                                                </div>
                                                            }

                                                            @* Audience mapper *@
                                                            @if (newMapperType == "oidc-audience-mapper")
                                                            {
                                                                <div class="col-md-6">
                                                                    <label class="form-label small">Included Audience</label>
                                                                    <input class="form-control form-control-sm font-monospace"
                                                                           @bind="MapperClientAudience" />
                                                                </div>
                                                            }
                                                        </div>
                                                        <div class="mt-2 d-flex gap-2">
                                                            <button class="btn btn-sm btn-primary" @onclick="AddMapper"
                                                                    disabled="@(savingMapper || string.IsNullOrWhiteSpace(newMapperName))">
                                                                @if (savingMapper) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                                Add
                                                            </button>
                                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => showAddMapper = false">Cancel</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            }

                                            @if (clientMappers is not null)
                                            {
                                                <div class="list-group">
                                                    @foreach (KeycloakProtocolMapper mapper in clientMappers)
                                                    {
                                                        bool isEditingMapper = editingMapperId == mapper.Id;
                                                        <div class="list-group-item py-2">
                                                            <div class="d-flex justify-content-between align-items-center">
                                                                <div>
                                                                    <strong>@mapper.Name</strong>
                                                                    <span class="badge bg-secondary-subtle text-secondary ms-2 small font-monospace">@mapper.ProtocolMapper</span>
                                                                    @if (mapper.Config.TryGetValue("claim.name", out string? claimName))
                                                                    {
                                                                        <span class="text-muted small ms-2">→ <code>@claimName</code></span>
                                                                    }
                                                                </div>
                                                                <div class="d-flex gap-1">
                                                                    <button class="btn btn-sm btn-outline-secondary border-0"
                                                                            @onclick="() => OpenMapperEdit(mapper)"
                                                                            aria-label="@($"Edit mapper {mapper.Name}")">
                                                                        <i class="bi bi-pencil"></i>
                                                                    </button>
                                                                    <button class="btn btn-sm btn-outline-danger border-0"
                                                                            @onclick='() => pendingConfirm = new PendingConfirm($"Delete protocol mapper \"{mapper.Name}\"? This cannot be undone.", "Delete", () => DeleteMapper(mapper.Id))'
                                                                            aria-label="@($"Delete mapper {mapper.Name}")">
                                                                        <i class="bi bi-trash"></i>
                                                                    </button>
                                                                </div>
                                                            </div>
                                                            @if (isEditingMapper)
                                                            {
                                                                <div class="mt-2 pt-2 border-top">
                                                                    @if (mapperError is not null)
                                                                    {
                                                                        <div class="alert alert-danger py-1 small mb-2">@mapperError</div>
                                                                    }
                                                                    <div class="row g-2" style="max-width:560px">
                                                                        <div class="col-12">
                                                                            <label class="form-label small">Mapper Name</label>
                                                                            <input class="form-control form-control-sm" @bind="newMapperName" />
                                                                        </div>
                                                                        @if (newMapperType == "oidc-usermodel-attribute-mapper")
                                                                        {
                                                                            <div class="col-md-6">
                                                                                <label class="form-label small">User Attribute</label>
                                                                                <input class="form-control form-control-sm font-monospace" @bind="MapperUserAttr" />
                                                                            </div>
                                                                            <div class="col-md-6">
                                                                                <label class="form-label small">Token Claim Name</label>
                                                                                <input class="form-control form-control-sm font-monospace" @bind="MapperClaimName" />
                                                                            </div>
                                                                            <div class="col-md-4">
                                                                                <label class="form-label small">JSON Type</label>
                                                                                <select class="form-select form-select-sm" @bind="MapperJsonType">
                                                                                    <option value="String">String</option>
                                                                                    <option value="long">long</option>
                                                                                    <option value="int">int</option>
                                                                                    <option value="boolean">boolean</option>
                                                                                    <option value="JSON">JSON</option>
                                                                                </select>
                                                                            </div>
                                                                        }
                                                                        @if (newMapperType == "oidc-usermodel-property-mapper")
                                                                        {
                                                                            <div class="col-md-6">
                                                                                <label class="form-label small">User Property</label>
                                                                                <select class="form-select form-select-sm" @bind="MapperUserAttr">
                                                                                    <option value="username">username</option>
                                                                                    <option value="email">email</option>
                                                                                    <option value="firstName">firstName</option>
                                                                                    <option value="lastName">lastName</option>
                                                                                </select>
                                                                            </div>
                                                                            <div class="col-md-6">
                                                                                <label class="form-label small">Token Claim Name</label>
                                                                                <input class="form-control form-control-sm font-monospace" @bind="MapperClaimName" />
                                                                            </div>
                                                                        }
                                                                        @if (newMapperType == "oidc-group-membership-mapper")
                                                                        {
                                                                            <div class="col-md-6">
                                                                                <label class="form-label small">Token Claim Name</label>
                                                                                <input class="form-control form-control-sm font-monospace" @bind="MapperClaimName" />
                                                                            </div>
                                                                            <div class="col-md-6 d-flex align-items-end pb-1">
                                                                                <div class="form-check">
                                                                                    <input class="form-check-input" type="checkbox" id="fullPathE" @bind="MapperFullPath" />
                                                                                    <label class="form-check-label small" for="fullPathE">Full group path</label>
                                                                                </div>
                                                                            </div>
                                                                        }
                                                                        @if (newMapperType == "oidc-hardcoded-claim-mapper")
                                                                        {
                                                                            <div class="col-md-6">
                                                                                <label class="form-label small">Token Claim Name</label>
                                                                                <input class="form-control form-control-sm font-monospace" @bind="MapperClaimName" />
                                                                            </div>
                                                                            <div class="col-md-6">
                                                                                <label class="form-label small">Claim Value</label>
                                                                                <input class="form-control form-control-sm" @bind="MapperClaimValue" />
                                                                            </div>
                                                                            <div class="col-md-4">
                                                                                <label class="form-label small">JSON Type</label>
                                                                                <select class="form-select form-select-sm" @bind="MapperJsonType">
                                                                                    <option value="String">String</option>
                                                                                    <option value="boolean">boolean</option>
                                                                                    <option value="int">int</option>
                                                                                    <option value="JSON">JSON</option>
                                                                                </select>
                                                                            </div>
                                                                        }
                                                                        @if (newMapperType == "oidc-audience-mapper")
                                                                        {
                                                                            <div class="col-md-6">
                                                                                <label class="form-label small">Included Audience</label>
                                                                                <input class="form-control form-control-sm font-monospace" @bind="MapperClientAudience" />
                                                                            </div>
                                                                        }
                                                                        @if (newMapperType != "oidc-audience-mapper")
                                                                        {
                                                                            <div class="col-12 d-flex flex-wrap gap-3">
                                                                                <div class="form-check">
                                                                                    <input class="form-check-input" type="checkbox" id="atcE" @bind="MapperAccessToken" />
                                                                                    <label class="form-check-label small" for="atcE">Access token</label>
                                                                                </div>
                                                                                <div class="form-check">
                                                                                    <input class="form-check-input" type="checkbox" id="itcE" @bind="MapperIdToken" />
                                                                                    <label class="form-check-label small" for="itcE">ID token</label>
                                                                                </div>
                                                                                <div class="form-check">
                                                                                    <input class="form-check-input" type="checkbox" id="uicE" @bind="MapperUserinfoToken" />
                                                                                    <label class="form-check-label small" for="uicE">Userinfo</label>
                                                                                </div>
                                                                            </div>
                                                                        }
                                                                    </div>
                                                                    <div class="mt-2 d-flex gap-2">
                                                                        <button class="btn btn-sm btn-primary" @onclick="SaveMapperEdit"
                                                                                disabled="@(savingMapper || string.IsNullOrWhiteSpace(newMapperName))">
                                                                            @if (savingMapper) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                                            Save
                                                                        </button>
                                                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => editingMapperId = null">Cancel</button>
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        }
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        }
    }

    @* ── Realm Settings ── *@
    @if (realmTab == "settings")
    {
        @if (loadingSettings)
        {
            <div class="spinner-border spinner-border-sm text-primary"></div>
        }
        else if (realmSettings is not null)
        {
            @if (settingsError is not null)
            {
                <div class="alert alert-danger py-2 small mb-3">@settingsError</div>
            }

            <div class="row g-4" style="max-width:620px">

                @* Login Settings *@
                <div class="col-12">
                    <h6 class="fw-semibold mb-2"><i class="bi bi-box-arrow-in-right me-1 text-muted"></i>Login</h6>
                    <div class="row g-2">
                        <div class="col-md-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="regAllowed" @bind="realmSettings.RegistrationAllowed" />
                                <label class="form-check-label small" for="regAllowed">Registration allowed</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="resetPwd" @bind="realmSettings.ResetPasswordAllowed" />
                                <label class="form-check-label small" for="resetPwd">Forgot password</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="rememberMe" @bind="realmSettings.RememberMe" />
                                <label class="form-check-label small" for="rememberMe">Remember me</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="loginEmail" @bind="realmSettings.LoginWithEmailAllowed" />
                                <label class="form-check-label small" for="loginEmail">Login with email</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="dupEmails" @bind="realmSettings.DuplicateEmailsAllowed" />
                                <label class="form-check-label small" for="dupEmails">Duplicate emails allowed</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="verifyEmail" @bind="realmSettings.VerifyEmail" />
                                <label class="form-check-label small" for="verifyEmail">Verify email</label>
                            </div>
                        </div>
                    </div>
                </div>

                @* Token lifetimes *@
                <div class="col-12">
                    <h6 class="fw-semibold mb-2"><i class="bi bi-clock me-1 text-muted"></i>Token Lifetimes</h6>
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label class="form-label small">Access Token Lifespan (seconds)</label>
                            <input type="number" class="form-control form-control-sm" @bind="realmSettings.AccessTokenLifespan" />
                            <div class="form-text">@FormatSeconds(realmSettings.AccessTokenLifespan)</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">SSO Session Idle (seconds)</label>
                            <input type="number" class="form-control form-control-sm" @bind="realmSettings.SsoSessionIdleTimeout" />
                            <div class="form-text">@FormatSeconds(realmSettings.SsoSessionIdleTimeout)</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">SSO Session Max (seconds)</label>
                            <input type="number" class="form-control form-control-sm" @bind="realmSettings.SsoSessionMaxLifespan" />
                            <div class="form-text">@FormatSeconds(realmSettings.SsoSessionMaxLifespan)</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Offline Session Idle (seconds)</label>
                            <input type="number" class="form-control form-control-sm" @bind="realmSettings.OfflineSessionIdleTimeout" />
                            <div class="form-text">@FormatSeconds(realmSettings.OfflineSessionIdleTimeout)</div>
                        </div>
                    </div>
                </div>

                @* Password Policy *@
                <div class="col-12">
                    <h6 class="fw-semibold mb-2"><i class="bi bi-shield-lock me-1 text-muted"></i>Password Policy</h6>
                    <input class="form-control form-control-sm font-monospace"
                           placeholder="e.g. length(8) and digits(1) and specialChars(1)"
                           @bind="realmSettings.PasswordPolicy" />
                    <div class="form-text">Keycloak password policy expression. Leave blank for no policy.</div>
                </div>

                @* Brute Force *@
                <div class="col-12">
                    <h6 class="fw-semibold mb-2"><i class="bi bi-shield-exclamation me-1 text-muted"></i>Brute Force Detection</h6>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="bfProtected" @bind="realmSettings.BruteForceProtected" />
                        <label class="form-check-label small" for="bfProtected">Enabled</label>
                    </div>
                    @if (realmSettings.BruteForceProtected)
                    {
                        <div class="row g-2">
                            <div class="col-md-4">
                                <label class="form-label small">Max Login Failures</label>
                                <input type="number" class="form-control form-control-sm" @bind="realmSettings.FailureFactor" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Wait Increment (seconds)</label>
                                <input type="number" class="form-control form-control-sm" @bind="realmSettings.WaitIncrementSeconds" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Max Wait (seconds)</label>
                                <input type="number" class="form-control form-control-sm" @bind="realmSettings.MaxFailureWaitSeconds" />
                            </div>
                        </div>
                    }
                </div>

                @* SMTP *@
                <div class="col-12">
                    <h6 class="fw-semibold mb-2"><i class="bi bi-envelope me-1 text-muted"></i>Email (SMTP)</h6>
                    <div class="row g-2">
                        <div class="col-md-8">
                            <label class="form-label small">SMTP Host</label>
                            <input class="form-control form-control-sm" placeholder="smtp.example.com" @bind="realmSettings.SmtpHost" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Port</label>
                            <input class="form-control form-control-sm" @bind="realmSettings.SmtpPort" />
                        </div>
                        <div class="col-12">
                            <label class="form-label small">From Address</label>
                            <input class="form-control form-control-sm" type="email" @bind="realmSettings.SmtpFrom" />
                        </div>
                        <div class="col-md-4">
                            <div class="form-check mt-1">
                                <input class="form-check-input" type="checkbox" id="smtpSsl" @bind="realmSettings.SmtpSsl" />
                                <label class="form-check-label small" for="smtpSsl">SSL</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check mt-1">
                                <input class="form-check-input" type="checkbox" id="smtpStarttls" @bind="realmSettings.SmtpStarttls" />
                                <label class="form-check-label small" for="smtpStarttls">STARTTLS</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check mt-1">
                                <input class="form-check-input" type="checkbox" id="smtpAuth" @bind="realmSettings.SmtpAuth" />
                                <label class="form-check-label small" for="smtpAuth">Authentication</label>
                            </div>
                        </div>
                        @if (realmSettings.SmtpAuth)
                        {
                            <div class="col-md-6">
                                <label class="form-label small">Username</label>
                                <input class="form-control form-control-sm" @bind="realmSettings.SmtpUser" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small">Password</label>
                                <input type="password" class="form-control form-control-sm" @bind="realmSettings.SmtpPassword" />
                            </div>
                        }
                    </div>
                </div>

                <div class="col-12">
                    <button class="btn btn-sm btn-primary" @onclick="SaveRealmSettings" disabled="@savingSettings">
                        @if (savingSettings) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-floppy me-1"></i>Save Settings
                    </button>
                    @if (settingsSaved)
                    {
                        <span class="text-success small ms-2"><i class="bi bi-check-circle me-1"></i>Saved</span>
                    }
                </div>
            </div>
        }
    }

    @* ── Customer Portal ── *@
    @if (realmTab == "portal")
    {
        @if (portalError is not null)
        {
            <div class="alert alert-danger py-2 small mb-3">@portalError</div>
        }
        @if (selectedRealm?.LinkedApp is not null)
        {
            <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-3">
                <i class="bi bi-link-45deg"></i>
                <span>Linked to <strong>@selectedRealm.LinkedApp.Customer.Name / @selectedRealm.LinkedApp.Name</strong></span>
                <button class="btn btn-sm btn-outline-secondary ms-auto" @onclick="UnlinkApp">Unlink</button>
            </div>
        }
        else
        {
            <p class="text-muted small mb-3">Link this realm to a customer app so the customer can manage users, groups, and IdPs through their portal.</p>
            <div class="row g-2 align-items-end" style="max-width:400px">
                <div class="col">
                    <label class="form-label small">App</label>
                    <select class="form-select form-select-sm" @bind="linkAppId">
                        <option value="@Guid.Empty">Select app...</option>
                        @if (apps is not null)
                        {
                            @foreach (Data.App app in apps)
                            {
                                <option value="@app.Id">@app.Customer.Name / @app.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <button class="btn btn-sm btn-primary" @onclick="LinkApp"
                            disabled="@(linkAppId == Guid.Empty)">
                        Link
                    </button>
                </div>
            </div>
        }
    }
}
else if (selectedKeycloak is not null)
{
    @* ── Level 2: Realm list for a specific Keycloak ── *@
    <nav class="mb-3">
        <button class="btn btn-sm btn-link text-decoration-none p-0" @onclick="BackToList">
            <i class="bi bi-arrow-left me-1"></i>All Keycloak Instances
        </button>
    </nav>

    <div class="d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-person-badge fs-4 text-primary"></i>
        <div>
            <h5 class="mb-0">@selectedKeycloak.DisplayName
                @if (selectedKeycloak.ClusterDisplayName is not null)
                {
                    <span class="badge bg-secondary-subtle text-secondary ms-2 small">@selectedKeycloak.ClusterDisplayName</span>
                }
                @if (selectedKeycloak.IsExternal)
                {
                    <span class="badge bg-info-subtle text-info ms-2 small"><i class="bi bi-box-arrow-up-right me-1"></i>External</span>
                }
            </h5>
            @if (selectedKeycloak.Config?.AdminUrl is not null)
            {
                <small class="text-muted font-monospace">@selectedKeycloak.Config.AdminUrl</small>
            }
        </div>
        <button class="btn btn-sm btn-outline-secondary ms-auto" @onclick="() => showEditConfig = !showEditConfig">
            <i class="bi bi-gear me-1"></i>Settings
        </button>
    </div>

    @if (showEditConfig && selectedKeycloak.Config is not null)
    {
        <div class="card mb-4 border-secondary-subtle">
            <div class="card-header small fw-semibold bg-secondary-subtle">Keycloak Settings</div>
            <div class="card-body">
                @if (configError is not null)
                {
                    <div class="alert alert-danger py-2 small">@configError</div>
                }
                <div class="row g-2" style="max-width:560px">
                    <div class="col-md-8">
                        <label class="form-label small">Admin URL</label>
                        <input class="form-control form-control-sm" placeholder="https://auth.example.com"
                               @bind="editAdminUrl" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small">Admin Username</label>
                        <input class="form-control form-control-sm" @bind="editAdminUsername" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">New Admin Password <span class="text-muted">(leave blank to keep)</span></label>
                        <input type="password" class="form-control form-control-sm" @bind="editAdminPassword" />
                    </div>
                </div>
                <div class="mt-2 d-flex gap-2">
                    <button class="btn btn-sm btn-primary" @onclick="SaveConfig" disabled="@savingConfig">
                        @if (savingConfig) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Save
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => showEditConfig = false">Cancel</button>
                </div>
            </div>
        </div>
    }

    @if (!selectedKeycloak.IsConfigured)
    {
        @* Setup form for unconfigured keycloak *@
        <div class="card border-warning-subtle">
            <div class="card-header small fw-semibold bg-warning-subtle text-warning-emphasis">
                <i class="bi bi-exclamation-triangle me-1"></i>Not Configured
            </div>
            <div class="card-body">
                @if (selectedKeycloak.Component?.Status == ComponentStatus.Failed)
                {
                    <div class="alert alert-danger py-2 small mb-3">
                        <i class="bi bi-x-circle me-1"></i>
                        The install failed — likely because the database credentials weren't available before
                        the pod started. Configure the database here, then retry the install from the
                        <strong>Cluster</strong> tab.
                    </div>
                }
                <p class="text-muted small mb-3">
                    Enter the admin credentials for this Keycloak instance. Optionally link a database
                    (CNPG-managed or registered Postgres) — if the instance already runs against its
                    own Postgres, leave unselected. Credentials are synced to a Kubernetes Secret in
                    the <code>@(selectedKeycloak.Component?.Namespace ?? "keycloak")</code> namespace.
                </p>
                @if (setupError is not null)
                {
                    <div class="alert alert-danger py-2 small">@setupError</div>
                }
                <div class="row g-2" style="max-width:560px">
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Database</label>
                        <select class="form-select form-select-sm" @bind="setupDatabaseSelection">
                            <option value="">No database (leave unselected)</option>
                            @if (availableDatabases is not null && availableDatabases.Count > 0)
                            {
                                <optgroup label="Managed CNPG">
                                    @foreach (CnpgDatabase db in availableDatabases)
                                    {
                                        <option value="cnpg:@db.Id">@db.CnpgCluster.Name / @db.Name (@db.Owner)</option>
                                    }
                                </optgroup>
                            }
                            @if (availableRegPgDatabases is not null && availableRegPgDatabases.Count > 0)
                            {
                                <optgroup label="Registered PostgreSQL">
                                    @foreach (RegisteredPostgresDatabase db in availableRegPgDatabases)
                                    {
                                        <option value="regpg:@db.Id">@db.RegisteredPostgresInstance.Name / @db.Name (@db.Owner)</option>
                                    }
                                </optgroup>
                            }
                        </select>
                        @if ((availableDatabases is not null && availableDatabases.Count == 0) &&
                             (availableRegPgDatabases is null || availableRegPgDatabases.Count == 0))
                        {
                            <div class="form-text text-muted">
                                No ready databases found on this cluster. Create one in the Databases tab.
                            </div>
                        }
                    </div>
                    <div class="col-md-8">
                        <label class="form-label small fw-semibold">Admin URL</label>
                        <input class="form-control form-control-sm"
                               placeholder="https://auth.example.com"
                               @bind="setupAdminUrl" />
                        @if (!string.IsNullOrWhiteSpace(selectedKeycloak.SuggestedAdminUrl))
                        {
                            <div class="form-text">
                                Suggested: <a href="#" @onclick:preventDefault
                                              @onclick="UseSuggestedUrl">
                                    @selectedKeycloak.SuggestedAdminUrl
                                </a>
                            </div>
                        }
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Admin Username</label>
                        <input class="form-control form-control-sm" @bind="setupUsername" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Admin Password</label>
                        <input type="password" class="form-control form-control-sm" @bind="setupPassword" />
                    </div>
                </div>
                <div class="mt-3">
                    <button class="btn btn-sm btn-primary" @onclick="ConfigureKeycloak"
                            disabled="@(configuringKeycloak || string.IsNullOrWhiteSpace(setupAdminUrl) || string.IsNullOrWhiteSpace(setupPassword))">
                        @if (configuringKeycloak) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-check-circle me-1"></i>Configure
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        @* Instance-level tabs: Realms | Themes *@
        <ul class="nav nav-tabs mb-4" role="tablist" aria-label="Instance sections">
            <li class="nav-item" role="presentation">
                <button class="nav-link @(instanceTab == "realms" ? "active" : "")"
                        role="tab"
                        aria-selected="@(instanceTab == "realms")"
                        tabindex="@(instanceTab == "realms" ? 0 : -1)"
                        @onclick='() => SwitchInstanceTab("realms")'>
                    <i class="bi bi-shield-lock me-1"></i>Realms
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(instanceTab == "themes" ? "active" : "")"
                        role="tab"
                        aria-selected="@(instanceTab == "themes")"
                        tabindex="@(instanceTab == "themes" ? 0 : -1)"
                        @onclick='() => SwitchInstanceTab("themes")'>
                    <i class="bi bi-palette me-1"></i>Themes
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(instanceTab == "migrate" ? "active" : "")"
                        role="tab"
                        aria-selected="@(instanceTab == "migrate")"
                        tabindex="@(instanceTab == "migrate" ? 0 : -1)"
                        @onclick='() => SwitchInstanceTab("migrate")'>
                    <i class="bi bi-arrow-left-right me-1"></i>Migrate
                </button>
            </li>
        </ul>

        @if (instanceTab == "themes")
        {
            @* ── Themes tab ── *@
            @if (loadingThemes)
            {
                <div class="spinner-border spinner-border-sm text-primary me-2"></div>
                <span class="text-muted small">Loading themes...</span>
            }
            else
            {
                @* ── Named theme list ── *@
                <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
                    @foreach (KeycloakTheme nt in namedThemes)
                    {
                        <button class="btn btn-sm @(selectedNamedTheme?.Id == nt.Id ? "btn-primary" : "btn-outline-secondary")"
                                @onclick="() => SelectNamedTheme(nt)">
                            <i class="bi bi-palette me-1"></i>@nt.Name
                        </button>
                    }
                    <button class="btn btn-sm btn-outline-success" @onclick="() => { showCreateTheme = !showCreateTheme; createThemeError = null; }">
                        <i class="bi bi-plus-lg me-1"></i>New Theme
                    </button>
                </div>

                @* ── Create theme form ── *@
                @if (showCreateTheme)
                {
                    <div class="card mb-3" style="max-width:480px">
                        <div class="card-body">
                            <h6 class="card-title mb-3">New Named Theme</h6>
                            @if (createThemeError is not null)
                            {
                                <div class="alert alert-danger py-2 small mb-2">@createThemeError</div>
                            }
                            <EditForm Model="createThemeForm" OnValidSubmit="CreateNamedTheme">
                                <DataAnnotationsValidator />
                                <div class="mb-2">
                                    <label class="form-label small fw-semibold">Name</label>
                                    <InputText class="form-control form-control-sm" placeholder="e.g. Capio Blue"
                                               @bind-Value="createThemeForm.Name" />
                                    <ValidationMessage For="() => createThemeForm.Name" class="text-danger small" />
                                </div>
                                @if (availableThemes is not null)
                                {
                                    <div class="row g-2 mb-2">
                                        <div class="col-6">
                                            <label class="form-label small fw-semibold">Login Theme</label>
                                            <InputSelect class="form-select form-select-sm" @bind-Value="createThemeForm.LoginTheme">
                                                <option value="">(default)</option>
                                                @foreach (string t in availableThemes.GetValueOrDefault("login") ?? [])
                                                {
                                                    <option value="@t">@t</option>
                                                }
                                            </InputSelect>
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label small fw-semibold">Account Theme</label>
                                            <InputSelect class="form-select form-select-sm" @bind-Value="createThemeForm.AccountTheme">
                                                <option value="">(default)</option>
                                                @foreach (string t in availableThemes.GetValueOrDefault("account") ?? [])
                                                {
                                                    <option value="@t">@t</option>
                                                }
                                            </InputSelect>
                                        </div>
                                    </div>
                                }
                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-sm btn-primary" disabled="@creatingTheme">
                                        @if (creatingTheme) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                        Create
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => showCreateTheme = false">Cancel</button>
                                </div>
                            </EditForm>
                        </div>
                    </div>
                }

                @* ── Named theme editor ── *@
                @if (selectedNamedTheme is not null)
                {
                    <div class="card">
                        <div class="card-body">
                            <h6 class="card-title mb-3">
                                <i class="bi bi-pencil-square me-1"></i>Editing: @selectedNamedTheme.Name
                            </h6>

                            @* Meta: name + native themes *@
                            <div class="row g-2 mb-3" style="max-width:560px">
                                <div class="col-12 col-sm-4">
                                    <label class="form-label small fw-semibold">Theme Name</label>
                                    <input class="form-control form-control-sm" @bind="editThemeName" />
                                </div>
                                @if (availableThemes is not null)
                                {
                                    <div class="col-6 col-sm-4">
                                        <label class="form-label small fw-semibold">Login Theme</label>
                                        <select class="form-select form-select-sm" @bind="editThemeLoginTheme">
                                            <option value="">(default)</option>
                                            @foreach (string t in availableThemes.GetValueOrDefault("login") ?? [])
                                            {
                                                <option value="@t">@t</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-6 col-sm-4">
                                        <label class="form-label small fw-semibold">Account Theme</label>
                                        <select class="form-select form-select-sm" @bind="editThemeAccountTheme">
                                            <option value="">(default)</option>
                                            @foreach (string t in availableThemes.GetValueOrDefault("account") ?? [])
                                            {
                                                <option value="@t">@t</option>
                                            }
                                        </select>
                                    </div>
                                }
                            </div>
                            <div class="d-flex gap-2 align-items-center mb-4 flex-wrap">
                                <button class="btn btn-sm btn-primary" @onclick="SaveNamedThemeMeta"
                                        disabled="@(savingThemeMeta || string.IsNullOrWhiteSpace(editThemeName))">
                                    @if (savingThemeMeta) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    <i class="bi bi-floppy me-1"></i>Save
                                </button>
                                @if (themeMetaSaved)
                                {
                                    <span class="text-success small"><i class="bi bi-check-circle me-1"></i>Saved</span>
                                }
                                @if (themeMetaError is not null)
                                {
                                    <span class="text-danger small">@themeMetaError</span>
                                }
                                <div class="d-flex gap-2 ms-auto">
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="DuplicateNamedTheme"
                                            disabled="@duplicatingTheme" title="Clone this theme including all CSS, variables, and resources">
                                        @if (duplicatingTheme) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                        <i class="bi bi-copy me-1"></i>Duplicate
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick='() => pendingConfirm = new PendingConfirm($"Delete theme \"{selectedNamedTheme?.Name}\"? All its CSS, variables, and resources will be removed. This cannot be undone.", "Delete", DeleteNamedTheme)'
                                            disabled="@deletingTheme">
                                        @if (deletingTheme) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                        <i class="bi bi-trash me-1"></i>Delete
                                    </button>
                                </div>
                                @if (duplicateThemeError is not null)
                                {
                                    <span class="text-danger small w-100">@duplicateThemeError</span>
                                }
                            </div>

                            @* Visual / CSS theme editor — keyed by theme ID so switching themes creates a fresh instance *@
                            <KeycloakThemeEditor @key="selectedNamedTheme.Id"
                                                 TenantId="TenantId"
                                                 ComponentId="selectedKeycloak!.ComponentId"
                                                 Theme="selectedNamedTheme"
                                                 IsManagedKeycloak="!selectedKeycloak.IsExternal" />
                        </div>
                    </div>
                }
                else if (namedThemes.Count == 0 && !showCreateTheme)
                {
                    <EmptyState Icon="bi-palette" Title="No themes yet"
                                Message="Create a named theme to save CSS overrides and native theme settings in one bundle."
                                ActionLabel="New theme" OnAction="() => { showCreateTheme = true; createThemeError = null; }" />
                }
            }
        }
        else if (instanceTab == "migrate")
        {
            @* ── Migrate tab ── *@
            <div class="card">
                <div class="card-body">
                    @if (migrateError is not null)
                    {
                        <div class="alert alert-danger py-2 small mb-3">@migrateError</div>
                    }
                    @if (migrateResult is not null)
                    {
                        bool anyErrors = migrateResult.Errors.Count > 0;
                        bool nothingCopied = migrateCopyUsers
                            ? migrateResult.Copied == 0 && migrateResult.Skipped == 0 && !anyErrors
                            : false;
                        string alertClass = anyErrors ? "alert-warning"
                            : nothingCopied ? "alert-warning"
                            : "alert-success";

                        <div class="alert @alertClass py-2 small mb-3">
                            @if (migrateCopyUsers)
                            {
                                @if (migrateResult.Copied > 0)
                                {
                                    <div><i class="bi bi-check-circle me-1"></i>
                                        Users: <strong>@migrateResult.Copied copied</strong>@(migrateResult.Skipped > 0 ? $", {migrateResult.Skipped} skipped (already exist)." : ".")</div>
                                }
                                else if (migrateResult.Skipped > 0)
                                {
                                    <div><i class="bi bi-info-circle me-1"></i>
                                        Users: 0 copied — all @migrateResult.Skipped already exist in target.</div>
                                }
                                else if (!anyErrors)
                                {
                                    <div><i class="bi bi-exclamation-triangle me-1"></i>
                                        No users found in the source realm.</div>
                                }
                            }
                            @if (migrateCopyThemeCss)
                            {
                                @if (migrateCssCopied > 0)
                                {
                                    <div><i class="bi bi-check-circle me-1"></i>
                                        Legacy CSS: <strong>@migrateCssCopied / 4 types</strong> copied.</div>
                                }
                                @if (migrateNamedThemesCopied > 0)
                                {
                                    <div><i class="bi bi-check-circle me-1"></i>
                                        Named themes: <strong>@migrateNamedThemesCopied</strong> copied (variables &amp; resources).
                                        Open each theme in the Themes tab and click <em>Save &amp; Deploy</em> to push to Keycloak.</div>
                                }
                                @if (migrateCssCopied == 0 && migrateNamedThemesCopied == 0)
                                {
                                    <div><i class="bi bi-exclamation-triangle me-1"></i>
                                        Theme CSS &amp; named themes: nothing to copy — the source instance has no theme data saved in EntKube yet.</div>
                                }
                            }
                            @if (anyErrors)
                            {
                                <ul class="mb-0 mt-1">
                                    @foreach (string err in migrateResult.Errors)
                                    {
                                        <li>@err</li>
                                    }
                                </ul>
                            }
                        </div>
                    }

                    <div class="row g-3" style="max-width:520px">
                        <div class="col-12">
                            <label class="form-label small fw-semibold">Source Keycloak</label>
                            <select class="form-select form-select-sm"
                                    @bind="migrateSourceKcId" @bind:after="OnMigrateSourceKcChanged">
                                <option value="@Guid.Empty">Select instance...</option>
                                @if (detectedKeycloaks is not null)
                                {
                                    @foreach (DetectedKeycloak kc in detectedKeycloaks.Where(k => k.IsConfigured))
                                    {
                                        <option value="@kc.ComponentId">@kc.DisplayName@(kc.ClusterDisplayName is not null ? $" ({kc.ClusterDisplayName})" : "")</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="col-12">
                            <div class="form-check mb-1">
                                <input class="form-check-input" type="checkbox" id="migrateCopyUsers" @bind="migrateCopyUsers" />
                                <label class="form-check-label small" for="migrateCopyUsers">Copy users <span class="text-muted">(without passwords)</span></label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="migrateCopyThemeCss" @bind="migrateCopyThemeCss" />
                                <label class="form-check-label small" for="migrateCopyThemeCss">Copy theme data <span class="text-muted">(CSS overrides, visual editor settings &amp; resources)</span></label>
                            </div>
                        </div>

                        @if (migrateCopyUsers)
                        {
                            <div class="col-12">
                                <label class="form-label small fw-semibold">Source Realm</label>
                                @if (loadingMigrateSourceRealms)
                                {
                                    <div class="spinner-border spinner-border-sm text-primary"></div>
                                }
                                else
                                {
                                    <select class="form-select form-select-sm" @bind="migrateSourceRealmId">
                                        <option value="@Guid.Empty">Select realm...</option>
                                        @if (migrateSourceRealms is not null)
                                        {
                                            @foreach (KeycloakRealm r in migrateSourceRealms)
                                            {
                                                <option value="@r.Id">@r.DisplayName (@r.RealmName)</option>
                                            }
                                        }
                                    </select>
                                }
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-semibold">Target Realm</label>
                                <select class="form-select form-select-sm" @bind="migrateTargetRealmId">
                                    <option value="@Guid.Empty">Select realm...</option>
                                    @if (realms is not null)
                                    {
                                        @foreach (KeycloakRealm r in realms)
                                        {
                                            <option value="@r.Id">@r.DisplayName (@r.RealmName)</option>
                                        }
                                    }
                                </select>
                            </div>
                        }

                        <div class="col-12">
                            <button class="btn btn-sm btn-primary" @onclick="ExecuteMigrate"
                                    disabled="@(migrating
                                        || migrateSourceKcId == Guid.Empty
                                        || (!migrateCopyUsers && !migrateCopyThemeCss)
                                        || (migrateCopyUsers && (migrateSourceRealmId == Guid.Empty || migrateTargetRealmId == Guid.Empty)))">
