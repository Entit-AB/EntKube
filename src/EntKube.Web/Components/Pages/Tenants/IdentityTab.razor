    private async Task AddRoleToUser(string userId)
    {
        if (selectedRealm is null || string.IsNullOrEmpty(addRoleToUserId) || roles is null) return;

        KeycloakRole? role = roles.FirstOrDefault(r => r.Id == addRoleToUserId);
        if (role is null) return;

        try
        {
            await KeycloakService.AddUserRoleMappingsAsync(TenantId, selectedRealm.Id, userId, [role]);
            userRoles = await KeycloakService.GetUserRoleMappingsAsync(TenantId, selectedRealm.Id, userId);
            addRoleToUserId = "";
        }
        catch (Exception ex) { userEditError = ex.Message; }
