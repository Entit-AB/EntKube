    private async Task OnMigrateSourceKcChanged()
    {
        migrateSourceRealms = null;
        migrateSourceRealmId = Guid.Empty;
        migrateError = null;

        if (migrateSourceKcId == Guid.Empty) return;

        DetectedKeycloak? sourceKc = detectedKeycloaks?.FirstOrDefault(k => k.ComponentId == migrateSourceKcId);
        if (sourceKc?.Config is null) return;

        loadingMigrateSourceRealms = true;
        StateHasChanged();

        try
        {
            migrateSourceRealms = await KeycloakService.GetRealmsForConfigAsync(TenantId, sourceKc.Config.Id);
        }
        catch (Exception ex)
        {
            migrateError = ex.Message;
        }
        finally
        {
            loadingMigrateSourceRealms = false;
        }
    }

    private async Task ExecuteMigrate()
    {
        if (selectedKeycloak is null || migrateSourceKcId == Guid.Empty) return;

        migrating = true;
        migrateResult = null;
        migrateCssCopied = 0;
        migrateNamedThemesCopied = 0;
        migrateError = null;

        try
        {
            CopyResult combined = new();

            if (migrateCopyUsers && migrateSourceRealmId != Guid.Empty && migrateTargetRealmId != Guid.Empty)
            {
                CopyResult r = await KeycloakService.CopyUsersAsync(
                    TenantId, migrateSourceRealmId, migrateTargetRealmId);
                combined.Copied += r.Copied;
                combined.Skipped += r.Skipped;
                combined.Errors.AddRange(r.Errors);
            }

            if (migrateCopyThemeCss)
            {
                migrateCssCopied = await KeycloakService.CopyThemeCssAsync(
                    TenantId, migrateSourceKcId, selectedKeycloak.ComponentId);
                migrateNamedThemesCopied = await KeycloakService.CopyNamedThemesAsync(
                    TenantId, migrateSourceKcId, selectedKeycloak.ComponentId);
            }

            migrateResult = combined;
        }
        catch (Exception ex)
        {
            migrateError = ex.Message;
        }
        finally
        {
            migrating = false;
        }
    }

