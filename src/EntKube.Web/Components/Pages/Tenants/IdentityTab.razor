    private void AddUserAttribute()
    {
        if (string.IsNullOrWhiteSpace(newAttrKey)) return;
        editUserAttributes[newAttrKey.Trim()] = newAttrValue;
        newAttrKey = "";
        newAttrValue = "";
    }

