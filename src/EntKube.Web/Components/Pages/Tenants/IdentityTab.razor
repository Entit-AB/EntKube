    // ── Confirm-before-destroy ────────────────────────────────────────────────
    // A destructive action awaiting user confirmation via the ConfirmDialog banner.
    private sealed record PendingConfirm(string Message, string ConfirmText, Func<Task> Action);
    private PendingConfirm? pendingConfirm;
    private bool confirmBusy;

    private async Task RunPendingConfirmAsync()
    {
        if (pendingConfirm is null) return;
        confirmBusy = true;
        try { await pendingConfirm.Action(); }
        finally { confirmBusy = false; pendingConfirm = null; }
    }

    protected override async Task OnInitializedAsync()
    {
        detectedKeycloaks = await LoadDetectedKeycloaksAsync();
        loading = false;
    }

    private async Task SelectKeycloak(DetectedKeycloak kc)
    {
        selectedKeycloak = kc;
        realms = null;
        availableDatabases = null;
        availableRegPgDatabases = null;
        setupError = null;
        setupDatabaseId = Guid.Empty;
        setupDatabaseSelection = "";
        setupAdminUrl = kc.SuggestedAdminUrl ?? "";
        setupPassword = "";
        instanceTab = "realms";
        availableThemes = null;
        namedThemes = [];
        selectedNamedTheme = null;
        showCreateTheme = false;
        realmSyncError = null;

        if (kc.IsConfigured)
        {
            try
            {
                realms = await KeycloakService.SyncRealmsFromKeycloakAsync(TenantId, kc.Config!.Id);
            }
            catch (Exception ex)
            {
                realmSyncError = ex.Message;
                realms = await KeycloakService.GetRealmsForConfigAsync(TenantId, kc.Config!.Id);
            }
            storageLinks ??= await StorageService.GetStorageLinksAsync(TenantId);
            apps ??= await KeycloakService.GetAppsAsync(TenantId);
        }
        else
        {
            if (kc.Component is not null)
            {
                var dbTask = KeycloakService.GetDatabasesForComponentAsync(TenantId, kc.Component.Id);
                var regPgTask = KeycloakService.GetRegisteredPostgresDatabasesForComponentAsync(TenantId, kc.Component.Id);
                await Task.WhenAll(dbTask, regPgTask);
                availableDatabases = dbTask.Result;
                availableRegPgDatabases = regPgTask.Result;
            }
            else
            {
                availableDatabases = [];
                availableRegPgDatabases = await KeycloakService.GetAllRegisteredPostgresDatabasesAsync(TenantId);
            }
        }

        if (kc.Config is not null)
        {
            editAdminUrl = kc.Config.AdminUrl ?? "";
            editAdminUsername = kc.Config.AdminUsername;
        }
    }

    private async Task SwitchInstanceTab(string tab)
    {
        instanceTab = tab;

        if (tab == "themes" && selectedKeycloak?.Config is not null)
        {
            await LoadThemesTab();
        }
        else if (tab == "migrate")
        {
            migrateResult = null;
            migrateError = null;
            migrateSourceKcId = Guid.Empty;
            migrateSourceRealms = null;
            migrateSourceRealmId = Guid.Empty;
            migrateTargetRealmId = Guid.Empty;
        }
    }

    private async Task LoadThemesTab()
    {
        if (selectedKeycloak?.Config is null) return;

        loadingThemes = true;
        StateHasChanged();

        try
        {
            availableThemes = await KeycloakService.GetAvailableThemesAsync(TenantId, selectedKeycloak.Config.Id);
            namedThemes = await KeycloakService.GetNamedThemesAsync(TenantId, selectedKeycloak.Config.Id);

            // Re-select the same named theme if it still exists after a reload.
            if (selectedNamedTheme is not null)
                selectedNamedTheme = namedThemes.FirstOrDefault(t => t.Id == selectedNamedTheme.Id);
        }
        catch
        {
            availableThemes = [];
            namedThemes = [];
        }
        finally
        {
            loadingThemes = false;
        }
    }

    private void SelectNamedTheme(KeycloakTheme theme)
    {
        selectedNamedTheme = theme;
        editThemeName = theme.Name;
        editThemeLoginTheme = theme.LoginTheme ?? "";
        editThemeAccountTheme = theme.AccountTheme ?? "";
        themeMetaSaved = false;
        themeMetaError = null;
        showCreateTheme = false;
    }

    private async Task CreateNamedTheme()
    {
        if (selectedKeycloak?.Config is null) return;

        creatingTheme = true;
        createThemeError = null;

        try
        {
            KeycloakTheme created = await KeycloakService.CreateNamedThemeAsync(
                TenantId, selectedKeycloak.Config.Id,
                createThemeForm.Name,
                string.IsNullOrWhiteSpace(createThemeForm.LoginTheme) ? null : createThemeForm.LoginTheme,
                string.IsNullOrWhiteSpace(createThemeForm.AccountTheme) ? null : createThemeForm.AccountTheme);

            namedThemes = await KeycloakService.GetNamedThemesAsync(TenantId, selectedKeycloak.Config.Id);
            showCreateTheme = false;
            createThemeForm = new CreateThemeForm();
            SelectNamedTheme(created);
            Toasts.Success("Theme created.");
        }
        catch (Exception ex)
        {
            createThemeError = ex.Message;
        }
        finally
        {
            creatingTheme = false;
        }
    }

    private async Task SaveNamedThemeMeta()
    {
        if (selectedNamedTheme is null || string.IsNullOrWhiteSpace(editThemeName)) return;

        savingThemeMeta = true;
        themeMetaSaved = false;
        themeMetaError = null;

        try
