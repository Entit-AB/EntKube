    // ── Identity bindings ─────────────────────────────────────────

    private async Task OpenIdentitySection()
    {
        section = "identity";
        if (!identityBindingsLoaded) await LoadAppIdentityBindings();
    }

    private async Task LoadAppIdentityBindings()
    {
        identityLoadError = null;
        try
        {
            identityBindingsByDeployment.Clear();
            foreach (AppDeployment dep in deployments ?? [])
                identityBindingsByDeployment[dep.Id] = await KeycloakService.GetIdentityBindingsForDeploymentAsync(dep.Id);
            identityBindingsLoaded = true;
        }
        catch (Exception ex)
        {
            identityLoadError = ex.Message;
            identityBindingsLoaded = true;
            return;
        }

        if (identityRealm is null)
        {
            identityRealm = await KeycloakService.GetRealmForAppAsync(TenantId, App.Id);

            if (identityRealm is null && !IsPortalView)
            {
                try { availableRealmsForLinking = await KeycloakService.GetAllRealmsForTenantAsync(TenantId); }
                catch { availableRealmsForLinking = []; }
            }

            if (identityRealm is not null && !IsPortalView)
            {
                clientsLoadError = null;
                loadingIdentityClients = true;
                StateHasChanged();
                try
                {
                    availableIdentityClients = (await KeycloakService.GetClientsAsync(TenantId, identityRealm.Id))
                        .Where(c => !c.PublicClient && !c.BearerOnly)
                        .OrderBy(c => c.ClientId)
                        .ToList();
                }
                catch (Exception ex) { availableIdentityClients = []; clientsLoadError = ex.Message; }
                finally { loadingIdentityClients = false; }
            }
        }
    }

    private async Task LinkRealmToApp()
    {
        linkRealmError = null;
        linkingRealm = true;
        try
        {
            await KeycloakService.LinkRealmToAppAsync(TenantId, newIdentityLinkRealmId, App.Id);
            identityRealm = null;
            newIdentityLinkRealmId = Guid.Empty;
            await LoadAppIdentityBindings();
        }
        catch (Exception ex) { linkRealmError = ex.Message; }
        finally { linkingRealm = false; }
    }

    private async Task AddIdentityBinding()
    {
        identityBindingError = null; addingIdentityBinding = true;
        try
        {
            KeycloakClientInfo? client = availableIdentityClients.FirstOrDefault(c => c.Id == newIdentityClientUuid);
            if (client is null) { identityBindingError = "Selected client not found."; return; }
            if (identityRealm is null) { identityBindingError = "No realm linked to this app."; return; }

            IdentityBinding binding = await KeycloakService.CreateIdentityBindingAsync(
                identityRealm.Id, newIdentityDeploymentId,
                client.Id, client.ClientId, newIdentitySecretName.Trim());

            try { await KeycloakService.SyncIdentityBindingAsync(TenantId, binding.Id); }
            catch (Exception syncEx) { identityBindingError = $"Attached, but sync failed: {syncEx.Message}"; }

            newIdentityDeploymentId = Guid.Empty; newIdentityClientUuid = ""; newIdentitySecretName = "";
            await LoadAppIdentityBindings();
        }
        catch (Exception ex) { identityBindingError = ex.Message; }
        finally { addingIdentityBinding = false; }
    }

    private async Task DetachIdentityBinding(Guid bindingId)
    {
        confirmDetachIdentityId = null;
        identityBindingSyncErrors.Remove(bindingId);
        try
        {
            await KeycloakService.RemoveIdentityBindingAsync(bindingId);
            await LoadAppIdentityBindings();
        }
        catch (Exception ex) { identityBindingError = ex.Message; }
    }

    private async Task SyncIdentityBinding(IdentityBinding binding)
    {
        syncingBindingIds.Add(binding.Id);
        identityBindingSyncErrors.Remove(binding.Id);
        try
        {
            await KeycloakService.SyncIdentityBindingAsync(TenantId, binding.Id);
            await LoadAppIdentityBindings();
        }
        catch (Exception ex) { identityBindingSyncErrors[binding.Id] = ex.Message; }
        finally { syncingBindingIds.Remove(binding.Id); }
    }

