@using EntKube.Web.Data
@using EntKube.Web.Services
@using EntKube.Web.Components.Pages.Portal
@using EntKube.Web.Components.Pages.Shared
@using Microsoft.EntityFrameworkCore
@implements IAsyncDisposable
@inject DeploymentService DeploymentService
@inject CnpgService CnpgService
@inject MongoService MongoService
@inject KubernetesOperationsService K8sOps
@inject PrometheusService PrometheusService
@inject AuditService AuditService
@inject RedisService RedisService
@inject GitSyncService GitSyncService
@inject TenantService TenantService
@inject AppGovernanceService AppGovernanceService
@inject CustomerGitService CustomerGitService
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject RabbitMQService RabbitMQService
@inject StorageService StorageService

@inject RegisteredPostgresService RegisteredPostgresService
@inject KeycloakService KeycloakService
@inject VaultService VaultService
@inject DeploymentStatusNotifier StatusNotifier

@* ═══════════════════════════════════════════════════════════════════
   Per-environment detail view. All tabs — deployments, resources,
   governance, metrics, and external access — are scoped to this
   single environment. Used in both tenant-admin and portal contexts.
   ═══════════════════════════════════════════════════════════════════ *@

@* --- Back button --- *@
<nav class="mb-3">
    <button class="btn btn-sm btn-link text-decoration-none p-0" @onclick="OnBack">
        <i class="bi bi-arrow-left me-1"></i>Back to @App.Name
    </button>
</nav>

@* --- Environment header --- *@
<div class="card shadow-sm mb-4">
    <div class="card-body py-2">
        <div class="d-flex align-items-center gap-3">
            <i class="bi bi-layers fs-4 text-primary"></i>
            <div>
                <h5 class="mb-0">@Environment.Name</h5>
                <small class="text-muted">@App.Name</small>
            </div>
        </div>
    </div>
</div>

@* --- Per-environment tabs --- *@
<ul class="nav nav-pills mb-3 gap-1">
    <li class="nav-item">
        <button class="nav-link @(section == "deployments" ? "active" : "")"
                @onclick="SwitchToDeployments">
            <i class="bi bi-rocket-takeoff me-1"></i>Deployments
            @if (deployments is not null && deployments.Count > 0)
            {
                <span class="badge bg-primary ms-1">@deployments.Count</span>
            }
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(section == "resources" ? "active" : "")"
                @onclick='() => section = "resources"'>
            <i class="bi bi-diagram-3 me-1"></i>Resources
        </button>
    </li>
    @if (!IsPortalView)
    {
        <li class="nav-item">
            <button class="nav-link @(section == "governance" ? "active" : "")"
                    @onclick='() => section = "governance"'>
                <i class="bi bi-shield-check me-1"></i>Governance
            </button>
        </li>
    }
    @if (!IsPortalView)
    {
        <li class="nav-item">
            <button class="nav-link @(section == "autoscaling" ? "active" : "")"
                    @onclick='() => section = "autoscaling"'>
                <i class="bi bi-arrows-angle-expand me-1"></i>Autoscaling
            </button>
        </li>
    }
    <li class="nav-item">
        <button class="nav-link @(section == "metrics" ? "active" : "")"
                @onclick="OpenMetricsSection">
            <i class="bi bi-bar-chart-line me-1"></i>Metrics
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(section == "external-access" ? "active" : "")"
                @onclick='() => section = "external-access"'>
            <i class="bi bi-globe me-1"></i>External Access
        </button>
    </li>
    @if (!IsPortalView)
    {
    <li class="nav-item">
        <button class="nav-link @(section == "git-access" ? "active" : "")"
                @onclick="SwitchToGitAccess">
            <i class="bi bi-git me-1"></i>Git Access
        </button>
    </li>
    }
    <li class="nav-item">
        <button class="nav-link @(section == "databases" ? "active" : "")"
                @onclick="OpenDatabasesSection">
            <i class="bi bi-database me-1"></i>Databases
            @if (dbBindingsByDeployment.Values.Any(b => b.Count > 0))
            {
                <span class="badge bg-primary ms-1">@dbBindingsByDeployment.Values.Sum(b => b.Count)</span>
            }
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(section == "messaging" ? "active" : "")"
                @onclick="OpenMessagingSection">
            <i class="bi bi-send me-1"></i>Messaging
            @if (msgBindingsByDeployment.Values.Any(b => b.Count > 0))
            {
                <span class="badge bg-primary ms-1">@msgBindingsByDeployment.Values.Sum(b => b.Count)</span>
            }
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(section == "cache" ? "active" : "")"
                @onclick="OpenCacheSection">
            <i class="bi bi-lightning me-1"></i>Cache
            @if (cacheBindingsByDeployment.Values.Any(b => b.Count > 0))
            {
                <span class="badge bg-warning text-dark ms-1">@cacheBindingsByDeployment.Values.Sum(b => b.Count)</span>
            }
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(section == "storage" ? "active" : "")"
                @onclick="OpenStorageSection">
            <i class="bi bi-bucket me-1"></i>Storage
            @if (storageBindingsByDeployment.Values.Any(b => b.Count > 0))
            {
                <span class="badge bg-info ms-1">@storageBindingsByDeployment.Values.Sum(b => b.Count)</span>
            }
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(section == "identity" ? "active" : "")"
                @onclick="OpenIdentitySection">
            <i class="bi bi-shield-lock me-1"></i>Identity
            @if (identityBindingsByDeployment.Values.Any(b => b.Count > 0))
            {
                <span class="badge bg-purple ms-1" style="background-color: #6f42c1 !important;">@identityBindingsByDeployment.Values.Sum(b => b.Count)</span>
            }
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(section == "vault" ? "active" : "")"
                @onclick='() => section = "vault"'>
            <i class="bi bi-key me-1"></i>Vault
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(section == "registries" ? "active" : "")"
                @onclick='() => section = "registries"'>
            <i class="bi bi-box-seam me-1"></i>Registries
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(section == "vpn" ? "active" : "")"
                @onclick='() => section = "vpn"'>
            <i class="bi bi-shield-lock me-1"></i>VPN
        </button>
    </li>
</ul>

@* ══════════════════════════════════════════════════════
   Deployments tab
   ══════════════════════════════════════════════════════ *@
@if (section == "deployments")
{
    @if (selectedDeployment is not null)
    {
        @* ── Deployment detail drill-down ── *@
        <nav class="mb-3">
            <button class="btn btn-sm btn-link text-decoration-none p-0"
                    @onclick="() => selectedDeployment = null">
                <i class="bi bi-arrow-left me-1"></i>Back to deployments
            </button>
        </nav>

        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <div class="d-flex align-items-start justify-content-between">
                    <div>
                        <h5 class="mb-1">
                            <i class="bi bi-rocket-takeoff me-2 text-primary"></i>@selectedDeployment.Name
                        </h5>
                        <div class="d-flex flex-wrap gap-2 text-muted small">
                            <span>@GetTypeBadge(selectedDeployment.Type)</span>
                            <span><i class="bi bi-hdd-network me-1"></i>@selectedDeployment.Cluster?.Name</span>
                            <span><i class="bi bi-box me-1"></i>@selectedDeployment.Namespace</span>
                            @if (!selectedDeployment.IsManaged)
                            {
                                <span class="badge bg-info-subtle text-info-emphasis border border-info"
                                      title="Observed only — the live workload is owned elsewhere (e.g. ArgoCD/Flux). EntKube tracks it but won't apply manifests until you enable management.">
                                    <i class="bi bi-eye me-1"></i>Observed
                                </span>
                            }
                        </div>
                    </div>
                    <div class="d-flex align-items-start gap-1">
                        <button class="btn btn-sm @(selectedDeployment.IsManaged ? "btn-outline-success" : "btn-outline-info")"
                                title="@(selectedDeployment.IsManaged ? "EntKube manages this deployment — click to stop managing (observe only)" : "Observed only — click to refresh manifests from the live cluster and let EntKube manage it")"
                                disabled="@managingDeployment"
                                @onclick="ToggleDeploymentManagement">
                            @if (managingDeployment)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            else
                            {
                                <i class="bi @(selectedDeployment.IsManaged ? "bi-shield-check" : "bi-shield")"></i>
                            }
                        </button>
                        <button class="btn btn-link p-0 border-0 bg-transparent" title="View resources"
                                @onclick="OpenDeploymentResourcesTab">
                            @GetSyncBadge(selectedDeployment.SyncStatus)
                        </button>
                        <button class="btn btn-link p-0 border-0 bg-transparent" title="View activity"
                                @onclick="OpenActivityTab">
                            @GetHealthBadge(selectedDeployment.HealthStatus)
                        </button>
                        <button class="btn btn-sm btn-outline-secondary ms-2"
                                @onclick="StartEditDeployment" title="Edit deployment">
                            <i class="bi bi-pencil"></i>
                        </button>
                        @if (!confirmDeleteDeployment)
                        {
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => confirmDeleteDeployment = true">
                                <i class="bi bi-trash"></i>
                            </button>
                        }
                    </div>
                </div>

                @if (showEditDeployment)
                {
                    <div class="mt-3 p-3 bg-light rounded">
                        @if (editDeployError is not null)
                        {
                            <div class="alert alert-danger py-1 small mb-2">@editDeployError</div>
                        }
                        <div class="row g-2 mb-2">
                            <div class="col-md-6">
                                <label class="form-label small">Name</label>
                                <input class="form-control form-control-sm" @bind="editDeployName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small">Namespace</label>
                                @if (!string.IsNullOrWhiteSpace(governanceNamespace))
                                {
                                    <input class="form-control form-control-sm font-monospace" value="@governanceNamespace" disabled />
                                    <div class="form-text small text-warning"><i class="bi bi-lock me-1"></i>Locked by governance policy.</div>
                                }
                                else
                                {
                                    <input class="form-control form-control-sm" @bind="editDeployNamespace" />
                                }
                            </div>
                            @if (selectedDeployment.Type == DeploymentType.HelmChart)
                            {
                                <div class="col-md-4">
                                    <label class="form-label small">Helm Repo URL</label>
                                    <input class="form-control form-control-sm" @bind="editHelmRepoUrl" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small">Chart Name</label>
                                    <input class="form-control form-control-sm" @bind="editHelmChartName" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small">Chart Version</label>
                                    <input class="form-control form-control-sm" @bind="editHelmChartVersion" />
                                </div>
                            }
                        </div>
                        <div class="d-flex gap-1">
                            <button class="btn btn-sm btn-primary" @onclick="SaveDeployment"
                                    disabled="@(string.IsNullOrWhiteSpace(editDeployName) || string.IsNullOrWhiteSpace(editDeployNamespace))">
                                Save
                            </button>
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => showEditDeployment = false">Cancel</button>
                        </div>
                    </div>
                }

                @if (confirmDeleteDeployment)
                {
                    <div class="mt-3 p-2 bg-danger bg-opacity-10 rounded d-flex align-items-center justify-content-between">
                        <span class="text-danger small">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Permanently delete <strong>@selectedDeployment.Name</strong>?
                        </span>
                        <div>
                            <button class="btn btn-sm btn-danger me-1" @onclick="DeleteDeployment">Yes, delete</button>
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => confirmDeleteDeployment = false">Cancel</button>
                        </div>
                    </div>
                }

                @if (!showEditDeployment && selectedDeployment.Type == DeploymentType.HelmChart)
                {
                    <div class="mt-3 p-2 bg-light rounded">
                        <small class="text-muted">
                            <i class="bi bi-box-seam me-1"></i>
                            @selectedDeployment.HelmChartName
                            <span class="mx-1">@selectedDeployment.HelmChartVersion</span>
                            <span class="text-muted">from @selectedDeployment.HelmRepoUrl</span>
                        </small>
                    </div>
                }

                @if (!showEditDeployment && IsGitManaged)
                {
                    @if (showEditGitSettings)
                    {
                        <div class="mt-3 p-3 bg-light rounded">
                            <h6 class="mb-2 small fw-semibold"><i class="bi bi-git me-1"></i>Git Source</h6>
                            @if (editGitError is not null)
                            {
                                <div class="alert alert-danger py-1 small mb-2">@editGitError</div>
                            }
                            @if (gitRepoPolicies is { Count: > 0 })
                            {
                                <div class="alert alert-warning py-1 small mb-2">
                                    <i class="bi bi-shield-check me-1"></i>
                                    <strong>Repo URL policy active.</strong>
                                    Allowed patterns:
                                    @foreach (CustomerGitRepoPolicy p in gitRepoPolicies)
                                    {
                                        <code class="ms-1">@p.UrlPattern</code>
                                    }
                                </div>
                            }
                            <div class="row g-2 mb-2">
                                <div class="col-md-5">
                                    <label class="form-label small">Git Repository URL</label>
                                    <input class="form-control form-control-sm font-monospace @(editGitUrlError is not null ? "is-invalid" : "")"
                                           value="@editGitUrl"
                                           @oninput="ValidateEditGitUrl"
                                           placeholder="https://github.com/org/repo" />
                                    @if (editGitUrlError is not null)
                                    {
                                        <div class="invalid-feedback">@editGitUrlError</div>
                                    }
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small">Path</label>
                                    <input class="form-control form-control-sm font-monospace" @bind="editGitPath" placeholder="." />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small">Branch / Tag / Commit</label>
                                    <input class="form-control form-control-sm font-monospace" @bind="editGitRevision"
                                           placeholder="default branch" />
                                </div>
                            </div>
                            <div class="mb-2">
                                <div class="form-check form-check-sm">
                                    <input class="form-check-input" type="checkbox" id="editGitAutoSyncEnv" @bind="editGitAutoSync" />
                                    <label class="form-check-label small" for="editGitAutoSyncEnv">
                                        Auto-sync (poll every 3 minutes)
                                    </label>
                                </div>
                            </div>
                            <div class="d-flex gap-1">
                                <button class="btn btn-sm btn-primary" @onclick="SaveGitSettings"
                                        disabled="@(editGitUrlError is not null || savingGitSettings)">
                                    @if (savingGitSettings) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    Save
                                </button>
                                <button class="btn btn-sm btn-outline-secondary"
                                        @onclick="() => showEditGitSettings = false">Cancel</button>
                            </div>
                        </div>
                    }
                    else if (selectedDeployment.GitUrl is not null)
                    {
                        <div class="mt-2 p-2 bg-light rounded d-flex align-items-center justify-content-between flex-wrap gap-2">
                            <div class="small text-muted">
                                <i class="bi bi-git me-1"></i>
                                <strong class="font-monospace">@selectedDeployment.GitUrl</strong>
                                <span class="ms-1">@(selectedDeployment.GitRevision ?? "main")</span>
                                @if (!string.IsNullOrEmpty(selectedDeployment.GitPath) && selectedDeployment.GitPath != ".")
                                {
                                    <span class="ms-1 text-muted">→ <code>@selectedDeployment.GitPath</code></span>
                                }
                                @if (selectedDeployment.GitLastSyncedCommit is not null)
                                {
                                    <span class="ms-2 badge bg-secondary">@selectedDeployment.GitLastSyncedCommit[..7]</span>
                                }
                                @if (selectedDeployment.GitAutoSync)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle ms-1">auto-sync</span>
                                }
                            </div>
                            <div class="d-flex gap-1">
                                <button class="btn btn-sm btn-outline-secondary" title="Edit git source"
                                        @onclick="StartEditGitSettings">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-primary" @onclick="TriggerGitSync" disabled="@syncingGit">
                                    @if (syncingGit) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    else { <i class="bi bi-arrow-repeat me-1"></i> }
                                    Sync now
                                </button>
                            </div>
                        </div>
                        @if (gitSyncResult is not null)
                        {
                            <div class="mt-1 alert @(gitSyncSuccess ? "alert-success" : "alert-danger") py-1 small">
                                <i class="bi @(gitSyncSuccess ? "bi-check-circle" : "bi-exclamation-triangle") me-1"></i>@gitSyncResult
                            </div>
                        }
                    }
                    else
                    {
                        <div class="mt-2 p-2 bg-light rounded d-flex align-items-center justify-content-between">
                            <span class="small text-muted"><i class="bi bi-git me-1"></i>No git source configured.</span>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="StartEditGitSettings">
                                <i class="bi bi-gear me-1"></i>Configure
                            </button>
                        </div>
                    }
                }
            </div>
        </div>

        @* ── Deployment sub-tabs ── *@
        <ul class="nav nav-tabs mb-3">
            @if (selectedDeployment.Type is DeploymentType.Manual or DeploymentType.Yaml or DeploymentType.GitYaml)
            {
                <li class="nav-item">
                    <button class="nav-link @(deploymentSection == "manifests" ? "active" : "")"
                            @onclick='() => deploymentSection = "manifests"'>
                        <i class="bi bi-file-earmark-code me-1"></i>Manifests
                    </button>
                </li>
            }
            @if (selectedDeployment.Type is DeploymentType.HelmChart or DeploymentType.GitHelm)
            {
                <li class="nav-item">
                    <button class="nav-link @(deploymentSection == "helm-values" ? "active" : "")"
                            @onclick='() => deploymentSection = "helm-values"'>
                        <i class="bi bi-sliders me-1"></i>Values
                    </button>
                </li>
            }
            <li class="nav-item">
                <button class="nav-link @(deploymentSection == "resources" ? "active" : "")"
                        @onclick="OpenDeploymentResourcesTab">
                    <i class="bi bi-diagram-3 me-1"></i>Resources
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(deploymentSection == "deployment-metrics" ? "active" : "")"
                        @onclick="OpenDeploymentMetricsTab">
                    <i class="bi bi-bar-chart-line me-1"></i>Metrics
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(deploymentSection == "activity" ? "active" : "")"
                        @onclick="OpenActivityTab">
                    <i class="bi bi-clock-history me-1"></i>Activity
                </button>
            </li>
        </ul>

        @* Manifests *@
        @if (deploymentSection == "manifests")
        {
            <div class="card shadow-sm">
                <div class="card-header bg-white py-2 d-flex align-items-center justify-content-between">
                    <div><i class="bi bi-file-earmark-code me-2 text-primary"></i><strong>Manifests</strong></div>
                    <div class="d-flex gap-1">
                        @if (selectedDeployment.IsManaged)
                        {
                            <button class="btn btn-sm btn-success" @onclick="ApplyYamlDeployment"
                                    disabled="@(applyingYaml || manifests is null || manifests.Count == 0)">
                                @if (applyingYaml) { <span class="spinner-border spinner-border-sm me-1"></span><span>Applying…</span> }
                                else { <i class="bi bi-cloud-upload me-1"></i><span>Apply to Cluster</span> }
                            </button>
                        }
                        else
                        {
                            <span class="badge bg-light text-muted border align-self-center"
                                  title="Observed only — enable management (shield icon above) to apply.">
                                <i class="bi bi-eye me-1"></i>observed — not applied by EntKube
                            </span>
                        }
                        @if (!IsGitManaged)
                        {
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => showAddManifest = !showAddManifest">
                                <i class="bi bi-plus me-1"></i>Add Manifest
                            </button>
                        }
                    </div>
                </div>
                <div class="card-body">
                    @if (showAddManifest && !IsGitManaged)
                    {
                        <div class="card border-primary mb-3">
                            <div class="card-body">
                                <h6 class="mb-3"><i class="bi bi-plus-circle me-1"></i>Add YAML Manifest</h6>
                                <div class="row g-2 mb-2">
                                    <div class="col-md-4">
                                        <label class="form-label small">Kind</label>
                                        <input class="form-control form-control-sm" @bind="newManifestKind" placeholder="e.g. Deployment" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small">Name</label>
                                        <input class="form-control form-control-sm" @bind="newManifestName" placeholder="e.g. billing-api" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small">Sort Order</label>
                                        <input class="form-control form-control-sm" type="number" @bind="newManifestSortOrder" />
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small">YAML Content</label>
                                    <YamlEditor @bind-Value="newManifestYaml" />
                                </div>
                                <div class="d-flex gap-1">
                                    <button class="btn btn-sm btn-primary" @onclick="AddManifest"
                                            disabled="@(string.IsNullOrWhiteSpace(newManifestKind) || string.IsNullOrWhiteSpace(newManifestYaml) || savingManifest)">
                                        @if (savingManifest) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                        Add
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => showAddManifest = false">Cancel</button>
                                </div>
                            </div>
                        </div>
                    }
                    <LoadingPanel Loading="@(manifests is null)">
                    @if (manifests is not null && manifests.Count == 0)
                    {
                        <EmptyState Icon="bi-file-earmark-code" Message="No manifests yet." />
                    }
                    else if (manifests is not null)
                    {
                        @foreach (DeploymentManifest manifest in manifests)
                        {
                            <div class="card mb-2">
                                <div class="card-header bg-white py-2 d-flex align-items-center justify-content-between">
                                    <div>
                                        <span class="badge bg-secondary me-1">@manifest.Kind</span>
                                        <span class="fw-medium">@manifest.Name</span>
                                        <span class="text-muted small ms-2">#@manifest.SortOrder</span>
                                    </div>
                                    @if (!IsGitManaged)
                                    {
                                        <div class="d-flex gap-1">
                                            @if (editingManifestId == manifest.Id)
                                            {
                                                <button class="btn btn-sm btn-primary" @onclick="() => SaveManifest(manifest.Id)" disabled="@savingManifest">
                                                    @if (savingManifest) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                    Save
                                                </button>
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => editingManifestId = null" disabled="@savingManifest">Cancel</button>
                                            }
                                            else if (confirmDeleteManifestId == manifest.Id)
                                            {
                                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteManifest(manifest.Id)">
                                                    <i class="bi bi-trash me-1"></i>Delete
                                                </button>
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => confirmDeleteManifestId = null">Cancel</button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEditManifest(manifest)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => confirmDeleteManifestId = manifest.Id">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                                @if (editingManifestId == manifest.Id)
                                {
                                    <div class="card-body p-2"><YamlEditor @bind-Value="editManifestYaml" /></div>
                                }
                                else
                                {
                                    <div class="card-body p-0" style="border-radius: 0 0 var(--bs-card-border-radius) var(--bs-card-border-radius); overflow: hidden;">
                                        <YamlEditor Value="@manifest.YamlContent" ReadOnly="true" Borderless="true" />
                                    </div>
                                }
                            </div>
                        }
                    }
                    </LoadingPanel>
                    @if (yamlApplyOutput is not null)
                    {
                        <div class="mt-3">
                            <div class="d-flex align-items-center justify-content-between mb-1">
                                <span class="small fw-medium @(yamlApplySuccess == true ? "text-success" : "text-danger")">
                                    <i class="bi @(yamlApplySuccess == true ? "bi-check-circle" : "bi-x-circle") me-1"></i>
                                    @(yamlApplySuccess == true ? "Applied successfully" : "Apply failed")
                                </span>
                                <button class="btn btn-sm btn-link text-muted py-0" @onclick="() => yamlApplyOutput = null">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                            <pre class="bg-dark text-light p-2 rounded small mb-0"
                                 style="max-height: 300px; overflow-y: auto; white-space: pre-wrap; word-break: break-all;">@yamlApplyOutput</pre>
                        </div>
                    }
                </div>
            </div>
        }

        @* Helm Values *@
        @if (deploymentSection == "helm-values")
        {
            <div class="card shadow-sm">
                <div class="card-header bg-white py-2">
                    <i class="bi bi-sliders me-2 text-primary"></i><strong>Helm Values</strong>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-2">Override the chart's default values (YAML format).</p>
                    @if (helmValuesError is not null) { <div class="alert alert-danger py-1 small mb-2">@helmValuesError</div> }
                    <YamlEditor @bind-Value="helmValuesYaml" />
                    <div class="d-flex align-items-center gap-2 mt-2 flex-wrap">
                        <button class="btn btn-sm btn-primary" @onclick="SaveHelmValues" disabled="@(savingHelmValues || installingHelm)">
                            @if (savingHelmValues) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            <i class="bi bi-floppy me-1"></i>Save Values
                        </button>
                        <button class="btn btn-sm btn-success" @onclick="InstallOrUpgradeHelm" disabled="@(installingHelm || savingHelmValues)">
                            @if (installingHelm) { <span class="spinner-border spinner-border-sm me-1"></span><span>Running helm upgrade…</span> }
                            else { <i class="bi bi-cloud-upload me-1"></i><span>Install / Upgrade Release</span> }
                        </button>
                        @if (helmValuesSaved) { <span class="text-success small"><i class="bi bi-check-circle me-1"></i>Saved</span> }
                    </div>
                    @if (helmInstallOutput is not null)
                    {
                        <div class="mt-3">
                            <div class="d-flex align-items-center justify-content-between mb-1">
                                <span class="small fw-medium @(helmInstallSuccess == true ? "text-success" : "text-danger")">
                                    <i class="bi @(helmInstallSuccess == true ? "bi-check-circle" : "bi-x-circle") me-1"></i>
                                    @(helmInstallSuccess == true ? "Release applied successfully" : "Helm operation failed")
                                </span>
                                <button class="btn btn-sm btn-link text-muted py-0" @onclick="() => helmInstallOutput = null"><i class="bi bi-x"></i></button>
                            </div>
                            <pre class="bg-dark text-light p-2 rounded small mb-0"
                                 style="max-height: 300px; overflow-y: auto; white-space: pre-wrap; word-break: break-all;">@helmInstallOutput</pre>
                        </div>
                    }
                </div>
            </div>
        }

        @* Deployment Resources *@
        @if (deploymentSection == "resources")
        {
            <div class="card shadow-sm">
                <div class="card-header bg-white py-2">
                    <i class="bi bi-diagram-3 me-2 text-primary"></i><strong>Resource Tree</strong>
                </div>
                <div class="card-body">
                    <ResourceTreePanel Loading="@(resourceTree is null)"
                                       Error="@resourcesError"
                                       Resources="@resourceTree"
                                       Namespace="@selectedDeployment?.Namespace"
                                       DeploymentId="@(selectedDeployment?.Id ?? Guid.Empty)"
                                       AccessRole="@null"
                                       OnRefresh="OpenDeploymentResourcesTab"
                                       LastRefreshed="@resourceTreeRefreshedAt" />
                </div>
            </div>
        }

        @* Deployment Metrics *@
        @if (deploymentSection == "deployment-metrics")
        {
            <div class="card shadow-sm">
                <div class="card-header bg-white py-2">
                    <i class="bi bi-bar-chart-line me-2 text-primary"></i><strong>Namespace Metrics</strong>
                    <span class="text-muted small ms-2">@selectedDeployment.Namespace</span>
                </div>
                <div class="card-body">
                    @if (deploymentMetricsLoading) { <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></div> }
                    else if (deploymentMetricsError is not null)
                    {
                        <div class="alert alert-warning small py-2 mb-0">
                            <i class="bi bi-exclamation-triangle me-1"></i>@deploymentMetricsError
                        </div>
                    }
                    else if (deploymentMetrics is not null)
                    {
                        <div class="row g-3 mb-2">
                            <div class="col-sm-6 col-lg-3">
                                <div class="border rounded text-center p-3">
                                    <div class="fs-3 fw-bold text-primary">@(deploymentMetrics.CpuCores >= 1 ? $"{(int)Math.Round(deploymentMetrics.CpuCores)} cores" : $"{(int)Math.Round(deploymentMetrics.CpuCores * 1000)}m")</div>
                                    <div class="small text-muted">CPU cores (5 m avg)</div>
                                </div>
                            </div>
                            <div class="col-sm-6 col-lg-3">
                                <div class="border rounded text-center p-3">
                                    <div class="fs-3 fw-bold text-info">@deploymentMetrics.MemoryMiB.ToString("F0") <small class="fs-6">MiB</small></div>
                                    <div class="small text-muted">Memory (working set)</div>
                                </div>
                            </div>
                            <div class="col-sm-6 col-lg-3">
                                <div class="border rounded text-center p-3">
                                    <div class="fs-3 fw-bold text-success">@deploymentMetrics.PodCount</div>
                                    <div class="small text-muted">Pods in namespace</div>
                                </div>
                            </div>
                            <div class="col-sm-6 col-lg-3">
                                <div class="border rounded text-center p-3">
                                    <div class="fs-3 fw-bold @(deploymentMetrics.RestartCount > 0 ? "text-warning" : "text-success")">@deploymentMetrics.RestartCount</div>
                                    <div class="small text-muted">Container restarts</div>
                                </div>
                            </div>
                        </div>
                        <div class="text-muted small"><i class="bi bi-clock me-1"></i>Queried @deploymentMetrics.QueriedAt.ToLocalTime().ToString("HH:mm:ss")</div>
                    }
                </div>
            </div>
        }

        @* Activity *@
        @if (deploymentSection == "activity")
        {
            <div class="card shadow-sm">
                <div class="card-header bg-white py-2">
                    <i class="bi bi-clock-history me-2 text-primary"></i><strong>Activity Log</strong>
                </div>
                <div class="card-body p-0">
                    @if (activityLoading) { <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></div> }
                    else if (deploymentAuditEvents is not null && deploymentAuditEvents.Count == 0)
                    {
                        <div class="text-muted small py-4 text-center">No activity recorded yet.</div>
                    }
                    else if (deploymentAuditEvents is not null)
                    {
                        <div class="list-group list-group-flush">
                            @foreach (AuditEvent ev in deploymentAuditEvents)
                            {
                                <div class="list-group-item px-3 py-2">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <span class="badge bg-secondary me-2">@ev.ResourceKind</span>
                                            <strong>@ev.Action</strong>
                                            @if (!string.IsNullOrEmpty(ev.ResourceName)) { <span class="text-muted ms-1 font-monospace small">@ev.ResourceName</span> }
                                            @if (!string.IsNullOrEmpty(ev.Details)) { <span class="text-muted ms-2 small">— @ev.Details</span> }
                                        </div>
                                        <div class="text-end text-nowrap ms-3">
                                            <div class="small text-muted">@ev.OccurredAt.ToLocalTime().ToString("MMM d HH:mm")</div>
                                            @if (!string.IsNullOrEmpty(ev.PerformedBy)) { <div class="small text-muted">@ev.PerformedBy</div> }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        @* ── Deployment list ── *@
        <div class="card shadow-sm">
            <div class="card-header bg-white py-2 d-flex align-items-center justify-content-between">
                <div><i class="bi bi-rocket-takeoff me-2 text-primary"></i><strong>Deployments</strong></div>
                <button class="btn btn-sm btn-outline-primary" @onclick="() => showCreateDeployment = !showCreateDeployment">
                    <i class="bi bi-plus me-1"></i>New Deployment
                </button>
            </div>
            <div class="card-body">
                @if (showCreateDeployment)
                {
                    <div class="card border-primary mb-3">
                        <div class="card-body">
                            <h6 class="mb-3"><i class="bi bi-plus-circle me-1"></i>Create Deployment</h6>
                            <div class="row g-2 mb-2">
                                <div class="col-md-6">
                                    <label class="form-label small">Name</label>
                                    <input class="form-control form-control-sm" @bind="newDeployName" placeholder="e.g. billing-api-prod" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small">Type</label>
                                    <select class="form-select form-select-sm" @bind="newDeployType" @bind:after="OnNewDeployTypeChanged">
                                        <option value="@DeploymentType.Manual">Manual</option>
                                        <option value="@DeploymentType.Yaml">YAML</option>
                                        <option value="@DeploymentType.HelmChart">Helm Chart</option>
                                        <option value="@DeploymentType.GitYaml">Git — YAML</option>
                                        <option value="@DeploymentType.GitHelm">Git — Helm</option>
                                        <option value="@DeploymentType.GitAppOfApps">Git — App of Apps</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row g-2 mb-2">
                                <div class="col-md-6">
                                    <label class="form-label small">Cluster</label>
                                    <select class="form-select form-select-sm" @bind="newDeployClusterId">
                                        <option value="@Guid.Empty">Select cluster…</option>
                                        @foreach (KubernetesCluster cluster in envClusters ?? [])
                                        {
                                            <option value="@cluster.Id">@cluster.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small">Namespace</label>
                                    @if (!string.IsNullOrWhiteSpace(governanceNamespace))
                                    {
                                        <input class="form-control form-control-sm font-monospace" value="@governanceNamespace" disabled />
                                        <div class="form-text small text-warning"><i class="bi bi-lock me-1"></i>Locked by governance policy.</div>
                                    }
                                    else
                                    {
                                        <input class="form-control form-control-sm" @bind="newDeployNamespace" placeholder="e.g. billing" />
                                    }
                                </div>
                            </div>
                            @if (newDeployType == DeploymentType.HelmChart)
                            {
                                <div class="row g-2 mb-2">
                                    <div class="col-md-4">
                                        <label class="form-label small">Helm Repo URL</label>
                                        <input class="form-control form-control-sm" @bind="newHelmRepoUrl" placeholder="https://charts.bitnami.com/bitnami" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small">Chart Name</label>
                                        <input class="form-control form-control-sm" @bind="newHelmChartName" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small">Chart Version</label>
                                        <input class="form-control form-control-sm" @bind="newHelmChartVersion" />
                                    </div>
                                </div>
                            }
                            @if (newDeployType is DeploymentType.GitYaml or DeploymentType.GitHelm or DeploymentType.GitAppOfApps)
                            {
                                <div class="row g-2 mb-2">
                                    <div class="col-md-5">
                                        <label class="form-label small">Git Repository URL</label>
                                        <input class="form-control form-control-sm font-monospace @(newGitUrlError is not null ? "is-invalid" : "")"
                                               value="@newGitUrl"
                                               @oninput="ValidateNewGitUrl"
                                               placeholder="https://github.com/org/repo" />
                                        @if (newGitUrlError is not null)
                                        {
                                            <div class="invalid-feedback">@newGitUrlError</div>
                                        }
                                        @if (gitRepoPolicies is { Count: > 0 })
                                        {
                                            <div class="form-text small">
                                                <i class="bi bi-shield-check me-1"></i>Allowed:
                                                @foreach (CustomerGitRepoPolicy p in gitRepoPolicies)
                                                {
                                                    <code class="ms-1">@p.UrlPattern</code>
                                                }
                                            </div>
                                        }
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label small">Path</label>
                                        <input class="form-control form-control-sm" @bind="newGitPath" placeholder="." />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small">Branch / Tag / Commit</label>
                                        <input class="form-control form-control-sm" @bind="newGitRevision" placeholder="leave blank for default" />
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <div class="form-check form-check-sm">
                                        <input class="form-check-input" type="checkbox" id="newGitAutoSyncEnv" @bind="newGitAutoSync" />
                                        <label class="form-check-label small" for="newGitAutoSyncEnv">
                                            Auto-sync (poll every 3 minutes)
                                        </label>
                                    </div>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(createDeployError)) { <div class="alert alert-danger py-1 small mb-2">@createDeployError</div> }
                            <div class="d-flex gap-1">
                                <button class="btn btn-sm btn-primary" @onclick="CreateDeployment"
                                        disabled="@(string.IsNullOrWhiteSpace(newDeployName) || newDeployClusterId == Guid.Empty || (newDeployType is DeploymentType.GitYaml or DeploymentType.GitHelm or DeploymentType.GitAppOfApps && (string.IsNullOrWhiteSpace(newGitUrl) || newGitUrlError is not null)))">
                                    Create
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => showCreateDeployment = false">Cancel</button>
                            </div>
                        </div>
                    </div>
                }

                <LoadingPanel Loading="@(deployments is null)">
                @if (deployments is not null && deployments.Count == 0)
                {
                    <EmptyState Icon="bi-rocket-takeoff" Message="@($"No deployments in {Environment.Name} yet.")" />
                }
                else if (deployments is not null)
                {
                    <div class="row row-cols-1 row-cols-lg-2 g-2">
                        @foreach (AppDeployment deploy in deployments)
                        {
                            <div class="col">
                                <div class="card border-light h-100" role="button" style="cursor: pointer;"
                                     @onclick="() => SelectDeployment(deploy)">
                                    <div class="card-body py-2">
                                        <div class="d-flex align-items-center justify-content-between mb-1">
                                            <span class="fw-medium">
                                                <i class="bi bi-rocket-takeoff me-1 text-primary"></i>@deploy.Name
                                            </span>
                                            <div class="d-flex gap-1">
                                                @GetSyncBadge(deploy.SyncStatus)
                                                @GetHealthBadge(deploy.HealthStatus)
                                            </div>
                                        </div>
                                        <div class="d-flex flex-wrap gap-2 text-muted small">
                                            @GetTypeBadge(deploy.Type)
                                            <span><i class="bi bi-hdd-network me-1"></i>@deploy.Cluster?.Name</span>
                                            <span><i class="bi bi-box me-1"></i>@deploy.Namespace</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                </LoadingPanel>
            </div>
        </div>
    }
}

@* ══════════════════════════════════════════════════════
   Resources tab
   ══════════════════════════════════════════════════════ *@
@if (section == "resources")
{
    <div style="flex: 1; display: flex; flex-direction: column; min-height: 0;">
        <AppResourcesPanel AppId="App.Id" EnvironmentId="Environment.Id" />
    </div>
}

@* ══════════════════════════════════════════════════════
   Governance tab — full editor for tenant admins, read-only for portal
   ══════════════════════════════════════════════════════ *@
@if (section == "governance")
{
    @if (IsPortalView)
    {
        <AppGovernancePanel AppId="App.Id" AppName="App.Name" EnvironmentId="Environment.Id" CustomerId="App.CustomerId" />
    }
    else
    {
        <GovernanceTab AppId="App.Id" TenantId="TenantId" EnvironmentId="Environment.Id" />
    }
}


@* ══════════════════════════════════════════════════════
   Autoscaling tab — KEDA ScaledObjects / ScaledJobs (tenant admins only)
   ══════════════════════════════════════════════════════ *@
@if (section == "autoscaling")
{
    <KedaTab AppId="App.Id" TenantId="TenantId" EnvironmentId="Environment.Id" />
}


@* ══════════════════════════════════════════════════════
   Env-aggregate metrics tab
   ══════════════════════════════════════════════════════ *@
@if (section == "metrics")
{
    <div class="card shadow-sm">
        <div class="card-header bg-white py-2 d-flex justify-content-between align-items-center">
            <div>
                <i class="bi bi-bar-chart-line me-2 text-primary"></i>
                <strong>@Environment.Name Metrics</strong>
                <span class="text-muted small ms-2">aggregate across all deployments in this environment</span>
            </div>
            <button class="btn btn-sm btn-outline-secondary" @onclick="OpenMetricsSection" disabled="@envMetricsLoading">
                <i class="bi bi-arrow-clockwise me-1"></i>Refresh
            </button>
        </div>
        <div class="card-body">
            @if (envMetricsLoading) { <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></div> }
            else if (envMetricsError is not null)
            {
                <div class="alert alert-warning small py-2 mb-0">
                    <i class="bi bi-exclamation-triangle me-1"></i>@envMetricsError
                </div>
            }
            else if (envMetrics is not null)
            {
                <div class="row g-3 mb-2">
                    <div class="col-sm-6 col-lg-3">
                        <div class="border rounded text-center p-3">
                            <div class="fs-3 fw-bold text-primary">
                                @(envMetrics.CpuCores >= 1 ? $"{(int)Math.Round(envMetrics.CpuCores)} cores" : $"{(int)Math.Round(envMetrics.CpuCores * 1000)}m")
                            </div>
                            <div class="small text-muted">CPU (5 m avg)</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <div class="border rounded text-center p-3">
                            <div class="fs-3 fw-bold text-info">@envMetrics.MemoryMiB.ToString("F0") <small class="fs-6">MiB</small></div>
                            <div class="small text-muted">Memory (working set)</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <div class="border rounded text-center p-3">
                            <div class="fs-3 fw-bold text-success">@envMetrics.PodCount</div>
                            <div class="small text-muted">Pods running</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <div class="border rounded text-center p-3">
                            <div class="fs-3 fw-bold @(envMetrics.RestartCount > 0 ? "text-warning" : "text-success")">@envMetrics.RestartCount</div>
                            <div class="small text-muted">Container restarts</div>
                        </div>
                    </div>
                </div>
                <div class="text-muted small"><i class="bi bi-clock me-1"></i>Queried @envMetrics.QueriedAt.ToLocalTime().ToString("HH:mm:ss")</div>
            }
        </div>
    </div>
}

@* ══════════════════════════════════════════════════════
   External Access tab
   ══════════════════════════════════════════════════════ *@
@if (section == "external-access")
{
    <AppExternalAccessPanel App="App" TenantId="TenantId" EnvironmentId="Environment.Id" IsPortalView="IsPortalView" />
}

@* ══════════════════════════════════════════════════════
   Git Access tab — URL policies + credentials for this customer/environment
   ══════════════════════════════════════════════════════ *@
@if (section == "git-access")
{
    <div class="row g-4">
        @* --- URL Policies --- *@
        <div class="col-12 col-xl-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white py-2">
                    <i class="bi bi-git me-2 text-primary"></i>
                    <strong>Git Repo URL Policies</strong>
                    <div><small class="text-muted">Allowed repository URL patterns. Supports <code>*</code> (within segment) and <code>**</code> (across segments).</small></div>
                </div>
                <div class="card-body">
                    <div class="input-group mb-3">
                        <input type="text" class="form-control form-control-sm font-monospace"
                               placeholder="e.g. https://github.com/acme/* or git@github.com:acme/**"
                               @bind="newRepoPolicyPattern" @bind:event="oninput"
                               @onkeydown="@(async (e) => { if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(newRepoPolicyPattern)) await AddRepoPolicy(); })" />
                        <button class="btn btn-sm btn-outline-primary" @onclick="AddRepoPolicy"
                                disabled="@string.IsNullOrWhiteSpace(newRepoPolicyPattern)">
                            <i class="bi bi-plus me-1"></i>Add
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(repoPolicyError))
                    {
                        <div class="alert alert-danger py-1 small mb-2">@repoPolicyError</div>
                    }
                    <LoadingPanel Loading="@(gitRepoPolicies is null)">
                    @if (gitRepoPolicies is not null && gitRepoPolicies.Count == 0)
                    {
                        <EmptyState Icon="bi-slash-circle"
                                    Message="No URL patterns defined. All repo URLs are implicitly denied for this customer." />
                    }
                    else if (gitRepoPolicies is not null)
                    {
                        @foreach (CustomerGitRepoPolicy policy in gitRepoPolicies)
                        {
                            <div class="d-flex align-items-center justify-content-between py-1 border-bottom">
                                <code class="small">@policy.UrlPattern</code>
                                @if (confirmDeletePolicyId == policy.Id)
                                {
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteRepoPolicy(policy.Id)">Remove</button>
                                        <button class="btn btn-sm btn-link p-0" @onclick="() => confirmDeletePolicyId = null">Cancel</button>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-danger" title="Remove pattern"
                                            @onclick="() => confirmDeletePolicyId = policy.Id">
                                        <i class="bi bi-x"></i>
                                    </button>
                                }
                            </div>
                        }
                    }
                    </LoadingPanel>
                </div>
            </div>
        </div>

        @* --- Credentials --- *@
        <div class="col-12 col-xl-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white py-2">
                    <i class="bi bi-key me-2 text-primary"></i>
                    <strong>Git Credentials</strong>
                    <div><small class="text-muted">Reusable credential sets for this customer's repositories in this environment.</small></div>
                </div>
                <div class="card-body">
                    <div class="row g-2 align-items-end mb-3">
                        <div class="col-md-4">
                            <label class="form-label small mb-1">Name</label>
                            <input type="text" class="form-control form-control-sm" placeholder="e.g. GitHub PAT"
                                   @bind="newCredName" @bind:event="oninput" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small mb-1">Auth type</label>
                            <select class="form-select form-select-sm" @bind="newCredAuthType">
                                <option value="@GitAuthType.None">None (public)</option>
                                <option value="@GitAuthType.HttpsPat">HTTPS – PAT</option>
                                <option value="@GitAuthType.HttpsPassword">HTTPS – Password</option>
                                <option value="@GitAuthType.SshKey">SSH Key</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small mb-1">Repo URL pattern <span class="text-muted">(optional)</span></label>
                            <input type="text" class="form-control form-control-sm font-monospace"
                                   placeholder="e.g. https://github.com/acme/*"
                                   @bind="newCredUrlPattern" @bind:event="oninput" />
                        </div>
                        @if (newCredAuthType == GitAuthType.HttpsPassword)
                        {
                            <div class="col-md-3">
                                <label class="form-label small mb-1">Username</label>
                                <input type="text" class="form-control form-control-sm" placeholder="e.g. myuser"
                                       @bind="newCredUsername" @bind:event="oninput" />
                            </div>
                        }
                        <div class="col-auto">
                            <button class="btn btn-sm btn-outline-primary" @onclick="AddGitCredential"
                                    disabled="@string.IsNullOrWhiteSpace(newCredName)">
                                <i class="bi bi-plus me-1"></i>Add
                            </button>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(credentialError))
                    {
                        <div class="alert alert-danger py-1 small mb-2">@credentialError</div>
                    }
                    @if (!string.IsNullOrEmpty(credentialSuccess))
                    {
                        <div class="alert alert-success py-1 small mb-2">@credentialSuccess</div>
                    }
                    <LoadingPanel Loading="@(gitCredentials is null)">
                    @if (gitCredentials is not null && gitCredentials.Count == 0)
                    {
                        <EmptyState Icon="bi-key" Message="No credentials configured yet." />
                    }
                    else if (gitCredentials is not null)
                    {
                        @foreach (CustomerGitCredential cred in gitCredentials)
                        {
                            <div class="border rounded p-3 mb-2">
                                <div class="d-flex align-items-start justify-content-between">
                                    <div>
                                        <span class="fw-semibold"><i class="bi bi-key me-1 text-primary"></i>@cred.Name</span>
                                        <span class="badge bg-secondary ms-2">@cred.AuthType</span>
                                        @if (cred.AuthType == GitAuthType.HttpsPassword && cred.Username is not null)
                                        {
                                            <span class="text-muted small ms-2">(@cred.Username)</span>
                                        }
                                        @if (cred.UrlPattern is not null)
                                        {
                                            <code class="small ms-2 text-muted">@cred.UrlPattern</code>
                                        }
                                    </div>
                                    @if (confirmDeleteCredentialId == cred.Id)
                                    {
                                        <div class="d-flex gap-1">
                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteGitCredential(cred.Id)">Delete</button>
                                            <button class="btn btn-sm btn-link p-0" @onclick="() => confirmDeleteCredentialId = null">Cancel</button>
                                        </div>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-danger" title="Delete credential"
                                                @onclick="() => confirmDeleteCredentialId = cred.Id">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>
                                @if (cred.AuthType != GitAuthType.None)
                                {
                                    <div class="mt-2">
                                        @if (cred.AuthType == GitAuthType.HttpsPat)
                                        {
                                            <div class="input-group input-group-sm">
                                                <span class="input-group-text">PAT</span>
                                                <input type="password" class="form-control form-control-sm"
                                                       placeholder="Personal Access Token"
                                                       @bind="credSecretValues[cred.Id]" @bind:event="oninput" />
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        @onclick="() => SaveCredentialSecret(cred)">Save</button>
                                            </div>
                                        }
                                        else if (cred.AuthType == GitAuthType.HttpsPassword)
                                        {
                                            <div class="input-group input-group-sm">
                                                <span class="input-group-text">Password</span>
                                                <input type="password" class="form-control form-control-sm"
                                                       placeholder="Password"
                                                       @bind="credSecretValues[cred.Id]" @bind:event="oninput" />
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        @onclick="() => SaveCredentialSecret(cred)">Save</button>
                                            </div>
                                        }
                                        else if (cred.AuthType == GitAuthType.SshKey)
                                        {
                                            <textarea class="form-control form-control-sm font-monospace mb-1"
                                                      rows="3" placeholder="-----BEGIN OPENSSH PRIVATE KEY-----"
                                                      @bind="credSecretValues[cred.Id]" @bind:event="oninput"></textarea>
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    @onclick="() => SaveCredentialSecret(cred)">Save SSH Key</button>
                                        }
                                        @if (credSaveMessages.TryGetValue(cred.Id, out string? msg) && msg is not null)
                                        {
                                            <div class="small mt-1 @(credSaveOk.GetValueOrDefault(cred.Id) ? "text-success" : "text-danger")">
                                                <i class="bi @(credSaveOk.GetValueOrDefault(cred.Id) ? "bi-check-circle" : "bi-x-circle") me-1"></i>@msg
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                    </LoadingPanel>
                </div>
            </div>
        </div>
    </div>
}

@* ══════════════════════════════════════════════════════
   Vault tab — app secrets scoped to this environment
   ══════════════════════════════════════════════════════ *@
@if (section == "vault")
{
    <PortalSecretsDetail App="App"
                         Environment="Environment"
                         TenantId="TenantId"
                         AccessRole="AccessRole"
                         InitialScope="app" />
}

@if (section == "registries")
{
    <DockerRegistriesPanel TenantId="TenantId"
                           AppId="App.Id"
                           IsAdmin="AccessRole >= CustomerAccessRole.Admin" />
}

@* ══════════════════════════════════════════════════════
   Databases tab
   ══════════════════════════════════════════════════════ *@
@if (section == "databases")
{
    @if (!dbBindingsLoaded)
    {
        <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else
    {
        @if (!IsPortalView)
        {
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-white py-2 d-flex align-items-center justify-content-between">
                    <div><i class="bi bi-plus-circle me-1 text-primary"></i><strong>Attach Database</strong></div>
                    <button class="btn btn-sm btn-outline-primary" @onclick="() => showDbAttachForm = !showDbAttachForm">
                        <i class="bi bi-plus me-1"></i>Attach
                    </button>
                </div>
                @if (showDbAttachForm)
                {
                    <div class="card-body">
                        <div class="row g-2 mb-2">
                            <div class="col-md-4">
                                <label class="form-label small">Deployment</label>
                                <select class="form-select form-select-sm" @bind="newDbAttachDeploymentId">
                                    <option value="@Guid.Empty">Select deployment…</option>
                                    @foreach (AppDeployment dep in deployments ?? [])
                                    {
                                        <option value="@dep.Id">@dep.Name (@dep.Namespace)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Database</label>
                                <select class="form-select form-select-sm" @bind="newBindingDatabaseId">
                                    <option value="@Guid.Empty">Select database…</option>
                                    @if (availableCnpgDatabases is { Count: > 0 })
                                    {
                                        <optgroup label="PostgreSQL (CNPG)">
                                            @foreach ((CnpgCluster cluster, CnpgDatabase database) in availableCnpgDatabases)
                                            {
                                                <option value="@database.Id">@cluster.Name / @database.Name</option>
                                            }
                                        </optgroup>
                                    }
                                    @if (availableMongoDatabases is { Count: > 0 })
                                    {
                                        <optgroup label="MongoDB">
                                            @foreach ((MongoCluster cluster, MongoDatabase database) in availableMongoDatabases)
                                            {
                                                <option value="@database.Id">@cluster.Name / @database.Name</option>
                                            }
                                        </optgroup>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">K8s Secret name</label>
                                <input class="form-control form-control-sm" @bind="newBindingSecretName" placeholder="e.g. my-app-db" />
                            </div>
                        </div>
                        @if (bindingError is not null) { <div class="alert alert-danger py-1 small mb-2">@bindingError</div> }
                        @if (bindingWarning is not null) { <div class="alert alert-warning py-1 small mb-2">@bindingWarning</div> }
                        <div class="d-flex gap-1">
                            <button class="btn btn-sm btn-primary" @onclick="AddDatabaseBindingAppLevel"
                                    disabled="@(newDbAttachDeploymentId == Guid.Empty || newBindingDatabaseId == Guid.Empty || string.IsNullOrWhiteSpace(newBindingSecretName))">
                                Attach &amp; Sync
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => showDbAttachForm = false">Cancel</button>
                        </div>
                    </div>
                }
            </div>
        }

        @if (!dbBindingsByDeployment.Values.Any(b => b.Count > 0))
        {
            <EmptyState Icon="bi-database" Message="No databases are connected to this app's deployments." />
        }
        else
        {
            @foreach (AppDeployment deployment in deployments ?? [])
            {
                List<DatabaseBinding> bindings = dbBindingsByDeployment.GetValueOrDefault(deployment.Id, []);
                if (bindings.Count == 0) continue;
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-white py-2">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-rocket-takeoff text-primary"></i>
                            <strong>@deployment.Name</strong>
                            <span class="text-muted small">
                                <i class="bi bi-hdd-network me-1"></i>@deployment.Cluster?.Name
                                <i class="bi bi-box ms-2 me-1"></i>@deployment.Namespace
                            </span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Type</th>
                                        <th>Database</th>
                                        <th>K8s Secret</th>
                                        <th>Last Synced</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (DatabaseBinding binding in bindings)
                                    {
                                        <tr>
                                            <td>@DbTypeBadge(binding)</td>
                                            <td>
                                                <span class="fw-medium">@DbDisplayName(binding)</span>
                                                @if (binding.CnpgDatabase?.CnpgCluster is not null)
                                                {
                                                    <br /><small class="text-muted">@binding.CnpgDatabase.CnpgCluster.Name</small>
                                                }
                                                else if (binding.MongoDatabase?.MongoCluster is not null)
                                                {
                                                    <br /><small class="text-muted">@binding.MongoDatabase.MongoCluster.Name</small>
                                                }
                                            </td>
                                            <td>
                                                <code class="small">@binding.KubernetesSecretName</code>
                                                <br /><small class="text-muted">@deployment.Namespace</small>
                                            </td>
                                            <td>
                                                @if (binding.LastSyncedAt is not null)
                                                { <small class="text-muted">@binding.LastSyncedAt.Value.ToString("MMM d, HH:mm")</small> }
                                                else
                                                { <span class="badge bg-warning text-dark small">Never synced</span> }
                                            </td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-secondary me-1"
                                                        @onclick="() => ToggleDbCredentials(binding)"
                                                        title="@(revealedDbBindingId == binding.Id ? "Hide credentials" : "View credentials")">
                                                    <i class="bi @(revealedDbBindingId == binding.Id ? "bi-eye-slash" : "bi-eye")"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-success me-1"
                                                        @onclick="() => SyncDatabaseBinding(binding)"
                                                        disabled="@syncingBindingIds.Contains(binding.Id)">
                                                    @if (syncingBindingIds.Contains(binding.Id))
                                                    { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                    else { <i class="bi bi-cloud-arrow-up me-1"></i> }
                                                    Sync
                                                </button>
                                                @if (!IsPortalView)
                                                {
                                                    @if (confirmRemoveBindingId == binding.Id)
                                                    {
                                                        <button class="btn btn-sm btn-danger me-1" @onclick="() => RemoveDatabaseBindingAppLevel(binding.Id)">Detach</button>
                                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => confirmRemoveBindingId = null">Cancel</button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => confirmRemoveBindingId = binding.Id" title="Detach database">
                                                            <i class="bi bi-x-circle"></i>
                                                        </button>
                                                    }
                                                }
                                                @if (bindingSyncErrors.TryGetValue(binding.Id, out string? dbErr) && dbErr is not null)
                                                { <div class="text-danger small mt-1">@dbErr</div> }
                                            </td>
                                        </tr>
                                        @if (revealedDbBindingId == binding.Id)
                                        {
                                            <tr class="table-light">
                                                <td colspan="5" class="px-3 py-2">
                                                    @if (dbCredLoading)
                                                    {
                                                        <div class="text-center py-2"><div class="spinner-border spinner-border-sm text-primary" role="status"></div></div>
                                                    }
                                                    else if (dbCredSecrets is { Count: > 0 })
                                                    {
                                                        <div class="d-flex flex-wrap gap-3 align-items-center">
                                                            @foreach (VaultSecret sec in dbCredSecrets)
                                                            {
                                                                <div class="d-flex align-items-center gap-1">
                                                                    <span class="text-muted small">@sec.Name:</span>
                                                                    @if (sec.Name == "PASSWORD")
                                                                    {
                                                                        @if (revealedDbPasswordSecretId == sec.Id)
                                                                        {
                                                                            <code class="user-select-all small">@dbCredValues.GetValueOrDefault(sec.Id, "•••")</code>
                                                                            <button class="btn btn-sm btn-link py-0 px-1" @onclick="() => revealedDbPasswordSecretId = null"><i class="bi bi-eye-slash"></i></button>
                                                                        }
                                                                        else
                                                                        {
                                                                            <code class="small text-muted">••••••••</code>
                                                                            <button class="btn btn-sm btn-link py-0 px-1" @onclick="() => RevealDbPassword(sec)" disabled="@dbPasswordRevealing">
                                                                                @if (dbPasswordRevealing) { <span class="spinner-border spinner-border-sm"></span> }
                                                                                else { <i class="bi bi-eye"></i> }
                                                                            </button>
                                                                        }
                                                                    }
                                                                    else
                                                                    {
                                                                        <code class="user-select-all small">@(dbCredValues.GetValueOrDefault(sec.Id, "…"))</code>
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                    else
                                                    { <div class="text-muted small">No credentials found in vault for this database.</div> }
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        }
    }
}

@* ══════════════════════════════════════════════════════
   Messaging tab
   ══════════════════════════════════════════════════════ *@
@if (section == "messaging")
{
    @if (!msgBindingsLoaded)
    {
        <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else
    {
        @if (!IsPortalView)
        {
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-white py-2 d-flex align-items-center justify-content-between">
                    <div><i class="bi bi-plus-circle me-1 text-primary"></i><strong>Attach Messaging</strong></div>
                    <button class="btn btn-sm btn-outline-primary" @onclick="() => showMsgAttachForm = !showMsgAttachForm">
                        <i class="bi bi-plus me-1"></i>Attach
                    </button>
                </div>
                @if (showMsgAttachForm)
                {
                    <div class="card-body">
                        @if (msgAttachError is not null) { <div class="alert alert-danger py-1 small mb-2">@msgAttachError</div> }
                        <div class="row g-2 mb-2">
                            <div class="col-md-4">
                                <label class="form-label small">Deployment</label>
                                <select class="form-select form-select-sm" @bind="newMsgDeploymentId">
                                    <option value="@Guid.Empty">Select deployment…</option>
                                    @foreach (AppDeployment dep in deployments ?? [])
                                    {
                                        <option value="@dep.Id">@dep.Name (@dep.Namespace)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">RabbitMQ Cluster</label>
                                <select class="form-select form-select-sm" @bind="newMsgClusterId">
                                    <option value="@Guid.Empty">Select cluster…</option>
                                    @if (availableRabbitClusters is not null)
                                    {
                                        @foreach (RabbitMQCluster rc in availableRabbitClusters)
                                        {
                                            <option value="@rc.Id">@rc.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Vhost</label>
                                <input class="form-control form-control-sm" @bind="newMsgVhost" placeholder="/" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Queue name <span class="text-muted">(optional)</span></label>
                                <input class="form-control form-control-sm" @bind="newMsgQueueName" placeholder="my-queue" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Exchange name <span class="text-muted">(optional)</span></label>
                                <input class="form-control form-control-sm" @bind="newMsgExchangeName" placeholder="my-exchange" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">K8s Secret name</label>
                                <input class="form-control form-control-sm" @bind="newMsgSecretName" placeholder="e.g. rabbitmq-creds" />
                            </div>
                        </div>
                        <div class="d-flex gap-1">
                            <button class="btn btn-sm btn-primary" @onclick="AddMessagingBinding"
                                    disabled="@(newMsgDeploymentId == Guid.Empty || newMsgClusterId == Guid.Empty || string.IsNullOrWhiteSpace(newMsgSecretName))">
                                Attach &amp; Sync
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => showMsgAttachForm = false">Cancel</button>
                        </div>
                    </div>
                }
            </div>
        }

        @if (!msgBindingsByDeployment.Values.Any(b => b.Count > 0))
        {
            <EmptyState Icon="bi-send" Message="No RabbitMQ connections are configured for this app's deployments." />
        }
        else
        {
            @foreach (AppDeployment deployment in deployments ?? [])
            {
                List<MessagingBinding> bindings = msgBindingsByDeployment.GetValueOrDefault(deployment.Id, []);
                if (bindings.Count == 0) continue;
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-white py-2">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-rocket-takeoff text-primary"></i>
                            <strong>@deployment.Name</strong>
                            <span class="text-muted small">
                                <i class="bi bi-hdd-network me-1"></i>@deployment.Cluster?.Name
                                <i class="bi bi-box ms-2 me-1"></i>@deployment.Namespace
                            </span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Cluster</th>
                                        <th>Vhost</th>
                                        <th>Queue / Exchange</th>
                                        <th>K8s Secret</th>
                                        <th>Last Synced</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (MessagingBinding binding in bindings)
                                    {
                                        <tr>
                                            <td><small>@binding.Cluster?.Name</small></td>
                                            <td><code class="small">@binding.Vhost</code></td>
                                            <td>
                                                @if (binding.QueueName is not null)
                                                {
                                                    <span class="badge bg-info-subtle text-info border border-info-subtle me-1">
                                                        <i class="bi bi-collection me-1"></i>Queue
                                                    </span>
                                                    <code class="small">@binding.QueueName</code>
                                                }
                                                @if (binding.ExchangeName is not null)
                                                {
                                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle me-1">
                                                        <i class="bi bi-arrow-left-right me-1"></i>Exchange
                                                    </span>
                                                    <code class="small">@binding.ExchangeName</code>
                                                }
                                                @if (binding.QueueName is null && binding.ExchangeName is null)
                                                {
                                                    <span class="text-muted small">vhost only</span>
                                                }
                                            </td>
                                            <td>
                                                <code class="small">@binding.KubernetesSecretName</code>
                                                <br /><small class="text-muted">@deployment.Namespace</small>
                                            </td>
                                            <td>
                                                @if (binding.LastSyncedAt is not null)
                                                { <small class="text-muted">@binding.LastSyncedAt.Value.ToString("MMM d, HH:mm")</small> }
                                                else
                                                { <span class="badge bg-warning text-dark small">Never synced</span> }
                                            </td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-success me-1"
                                                        @onclick="() => SyncMessagingBinding(binding)"
                                                        disabled="@syncingBindingIds.Contains(binding.Id)">
                                                    @if (syncingBindingIds.Contains(binding.Id))
                                                    { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                    else { <i class="bi bi-cloud-arrow-up me-1"></i> }
                                                    Sync
                                                </button>
                                                @if (!IsPortalView)
                                                {
                                                    @if (confirmDetachMsgId == binding.Id)
                                                    {
                                                        <button class="btn btn-sm btn-danger me-1" @onclick="() => RemoveMessagingBinding(binding.Id)">Detach</button>
                                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => confirmDetachMsgId = null">Cancel</button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => confirmDetachMsgId = binding.Id" title="Detach">
                                                            <i class="bi bi-x-circle"></i>
                                                        </button>
                                                    }
                                                }
                                                @if (bindingSyncErrors.TryGetValue(binding.Id, out string? msgErr) && msgErr is not null)
                                                { <div class="text-danger small mt-1">@msgErr</div> }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        }
    }
}

@* ══════════════════════════════════════════════════════
   Cache tab
   ══════════════════════════════════════════════════════ *@
@if (section == "cache")
{
    @if (!cacheBindingsLoaded)
    {
        <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else
    {
        @if (!IsPortalView)
        {
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-white py-2 d-flex align-items-center justify-content-between">
                    <div><i class="bi bi-plus-circle me-1 text-primary"></i><strong>Attach Redis Cluster</strong></div>
                    <button class="btn btn-sm btn-outline-warning" @onclick="() => showCacheAttachForm = !showCacheAttachForm">
                        <i class="bi bi-plus me-1"></i>Attach
                    </button>
                </div>
                @if (showCacheAttachForm)
                {
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(cacheBindingError)) { <div class="alert alert-danger py-1 small mb-2">@cacheBindingError</div> }
                        <div class="row g-2 mb-2">
                            <div class="col-md-4">
                                <label class="form-label small">Deployment</label>
                                <select class="form-select form-select-sm" @bind="newCacheAttachDeploymentId">
                                    <option value="@Guid.Empty">Select deployment…</option>
                                    @foreach (AppDeployment dep in deployments ?? [])
                                    {
                                        <option value="@dep.Id">@dep.Name (@dep.Namespace)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Redis Cluster</label>
                                <select class="form-select form-select-sm" @bind="newCacheBindingClusterId">
                                    <option value="@Guid.Empty">Select cluster…</option>
                                    @if (availableRedisClusters is not null)
                                    {
                                        @foreach (RedisCluster rc in availableRedisClusters)
                                        {
                                            <option value="@rc.Id">@rc.Name (@rc.Namespace)</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">K8s Secret name</label>
                                <input class="form-control form-control-sm" @bind="newCacheBindingSecretName" placeholder="redis-cache" />
                            </div>
                        </div>
                        <div class="d-flex gap-1">
                            <button class="btn btn-sm btn-warning" @onclick="AddCacheBindingAppLevel"
                                    disabled="@(newCacheAttachDeploymentId == Guid.Empty || newCacheBindingClusterId == Guid.Empty || string.IsNullOrWhiteSpace(newCacheBindingSecretName))">
                                Attach &amp; Sync
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => showCacheAttachForm = false">Cancel</button>
                        </div>
                    </div>
                }
            </div>
        }

        @if (!cacheBindingsByDeployment.Values.Any(b => b.Count > 0))
        {
            <EmptyState Icon="bi-lightning" Message="No Redis cache connections are configured for this app's deployments." />
        }
        else
        {
            @foreach (AppDeployment deployment in deployments ?? [])
            {
                List<CacheBinding> bindings = cacheBindingsByDeployment.GetValueOrDefault(deployment.Id, []);
                if (bindings.Count == 0) continue;
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-white py-2">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-rocket-takeoff text-primary"></i>
                            <strong>@deployment.Name</strong>
                            <span class="text-muted small">
                                <i class="bi bi-hdd-network me-1"></i>@deployment.Cluster?.Name
                                <i class="bi bi-box ms-2 me-1"></i>@deployment.Namespace
                            </span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Redis Cluster</th>
                                        <th>K8s Secret</th>
                                        <th>Last Synced</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (CacheBinding binding in bindings)
                                    {
                                        <tr>
                                            <td>
                                                <i class="bi bi-lightning text-warning me-1"></i>
                                                <span class="fw-medium">@binding.RedisCluster.Name</span>
                                                @if (binding.RedisCluster.KubernetesCluster is not null)
                                                {
                                                    <br /><small class="text-muted">@binding.RedisCluster.KubernetesCluster.Name</small>
                                                }
                                            </td>
                                            <td>
                                                <code class="small">@binding.KubernetesSecretName</code>
                                                <br /><small class="text-muted">@deployment.Namespace</small>
                                            </td>
                                            <td>
                                                @if (binding.LastSyncedAt is not null)
                                                { <small class="text-muted">@binding.LastSyncedAt.Value.ToString("MMM d, HH:mm")</small> }
                                                else
                                                { <span class="badge bg-warning text-dark small">Never synced</span> }
                                            </td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-success me-1"
                                                        @onclick="() => SyncCacheBinding(binding)"
                                                        disabled="@syncingBindingIds.Contains(binding.Id)">
                                                    @if (syncingBindingIds.Contains(binding.Id))
                                                    { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                    else { <i class="bi bi-cloud-arrow-up me-1"></i> }
                                                    Sync
                                                </button>
                                                @if (!IsPortalView)
                                                {
                                                    @if (confirmRemoveCacheBindingId == binding.Id)
                                                    {
                                                        <button class="btn btn-sm btn-danger me-1" @onclick="() => RemoveCacheBindingAppLevel(binding.Id)">Detach</button>
                                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => confirmRemoveCacheBindingId = null">Cancel</button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => confirmRemoveCacheBindingId = binding.Id" title="Detach">
                                                            <i class="bi bi-x-circle"></i>
                                                        </button>
                                                    }
                                                }
                                                @if (bindingSyncErrors.TryGetValue(binding.Id, out string? cacheErr) && cacheErr is not null)
                                                { <div class="text-danger small mt-1">@cacheErr</div> }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        }
    }
}

@* ══════════════════════════════════════════════════════
   Storage tab
   ══════════════════════════════════════════════════════ *@
@if (section == "storage")
{
    @if (!storageBindingsLoaded)
    {
        <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else
    {
        @if (!IsPortalView)
        {
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-white py-2">
                    <i class="bi bi-plus-circle me-1 text-primary"></i><strong>Attach Storage</strong>
                </div>
                <div class="card-body">
                    @if (storageBindingError is not null) { <div class="alert alert-danger py-1 small mb-2">@storageBindingError</div> }
                    <div class="row g-2 mb-2">
                        <div class="col-md-4">
                            <label class="form-label small">Deployment</label>
                            <select class="form-select form-select-sm" @bind="newStorageDeploymentId">
                                <option value="@Guid.Empty">Select deployment…</option>
                                @foreach (AppDeployment dep in deployments ?? [])
                                {
                                    <option value="@dep.Id">@dep.Name (@dep.Namespace)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Storage Link</label>
                            <select class="form-select form-select-sm" @bind="newStorageLinkId">
                                <option value="@Guid.Empty">Select storage link…</option>
                                @foreach (StorageLink link in availableStorageLinks)
                                {
                                    <option value="@link.Id">@link.Name (@link.Provider)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">K8s Secret name</label>
                            <input class="form-control form-control-sm" @bind="newStorageSecretName" placeholder="e.g. s3-creds" />
                        </div>
                    </div>
                    <div class="d-flex gap-1">
                        <button class="btn btn-sm btn-info" @onclick="AddStorageBinding"
                                disabled="@(addingStorageBinding || newStorageDeploymentId == Guid.Empty || newStorageLinkId == Guid.Empty || string.IsNullOrWhiteSpace(newStorageSecretName))">
                            @if (addingStorageBinding) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Attach
                        </button>
                    </div>
                </div>
            </div>
        }

        @if (!storageBindingsByDeployment.Values.Any(b => b.Count > 0))
        {
            <EmptyState Icon="bi-bucket" Message="No storage buckets are connected to this app's deployments." />
        }
        else
        {
            @foreach (AppDeployment deployment in deployments ?? [])
            {
                List<StorageBinding> bindings = storageBindingsByDeployment.GetValueOrDefault(deployment.Id, []);
                if (bindings.Count == 0) continue;
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-white py-2">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-rocket-takeoff text-primary"></i>
                            <strong>@deployment.Name</strong>
                            <span class="text-muted small">
                                <i class="bi bi-hdd-network me-1"></i>@deployment.Cluster?.Name
                                <i class="bi bi-box ms-2 me-1"></i>@deployment.Namespace
                            </span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Provider</th>
                                        <th>Bucket</th>
                                        <th>K8s Secret</th>
                                        <th>Linked</th>
                                        @if (!IsPortalView) { <th class="text-end">Actions</th> }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (StorageBinding binding in bindings)
                                    {
                                        <tr>
                                            <td>
                                                <span class="badge bg-info-subtle text-info border border-info-subtle">
                                                    <i class="bi bi-bucket me-1"></i>@binding.StorageLink.Provider
                                                </span>
                                            </td>
                                            <td>
                                                <span class="fw-medium">@binding.StorageLink.Name</span>
                                                @if (!string.IsNullOrWhiteSpace(binding.StorageLink.BucketName))
                                                {
                                                    <br /><code class="small text-muted">@binding.StorageLink.BucketName</code>
                                                }
                                            </td>
                                            <td>
                                                <code class="small">@binding.KubernetesSecretName</code>
                                                <br /><small class="text-muted">@deployment.Namespace</small>
                                            </td>
                                            <td>
                                                <small class="text-muted">@binding.CreatedAt.ToString("MMM d, HH:mm")</small>
                                            </td>
                                            @if (!IsPortalView)
                                            {
                                                <td class="text-end">
                                                    @if (confirmUnbindStorageId == binding.Id)
                                                    {
                                                        <button class="btn btn-sm btn-danger me-1" @onclick="() => UnbindStorage(binding.Id)">Unlink</button>
                                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => confirmUnbindStorageId = null">Cancel</button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => confirmUnbindStorageId = binding.Id" title="Unlink storage">
                                                            <i class="bi bi-x-circle"></i>
                                                        </button>
                                                    }
                                                    @if (storageBindingSyncErrors.TryGetValue(binding.Id, out string? stErr) && stErr is not null)
                                                    { <div class="text-danger small mt-1">@stErr</div> }
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        }
    }
}

@* ══════════════════════════════════════════════════════
   Identity tab — Keycloak OIDC client bindings
   ══════════════════════════════════════════════════════ *@
@if (section == "identity")
{
    @if (!identityBindingsLoaded)
    {
        <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (identityLoadError is not null)
    {
        <div class="alert alert-danger small">
            <i class="bi bi-exclamation-triangle me-1"></i>
            Failed to load identity bindings: <code>@identityLoadError</code>
            <br /><small class="text-muted mt-1 d-block">A pending database migration may not have run yet. Restarting the application will apply it automatically.</small>
        </div>
    }
    else
    {
        @if (identityRealm is null)
        {
            @if (!IsPortalView && availableRealmsForLinking.Count > 0)
            {
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-white py-2">
                        <i class="bi bi-link-45deg me-1 text-primary"></i><strong>Link a Keycloak Realm</strong>
                    </div>
                    <div class="card-body">
                        @if (linkRealmError is not null)
                        {
                            <div class="alert alert-danger py-1 small mb-2">@linkRealmError</div>
                        }
                        <div class="d-flex align-items-end gap-2">
                            <div>
                                <label class="form-label small">Realm</label>
                                <select class="form-select form-select-sm" @bind="newIdentityLinkRealmId">
                                    <option value="@Guid.Empty">Select realm…</option>
                                    @foreach (KeycloakRealm r in availableRealmsForLinking.Where(r => r.LinkedAppId is null))
                                    {
                                        <option value="@r.Id">@r.DisplayName (@r.RealmName)</option>
                                    }
                                </select>
                            </div>
                            <button class="btn btn-sm btn-primary" @onclick="LinkRealmToApp"
                                    disabled="@(linkingRealm || newIdentityLinkRealmId == Guid.Empty)">
                                @if (linkingRealm) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Link Realm
                            </button>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info small">
                    <i class="bi bi-info-circle me-1"></i>
                    No Keycloak realm is linked to this app. Link a realm from the
                    <strong>Identity</strong> tab in the tenant admin view.
                </div>
            }
        }
        else if (!IsPortalView)
        {
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-white py-2">
                    <i class="bi bi-plus-circle me-1 text-primary"></i><strong>Attach OIDC Client</strong>
                    <small class="text-muted ms-2">Realm: <code>@identityRealm.RealmName</code></small>
                </div>
                <div class="card-body">
                    @if (identityBindingError is not null)
                    {
                        <div class="alert alert-danger py-1 small mb-2">@identityBindingError</div>
                    }
                    @if (clientsLoadError is not null)
                    {
                        <div class="alert alert-warning py-1 small mb-2">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Could not load OIDC clients from Keycloak: <code>@clientsLoadError</code>
                        </div>
                    }
                    <div class="row g-2 mb-2">
                        <div class="col-md-3">
                            <label class="form-label small">Deployment</label>
                            <select class="form-select form-select-sm" @bind="newIdentityDeploymentId">
                                <option value="@Guid.Empty">Select deployment…</option>
                                @foreach (AppDeployment dep in deployments ?? [])
                                {
                                    <option value="@dep.Id">@dep.Name (@dep.Namespace)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small">OIDC Client</label>
                            @if (loadingIdentityClients)
                            {
                                <div class="mt-1"><span class="spinner-border spinner-border-sm text-primary"></span></div>
                            }
                            else
                            {
                                <select class="form-select form-select-sm" @bind="newIdentityClientUuid">
                                    <option value="">Select client…</option>
                                    @foreach (KeycloakClientInfo client in availableIdentityClients)
                                    {
                                        <option value="@client.Id">@client.ClientId@(string.IsNullOrEmpty(client.Name) ? "" : $" — {client.Name}")</option>
                                    }
                                </select>
                            }
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small">K8s Secret name</label>
                            <input class="form-control form-control-sm" @bind="newIdentitySecretName" placeholder="e.g. oidc-credentials" />
                        </div>
                    </div>
                    <button class="btn btn-sm btn-primary" @onclick="AddIdentityBinding"
                            disabled="@(addingIdentityBinding || newIdentityDeploymentId == Guid.Empty || string.IsNullOrWhiteSpace(newIdentityClientUuid) || string.IsNullOrWhiteSpace(newIdentitySecretName))">
                        @if (addingIdentityBinding) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Attach
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-info small mb-3">
                <i class="bi bi-shield-lock me-1"></i>
                Realm <code>@identityRealm.RealmName</code> is linked to this app.
                OIDC client bindings are managed by your administrator.
            </div>
        }

        @if (!identityBindingsByDeployment.Values.Any(b => b.Count > 0) && (identityRealm is null || IsPortalView))
        {
            <EmptyState Icon="bi-shield-lock" Message="No OIDC clients are connected to this app's deployments." />
        }
        else
        {
            @foreach (AppDeployment deployment in deployments ?? [])
            {
                List<IdentityBinding> bindings = identityBindingsByDeployment.GetValueOrDefault(deployment.Id, []);
                if (bindings.Count == 0) continue;
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-white py-2">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-rocket-takeoff text-primary"></i>
                            <strong>@deployment.Name</strong>
                            <span class="text-muted small">
                                <i class="bi bi-hdd-network me-1"></i>@deployment.Cluster?.Name
                                <i class="bi bi-box ms-2 me-1"></i>@deployment.Namespace
                            </span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Client</th>
                                        <th>Realm</th>
                                        <th>K8s Secret</th>
                                        <th>Last Synced</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (IdentityBinding binding in bindings)
                                    {
                                        <tr>
                                            <td>
                                                <span class="fw-medium font-monospace small">@binding.ClientId</span>
                                            </td>
                                            <td>
                                                <code class="small">@binding.KeycloakRealm.RealmName</code>
                                            </td>
                                            <td>
                                                <code class="small">@binding.KubernetesSecretName</code>
                                                <br /><small class="text-muted">@deployment.Namespace</small>
                                            </td>
                                            <td>
                                                @if (binding.LastSyncedAt.HasValue)
                                                {
                                                    <small class="text-success"><i class="bi bi-check-circle me-1"></i>@binding.LastSyncedAt.Value.ToString("MMM d, HH:mm")</small>
                                                }
                                                else
                                                {
                                                    <small class="text-muted">Never</small>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-primary me-1"
                                                        @onclick="() => SyncIdentityBinding(binding)"
                                                        disabled="@syncingBindingIds.Contains(binding.Id)"
                                                        title="Sync to K8s">
                                                    @if (syncingBindingIds.Contains(binding.Id))
                                                    { <span class="spinner-border spinner-border-sm"></span> }
                                                    else
                                                    { <i class="bi bi-cloud-arrow-up"></i> }
                                                </button>
                                                @if (identityBindingSyncErrors.TryGetValue(binding.Id, out string? idErr) && idErr is not null)
                                                {
                                                    <div class="text-danger small mt-1">@idErr</div>
                                                }
                                                @if (!IsPortalView)
                                                {
                                                    @if (confirmDetachIdentityId == binding.Id)
                                                    {
                                                        <button class="btn btn-sm btn-danger me-1" @onclick="() => DetachIdentityBinding(binding.Id)">Detach</button>
                                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => confirmDetachIdentityId = null">Cancel</button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => confirmDetachIdentityId = binding.Id" title="Detach">
                                                            <i class="bi bi-x-circle"></i>
                                                        </button>
                                                    }
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        }
    }
}

@* ══════════════════════════════════════════════════════
   VPN tab — Tailscale Kubernetes Operator
   ══════════════════════════════════════════════════════ *@
@if (section == "vpn")
{
    <TailscaleVpnTab TenantId="TenantId" AppId="App.Id" EnvironmentId="Environment.Id" />
}

@code {
    [Parameter] public required Data.App App { get; set; }
    [Parameter] public required Data.Environment Environment { get; set; }
    [Parameter] public Guid TenantId { get; set; }
    [Parameter] public bool IsPortalView { get; set; }
    [Parameter] public CustomerAccessRole AccessRole { get; set; } = CustomerAccessRole.Admin;
    [Parameter] public EventCallback OnBack { get; set; }

    /// When set, the view opens straight into this deployment's detail (used by the
    /// portal log viewer's "Go to deployment" action) instead of the deployment list.
    [Parameter] public Guid? InitialDeploymentId { get; set; }

    private string section = "deployments";

    // Governance
    private string? governanceNamespace;

    // Deployments
    private List<AppDeployment>? deployments;
    private List<KubernetesCluster>? envClusters;
    private AppDeployment? selectedDeployment;
    private string deploymentSection = "manifests";
    private bool IsGitManaged => selectedDeployment?.Type is
        DeploymentType.GitYaml or DeploymentType.GitHelm or DeploymentType.GitAppOfApps;
    private bool confirmDeleteDeployment;

    // Create deployment form
    private bool showCreateDeployment;
    private string newDeployName = "";
    private DeploymentType newDeployType = DeploymentType.Manual;
    private Guid newDeployClusterId;
    private string newDeployNamespace = "";
    private string newHelmRepoUrl = "", newHelmChartName = "", newHelmChartVersion = "";
    private string? createDeployError;
    private string newGitUrl = "";
    private string? newGitUrlError;
    private string newGitPath = ".", newGitRevision = "";
    private bool newGitAutoSync = true;

    // Git sync
    private bool syncingGit;
    private string? gitSyncResult;
    private bool gitSyncSuccess;

    // Edit deployment
    private bool showEditDeployment;
    private string editDeployName = "", editDeployNamespace = "";
    private string editHelmRepoUrl = "", editHelmChartName = "", editHelmChartVersion = "";
    private string? editDeployError;

    // Edit git settings
    private bool showEditGitSettings;
    private string editGitUrl = "";
    private string? editGitUrlError;
    private string editGitPath = ".";
    private string editGitRevision = "";
    private bool editGitAutoSync = true;
    private string? editGitError;
    private bool savingGitSettings;

    // Manifests
    private List<DeploymentManifest>? manifests;
    private bool showAddManifest, savingManifest;
    private string newManifestKind = "", newManifestName = "", newManifestYaml = "";
    private int newManifestSortOrder;
    private Guid? editingManifestId, confirmDeleteManifestId;
    private string editManifestYaml = "";

    // Helm
    private string helmValuesYaml = "";
    private bool savingHelmValues, helmValuesSaved, installingHelm;
    private bool? helmInstallSuccess;
    private string? helmInstallOutput, helmValuesError;

    // YAML apply
    private bool applyingYaml;
    private bool? yamlApplySuccess;
    private string? yamlApplyOutput;

    // Resource tree (per-deployment)
    private List<DeploymentResource>? resourceTree;
    private string? resourcesError;
    private DateTime? resourceTreeRefreshedAt;

    // Deployment metrics
    private DeploymentMetricsSummary? deploymentMetrics;
    private bool deploymentMetricsLoading;
    private string? deploymentMetricsError;

    // Activity
    private List<AuditEvent>? deploymentAuditEvents;
    private bool activityLoading;

    // Env-aggregate metrics
    private DeploymentMetricsSummary? envMetrics;
    private bool envMetricsLoading;
