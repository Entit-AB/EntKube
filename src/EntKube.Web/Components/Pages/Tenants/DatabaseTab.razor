                            </div>
                            <div class="col-md-4 d-flex gap-2">
                                <button class="btn btn-sm btn-secondary" @onclick="ExecuteMongoUpgrade" disabled="@mongoUpgrading">
                                    @if (mongoUpgrading) { <span class="spinner-border spinner-border-sm me-1"></span> }
