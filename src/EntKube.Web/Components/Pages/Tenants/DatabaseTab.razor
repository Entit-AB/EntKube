            var names = new HashSet<string>(StringComparer.Ordinal);
            if (managedClusters is not null)
                foreach (var c in managedClusters.Where(c => InScope(c.KubernetesClusterId))) names.Add(c.KubernetesCluster.Environment.Name);
            if (managedMongoClusters is not null)
                foreach (var c in managedMongoClusters.Where(c => InScope(c.KubernetesClusterId))) names.Add(c.KubernetesCluster.Environment.Name);
            if (registeredPgInstances is not null)
                foreach (var i in registeredPgInstances.Where(i => InScope(i.KubernetesClusterId))) names.Add(i.KubernetesCluster.Environment.Name);
            return names.OrderBy(n => n).ToList();
        }
