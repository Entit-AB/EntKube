                                <div class="form-text small">Leave blank to keep current (@mongoResizeCluster.StorageSize)</div>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small">CPU Request</label>
                                <input class="form-control form-control-sm font-monospace"
