    // K8s cluster ids belonging to the scoped environment (empty when not scoped / not yet loaded).
    private HashSet<Guid> EnvClusterIds =>
        EnvironmentId is null || allClusters is null
            ? new HashSet<Guid>()
            : allClusters.Where(c => c.EnvironmentId == EnvironmentId.Value).Select(c => c.Id).ToHashSet();

    // True when the resource's Kubernetes cluster is in scope (always true when not env-scoped).
    private bool InScope(Guid kubernetesClusterId) =>
        EnvironmentId is null || EnvClusterIds.Contains(kubernetesClusterId);

    // Returns the sole env cluster's id for preselection, or Guid.Empty otherwise.
    private Guid PreselectEnvCluster(IEnumerable<KubernetesCluster>? clusters)
    {
        if (EnvironmentId is null || clusters is null) return Guid.Empty;
        var envList = clusters.Where(c => c.EnvironmentId == EnvironmentId.Value).ToList();
        return envList.Count == 1 ? envList[0].Id : Guid.Empty;
    }

