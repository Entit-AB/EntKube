@using EntKube.Web.Data
@using EntKube.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject OperationsAdvisorService Advisor
@inject AdvisorStateService State
@inject AdvisorDigestConfigService DigestConfig
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

@* Operations Advisor: turns raw signals (expiring secrets, open incidents, stale
   backups) into one prioritized "what needs doing" feed, bucketed by time-to-impact.
   Two lenses over the same findings — Ops (everything) and Customer (per-customer). *@

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h5 class="mb-0"><i class="bi bi-lightbulb me-2"></i>Operations Advisor</h5>
        <small class="text-muted">What needs doing — and by when — across security, reliability, and data protection.</small>
    </div>
    <AutoRefresh OnRefresh="Reload" IntervalSeconds="60" Enabled="true" LastRefreshed="lastRefreshed" />
</div>

@if (loadError is not null)
{
    <div class="alert alert-danger py-2 d-flex justify-content-between align-items-center">
        <span>@loadError</span>
        <button class="btn btn-sm btn-outline-danger" @onclick="Reload">Retry</button>
    </div>
}
else if (report is null)
{
    <div class="text-center py-4">
        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        <p class="text-muted small mt-2 mb-0">Analyzing signals…</p>
    </div>
}
else
{
    @* ── Lens switch ── *@
    <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
        <div class="btn-group btn-group-sm" role="group">
            <button class="btn @(lens == Lens.Ops ? "btn-primary" : "btn-outline-primary")"
                    @onclick="() => SetLens(Lens.Ops)">
                <i class="bi bi-hdd-network me-1"></i>Ops
            </button>
            <button class="btn @(lens == Lens.Customer ? "btn-primary" : "btn-outline-primary")"
                    @onclick="() => SetLens(Lens.Customer)">
                <i class="bi bi-people me-1"></i>Customer
            </button>
        </div>
        @if (lens == Lens.Customer)
        {
            <select class="form-select form-select-sm w-auto" @bind="selectedCustomer" @bind:after="StateHasChanged">
                <option value="@Guid.Empty">All customers</option>
                @foreach ((Guid id, string name) in report.Customers)
                {
                    <option value="@id">@name</option>
                }
            </select>
            <span class="text-muted small">Showing only findings a customer can act on.</span>
        }
        <div class="form-check form-switch ms-auto">
            <input class="form-check-input" type="checkbox" id="showResolved" @bind="showResolved" @bind:after="StateHasChanged" />
            <label class="form-check-label small text-muted" for="showResolved">Show snoozed &amp; dismissed</label>
        </div>
        <button class="btn btn-sm btn-outline-secondary" title="Digest settings"
                @onclick="() => showDigestSettings = !showDigestSettings">
            <i class="bi bi-envelope-gear"></i>
        </button>
    </div>

    @if (showDigestSettings && digestCfg is not null)
    {
        <div class="card mb-3">
            <div class="card-body py-2">
                <div class="d-flex flex-wrap align-items-end gap-2">
                    <div>
                        <label class="form-label small mb-0">Digest</label>
                        <select class="form-select form-select-sm" @bind="digestCfg.Frequency">
                            <option value="@DigestFrequency.Off">Off</option>
                            <option value="@DigestFrequency.Daily">Daily</option>
                            <option value="@DigestFrequency.Weekly">Weekly</option>
                        </select>
                    </div>
                    @if (digestCfg.Frequency == DigestFrequency.Weekly)
                    {
                        <div>
                            <label class="form-label small mb-0">Day</label>
                            <select class="form-select form-select-sm" @bind="digestCfg.WeeklyDay">
                                @foreach (DayOfWeek d in Enum.GetValues<DayOfWeek>())
                                {
                                    <option value="@d">@d</option>
                                }
                            </select>
                        </div>
                    }
                    @if (digestCfg.Frequency != DigestFrequency.Off)
                    {
                        <div>
                            <label class="form-label small mb-0">Hour (UTC)</label>
                            <input type="number" min="0" max="23" class="form-control form-control-sm" style="width:5rem"
                                   @bind="digestCfg.HourUtc" />
                        </div>
                    }
                    <button class="btn btn-sm btn-primary" @onclick="SaveDigest" disabled="@savingDigest">
                        @if (savingDigest) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Save
                    </button>
                    <span class="text-muted small">
                        Summary of overdue &amp; due-today items sent to this tenant's notification channels.
                        @if (digestCfg.LastSentAt is not null) { <text>Last sent @digestCfg.LastSentAt.Value.ToString("MMM d HH:mm") UTC.</text> }
                    </span>
                </div>
            </div>
        </div>
    }

    @* ── Summary strip: counts by time horizon ── *@
    <div class="d-flex flex-wrap gap-2 mb-4">
        @foreach (AdvisorHorizon h in Horizons)
        {
            int n = VisibleFindings.Count(f => f.Horizon == h);
            (string label, string _, string tone) = HorizonMeta(h);
            <div class="card border-0 text-center px-3 py-2 @(n > 0 ? tone : "bg-light")"
                 style="min-width:9rem">
                <div class="fw-bold fs-4">@n</div>
                <div class="text-muted small">@label</div>
            </div>
        }
        <div class="card border-0 bg-light text-center px-3 py-2" style="min-width:7rem">
            <div class="fw-bold fs-4 @(VisibleFindings.Any(f => f.Severity == AdvisorSeverity.Critical) ? "text-danger" : "")">
                @VisibleFindings.Count(f => f.Severity == AdvisorSeverity.Critical)
            </div>
            <div class="text-muted small">Critical</div>
        </div>
    </div>

    @if (VisibleFindings.Count == 0)
    {
        <EmptyState Icon="bi-check2-circle" Title="All clear"
                    Message="@(lens == Lens.Customer ? "No open items for this customer." : "No open findings across secrets, incidents, or backups. Nice.")" />
    }
    else
    {
        @foreach (AdvisorHorizon h in Horizons)
        {
            List<OperationsFinding> bucket = VisibleFindings.Where(f => f.Horizon == h).ToList();
            if (bucket.Count == 0) continue;
            (string label, string icon, string tone) = HorizonMeta(h);

            <div class="card mb-3">
                <div class="card-header d-flex align-items-center gap-2 @tone">
                    <i class="bi @icon"></i>
                    <span class="fw-semibold">@label</span>
                    <span class="badge bg-secondary-subtle text-secondary border ms-1">@bucket.Count</span>
                    <span class="text-muted small ms-1">@HorizonHint(h)</span>
                </div>
                <div class="list-group list-group-flush">
                    @foreach (OperationsFinding f in bucket)
                    {
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center gap-2 flex-wrap">
                                        <span class="badge @SeverityClass(f.Severity)">@f.Severity</span>
                                        <span class="badge bg-light text-muted border"><i class="bi @CategoryIcon(f.Category) me-1"></i>@CategoryLabel(f.Category)</span>
                                        @if (f.IsNew)
                                        {
                                            <span class="badge bg-info-subtle text-info border border-info-subtle"><i class="bi bi-stars me-1"></i>New</span>
                                        }
                                        @if (f.IsEscalated)
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-fire me-1"></i>Escalated · @f.AgeDays d</span>
                                        }
                                        @if (f.State == AdvisorFindingStatus.Acknowledged)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle"><i class="bi bi-check2 me-1"></i>Ack’d@(string.IsNullOrWhiteSpace(f.AcknowledgedBy) ? "" : " · " + f.AcknowledgedBy)</span>
                                        }
                                        @if (f.State == AdvisorFindingStatus.Snoozed && f.SnoozedUntil is not null)
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary border"><i class="bi bi-moon me-1"></i>Snoozed → @f.SnoozedUntil.Value.ToString("MMM d")</span>
                                        }
                                        @if (f.State == AdvisorFindingStatus.Dismissed)
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary border"><i class="bi bi-slash-circle me-1"></i>Dismissed</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(f.AssignedTo))
                                        {
                                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle"><i class="bi bi-person me-1"></i>@f.AssignedTo</span>
                                        }
                                        <span class="fw-semibold">@f.Title</span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(f.Detail))
                                    {
                                        <div class="text-muted small mt-1">@f.Detail</div>
                                    }
                                    <div class="small mt-1 d-flex flex-wrap gap-3">
                                        <span class="text-muted"><i class="bi bi-diagram-2 me-1"></i>@f.ScopeLabel</span>
                                        @if (!string.IsNullOrWhiteSpace(f.TimingText))
                                        {
                                            <span class="text-muted"><i class="bi bi-clock-history me-1"></i>@f.TimingText</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(f.Remediation))
                                    {
                                        <div class="small mt-1">
                                            <i class="bi bi-arrow-return-right me-1 text-primary"></i>@f.Remediation
                                            @if (!string.IsNullOrWhiteSpace(f.RunbookUrl))
                                            {
                                                <a href="@f.RunbookUrl" target="_blank" rel="noopener noreferrer" class="ms-1">
                                                    <i class="bi bi-journal-text me-1"></i>Runbook<i class="bi bi-box-arrow-up-right ms-1"></i>
                                                </a>
                                            }
                                        </div>
                                    }
                                </div>
                                <div class="d-flex flex-column align-items-end gap-1 flex-shrink-0">
                                    @if (f.IncidentId is not null)
                                    {
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenIncident(f.IncidentId!.Value)">
                                            Open <i class="bi bi-arrow-right ms-1"></i>
                                        </button>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(f.LinkSection) && OnNavigateTab.HasDelegate)
                                    {
                                        <button class="btn btn-sm btn-outline-primary"
                                                @onclick="() => OnNavigateTab.InvokeAsync(f.LinkSection)">
                                            Go <i class="bi bi-arrow-right ms-1"></i>
                                        </button>
                                    }
                                    <div class="btn-group btn-group-sm" role="group">
                                        @if (f.State == AdvisorFindingStatus.Active)
                                        {
                                            <button class="btn btn-outline-secondary" title="Acknowledge — mark as being handled"
                                                    @onclick="() => Acknowledge(f)"><i class="bi bi-check2"></i></button>
                                        }
                                        <button class="btn btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown"
                                                title="Snooze"><i class="bi bi-moon"></i></button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li><button class="dropdown-item" @onclick="() => Snooze(f, 1)">Snooze 1 day</button></li>
                                            <li><button class="dropdown-item" @onclick="() => Snooze(f, 3)">Snooze 3 days</button></li>
                                            <li><button class="dropdown-item" @onclick="() => Snooze(f, 7)">Snooze 1 week</button></li>
                                        </ul>
                                        @if (f.State != AdvisorFindingStatus.Dismissed)
                                        {
                                            <button class="btn btn-outline-secondary" title="Dismiss — accept/ignore"
                                                    @onclick="() => Dismiss(f)"><i class="bi bi-slash-circle"></i></button>
                                        }
                                        @if (f.State != AdvisorFindingStatus.Active)
                                        {
                                            <button class="btn btn-outline-secondary" title="Reactivate"
                                                    @onclick="() => Reactivate(f)"><i class="bi bi-arrow-counterclockwise"></i></button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
}

@code {
    [Parameter, EditorRequired] public Guid TenantId { get; set; }

    /// <summary>Deep-links a finding to the relevant tenant-explorer section.</summary>
    [Parameter] public EventCallback<string> OnNavigateTab { get; set; }

    private enum Lens { Ops, Customer }

    private AdvisorReport? report;
    private string? loadError;
    private DateTime? lastRefreshed;
    private Lens lens = Lens.Ops;
    private Guid selectedCustomer = Guid.Empty;
    private bool showResolved;
    private string currentUser = "Unknown";
    private bool showDigestSettings;
    private bool savingDigest;
    private AdvisorDigestConfig? digestCfg;

    // Findings after the active lens/customer filter — recomputed per render; lists are small.
    private List<OperationsFinding> VisibleFindings =>
        report is null ? [] : Filter(report.Findings).ToList();

    private static readonly AdvisorHorizon[] Horizons =
        [AdvisorHorizon.Overdue, AdvisorHorizon.Today, AdvisorHorizon.ThisWeek, AdvisorHorizon.Later];

    protected override async Task OnInitializedAsync()
    {
        AuthenticationState auth = await AuthState.GetAuthenticationStateAsync();
        currentUser = auth.User.Identity?.Name ?? "Unknown";
        digestCfg = await DigestConfig.GetAsync(TenantId);
        await Reload();
    }

    private async Task SaveDigest()
    {
        if (digestCfg is null) return;
        savingDigest = true;
        try
        {
            await DigestConfig.SaveAsync(TenantId, digestCfg.Frequency, digestCfg.HourUtc, digestCfg.WeeklyDay);
            digestCfg = await DigestConfig.GetAsync(TenantId);
            showDigestSettings = false;
        }
        finally { savingDigest = false; }
    }

    // Deep-link straight to the incident's detail on this same tenant page — the finding
    // already knows the exact incident, so no drilling through the list.
    private void OpenIncident(Guid incidentId) =>
        Nav.NavigateTo(Nav.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["section"] = "incidents",
            ["incident"] = incidentId,
            ["app"] = null,
            ["cluster"] = null,
            ["env"] = null,
        }));

    private async Task Acknowledge(OperationsFinding f) { await State.AcknowledgeAsync(TenantId, f.Id, currentUser); await Reload(); }
    private async Task Snooze(OperationsFinding f, int days) { await State.SnoozeAsync(TenantId, f.Id, DateTime.UtcNow.AddDays(days), currentUser); await Reload(); }
    private async Task Dismiss(OperationsFinding f) { await State.DismissAsync(TenantId, f.Id, currentUser); await Reload(); }
    private async Task Reactivate(OperationsFinding f) { await State.ReactivateAsync(TenantId, f.Id); await Reload(); }

    private async Task Reload()
    {
        loadError = null;
        try
        {
            report = await Advisor.GetReportAsync(TenantId);
            lastRefreshed = DateTime.UtcNow;
        }
        catch (Exception ex)
        {
            loadError = $"Could not analyze signals: {ex.Message}";
        }
        StateHasChanged();
    }

    private void SetLens(Lens l)
    {
        lens = l;
        if (l == Lens.Ops) selectedCustomer = Guid.Empty;
    }

    private IEnumerable<OperationsFinding> Filter(IEnumerable<OperationsFinding> all)
    {
        IEnumerable<OperationsFinding> q = all;

        if (lens == Lens.Customer)
        {
            q = q.Where(f => f.CustomerId is not null);
            if (selectedCustomer != Guid.Empty)
                q = q.Where(f => f.CustomerId == selectedCustomer);
        }

        // Hide dismissed and still-snoozed items unless the user opts to see them.
        if (!showResolved)
        {
            DateTime now = DateTime.UtcNow;
            q = q.Where(f => f.State != AdvisorFindingStatus.Dismissed
                          && !(f.State == AdvisorFindingStatus.Snoozed && f.SnoozedUntil > now));
        }

        return q;
    }

    private static (string Label, string Icon, string Tone) HorizonMeta(AdvisorHorizon h) => h switch
    {
        AdvisorHorizon.Overdue => ("Overdue", "bi-exclamation-octagon-fill", "bg-danger-subtle text-danger"),
        AdvisorHorizon.Today => ("Today", "bi-exclamation-triangle-fill", "bg-warning-subtle text-warning-emphasis"),
        AdvisorHorizon.ThisWeek => ("This week", "bi-calendar-week", "bg-info-subtle text-info-emphasis"),
        _ => ("Coming up", "bi-hourglass-split", "bg-light text-muted"),
    };

    private static string HorizonHint(AdvisorHorizon h) => h switch
    {
        AdvisorHorizon.Overdue => "should already have been done",
        AdvisorHorizon.Today => "act within ~48 hours",
        AdvisorHorizon.ThisWeek => "within the next week",
        _ => "on the radar, no near-term deadline",
    };

    private static string SeverityClass(AdvisorSeverity s) => s switch
    {
        AdvisorSeverity.Critical => "bg-danger",
        AdvisorSeverity.Warning => "bg-warning text-dark",
        _ => "bg-secondary",
    };

    private static string CategoryLabel(AdvisorCategory c) => c switch
    {
        AdvisorCategory.Security => "Security",
        AdvisorCategory.Reliability => "Reliability",
        AdvisorCategory.Capacity => "Capacity",
        _ => "Data protection",
    };

    private static string CategoryIcon(AdvisorCategory c) => c switch
    {
        AdvisorCategory.Security => "bi-shield-lock",
        AdvisorCategory.Reliability => "bi-activity",
        AdvisorCategory.Capacity => "bi-speedometer2",
        _ => "bi-hdd-stack",
    };
}
