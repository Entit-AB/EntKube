@using System.ComponentModel.DataAnnotations
@using EntKube.Web.Data
@using EntKube.Web.Services
@inject OnCallService OnCallService
@inject AuthenticationStateProvider AuthStateProvider
@inject ToastService Toasts

<ConfirmDialog Visible="@(pendingConfirm is not null)"
               Message="@(pendingConfirm?.Message ?? "")"
               ConfirmText="@(pendingConfirm?.ConfirmText ?? "Delete")"
               IsBusy="confirmBusy"
               OnConfirm="RunPendingConfirmAsync"
               OnCancel="() => pendingConfirm = null" />

@* ── Current on-call banner ── *@
@if (currentShift is not null)
{
    <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-3">
        <span class="bi bi-person-check-fill fs-5"></span>
        <div>
            <strong>@currentShift.AssigneeName</strong> is currently on call
            @if (!string.IsNullOrEmpty(currentShift.AssigneeEmail))
            {
                <span class="text-muted ms-1">— <a href="mailto:@currentShift.AssigneeEmail">@currentShift.AssigneeEmail</a></span>
            }
            <span class="text-muted ms-2 small">until @currentShift.EndsAt.ToLocalTime().ToString("MMM d HH:mm")</span>
            <span class="badge bg-success ms-2 small">@currentShift.Schedule.Name</span>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning d-flex align-items-center gap-2 py-2 mb-3">
        <span class="bi bi-person-exclamation fs-5"></span>
        <span>No one is currently on call. Add a shift to cover now.</span>
    </div>
}

@* ── Schedules + Create ── *@
<div class="d-flex justify-content-between align-items-center mb-3">
    <h6 class="mb-0">Schedules</h6>
    <button class="btn btn-sm btn-primary" @onclick="() => showCreateSchedule = !showCreateSchedule">
        <span class="bi bi-plus-circle me-1"></span>New Schedule
    </button>
</div>

@if (showCreateSchedule)
{
    <div class="card border-primary mb-3">
        <div class="card-body">
            <EditForm Model="scheduleForm" OnValidSubmit="CreateSchedule">
                <DataAnnotationsValidator />
                <div class="row g-2 mb-2">
                    <div class="col-md-5">
                        <label class="form-label small">Name</label>
                        <InputText class="form-control form-control-sm" @bind-Value="scheduleForm.Name" placeholder="Primary On-Call" />
                        <ValidationMessage For="() => scheduleForm.Name" class="text-danger small" />
                    </div>
                    <div class="col-md-7">
                        <label class="form-label small">Description</label>
                        <InputText class="form-control form-control-sm" @bind-Value="scheduleForm.Description" placeholder="Optional description" />
                        <ValidationMessage For="() => scheduleForm.Description" class="text-danger small" />
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-primary" disabled="@savingSchedule">
                        @if (savingSchedule) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Create
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => showCreateSchedule = false">Cancel</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (schedules.Count == 0 && !isLoading)
{
    <EmptyState Icon="bi-calendar2-week"
                Title="No schedules"
                Message="Create a schedule to track who is on call." />
}
else
{
    @foreach (OnCallSchedule schedule in schedules)
    {
        bool isExpanded = expandedScheduleId == schedule.Id;
        <div class="card mb-3 @(isExpanded ? "border-primary" : "")">
            <div class="card-header d-flex align-items-center py-2 gap-2" style="cursor:pointer"
                 @onclick="() => ToggleSchedule(schedule.Id)">
                <span class="bi bi-calendar2-week text-primary"></span>
                <strong class="me-auto">@schedule.Name</strong>
                @if (!string.IsNullOrEmpty(schedule.Description))
                {
                    <span class="text-muted small me-2">@schedule.Description</span>
                }
                @if (!schedule.IsEnabled)
                {
                    <span class="badge bg-secondary">Disabled</span>
                }
                else
                {
                    int activeCount = schedule.Shifts.Count(sh => sh.StartsAt <= DateTime.UtcNow && sh.EndsAt >= DateTime.UtcNow);
                    int upcomingCount = schedule.Shifts.Count(sh => sh.StartsAt > DateTime.UtcNow);
                    @if (activeCount > 0)
                    {
                        <span class="badge bg-success">Active now</span>
                    }
                    <span class="text-muted small">@schedule.Shifts.Count shift@(schedule.Shifts.Count == 1 ? "" : "s")</span>
                }
                <button class="btn btn-sm btn-outline-danger ms-2"
                        @onclick:stopPropagation="true"
                        aria-label="@($"Delete schedule {schedule.Name}")"
                        @onclick='() => pendingConfirm = new PendingConfirm($"Delete schedule \"{schedule.Name}\" and all its shifts? This cannot be undone.", "Delete schedule", () => DeleteSchedule(schedule))'>
                    <span class="bi bi-trash"></span>
                </button>
                <span class="bi bi-chevron-@(isExpanded ? "up" : "down") text-muted"></span>
            </div>

            @if (isExpanded)
            {
                <div class="card-body">
                    @* ── Shifts list ── *@
                    @if (schedule.Shifts.Count == 0)
                    {
                        <p class="text-muted small mb-3">No shifts yet. Add the first shift below.</p>
                    }
                    else
                    {
                        <div class="table-responsive mb-3">
                            <table class="table table-sm align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Assignee</th>
                                        <th>Start</th>
                                        <th>End</th>
                                        <th>Status</th>
                                        <th style="width:60px"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (OnCallShift shift in schedule.Shifts.OrderBy(sh => sh.StartsAt))
                                    {
                                        bool active = shift.StartsAt <= DateTime.UtcNow && shift.EndsAt >= DateTime.UtcNow;
                                        bool past = shift.EndsAt < DateTime.UtcNow;
                                        <tr class="@(active ? "table-success" : past ? "text-muted" : "")">
                                            <td>
                                                <div class="fw-semibold small">@shift.AssigneeName</div>
                                                @if (!string.IsNullOrEmpty(shift.AssigneeEmail))
                                                {
                                                    <div class="text-muted" style="font-size:.77rem">@shift.AssigneeEmail</div>
                                                }
                                            </td>
                                            <td class="small">@shift.StartsAt.ToLocalTime().ToString("MMM d HH:mm")</td>
                                            <td class="small">@shift.EndsAt.ToLocalTime().ToString("MMM d HH:mm")</td>
                                            <td>
                                                @if (active)
                                                {
                                                    <span class="badge bg-success">Active</span>
                                                }
                                                else if (past)
                                                {
                                                    <span class="badge bg-secondary">Past</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-info text-dark">Upcoming</span>
                                                }
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-danger"
                                                        aria-label="@($"Delete shift for {shift.AssigneeName}")"
                                                        @onclick='() => pendingConfirm = new PendingConfirm($"Delete the on-call shift for \"{shift.AssigneeName}\"? This cannot be undone.", "Delete shift", () => DeleteShift(shift))'>
                                                    <span class="bi bi-trash"></span>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    @* ── Add shift form ── *@
                    @if (addShiftScheduleId == schedule.Id)
                    {
                        <div class="border rounded p-3 bg-light">
                            <h6 class="mb-2 small fw-semibold">Add Shift</h6>
                            <EditForm Model="shiftForm" OnValidSubmit="() => AddShift(schedule.Id)">
                                <DataAnnotationsValidator />
                                <div class="row g-2 mb-2">
                                    <div class="col-md-4">
                                        <label class="form-label small">Assignee name</label>
                                        <InputText class="form-control form-control-sm" @bind-Value="shiftForm.AssigneeName" placeholder="Alice Smith" />
                                        <ValidationMessage For="() => shiftForm.AssigneeName" class="text-danger small" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small">Email (optional)</label>
                                        <InputText class="form-control form-control-sm" @bind-Value="shiftForm.Email" placeholder="alice@example.com" />
                                        <ValidationMessage For="() => shiftForm.Email" class="text-danger small" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small">Notes</label>
                                        <InputText class="form-control form-control-sm" @bind-Value="shiftForm.Notes" placeholder="Optional notes" />
                                        <ValidationMessage For="() => shiftForm.Notes" class="text-danger small" />
                                    </div>
                                </div>
                                <div class="row g-2 mb-2">
                                    <div class="col-md-4">
                                        <label class="form-label small">Starts at (local time)</label>
                                        <InputDate Type="InputDateType.DateTimeLocal" class="form-control form-control-sm" @bind-Value="shiftForm.StartsAt" />
                                        <ValidationMessage For="() => shiftForm.StartsAt" class="text-danger small" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small">Ends at (local time)</label>
                                        <InputDate Type="InputDateType.DateTimeLocal" class="form-control form-control-sm" @bind-Value="shiftForm.EndsAt" />
                                        <ValidationMessage For="() => shiftForm.EndsAt" class="text-danger small" />
                                    </div>
                                </div>
                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-sm btn-primary" disabled="@savingShift">
                                        @if (savingShift) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                        Add Shift
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CancelAddShift">Cancel</button>
                                </div>
                            </EditForm>
                        </div>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => StartAddShift(schedule.Id)">
                            <span class="bi bi-plus-circle me-1"></span>Add Shift
                        </button>
                    }
                </div>
            }
        </div>
    }
}

@code {
    [Parameter] public required Guid TenantId { get; set; }

    private List<OnCallSchedule> schedules = [];
    private OnCallShift? currentShift;
    private bool isLoading = true;
    private Guid? expandedScheduleId;

    // Create schedule form
    private bool showCreateSchedule;
    private bool savingSchedule;
    private ScheduleForm scheduleForm = new();

    // Add shift form
    private Guid? addShiftScheduleId;
    private bool savingShift;
    private ShiftForm shiftForm = new();

    private sealed class ScheduleForm
    {
        [Required(ErrorMessage = "Name is required.")]
        [StringLength(100, MinimumLength = 1, ErrorMessage = "Name must be 1-100 characters.")]
        public string Name { get; set; } = "";

        [StringLength(500, ErrorMessage = "Description must be 500 characters or fewer.")]
        public string? Description { get; set; }
    }

    private sealed class ShiftForm : IValidatableObject
    {
        [Required(ErrorMessage = "Assignee name is required.")]
        [StringLength(200, MinimumLength = 1, ErrorMessage = "Assignee name must be 1-200 characters.")]
        public string AssigneeName { get; set; } = "";

        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string? Email { get; set; }

        [StringLength(1000, ErrorMessage = "Notes must be 1000 characters or fewer.")]
        public string? Notes { get; set; }

        [Required]
        public DateTime StartsAt { get; set; } = DateTime.Now.Date.AddHours(DateTime.Now.Hour + 1);

        [Required]
        public DateTime EndsAt { get; set; } = DateTime.Now.Date.AddHours(DateTime.Now.Hour + 9);

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (EndsAt <= StartsAt)
                yield return new ValidationResult("End time must be after start time.", new[] { nameof(EndsAt) });
        }
    }

    // A destructive action awaiting user confirmation.
    private sealed record PendingConfirm(string Message, string ConfirmText, Func<Task> Action);
    private PendingConfirm? pendingConfirm;
    private bool confirmBusy;

    private async Task RunPendingConfirmAsync()
    {
        if (pendingConfirm is null) return;
        confirmBusy = true;
        try { await pendingConfirm.Action(); }
        finally { confirmBusy = false; pendingConfirm = null; }
    }

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        isLoading = true;
        Task<List<OnCallSchedule>> schedulesTask = OnCallService.GetSchedulesAsync(TenantId);
        Task<OnCallShift?> currentTask = OnCallService.GetCurrentOnCallAsync(TenantId);
        await Task.WhenAll(schedulesTask, currentTask);
        schedules = schedulesTask.Result;
        currentShift = currentTask.Result;
        isLoading = false;
    }

    private void ToggleSchedule(Guid id)
    {
        expandedScheduleId = expandedScheduleId == id ? null : id;
        addShiftScheduleId = null;
    }

    private async Task CreateSchedule()
    {
        savingSchedule = true;
        try
        {
            await OnCallService.CreateScheduleAsync(TenantId, scheduleForm.Name.Trim(),
                string.IsNullOrWhiteSpace(scheduleForm.Description) ? null : scheduleForm.Description.Trim());
            scheduleForm = new ScheduleForm();
            showCreateSchedule = false;
            await Load();
            Toasts.Success("Schedule created.");
        }
        catch (Exception ex)
        {
            Toasts.Error($"Failed to create schedule: {ex.Message}");
        }
        finally
        {
            savingSchedule = false;
        }
    }

    private async Task DeleteSchedule(OnCallSchedule schedule)
    {
        try
        {
            await OnCallService.DeleteScheduleAsync(schedule.Id);
            await Load();
            Toasts.Success($"Deleted schedule \"{schedule.Name}\".");
        }
        catch (Exception ex)
        {
            Toasts.Error($"Failed to delete schedule \"{schedule.Name}\": {ex.Message}");
        }
    }

    private void StartAddShift(Guid scheduleId)
    {
        addShiftScheduleId = scheduleId;
        shiftForm = new ShiftForm
        {
            StartsAt = DateTime.Now.Date.AddHours(DateTime.Now.Hour + 1),
            EndsAt = DateTime.Now.Date.AddHours(DateTime.Now.Hour + 9),
        };
    }

    private void CancelAddShift()
    {
        addShiftScheduleId = null;
    }

    private async Task AddShift(Guid scheduleId)
    {
        savingShift = true;
        try
        {
            await OnCallService.AddShiftAsync(
                scheduleId,
                shiftForm.AssigneeName.Trim(),
                string.IsNullOrWhiteSpace(shiftForm.Email) ? null : shiftForm.Email.Trim(),
                shiftForm.StartsAt.ToUniversalTime(),
                shiftForm.EndsAt.ToUniversalTime(),
                string.IsNullOrWhiteSpace(shiftForm.Notes) ? null : shiftForm.Notes.Trim());

            addShiftScheduleId = null;
            await Load();
            expandedScheduleId = scheduleId;
            Toasts.Success($"Added shift for \"{shiftForm.AssigneeName.Trim()}\".");
        }
        catch (Exception ex)
        {
            Toasts.Error($"Failed to add shift: {ex.Message}");
        }
        finally
        {
            savingShift = false;
        }
    }

    private async Task DeleteShift(OnCallShift shift)
    {
        try
        {
            await OnCallService.DeleteShiftAsync(shift.Id);
            await Load();
            expandedScheduleId = shift.ScheduleId;
            Toasts.Success($"Deleted shift for \"{shift.AssigneeName}\".");
        }
        catch (Exception ex)
        {
            Toasts.Error($"Failed to delete shift: {ex.Message}");
        }
    }
}
