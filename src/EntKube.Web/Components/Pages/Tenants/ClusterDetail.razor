    private async Task SaveAndApply(Guid componentId)
    {
        // Save the configuration, then run a helm upgrade to apply
        // the changes to the live deployment.

        await SaveConfiguration(componentId);

        if (componentError is null)
        {
            await UpgradeComponent(componentId);
        }
    }

