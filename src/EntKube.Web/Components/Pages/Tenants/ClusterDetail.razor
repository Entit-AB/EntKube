    /// <summary>
    /// True when the value parses as a bare IPv4/IPv6 address. Used to warn that a
    /// field feeding an HTTPRoute hostname (e.g. wg-easy's WG_HOST) needs a DNS name.
    /// </summary>
    private static bool LooksLikeIpAddress(string? value)
    {
        return !string.IsNullOrWhiteSpace(value) && System.Net.IPAddress.TryParse(value.Trim(), out _);
    }

    private void InitEditFormFields(ClusterComponent comp)
    {
        // Look up the catalog entry to get form field definitions,
        // then initialize from defaults (or extract from existing YAML).

        editFormFieldValues = new();
        CatalogEntry? catalogMatch = ResolveCatalog(comp);

        if (catalogMatch is null)
        {
            return;
        }

        foreach (ComponentFormField field in catalogMatch.FormFields)
        {
            editFormFieldValues[field.Key] = field.DefaultValue ?? "";
        }

        // Try to extract current values from the component's YAML.
        // If the YAML has the value, it overrides the default.

        if (!string.IsNullOrWhiteSpace(comp.HelmValues))
        {
            foreach (ComponentFormField field in catalogMatch.FormFields)
            {
                // Subchart toggles are stored as comment markers, not YAML paths.

                if (field.YamlPath.StartsWith("subchart:", StringComparison.Ordinal))
                {
                    string marker = $"# {field.YamlPath}=";

                    foreach (string line in comp.HelmValues.Split('\n'))
                    {
                        if (line.TrimStart().StartsWith(marker, StringComparison.Ordinal))
                        {
                            editFormFieldValues[field.Key] = line.TrimStart()[marker.Length..].Trim();
                            break;
                        }
                    }

                    continue;
                }

                // Secret-backed / manifest-placeholder fields have no YAML path —
                // their values live in the vault and are loaded in ToggleComponentDetail.
                if (string.IsNullOrEmpty(field.YamlPath))
                {
                    continue;
                }

                // cnpg:/harbor:/loki:/headscale: fields are not in YAML — loaded from component configs in ToggleComponentDetail.

                if (field.YamlPath.StartsWith("cnpg:", StringComparison.Ordinal)
                    || field.YamlPath.StartsWith("harbor:", StringComparison.Ordinal)
                    || field.YamlPath.StartsWith("loki:", StringComparison.Ordinal)
    )
                {
                    continue;
                }

                string? extracted = YamlFormMerger.ExtractValue(comp.HelmValues, field.YamlPath);

                if (extracted is not null)
                {
                    editFormFieldValues[field.Key] = extracted;
                }
            }
        }

        // For letsencrypt-issuer the solver config isn't captured by field YamlPaths
        // (it's built by LetsEncryptSolverBuilder), so derive the challenge/provider
        // toggles from the installed YAML to keep the edit form non-destructive.
        if (catalogMatch.Key == LetsEncryptSolverBuilder.CatalogKey)
        {
            LetsEncryptSolverBuilder.PopulateEditValues(comp.HelmValues, editFormFieldValues);
        }
    }

    /// <summary>
    /// If the component has a CnpgDatabase field, writes DB connection details into HelmValues
    /// immediately (no admin password needed). If admin password is also provided, calls
    /// ConfigureAsync to set up the full vault/secret config and the KeycloakComponentConfig record.
    /// </summary>
    private async Task SaveKeycloakConfigIfNeeded(
        Guid componentId, Dictionary<string, string> fieldValues, CatalogEntry? catalogEntry)
    {
        // Skip if no CnpgDatabase field, or if this is a Harbor component (has StorageLink field).
        // Harbor has its own SaveHarborConfigIfNeeded that handles the database and route.
        if (catalogEntry is null
            || !catalogEntry.FormFields.Any(f => f.Type == FormFieldType.CnpgDatabase)
            || catalogEntry.FormFields.Any(f => f.Type == FormFieldType.StorageLink))
        {
            return;
        }

        // Write DB hostname/port/name/username into HelmValues and vault as soon as a database
        // is selected — admin password is NOT required for this. This ensures the Helm chart
        // always has KC_DB_URL_HOST etc. even on first install before IdentityTab Configure runs.
        if (fieldValues.TryGetValue("cnpg-database", out string? dbIdStr)
            && Guid.TryParse(dbIdStr, out Guid parsedDbId)
            && parsedDbId != Guid.Empty)
        {
            await KeycloakService.WriteDatabaseHelmValuesAsync(TenantId, componentId, parsedDbId);
        }

        if (!fieldValues.TryGetValue("admin-password", out string? adminPassword)
            || string.IsNullOrWhiteSpace(adminPassword))
        {
            return;
        }

        Guid? cnpgDatabaseId = null;
        if (fieldValues.TryGetValue("cnpg-database", out string? dbIdStr2)
            && Guid.TryParse(dbIdStr2, out Guid parsedDbId2)
            && parsedDbId2 != Guid.Empty)
        {
            cnpgDatabaseId = parsedDbId2;
        }

        string hostname = fieldValues.TryGetValue("hostname", out string? h) ? h.Trim() : "";
        string httpPath = fieldValues.TryGetValue("http-path", out string? p) && !string.IsNullOrWhiteSpace(p) ? p : "/auth";

        // Derive admin URL from hostname if not explicitly provided.
        string adminUrl = fieldValues.TryGetValue("admin-url", out string? u) && !string.IsNullOrWhiteSpace(u)
            ? u
            : string.IsNullOrEmpty(hostname) ? "" : $"https://{hostname}{httpPath}";

        string adminUsername = fieldValues.TryGetValue("admin-username", out string? n) && !string.IsNullOrWhiteSpace(n) ? n : "admin";

        await KeycloakService.ConfigureAsync(TenantId, componentId, cnpgDatabaseId, adminUsername, adminPassword, adminUrl);

        // Create the HTTPRoute + Certificate if a hostname was provided.
        if (!string.IsNullOrEmpty(hostname))
        {
            await EnsureKeycloakRouteAsync(componentId, fieldValues, hostname);
        }
    }

    private async Task EnsureKeycloakRouteAsync(
        Guid componentId, Dictionary<string, string> fieldValues, string hostname)
    {
        // Skip if a route for this hostname already exists on the component.
        List<ExternalRoute> existing = await RouteService.GetRoutesAsync(componentId);
        if (existing.Any(r => r.Hostname.Equals(hostname, StringComparison.OrdinalIgnoreCase)))
        {
            return;
        }

        string tlsMode = fieldValues.TryGetValue("tls-mode", out string? t) ? t : "ClusterIssuer";
        string issuerName = fieldValues.TryGetValue("cluster-issuer", out string? i) && !string.IsNullOrWhiteSpace(i) ? i : "letsencrypt-prod";
        string tlsCert = fieldValues.TryGetValue("tls-cert", out string? c) ? c : "";
        string tlsKey = fieldValues.TryGetValue("tls-key", out string? k) ? k : "";

        bool isManual = string.Equals(tlsMode, "Manual", StringComparison.Ordinal);

        // keycloakx chart creates {releaseName}-keycloakx-http (ClusterIP, ports 80/8443/9000).
        ClusterComponent? comp = components?.FirstOrDefault(c => c.Id == componentId);
        string releaseName = comp?.ReleaseName ?? comp?.Name ?? "keycloak";
        string serviceName = $"{releaseName}-keycloakx-http";

        ExternalRouteRequest routeRequest = new()
        {
            Hostname = hostname,
            ServiceName = serviceName,
            ServicePort = 80,
            PathPrefix = "/",
            TlsMode = isManual ? TlsMode.Manual : TlsMode.ClusterIssuer,
            ClusterIssuerName = isManual ? null : issuerName,
            TlsCertificate = isManual ? tlsCert : null,
            TlsPrivateKey = isManual && !string.IsNullOrWhiteSpace(tlsKey) ? tlsKey : null
        };

        await RouteService.AddRouteAsync(componentId, routeRequest);
    }


    private async Task RepairMissingGatewayApiCrds()
    {
        componentError = null;

        CatalogEntry? entry = ComponentCatalog.GetByKey("gateway-api-crds");
        if (entry is null) return;

        ComponentRegistration registration = ComponentCatalog.ToRegistration(entry);
        ClusterComponent created = await LifecycleService.RegisterComponentAsync(Cluster.Id, registration);
        await LoadComponents();
        await InstallComponent(created.Id);
        await CheckGatewayApiCrdsIfNeededAsync();
    }

    private async Task RepairCertManagerGatewayApi()
    {
        componentError = null;

        ClusterComponent? certManager = components?.FirstOrDefault(c =>
            (c.Name == "cert-manager" || c.HelmChartName == "cert-manager")
            && c.Status == ComponentStatus.Installed);
        if (certManager is null) return;

        // cert-manager v1.15+ uses config.enableGatewayAPI: true instead of feature gates.
        // A Helm upgrade with this value also restarts the pod, which is needed when
        // Gateway API CRDs were installed after cert-manager (cert-manager checks for CRDs on startup).
        string currentValues = certManager.HelmValues ?? "";
        string updatedValues = YamlFormMerger.MergeFormValues(currentValues,
            new Dictionary<string, string> { ["config.enableGatewayAPI"] = "true" });

        await LifecycleService.UpdateConfigurationAsync(certManager.Id, updatedValues);

        // Refresh the in-memory component so UpgradeComponent picks up the new values.
        // Use noWait=true so Helm applies the values and returns immediately;
        // cert-manager's rollout can be slow and we don't need to block on readiness.
        await LoadComponents();
        await UpgradeComponent(certManager.Id, noWait: true);
    }

    private static bool HasCatalogUpdate(ClusterComponent comp, CatalogEntry? entry) =>
        entry is not null
        && !string.IsNullOrEmpty(entry.HelmChartVersion)
        && comp.Status == ComponentStatus.Installed
        && comp.HelmChartVersion != entry.HelmChartVersion;

