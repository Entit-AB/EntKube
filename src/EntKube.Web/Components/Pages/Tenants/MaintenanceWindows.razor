@using System.ComponentModel.DataAnnotations
@using EntKube.Web.Data
@using EntKube.Web.Services
@using Microsoft.EntityFrameworkCore
@inject IncidentService IncidentService
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject ToastService Toasts

<ConfirmDialog Visible="@(pendingConfirm is not null)"
               Message="@(pendingConfirm?.Message ?? "")"
               ConfirmText="@(pendingConfirm?.ConfirmText ?? "Delete")"
               IsBusy="confirmBusy"
               OnConfirm="RunPendingConfirmAsync"
               OnCancel="() => pendingConfirm = null" />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h6 class="mb-0">Maintenance Windows</h6>
    <button class="btn btn-sm btn-primary" @onclick="ShowAdd">
        <span class="bi bi-plus-lg"></span> Schedule Window
    </button>
</div>

@if (activeWindows.Count > 0)
{
    <div class="alert alert-warning d-flex align-items-center gap-2 mb-3 py-2">
        <span class="bi bi-tools fs-5"></span>
        <div>
            <strong>Active maintenance:</strong>
            @foreach (MaintenanceWindow w in activeWindows)
            {
                <span class="me-2">@w.Title (until @w.EndsAt.ToLocalTime().ToString("HH:mm"))</span>
            }
            <div class="small text-muted">Alert notifications are suppressed for covered clusters.</div>
        </div>
    </div>
}

@if (windows.Count == 0)
{
    <EmptyState Icon="bi-calendar-x"
                Title="No maintenance windows"
                Message="No windows scheduled." />
}
else
{
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>Title</th>
                    <th>Cluster</th>
                    <th>Starts</th>
                    <th>Ends</th>
                    <th>Created By</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (MaintenanceWindow w in windows)
                {
                    DateTime now = DateTime.UtcNow;
                    bool active = w.StartsAt <= now && w.EndsAt >= now;
                    bool past = w.EndsAt < now;
                    <tr class="@(active ? "table-warning" : past ? "text-muted" : "")">
                        <td class="fw-semibold">@w.Title</td>
                        <td class="small">@(w.Cluster?.Name ?? "All clusters")</td>
                        <td class="small">@w.StartsAt.ToLocalTime().ToString("MMM d HH:mm")</td>
                        <td class="small">@w.EndsAt.ToLocalTime().ToString("MMM d HH:mm")</td>
                        <td class="small text-muted">@w.CreatedBy</td>
                        <td>
                            @if (active)
                            {
                                <span class="badge bg-warning text-dark">Active</span>
                            }
                            else if (past)
                            {
                                <span class="badge bg-secondary">Completed</span>
                            }
                            else
                            {
                                <span class="badge bg-info text-dark">Scheduled</span>
                            }
                        </td>
                        <td>
                            @if (!past)
                            {
                                <button class="btn btn-sm btn-outline-danger"
                                        aria-label="@($"Delete maintenance window {w.Title}")"
                                        @onclick='() => pendingConfirm = new PendingConfirm($"Delete the maintenance window \"{w.Title}\"? Alert suppression for its covered clusters will end. This cannot be undone.", "Delete window", () => Delete(w.Id))'>
                                    <span class="bi bi-trash"></span>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (showAdd)
{
    <div class="card mt-3 border-primary">
        <div class="card-header d-flex justify-content-between align-items-center py-2">
            <h6 class="mb-0">Schedule Maintenance Window</h6>
            <button class="btn-close btn-sm" @onclick="() => showAdd = false"></button>
        </div>
        <div class="card-body">
            <EditForm Model="windowForm" OnValidSubmit="Save">
                <DataAnnotationsValidator />
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label small">Title <span class="text-danger">*</span></label>
                        <InputText class="form-control form-control-sm" @bind-Value="windowForm.Title" placeholder="e.g. Scheduled database maintenance" />
                        <ValidationMessage For="() => windowForm.Title" class="text-danger small" />
                    </div>
                    <div class="col-12">
                        <label class="form-label small">Description</label>
                        <InputTextArea class="form-control form-control-sm" rows="2" @bind-Value="windowForm.Description" placeholder="Optional details" />
                        <ValidationMessage For="() => windowForm.Description" class="text-danger small" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">Cluster</label>
                        <InputSelect class="form-select form-select-sm" @bind-Value="windowForm.ClusterId">
                            <option value="">All clusters</option>
                            @foreach (KubernetesCluster c in clusters)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Start (local)</label>
                        <InputDate Type="InputDateType.DateTimeLocal" class="form-control form-control-sm" @bind-Value="windowForm.StartsAt" />
                        <ValidationMessage For="() => windowForm.StartsAt" class="text-danger small" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">End (local)</label>
                        <InputDate Type="InputDateType.DateTimeLocal" class="form-control form-control-sm" @bind-Value="windowForm.EndsAt" />
                        <ValidationMessage For="() => windowForm.EndsAt" class="text-danger small" />
                    </div>
                </div>
                <div class="mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-primary" disabled="@saving">
                        @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Save Window
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => showAdd = false">Cancel</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public required Guid TenantId { get; set; }

    private List<MaintenanceWindow> windows = [];
    private List<MaintenanceWindow> activeWindows = [];
    private List<KubernetesCluster> clusters = [];
    private bool showAdd;
    private bool saving;
    private MaintenanceWindowForm windowForm = new();
    private string? currentUser;

    private sealed class MaintenanceWindowForm : IValidatableObject
    {
        [Required(ErrorMessage = "Title is required.")]
        [StringLength(200, MinimumLength = 1, ErrorMessage = "Title must be 1-200 characters.")]
        public string Title { get; set; } = "";

        [StringLength(2000, ErrorMessage = "Description must be 2000 characters or fewer.")]
        public string? Description { get; set; }

        public Guid? ClusterId { get; set; }

        [Required]
        public DateTime StartsAt { get; set; } = DateTime.Now.AddMinutes(5);

        [Required]
        public DateTime EndsAt { get; set; } = DateTime.Now.AddHours(2);

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (EndsAt <= StartsAt)
                yield return new ValidationResult("End time must be after start time.", new[] { nameof(EndsAt) });
        }
    }

    // A destructive action awaiting user confirmation.
    private sealed record PendingConfirm(string Message, string ConfirmText, Func<Task> Action);
    private PendingConfirm? pendingConfirm;
    private bool confirmBusy;

    private async Task RunPendingConfirmAsync()
    {
        if (pendingConfirm is null) return;
        confirmBusy = true;
        try { await pendingConfirm.Action(); }
        finally { confirmBusy = false; pendingConfirm = null; }
    }

    protected override async Task OnInitializedAsync()
    {
        AuthenticationState auth = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUser = auth.User.Identity?.Name ?? "Unknown";
        await Load();
    }

    private async Task Load()
    {
        windows = await IncidentService.GetMaintenanceWindowsAsync(TenantId);
        DateTime now = DateTime.UtcNow;
        activeWindows = windows.Where(w => w.StartsAt <= now && w.EndsAt >= now).ToList();

        using ApplicationDbContext db = DbFactory.CreateDbContext();
        clusters = await db.KubernetesClusters
            .Where(c => c.TenantId == TenantId)
            .OrderBy(c => c.Name)
            .ToListAsync();
    }

    private void ShowAdd()
    {
        windowForm = new MaintenanceWindowForm();
        showAdd = true;
    }

    private async Task Save()
    {
        saving = true;
        try
        {
            await IncidentService.CreateMaintenanceWindowAsync(
                TenantId,
                windowForm.Title.Trim(),
                string.IsNullOrWhiteSpace(windowForm.Description) ? null : windowForm.Description.Trim(),
                windowForm.ClusterId,
                windowForm.StartsAt.ToUniversalTime(),
                windowForm.EndsAt.ToUniversalTime(),
                currentUser!);

            showAdd = false;
            await Load();
            Toasts.Success($"Maintenance window \"{windowForm.Title.Trim()}\" scheduled.");
        }
        catch (Exception ex)
        {
            Toasts.Error($"Failed to schedule maintenance window: {ex.Message}");
        }
        finally
        {
            saving = false;
        }
    }

    private async Task Delete(Guid id)
    {
        try
        {
            await IncidentService.DeleteMaintenanceWindowAsync(id);
            await Load();
            Toasts.Success("Maintenance window deleted.");
        }
        catch (Exception ex)
        {
            Toasts.Error($"Failed to delete maintenance window: {ex.Message}");
        }
    }
}
