@using EntKube.Web.Data
@using EntKube.Web.Services
@using Microsoft.EntityFrameworkCore
@using System.ComponentModel.DataAnnotations
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NotificationService NotificationService
@inject NotificationProviderConfigService ProviderConfigService
@inject ToastService Toasts

<ConfirmDialog Visible="@(pendingConfirm is not null)"
               Message="@(pendingConfirm?.Message ?? "")"
               ConfirmText="@(pendingConfirm?.ConfirmText ?? "Delete")"
               IsBusy="confirmBusy"
               OnConfirm="RunPendingConfirmAsync"
               OnCancel="() => pendingConfirm = null" />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h6 class="mb-0">Notification Channels</h6>
    <button class="btn btn-sm btn-primary" @onclick="ShowAddModal">
        <span class="bi bi-plus-lg"></span> Add Channel
    </button>
</div>

@if (channels.Count == 0)
{
    <EmptyState Icon="bi-send"
                Title="No notification channels"
                Message="Add a channel to get alerted via Slack, Teams, email, or webhook." />
}
else
{
    <div class="row g-3">
        @foreach (NotificationChannel channel in channels)
        {
            <div class="col-12 col-md-6">
                <div class="card border-@(channel.IsEnabled ? "success" : "secondary")">
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="@TypeIcon(channel.Type) fs-5 text-@TypeColor(channel.Type)"></span>
                            <strong>@channel.Name</strong>
                            <span class="badge bg-secondary ms-1">@channel.Type</span>
                            <div class="ms-auto form-check form-switch mb-0">
                                <input class="form-check-input" type="checkbox" role="switch"
                                       checked="@channel.IsEnabled"
                                       @onchange="() => ToggleEnabled(channel)" />
                            </div>
                        </div>
                        <div class="d-flex flex-wrap gap-1 mb-2">
                            <span class="badge bg-light text-dark">@FormatSeverityFilter(channel.SeverityFilter)</span>
                            <span class="badge bg-light text-dark">@FormatFiringFilter(channel.FiringFilter)</span>
                            <span class="badge bg-light text-dark">@FormatAcknowledgeFilter(channel.AcknowledgeFilter)</span>
                        </div>

                        @if (deliveries.TryGetValue(channel.Id, out List<NotificationDelivery>? recent) && recent.Count > 0)
                        {
                            <div class="small mb-2">
                                <span class="text-muted">Recent deliveries: </span>
                                @foreach (NotificationDelivery d in recent.Take(5))
                                {
                                    <span class="badge me-1 @(d.Success ? "bg-success" : "bg-danger")"
                                          title="@(d.IsFiring ? "Fired" : "Resolved") · @d.SentAt.ToLocalTime():g">
                                        @(d.Success ? "✓" : "✗")
                                    </span>
                                }
                            </div>
                        }

                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => TestChannel(channel)"
                                    disabled="@(testingId == channel.Id)">
                                @if (testingId == channel.Id)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                Test
                            </button>
                            <button class="btn btn-sm btn-outline-danger ms-auto"
                                    @onclick='() => pendingConfirm = new PendingConfirm($"Delete the notification channel \"{channel.Name}\"? It will stop receiving alerts. This cannot be undone.", "Delete", () => DeleteChannel(channel))'>
                                Delete
                            </button>
                        </div>
                        @if (testResults.TryGetValue(channel.Id, out string? result))
                        {
                            <div class="alert @(result.StartsWith("✓") ? "alert-success" : "alert-danger") alert-sm mt-2 mb-0 py-1 px-2 small">
                                @result
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (showModal)
{
    <div class="modal fade show d-block" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Notification Channel</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <EditForm Model="addForm" OnValidSubmit="SaveChannel">
                <DataAnnotationsValidator />
                <div class="modal-body">
                    @if (modalStep == 1)
                    {
                        <p class="text-muted mb-3">Select the channel type:</p>
                        <div class="d-grid gap-2">
                            @foreach (NotificationChannelType t in Enum.GetValues<NotificationChannelType>())
                            {
                                <button type="button" class="btn btn-outline-secondary text-start" @onclick="() => SelectType(t)">
                                    <span class="@TypeIcon(t) me-2"></span> @t
                                </button>
                            }
                        </div>
                    }
                    else if (modalStep == 2)
                    {
                        <div class="mb-3">
                            <label class="form-label">Channel Name</label>
                            <InputText class="form-control" @bind-Value="addForm.Name" placeholder="e.g. Ops Slack" />
                            <ValidationMessage For="() => addForm.Name" class="text-danger small" />
                        </div>

                        @if (newType == NotificationChannelType.Slack)
                        {
                            <div class="mb-3">
                                <label class="form-label">Webhook URL</label>
                                <InputText class="form-control" @bind-Value="addForm.WebhookUrl" placeholder="https://hooks.slack.com/services/…" />
                                <ValidationMessage For="() => addForm.WebhookUrl" class="text-danger small" />
                            </div>
                        }
                        else if (newType == NotificationChannelType.Teams)
                        {
                            @if (teamsGraphConfigured)
                            {
                                <div class="alert alert-info py-2 small mb-3">
                                    <i class="bi bi-microsoft-teams me-1"></i>
                                    Teams Graph API is configured. Messages will be sent via Microsoft Graph.
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Team ID</label>
                                    <InputText class="form-control font-monospace" @bind-Value="addForm.TeamId" placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" />
                                    <ValidationMessage For="() => addForm.TeamId" class="text-danger small" />
                                    <div class="form-text">Found in Teams → right-click team → Get link to team</div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Channel ID</label>
                                    <InputText class="form-control font-monospace" @bind-Value="addForm.ChannelId" placeholder="19:xxxxxxxxxxxxxxxx@thread.tacv2" />
                                    <ValidationMessage For="() => addForm.ChannelId" class="text-danger small" />
                                    <div class="form-text">Found in Teams → right-click channel → Get link to channel</div>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-warning py-2 small mb-3">
                                    <i class="bi bi-exclamation-triangle me-1"></i>
                                    Teams Graph API is not configured. Using legacy incoming webhook.
                                    <a href="/admin/notifications" target="_blank">Configure it here</a>.
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Webhook URL</label>
                                    <InputText class="form-control" @bind-Value="addForm.WebhookUrl" placeholder="https://…webhook.office.com/…" />
                                    <ValidationMessage For="() => addForm.WebhookUrl" class="text-danger small" />
                                </div>
                            }
                        }
                        else if (newType == NotificationChannelType.Email)
                        {
                            <div class="mb-3">
                                <label class="form-label">Recipient Email</label>
                                <InputText class="form-control" type="email" @bind-Value="addForm.Email" placeholder="ops@example.com" />
                                <ValidationMessage For="() => addForm.Email" class="text-danger small" />
                            </div>
                        }
                        else if (newType == NotificationChannelType.Webhook)
                        {
                            <div class="mb-3">
                                <label class="form-label">URL</label>
                                <InputText class="form-control" @bind-Value="addForm.WebhookUrl" placeholder="https://…" />
                                <ValidationMessage For="() => addForm.WebhookUrl" class="text-danger small" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Bearer Token (optional)</label>
                                <InputText class="form-control" type="password" @bind-Value="addForm.BearerToken" />
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label">Severity</label>
                            <InputSelect class="form-select" @bind-Value="addForm.SeverityFilter">
                                <option value="@AlertSeverityFilter.All">All severities</option>
                                <option value="@AlertSeverityFilter.WarningAndAbove">Warning and above</option>
                                <option value="@AlertSeverityFilter.CriticalOnly">Critical only</option>
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Alert state</label>
                            <InputSelect class="form-select" @bind-Value="addForm.FiringFilter">
                                <option value="@AlertFiringFilter.All">Firing and resolved</option>
                                <option value="@AlertFiringFilter.FiringOnly">Firing only</option>
                                <option value="@AlertFiringFilter.ResolvedOnly">Resolved only</option>
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Acknowledgement</label>
                            <InputSelect class="form-select" @bind-Value="addForm.AcknowledgeFilter">
                                <option value="@AlertAcknowledgeFilter.All">Acknowledged and unacknowledged</option>
                                <option value="@AlertAcknowledgeFilter.UnacknowledgedOnly">Unacknowledged only</option>
                                <option value="@AlertAcknowledgeFilter.AcknowledgedOnly">Acknowledged only</option>
                            </InputSelect>
                        </div>

                        @if (!string.IsNullOrEmpty(modalError))
                        {
                            <div class="alert alert-danger py-2 small">@modalError</div>
                        }
                    }
                </div>
                <div class="modal-footer">
                    @if (modalStep == 2)
                    {
                        <button type="button" class="btn btn-secondary" @onclick="() => modalStep = 1">Back</button>
                        <button type="submit" class="btn btn-primary">Save Channel</button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    }
                </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public required Guid TenantId { get; set; }

    private List<NotificationChannel> channels = [];
    private Dictionary<Guid, List<NotificationDelivery>> deliveries = new();
    private bool showModal;
    private int modalStep = 1;
    private NotificationChannelType newType;
    private AddChannelForm addForm = new();
    private string? modalError;
    private Guid? testingId;
    private Dictionary<Guid, string> testResults = new();
    private bool teamsGraphConfigured;

    private sealed class AddChannelForm : IValidatableObject
    {
        // Context that drives conditional validation (set by the caller).
        public NotificationChannelType Type { get; set; }
        public bool TeamsGraphConfigured { get; set; }

        [Required(ErrorMessage = "Channel name is required.")]
        [StringLength(100, MinimumLength = 1)]
        public string Name { get; set; } = "";

        [Url(ErrorMessage = "Enter a valid URL (https://…).")]
        public string WebhookUrl { get; set; } = "";

        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = "";

        public string BearerToken { get; set; } = "";
        public string TeamId { get; set; } = "";
        public string ChannelId { get; set; } = "";

        public AlertSeverityFilter SeverityFilter { get; set; } = AlertSeverityFilter.All;
        public AlertFiringFilter FiringFilter { get; set; } = AlertFiringFilter.All;
        public AlertAcknowledgeFilter AcknowledgeFilter { get; set; } = AlertAcknowledgeFilter.All;

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            switch (Type)
            {
                case NotificationChannelType.Slack:
                    if (string.IsNullOrWhiteSpace(WebhookUrl))
                        yield return new ValidationResult("Webhook URL is required.", new[] { nameof(WebhookUrl) });
                    break;
                case NotificationChannelType.Teams when TeamsGraphConfigured:
                    if (string.IsNullOrWhiteSpace(TeamId))
                        yield return new ValidationResult("Team ID is required.", new[] { nameof(TeamId) });
                    if (string.IsNullOrWhiteSpace(ChannelId))
                        yield return new ValidationResult("Channel ID is required.", new[] { nameof(ChannelId) });
                    break;
                case NotificationChannelType.Teams:
                    if (string.IsNullOrWhiteSpace(WebhookUrl))
                        yield return new ValidationResult("Webhook URL is required.", new[] { nameof(WebhookUrl) });
                    break;
                case NotificationChannelType.Email:
                    if (string.IsNullOrWhiteSpace(Email))
                        yield return new ValidationResult("Email address is required.", new[] { nameof(Email) });
                    break;
                case NotificationChannelType.Webhook:
                    if (string.IsNullOrWhiteSpace(WebhookUrl))
                        yield return new ValidationResult("URL is required.", new[] { nameof(WebhookUrl) });
                    break;
            }
        }
    }

    // A destructive action awaiting user confirmation.
    private sealed record PendingConfirm(string Message, string ConfirmText, Func<Task> Action);
    private PendingConfirm? pendingConfirm;
    private bool confirmBusy;

    private async Task RunPendingConfirmAsync()
    {
        if (pendingConfirm is null) return;
        confirmBusy = true;
        try { await pendingConfirm.Action(); }
        finally { confirmBusy = false; pendingConfirm = null; }
    }

    protected override async Task OnInitializedAsync()
    {
        NotificationProviderConfig? graphConfig = await ProviderConfigService.GetAsync(NotificationProviderType.MsTeamsGraph);
        teamsGraphConfigured = graphConfig?.IsEnabled == true;
        await LoadChannels();
    }

    private async Task LoadChannels()
    {
        using ApplicationDbContext db = DbFactory.CreateDbContext();
        channels = await db.NotificationChannels
            .Where(c => c.TenantId == TenantId && c.CustomerId == null)
            .OrderBy(c => c.Name)
            .ToListAsync();

        var ids = channels.Select(c => c.Id).ToList();
        List<NotificationDelivery> recent = await db.NotificationDeliveries
            .Where(d => ids.Contains(d.ChannelId))
            .OrderByDescending(d => d.SentAt)
            .ToListAsync();

        deliveries = recent
            .GroupBy(d => d.ChannelId)
            .ToDictionary(g => g.Key, g => g.Take(5).ToList());
    }

    private void ShowAddModal()
    {
        showModal = true;
        modalStep = 1;
        addForm = new AddChannelForm { TeamsGraphConfigured = teamsGraphConfigured };
        modalError = null;
    }

    private void CloseModal() => showModal = false;

    private void SelectType(NotificationChannelType type)
    {
        newType = type;
        addForm.Type = type;
        modalStep = 2;
    }

    private async Task SaveChannel()
    {
        modalError = null;

        string configJson;
        try
        {
            configJson = BuildConfigJson();
        }
        catch (Exception ex)
        {
            modalError = ex.Message;
            return;
        }

        try
        {
            using ApplicationDbContext db = DbFactory.CreateDbContext();
            db.NotificationChannels.Add(new NotificationChannel
            {
                TenantId = TenantId,
                Name = addForm.Name.Trim(),
                Type = newType,
                ConfigurationJson = configJson,
                SeverityFilter = addForm.SeverityFilter,
                FiringFilter = addForm.FiringFilter,
                AcknowledgeFilter = addForm.AcknowledgeFilter
            });
            await db.SaveChangesAsync();
            CloseModal();
            await LoadChannels();
            Toasts.Success($"Added channel \"{addForm.Name.Trim()}\".");
        }
        catch (Exception ex)
        {
            modalError = ex.Message;
            Toasts.Error($"Failed to add channel: {ex.Message}");
        }
    }

    private string BuildConfigJson()
    {
        return newType switch
        {
            NotificationChannelType.Slack =>
                System.Text.Json.JsonSerializer.Serialize(new { webhookUrl = addForm.WebhookUrl.Trim() }),

            NotificationChannelType.Teams when teamsGraphConfigured =>
                System.Text.Json.JsonSerializer.Serialize(new { teamId = addForm.TeamId.Trim(), channelId = addForm.ChannelId.Trim() }),

            NotificationChannelType.Teams =>
                System.Text.Json.JsonSerializer.Serialize(new { webhookUrl = addForm.WebhookUrl.Trim() }),

            NotificationChannelType.Email =>
                System.Text.Json.JsonSerializer.Serialize(new { to = addForm.Email.Trim() }),

            NotificationChannelType.Webhook =>
                System.Text.Json.JsonSerializer.Serialize(new
                {
                    url = addForm.WebhookUrl.Trim(),
                    token = string.IsNullOrWhiteSpace(addForm.BearerToken) ? null : addForm.BearerToken.Trim()
                }),

            _ => "{}"
        };
    }

    private async Task ToggleEnabled(NotificationChannel channel)
    {
        using ApplicationDbContext db = DbFactory.CreateDbContext();
        NotificationChannel? ch = await db.NotificationChannels.FindAsync(channel.Id);
        if (ch is null) return;
        ch.IsEnabled = !ch.IsEnabled;
        await db.SaveChangesAsync();
        channel.IsEnabled = ch.IsEnabled;
    }

    private async Task DeleteChannel(NotificationChannel channel)
    {
        try
        {
            using ApplicationDbContext db = DbFactory.CreateDbContext();
            NotificationChannel? ch = await db.NotificationChannels.FindAsync(channel.Id);
            if (ch is not null) db.NotificationChannels.Remove(ch);
            await db.SaveChangesAsync();
            await LoadChannels();
            Toasts.Success($"Deleted channel \"{channel.Name}\".");
        }
        catch (Exception ex)
        {
            Toasts.Error($"Failed to delete channel \"{channel.Name}\": {ex.Message}");
        }
    }

    private async Task TestChannel(NotificationChannel channel)
    {
        testingId = channel.Id;
        testResults.Remove(channel.Id);
        StateHasChanged();

        try
        {
            await NotificationService.SendTestAsync(channel);
            testResults[channel.Id] = "✓ Test notification sent successfully";
        }
        catch (Exception ex)
        {
            testResults[channel.Id] = $"✗ {ex.Message}";
        }
        finally
        {
            testingId = null;
            StateHasChanged();
        }
    }

    private static string TypeIcon(NotificationChannelType type) => type switch
    {
        NotificationChannelType.Slack   => "bi bi-slack",
        NotificationChannelType.Teams   => "bi bi-microsoft-teams",
        NotificationChannelType.Email   => "bi bi-envelope-fill",
        NotificationChannelType.Webhook => "bi bi-link-45deg",
        _ => "bi bi-bell"
    };

    private static string TypeColor(NotificationChannelType type) => type switch
    {
        NotificationChannelType.Slack   => "success",
        NotificationChannelType.Teams   => "primary",
        NotificationChannelType.Email   => "warning",
        NotificationChannelType.Webhook => "secondary",
        _ => "secondary"
    };

    private static string FormatSeverityFilter(AlertSeverityFilter filter) => filter switch
    {
        AlertSeverityFilter.All             => "All severities",
        AlertSeverityFilter.WarningAndAbove => "Warning+",
        AlertSeverityFilter.CriticalOnly    => "Critical only",
        _ => filter.ToString()
    };

    private static string FormatFiringFilter(AlertFiringFilter filter) => filter switch
    {
        AlertFiringFilter.FiringOnly   => "Firing only",
        AlertFiringFilter.ResolvedOnly => "Resolved only",
        _ => "Firing + resolved"
    };

    private static string FormatAcknowledgeFilter(AlertAcknowledgeFilter filter) => filter switch
    {
        AlertAcknowledgeFilter.UnacknowledgedOnly => "Unacknowledged only",
        AlertAcknowledgeFilter.AcknowledgedOnly   => "Acknowledged only",
        _ => "All states"
    };
}
