    private async Task CreateReplication()
    {
        if (selectedHarbor?.Config is null || string.IsNullOrWhiteSpace(newReplicationName)) return;
        savingReplication = true;
        replicationError = null;
        try
        {
            long? srcId = long.TryParse(newReplicationSrcRegistryIdStr, out long s) ? s : null;
            long? destId = long.TryParse(newReplicationDestRegistryIdStr, out long d) ? d : null;

            await HarborService.CreateReplicationAsync(
                TenantId, selectedHarbor.Config,
                newReplicationName.Trim(),
                string.IsNullOrWhiteSpace(newReplicationDescription) ? null : newReplicationDescription.Trim(),
                srcId, destId,
                string.IsNullOrWhiteSpace(newReplicationDestNamespace) ? null : newReplicationDestNamespace.Trim(),
                string.IsNullOrWhiteSpace(newReplicationNameFilter) ? "**" : newReplicationNameFilter.Trim(),
                enabled: true, newReplicationOverride);

            replications = await HarborService.GetReplicationsAsync(TenantId, selectedHarbor.Config);
            showCreateReplication = false;
            newReplicationName = "";
            newReplicationDescription = "";
            newReplicationSrcRegistryIdStr = "";
            newReplicationDestRegistryIdStr = "";
            newReplicationNameFilter = "**";
            newReplicationDestNamespace = "";
            newReplicationOverride = true;
        }
        catch (Exception ex) { replicationError = ex.Message; }
        finally { savingReplication = false; }
    }

