@using EntKube.Web.Data
@using EntKube.Web.Services
@inject HarborService HarborService
@inject TenantService TenantService

<LoadingPanel Loading="@loading" LoadingText="Scanning for Harbor instances…">
@if (selectedProject is not null && selectedHarbor is not null)
{
    @* ── Level 3: Project detail (repos + webhooks) ── *@
    <nav class="mb-3">
        <button class="btn btn-sm btn-link text-decoration-none p-0" @onclick="BackToProjects">
            <i class="bi bi-arrow-left me-1"></i>Back to Projects
        </button>
    </nav>

    <div class="d-flex align-items-center gap-2 mb-3">
        <i class="bi bi-folder2-open fs-4 text-primary"></i>
        <div>
            <h5 class="mb-0">
                @selectedProject.Name
                @if (selectedProject.IsProxyCache)
                {
                    <span class="badge bg-info-subtle text-info border border-info-subtle ms-2 small">Proxy Cache</span>
                }
            </h5>
            <small class="text-muted">
                @if (selectedProject.Public) { <span class="badge bg-success-subtle text-success border border-success-subtle me-2">Public</span> }
                else { <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle me-2">Private</span> }
                @selectedProject.RepoCount repos · @FormatSize(selectedProject.StorageUsedBytes) used
            </small>
        </div>
    </div>

    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <button class="nav-link @(projectSubTab == "repos" ? "active" : "")"
                    @onclick="@(() => SwitchProjectTab("repos"))">Repositories</button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(projectSubTab == "webhooks" ? "active" : "")"
                    @onclick="@(() => SwitchProjectTab("webhooks"))">Webhooks</button>
        </li>
    </ul>

    @* ── Repositories sub-tab ── *@
    @if (projectSubTab == "repos")
    {
        @if (loadingRepos)
        {
            <div class="spinner-border spinner-border-sm text-primary"></div>
        }
        else if (repos is not null && repos.Count == 0)
        {
            <div class="alert alert-light border text-muted small">
                <i class="bi bi-inbox me-1"></i>No repositories in this project yet.
                @if (!selectedProject.IsProxyCache)
                {
                    <span>Push an image to <code>@(selectedHarbor.Config?.RegistryUrl?.TrimEnd('/') ?? "registry")/@selectedProject.Name/your-image:tag</code> to get started.</span>
                }
                else
                {
                    <span>Pull an image through this proxy cache to populate it: <code>docker pull @(selectedHarbor.Config?.RegistryUrl?.TrimEnd('/') ?? "registry")/@selectedProject.Name/image:tag</code></span>
                }
            </div>
        }
        else if (repos is not null)
        {
            <div class="list-group">
                @foreach (HarborRepositoryInfo repo in repos)
                {
                    string shortName = repo.Name.Contains('/') ? repo.Name[(repo.Name.IndexOf('/') + 1)..] : repo.Name;
                    bool isExpanded = expandedRepo == repo.Name;

                    <div class="list-group-item p-0">
                        <button class="btn w-100 text-start py-2 px-3 d-flex align-items-center justify-content-between"
                                @onclick="() => ToggleRepo(repo)">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi @(isExpanded ? "bi-chevron-down" : "bi-chevron-right") text-muted small"></i>
                                <i class="bi bi-box-seam text-primary"></i>
                                <span class="font-monospace small">@shortName</span>
                            </div>
                            <div class="d-flex gap-3 text-muted small">
                                <span>@repo.ArtifactCount artifacts</span>
                                <span>@FormatSize(repo.SizeBytes)</span>
                                @if (repo.UpdatedAt.HasValue)
                                {
                                    <span>@repo.UpdatedAt.Value.ToString("yyyy-MM-dd")</span>
                                }
                            </div>
                        </button>

                        @if (isExpanded)
                        {
                            <div class="border-top bg-light px-3 py-2">
                                @if (loadingArtifacts)
                                {
                                    <div class="spinner-border spinner-border-sm text-primary m-2"></div>
                                }
                                else if (artifacts is not null && artifacts.Count == 0)
                                {
                                    <p class="text-muted small mb-0">No artifacts.</p>
                                }
                                else if (artifacts is not null)
                                {
                                    <table class="table table-sm table-borderless mb-0 small">
                                        <thead>
                                            <tr class="text-muted">
                                                <th>Tags</th>
                                                <th>Digest</th>
                                                <th>Size</th>
                                                <th>Pushed</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (HarborArtifactInfo artifact in artifacts)
                                            {
                                                <tr>
                                                    <td>
                                                        @if (artifact.Tags.Count == 0)
                                                        {
                                                            <span class="text-muted fst-italic">untagged</span>
                                                        }
                                                        else
                                                        {
                                                            @foreach (string tag in artifact.Tags)
                                                            {
                                                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle me-1">@tag</span>
                                                            }
                                                        }
                                                    </td>
                                                    <td class="font-monospace text-muted">@artifact.Digest[..19]…</td>
                                                    <td>@FormatSize(artifact.SizeBytes)</td>
                                                    <td>@artifact.PushedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
        @if (repoError is not null)
        {
            <div class="alert alert-danger small mt-2">@repoError</div>
        }
    }

    @* ── Webhooks sub-tab ── *@
    @if (projectSubTab == "webhooks")
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="text-muted small">@(webhooks?.Count ?? 0) webhooks</span>
            <button class="btn btn-sm btn-primary" @onclick="() => showCreateWebhook = !showCreateWebhook">
                <i class="bi bi-bell me-1"></i>New Webhook
            </button>
        </div>

        @if (showCreateWebhook)
        {
            <div class="card mb-3 border-primary-subtle">
                <div class="card-body">
                    @if (webhookError is not null)
                    {
                        <div class="alert alert-danger py-2 small">@webhookError</div>
                    }
                    <div class="row g-2">
                        <div class="col-md-4">
                            <label class="form-label form-label-sm">Name</label>
                            <input class="form-control form-control-sm" placeholder="my-webhook" @bind="newWebhookName" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label form-label-sm">Target URL</label>
                            <input class="form-control form-control-sm font-monospace" placeholder="https://example.com/webhook"
                                   @bind="newWebhookUrl" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label form-label-sm">Auth Header (optional)</label>
                            <input class="form-control form-control-sm font-monospace" placeholder="Bearer token…"
                                   @bind="newWebhookAuthHeader" />
                        </div>
                        <div class="col-md-6 d-flex align-items-end gap-3 pb-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="whSkipCert"
                                       @bind="newWebhookSkipCert" />
                                <label class="form-check-label small" for="whSkipCert">Skip TLS verify</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label form-label-sm">Event types</label>
                            <div class="d-flex flex-wrap gap-3">
                                @foreach (string evt in WebhookEventTypes)
                                {
                                    bool isChecked = newWebhookEvents.Contains(evt);
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input"
                                               id="whe_@evt"
                                               checked="@isChecked"
                                               @onchange="e => ToggleWebhookEvent(evt, (bool)(e.Value ?? false))" />
                                        <label class="form-check-label small" for="whe_@evt">@evt.Replace("_", " ")</label>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <button class="btn btn-sm btn-primary" @onclick="CreateWebhook" disabled="@savingWebhook">
                            @if (savingWebhook) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Create
                        </button>
                        <button class="btn btn-sm btn-outline-secondary"
                                @onclick="() => { showCreateWebhook = false; webhookError = null; }">Cancel</button>
                    </div>
                </div>
            </div>
        }

        @if (loadingWebhooks)
        {
            <div class="spinner-border spinner-border-sm text-primary"></div>
        }
        else if (webhookListError is not null)
        {
            <div class="alert alert-danger small">@webhookListError</div>
        }
        else if (webhooks is not null)
        {
            @if (webhooks.Count == 0)
            {
                <p class="text-muted small">No webhooks configured for this project.</p>
            }
            else
            {
                <div class="list-group">
                    @foreach (HarborWebhookInfo wh in webhooks)
                    {
                        <div class="list-group-item py-2">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="bi bi-bell text-primary"></i>
                                        <span class="fw-medium small">@wh.Name</span>
                                        @if (wh.Enabled)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle small">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle small">Disabled</span>
                                        }
                                    </div>
                                    <div class="text-muted small mt-1">
                                        <code>@wh.TargetUrl</code>
                                    </div>
                                    <div class="mt-1 d-flex flex-wrap gap-1">
                                        @foreach (string evt in wh.EventTypes)
                                        {
                                            <span class="badge bg-light text-secondary border small">@evt.Replace("_", " ")</span>
                                        }
                                    </div>
                                </div>
                                @if (confirmDeleteWebhook == wh.Id)
                                {
                                    <div class="d-flex gap-1 align-items-center">
                                        <span class="text-danger small me-2">Delete?</span>
                                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteWebhook(wh.Id)">Yes</button>
                                        <button class="btn btn-sm btn-outline-secondary"
                                                @onclick="() => confirmDeleteWebhook = null">Cancel</button>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => confirmDeleteWebhook = wh.Id">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        }
    }
}
else if (selectedHarbor is not null)
{
    @* ── Level 2: Harbor instance detail ── *@
    <nav class="mb-3">
        <button class="btn btn-sm btn-link text-decoration-none p-0" @onclick="BackToList">
            <i class="bi bi-arrow-left me-1"></i>Back to Harbor instances
        </button>
    </nav>

    <div class="d-flex align-items-center justify-content-between mb-3">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-archive fs-4 text-primary"></i>
            <div>
                <h5 class="mb-0">@selectedHarbor.DisplayName</h5>
                <small class="text-muted">
                    @if (selectedHarbor.ClusterDisplayName is not null)
                    {
                        <span><i class="bi bi-hdd-rack me-1"></i>@selectedHarbor.ClusterDisplayName</span>
                    }
                    @if (selectedHarbor.Config?.RegistryUrl is not null)
                    {
                        <span class="ms-2"><i class="bi bi-link-45deg me-1"></i><code>@selectedHarbor.Config.RegistryUrl</code></span>
                    }
                </small>
            </div>
        </div>

        @if (!selectedHarbor.IsConfigured)
        {
            <span class="badge bg-warning-subtle text-warning border border-warning-subtle">Not configured</span>
        }
        else
        {
            <span class="badge bg-success-subtle text-success border border-success-subtle">
                <i class="bi bi-check-circle me-1"></i>Configured
            </span>
        }
    </div>

    @if (!selectedHarbor.IsConfigured)
    {
        <div class="alert alert-warning small">
            <i class="bi bi-exclamation-triangle me-2"></i>
            This Harbor instance has no admin credentials configured. Configure it from the
            <strong>Components</strong> tab on the cluster detail page.
        </div>
    }
    else
    {
        <ul class="nav nav-tabs mb-3 flex-wrap">
            @foreach ((string id, string label) in InstanceTabs)
            {
                <li class="nav-item">
                    <button class="nav-link @(instanceTab == id ? "active" : "")"
                            @onclick="() => SwitchTab(id)">@label</button>
                </li>
            }
        </ul>

        @* ── Projects tab ── *@
        @if (instanceTab == "projects")
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted small">@(projects?.Count ?? 0) projects</span>
                <button class="btn btn-sm btn-primary" @onclick="() => showCreateProject = !showCreateProject">
                    <i class="bi bi-plus-circle me-1"></i>New Project
                </button>
            </div>

            @if (showCreateProject)
            {
                <div class="card mb-3 border-primary-subtle">
                    <div class="card-body">
                        @if (projectError is not null)
                        {
                            <div class="alert alert-danger py-2 small">@projectError</div>
                        }
                        <div class="row g-2 align-items-start">
                            <div class="col-md-4">
                                <label class="form-label form-label-sm">Project name</label>
                                <input class="form-control form-control-sm font-monospace" placeholder="my-project"
                                       @bind="newProjectName" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label form-label-sm">Description (optional)</label>
                                <input class="form-control form-control-sm" placeholder="Description"
                                       @bind="newProjectDescription" />
                            </div>
                            <div class="col-md-4 d-flex align-items-end gap-3 pb-1">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="projPublic" @bind="newProjectPublic" />
                                    <label class="form-check-label small" for="projPublic">Public</label>
                                </div>
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="projProxy" @bind="newProjectIsProxy" />
                                    <label class="form-check-label small" for="projProxy">Proxy Cache</label>
                                </div>
                            </div>
                            @if (newProjectIsProxy)
                            {
                                <div class="col-md-6">
                                    <label class="form-label form-label-sm">Remote registry to proxy</label>
                                    @if (registries is null)
                                    {
                                        <div class="text-muted small"><span class="spinner-border spinner-border-sm me-1"></span>Loading registries…</div>
                                    }
                                    else if (registries.Count == 0)
                                    {
                                        <div class="alert alert-warning py-1 small mb-0">
                                            No remote registries configured yet. Add one in the <strong>Registries</strong> tab first.
                                        </div>
                                    }
                                    else
                                    {
                                        <select class="form-select form-select-sm" @bind="newProjectProxyRegistryId">
                                            <option value="">Select registry…</option>
                                            @foreach (HarborRegistryInfo reg in registries)
                                            {
                                                <option value="@reg.Id">@reg.Name (@reg.Type — @reg.Url)</option>
                                            }
                                        </select>
                                    }
                                </div>
                            }
                        </div>
                        <div class="mt-2 d-flex gap-2">
                            <button class="btn btn-sm btn-primary" @onclick="CreateProject" disabled="@savingProject">
                                @if (savingProject) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Create
                            </button>
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => { showCreateProject = false; projectError = null; newProjectIsProxy = false; }">Cancel</button>
                        </div>
                    </div>
                </div>
            }

            @if (loadingProjects)
            {
                <div class="spinner-border spinner-border-sm text-primary"></div>
            }
            else if (projectError is not null && !showCreateProject)
            {
                <div class="alert alert-danger small">@projectError</div>
            }
            else if (projects is not null)
            {
                <div class="list-group">
                    @foreach (HarborProjectInfo project in projects)
                    {
                        HarborProject? tracked = trackedProjects?.FirstOrDefault(p => p.ProjectName == project.Name);
                        bool showingPortalForm = portalLinkProjectName == project.Name;

                        <div class="list-group-item py-2">
                            <div class="d-flex justify-content-between align-items-start">
                                <button class="btn btn-link text-start p-0 text-decoration-none flex-grow-1"
                                        @onclick="() => OpenProject(project)">
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="bi bi-folder2 text-warning"></i>
                                        <span class="fw-medium">@project.Name</span>
                                        @if (project.Public)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle small">Public</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle small">Private</span>
                                        }
                                        @if (project.IsProxyCache)
                                        {
                                            <span class="badge bg-info-subtle text-info border border-info-subtle small">
                                                <i class="bi bi-arrow-repeat me-1"></i>Proxy Cache
                                            </span>
                                        }
                                        @if (tracked?.LinkedApp is not null)
                                        {
                                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle small">
                                                <i class="bi bi-link-45deg me-1"></i>@tracked.LinkedApp.Customer.Name / @tracked.LinkedApp.Name
                                            </span>
                                        }
                                    </div>
                                    <div class="text-muted small mt-1">
                                        <span><i class="bi bi-box-seam me-1"></i>@project.RepoCount repos</span>
                                        <span class="ms-2"><i class="bi bi-hdd me-1"></i>@FormatSize(project.StorageUsedBytes)</span>
                                    </div>
                                </button>

                                <div class="d-flex gap-1 align-items-start ms-2">
                                    @if (confirmDeleteProject == project.Name)
                                    {
                                        <span class="text-danger small me-1 mt-1">Delete?</span>
                                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteProject(project.Name)">Yes</button>
                                        <button class="btn btn-sm btn-outline-secondary"
                                                @onclick="() => confirmDeleteProject = null">Cancel</button>
                                    }
                                    else
                                    {
                                        @if (tracked?.LinkedApp is not null)
                                        {
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    @onclick="() => UnlinkProject(tracked.Id)"
                                                    title="Unlink from portal app">
                                                <i class="bi bi-link-45deg me-1"></i>Unlink
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-primary"
                                                    @onclick="() => ShowPortalLinkForm(project.Name)"
                                                    title="Link to customer app for portal access">
                                                <i class="bi bi-people me-1"></i>Link to app
                                            </button>
                                        }
                                        <button class="btn btn-sm btn-outline-danger"
                                                @onclick="() => confirmDeleteProject = project.Name"
                                                title="Delete project">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>
                            </div>

                            @if (showingPortalForm)
                            {
                                <div class="mt-2 p-2 bg-light rounded border">
                                    @if (portalLinkError is not null)
                                    {
                                        <div class="alert alert-danger py-1 small mb-2">@portalLinkError</div>
                                    }
                                    <div class="d-flex gap-2 align-items-center flex-wrap">
                                        <select class="form-select form-select-sm" style="max-width:300px" @bind="portalLinkAppId">
                                            <option value="@Guid.Empty">Select app…</option>
                                            @if (allApps is not null)
                                            {
                                                @foreach (Data.App app in allApps)
                                                {
                                                    <option value="@app.Id">@app.Customer.Name / @app.Name</option>
                                                }
                                            }
                                        </select>
                                        <button class="btn btn-sm btn-primary"
                                                @onclick="() => LinkProjectToApp(project.Name)"
                                                disabled="@(savingPortalLink || portalLinkAppId == Guid.Empty)">
                                            @if (savingPortalLink) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                            Link
                                        </button>
                                        <button class="btn btn-sm btn-outline-secondary"
                                                @onclick="() => { portalLinkProjectName = null; portalLinkError = null; }">Cancel</button>
                                    </div>
                                    <div class="text-muted small mt-1">
                                        The customer will see a <strong>Registry</strong> button in their portal for this app.
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        }

        @* ── Registries tab ── *@
        @if (instanceTab == "registries")
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <span class="text-muted small">@(registries?.Count ?? 0) remote registries</span>
                    <div class="text-muted small">Add remote registries to use as proxy caches when creating projects.</div>
                </div>
                <button class="btn btn-sm btn-primary" @onclick="() => showCreateRegistry = !showCreateRegistry">
                    <i class="bi bi-plus-circle me-1"></i>Add Registry
                </button>
            </div>

            @if (showCreateRegistry)
            {
                <div class="card mb-3 border-primary-subtle">
                    <div class="card-body">
                        @if (registryError is not null)
                        {
                            <div class="alert alert-danger py-2 small">@registryError</div>
                        }
                        <div class="row g-2">
                            <div class="col-md-4">
                                <label class="form-label form-label-sm">Name</label>
                                <input class="form-control form-control-sm" placeholder="docker-hub-proxy"
                                       @bind="newRegistryName" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label form-label-sm">Registry type</label>
                                <select class="form-select form-select-sm" @bind="newRegistryType"
                                        @bind:after="OnRegistryTypeChanged">
                                    @foreach ((string id, string label) in RegistryTypes)
                                    {
                                        <option value="@id">@label</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label form-label-sm">
                                    URL @(RegistryHasFixedUrl(newRegistryType) ? "(auto-filled)" : "")
                                </label>
                                <input class="form-control form-control-sm font-monospace"
                                       placeholder="https://registry.example.com"
                                       @bind="newRegistryUrl"
                                       disabled="@RegistryHasFixedUrl(newRegistryType)" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label form-label-sm">Username / Access Key (optional)</label>
                                <input class="form-control form-control-sm" placeholder="username"
                                       @bind="newRegistryAccessKey" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label form-label-sm">Password / Secret (optional)</label>
                                <input type="password" class="form-control form-control-sm"
                                       @bind="newRegistryAccessSecret" />
                            </div>
                            <div class="col-md-4 d-flex align-items-end pb-1">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="regInsecure"
                                           @bind="newRegistryInsecure" />
                                    <label class="form-check-label small" for="regInsecure">Skip TLS verify</label>
                                </div>
                            </div>
                        </div>
                        <div class="mt-2 d-flex gap-2">
                            <button class="btn btn-sm btn-primary" @onclick="CreateRegistry" disabled="@savingRegistry">
                                @if (savingRegistry) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Add Registry
                            </button>
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => { showCreateRegistry = false; registryError = null; }">Cancel</button>
                        </div>
                    </div>
                </div>
            }

            @if (loadingRegistries)
            {
                <div class="spinner-border spinner-border-sm text-primary"></div>
            }
            else if (registryListError is not null)
            {
                <div class="alert alert-danger small">@registryListError</div>
            }
            else if (registries is not null)
            {
                @if (registries.Count == 0)
                {
                    <div class="alert alert-light border text-muted small">
                        <i class="bi bi-diagram-3 me-2"></i>
                        No remote registries yet. Add a registry to use it as a proxy cache (e.g. Docker Hub, Quay.io, GHCR).
                    </div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (HarborRegistryInfo reg in registries)
                        {
                            bool isPinging = pingingRegistryId == reg.Id;
                            <div class="list-group-item py-2">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="bi @RegistryTypeIcon(reg.Type) text-primary"></i>
                                            <span class="fw-medium">@reg.Name</span>
                                            <span class="badge bg-light text-secondary border small">@reg.Type</span>
                                            @if (reg.Status == "healthy")
                                            {
                                                <span class="badge bg-success-subtle text-success border border-success-subtle small">Healthy</span>
                                            }
                                            else if (!string.IsNullOrEmpty(reg.Status))
                                            {
                                                <span class="badge bg-warning-subtle text-warning border border-warning-subtle small">@reg.Status</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrEmpty(reg.Url))
                                        {
                                            <div class="text-muted small mt-1 font-monospace">@reg.Url</div>
                                        }
                                        @if (reg.Insecure)
                                        {
                                            <span class="badge bg-warning-subtle text-warning border border-warning-subtle small mt-1">TLS skip</span>
                                        }
                                        @if (pingResults.TryGetValue(reg.Id, out string? pingResult))
                                        {
                                            <div class="small mt-1 @(pingResult == "healthy" ? "text-success" : "text-danger")">
                                                <i class="bi @(pingResult == "healthy" ? "bi-check-circle" : "bi-x-circle") me-1"></i>@pingResult
                                            </div>
                                        }
                                    </div>
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => PingRegistry(reg.Id)"
                                                disabled="@isPinging" title="Test connectivity">
                                            @if (isPinging)
                                            {
                                                <span class="spinner-border spinner-border-sm"></span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-wifi"></i>
                                            }
                                        </button>
                                        @if (confirmDeleteRegistry == reg.Id)
                                        {
                                            <span class="text-danger small me-1 mt-1">Delete?</span>
                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteRegistry(reg.Id)">Yes</button>
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    @onclick="() => confirmDeleteRegistry = null">Cancel</button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-danger"
                                                    @onclick="() => confirmDeleteRegistry = reg.Id">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
        }

        @* ── Replication tab ── *@
        @if (instanceTab == "replication")
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted small">@(replications?.Count ?? 0) replication policies</span>
                <button class="btn btn-sm btn-primary" @onclick="() => showCreateReplication = !showCreateReplication">
                    <i class="bi bi-plus-circle me-1"></i>New Policy
                </button>
            </div>

            @if (showCreateReplication)
            {
                <div class="card mb-3 border-primary-subtle">
                    <div class="card-body">
                        @if (replicationError is not null)
                        {
                            <div class="alert alert-danger py-2 small">@replicationError</div>
                        }
                        <div class="row g-2">
                            <div class="col-md-6">
                                <label class="form-label form-label-sm">Policy name</label>
                                <input class="form-control form-control-sm" placeholder="sync-from-dockerhub"
                                       @bind="newReplicationName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label form-label-sm">Description (optional)</label>
                                <input class="form-control form-control-sm" @bind="newReplicationDescription" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label form-label-sm">
                                    Source registry <small class="text-muted">(leave blank = this Harbor)</small>
                                </label>
                                <select class="form-select form-select-sm" @bind="newReplicationSrcRegistryIdStr">
                                    <option value="">Local (this Harbor)</option>
                                    @if (registries is not null)
                                    {
                                        @foreach (HarborRegistryInfo reg in registries)
                                        {
                                            <option value="@reg.Id">@reg.Name (@reg.Type)</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label form-label-sm">
                                    Destination registry <small class="text-muted">(leave blank = this Harbor)</small>
                                </label>
                                <select class="form-select form-select-sm" @bind="newReplicationDestRegistryIdStr">
                                    <option value="">Local (this Harbor)</option>
                                    @if (registries is not null)
                                    {
                                        @foreach (HarborRegistryInfo reg in registries)
                                        {
                                            <option value="@reg.Id">@reg.Name (@reg.Type)</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label form-label-sm">
                                    Name filter <small class="text-muted">(**=all)</small>
                                </label>
                                <input class="form-control form-control-sm font-monospace" placeholder="library/**"
                                       @bind="newReplicationNameFilter" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label form-label-sm">Destination namespace (optional)</label>
                                <input class="form-control form-control-sm font-monospace" placeholder="my-project"
                                       @bind="newReplicationDestNamespace" />
                            </div>
                            <div class="col-md-4 d-flex align-items-end gap-3 pb-1">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="replOverride"
                                           @bind="newReplicationOverride" />
                                    <label class="form-check-label small" for="replOverride">Override existing</label>
                                </div>
                            </div>
                        </div>
                        <div class="mt-2 d-flex gap-2">
                            <button class="btn btn-sm btn-primary" @onclick="CreateReplication"
                                    disabled="@savingReplication">
                                @if (savingReplication) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Create Policy
                            </button>
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => { showCreateReplication = false; replicationError = null; }">Cancel</button>
                        </div>
                    </div>
                </div>
            }

            @if (loadingReplications)
            {
                <div class="spinner-border spinner-border-sm text-primary"></div>
            }
            else if (replicationListError is not null)
            {
                <div class="alert alert-danger small">@replicationListError</div>
            }
            else if (replications is not null)
            {
                @if (replications.Count == 0)
                {
                    <div class="alert alert-light border text-muted small">
                        <i class="bi bi-arrow-left-right me-2"></i>
                        No replication policies yet. Create one to synchronise images between registries.
                    </div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (HarborReplicationInfo repl in replications)
                        {
                            bool isTriggering = triggeringReplicationId == repl.Id;
                            <div class="list-group-item py-2">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="bi bi-arrow-left-right text-primary"></i>
                                            <span class="fw-medium">@repl.Name</span>
                                            @if (repl.Enabled)
                                            {
                                                <span class="badge bg-success-subtle text-success border border-success-subtle small">Enabled</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle small">Disabled</span>
                                            }
                                        </div>
                                        <div class="text-muted small mt-1">
                                            <span>
                                                <strong>From:</strong> @(repl.SrcRegistryName ?? "Local")
                                                <i class="bi bi-arrow-right mx-1"></i>
                                                <strong>To:</strong> @(repl.DestRegistryName ?? "Local")
                                            </span>
                                            @if (!string.IsNullOrWhiteSpace(repl.NameFilter) && repl.NameFilter != "**")
                                            {
                                                <span class="ms-2">· Filter: <code>@repl.NameFilter</code></span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(repl.DestNamespace))
                                            {
                                                <span class="ms-2">· Dest namespace: <code>@repl.DestNamespace</code></span>
                                            }
                                        </div>
                                        @if (triggerResults.TryGetValue(repl.Id, out string? triggerMsg))
                                        {
                                            <div class="small text-success mt-1"><i class="bi bi-check-circle me-1"></i>@triggerMsg</div>
                                        }
                                    </div>
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-outline-secondary"
                                                @onclick="() => TriggerReplication(repl.Id)"
                                                disabled="@isTriggering" title="Run now">
                                            @if (isTriggering)
                                            {
                                                <span class="spinner-border spinner-border-sm"></span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-play-fill"></i>
                                            }
                                        </button>
                                        @if (confirmDeleteReplication == repl.Id)
                                        {
                                            <span class="text-danger small me-1 mt-1">Delete?</span>
                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteReplication(repl.Id)">Yes</button>
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    @onclick="() => confirmDeleteReplication = null">Cancel</button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-danger"
                                                    @onclick="() => confirmDeleteReplication = repl.Id">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
        }

        @* ── Robot Accounts tab ── *@
        @if (instanceTab == "robots")
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted small">@(robots?.Count ?? 0) robot accounts</span>
                <button class="btn btn-sm btn-primary" @onclick="() => showCreateRobot = !showCreateRobot">
                    <i class="bi bi-robot me-1"></i>New Robot
                </button>
            </div>

            @if (showCreateRobot)
            {
                <div class="card mb-3 border-primary-subtle">
                    <div class="card-body">
                        @if (robotError is not null)
                        {
                            <div class="alert alert-danger py-2 small">@robotError</div>
                        }
                        @if (newRobotSecret is not null)
                        {
                            <div class="alert alert-success py-2">
                                <strong><i class="bi bi-key me-1"></i>Robot created!</strong> Copy the secret now — it will not be shown again.
                                <div class="mt-2 font-monospace small bg-white border rounded p-2 user-select-all">@newRobotSecret</div>
                                <div class="mt-2 text-muted small">The secret is also stored in Vault as <code>harbor-robot-@newRobotName</code>.</div>
                                <button class="btn btn-sm btn-outline-secondary mt-2"
                                        @onclick="() => { showCreateRobot = false; newRobotSecret = null; }">Close</button>
                            </div>
                        }
                        else
                        {
                            <div class="row g-2">
                                <div class="col-md-4">
                                    <label class="form-label form-label-sm">Robot name</label>
                                    <input class="form-control form-control-sm font-monospace" placeholder="ci-runner"
                                           @bind="newRobotName" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label form-label-sm">Description (optional)</label>
                                    <input class="form-control form-control-sm" placeholder="Description"
                                           @bind="newRobotDescription" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label form-label-sm">Scope</label>
                                    <select class="form-select form-select-sm" @bind="newRobotScope">
                                        <option value="system">System-wide</option>
                                        <option value="project">Specific project</option>
                                    </select>
                                </div>
                                @if (newRobotScope == "project")
                                {
                                    <div class="col-md-4">
                                        <label class="form-label form-label-sm">Project</label>
                                        <select class="form-select form-select-sm" @bind="newRobotProject">
                                            <option value="">Select project…</option>
                                            @if (projects is not null)
                                            {
                                                @foreach (HarborProjectInfo p in projects)
                                                {
                                                    <option value="@p.Name">@p.Name</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                }
                                <div class="col-12 d-flex gap-3 align-items-center">
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" id="robotPull" @bind="newRobotCanPull" />
                                        <label class="form-check-label small" for="robotPull">Pull</label>
                                    </div>
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" id="robotPush" @bind="newRobotCanPush" />
                                        <label class="form-check-label small" for="robotPush">Push</label>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-2 d-flex gap-2">
                                <button class="btn btn-sm btn-primary" @onclick="CreateRobot" disabled="@savingRobot">
                                    @if (savingRobot) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    Create
                                </button>
                                <button class="btn btn-sm btn-outline-secondary"
                                        @onclick="() => { showCreateRobot = false; robotError = null; }">Cancel</button>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (loadingRobots)
            {
                <div class="spinner-border spinner-border-sm text-primary"></div>
            }
            else if (robotListError is not null)
            {
                <div class="alert alert-danger small">@robotListError</div>
            }
            else if (robots is not null)
            {
                @if (robots.Count == 0)
                {
                    <p class="text-muted small">No robot accounts yet.</p>
                }
                else
                {
                    <div class="list-group">
                        @foreach (HarborRobotInfo robot in robots)
                        {
                            <div class="list-group-item py-2">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="bi bi-robot text-primary"></i>
                                            <span class="font-monospace small fw-medium">@robot.Name</span>
                                            @if (robot.Disabled)
                                            {
                                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle small">Disabled</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success-subtle text-success border border-success-subtle small">Active</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(robot.Description))
                                        {
                                            <div class="text-muted small mt-1">@robot.Description</div>
                                        }
                                        <div class="text-muted small mt-1">
                                            Created @robot.CreatedAt.ToString("yyyy-MM-dd")
                                            @if (robot.ExpiresAt == -1)
                                            {
                                                <span class="ms-2">· Never expires</span>
                                            }
                                            else
                                            {
                                                DateTime expiry = DateTimeOffset.FromUnixTimeSeconds(robot.ExpiresAt).UtcDateTime;
                                                <span class="ms-2">· Expires @expiry.ToString("yyyy-MM-dd")</span>
                                            }
                                        </div>
                                    </div>

                                    @if (confirmDeleteRobot == robot.Id)
                                    {
                                        <div class="d-flex gap-1 align-items-center">
                                            <span class="text-danger small me-2">Delete?</span>
                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteRobot(robot.Id)">Yes</button>
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    @onclick="() => confirmDeleteRobot = null">Cancel</button>
                                        </div>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-danger"
                                                @onclick="() => confirmDeleteRobot = robot.Id"
                                                title="Delete robot">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            }
        }

        @* ── System Info tab ── *@
        @if (instanceTab == "info")
        {
            @if (loadingInfo)
            {
                <div class="spinner-border spinner-border-sm text-primary"></div>
            }
            else if (infoError is not null)
            {
                <div class="alert alert-danger small">@infoError</div>
            }
            else if (systemInfo is not null)
            {
                <div class="card border-0 bg-light">
                    <div class="card-body">
                        <dl class="row mb-0 small">
                            <dt class="col-sm-3 text-muted">Harbor Version</dt>
                            <dd class="col-sm-9 font-monospace">@(systemInfo.HarborVersion ?? "—")</dd>

                            <dt class="col-sm-3 text-muted">Registry URL</dt>
                            <dd class="col-sm-9">
                                @if (systemInfo.RegistryUrl is not null)
                                {
                                    <code>@systemInfo.RegistryUrl</code>
                                }
                                else
                                {
                                    <span>—</span>
                                }
                            </dd>

                            <dt class="col-sm-3 text-muted">Auth Mode</dt>
                            <dd class="col-sm-9">@(systemInfo.AuthMode ?? "—")</dd>

                            <dt class="col-sm-3 text-muted">Trivy Scanner</dt>
                            <dd class="col-sm-9">
                                @if (systemInfo.WithTrivy)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle">Enabled</span>
                                }
                                else
                                {
                                    <span class="text-muted">Disabled</span>
                                }
                            </dd>
                        </dl>
                    </div>
                </div>

                @if (selectedHarbor.Config?.RegistryUrl is not null)
                {
                    <div class="mt-3">
                        <h6 class="text-muted mb-2">Quick start</h6>
                        <div class="bg-dark text-white rounded p-3 font-monospace small">
                            <div class="text-success mb-1"># Login</div>
                            <div>docker login @selectedHarbor.Config.RegistryUrl.TrimEnd('/')</div>
                            <div class="text-success mt-2 mb-1"># Pull an image</div>
                            <div>docker pull @selectedHarbor.Config.RegistryUrl.TrimEnd('/')/<span class="text-warning">project/image:tag</span></div>
                            <div class="text-success mt-2 mb-1"># Add as Helm OCI repo</div>
                            <div>helm repo add <span class="text-warning">my-harbor</span> oci://@selectedHarbor.Config.RegistryUrl.TrimEnd('/')/<span class="text-warning">project</span></div>
                            <div class="text-success mt-2 mb-1"># Pull via proxy cache</div>
                            <div>docker pull @selectedHarbor.Config.RegistryUrl.TrimEnd('/')/<span class="text-warning">dockerhub-proxy</span>/library/nginx:latest</div>
                        </div>
                    </div>
                }
            }
        }
    }
}
else
{
    @* ── Level 1: List of Harbor instances ── *@
    @if (harborInstances is null || harborInstances.Count == 0)
    {
        <div class="alert alert-light border text-muted">
            <i class="bi bi-archive me-2"></i>
            No Harbor instances found. Install Harbor from the Components tab on a cluster.
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (DetectedHarbor harbor in harborInstances)
            {
                <div class="col-md-6">
                    <div class="card h-100 @(harbor.IsConfigured ? "" : "border-warning-subtle")"
                         style="cursor: pointer" @onclick="() => SelectHarbor(harbor)">
                        <div class="card-body">
                            <div class="d-flex align-items-start justify-content-between">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-archive fs-4 text-primary"></i>
                                    <div>
                                        <div class="fw-medium">@harbor.DisplayName</div>
                                        @if (harbor.ClusterDisplayName is not null)
                                        {
                                            <div class="text-muted small">
                                                <i class="bi bi-hdd-rack me-1"></i>@harbor.ClusterDisplayName
                                            </div>
                                        }
                                    </div>
                                </div>
                                @if (harbor.IsConfigured)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle small">
                                        <i class="bi bi-check-circle me-1"></i>Ready
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle small">
                                        <i class="bi bi-exclamation-triangle me-1"></i>Not configured
                                    </span>
                                }
                            </div>
                            @if (harbor.Config?.RegistryUrl is not null)
                            {
                                <div class="mt-2 text-muted small font-monospace">@harbor.Config.RegistryUrl</div>
                            }
                        </div>
                        <div class="card-footer bg-transparent border-top-0 text-end">
                            <small class="text-muted">Click to manage <i class="bi bi-arrow-right ms-1"></i></small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
</LoadingPanel>

@code {
    [Parameter] public Guid TenantId { get; set; }

    /// <summary>
    /// When set, restricts the tab to Harbor instances whose backing cluster is in this
    /// environment. Harbor ties to an environment via
    /// ClusterComponent.ClusterId → KubernetesCluster.EnvironmentId (exposed here as
    /// DetectedHarbor.Component.Cluster.EnvironmentId, already eager-loaded by the service).
    /// When null the tab behaves exactly as before (all tenant Harbor instances).
    /// </summary>
    [Parameter] public Guid? EnvironmentId { get; set; }

    private static readonly (string Id, string Label)[] InstanceTabs =
    [
        ("projects",    "Projects"),
        ("registries",  "Registries"),
        ("replication", "Replication"),
        ("robots",      "Robot Accounts"),
        ("info",        "System Info")
    ];

    private static readonly (string Id, string Label)[] RegistryTypes =
    [
        ("docker-hub",      "Docker Hub"),
        ("quay",            "Quay.io"),
        ("ghcr",            "GitHub Container Registry"),
        ("gcr",             "Google Container Registry"),
        ("docker-registry", "Docker Registry V2"),
        ("harbor",          "Another Harbor"),
        ("aws-ecr",         "Amazon ECR"),
        ("gitlab",          "GitLab Registry")
    ];

    private static readonly Dictionary<string, string> RegistryDefaultUrls = new()
    {
        ["docker-hub"] = "https://hub.docker.com",
        ["quay"]       = "https://quay.io",
        ["ghcr"]       = "https://ghcr.io",
        ["gcr"]        = "https://gcr.io"
    };

    private static readonly string[] WebhookEventTypes =
    [
        "PUSH_ARTIFACT", "PULL_ARTIFACT", "DELETE_ARTIFACT",
        "CREATE_TAG", "DELETE_TAG",
        "SCANNING_COMPLETED", "SCANNING_FAILED",
        "REPLICATION"
    ];

    private bool loading = true;
    private List<DetectedHarbor>? harborInstances;
    private DetectedHarbor? selectedHarbor;
    private string instanceTab = "projects";

    // Projects
    private List<HarborProjectInfo>? projects;
    private bool loadingProjects;
    private bool showCreateProject;
    private bool savingProject;
    private string newProjectName = "";
    private string newProjectDescription = "";
