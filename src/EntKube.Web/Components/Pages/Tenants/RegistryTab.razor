    private void ToggleWebhookEvent(string evt, bool isChecked)
    {
        if (isChecked) newWebhookEvents.Add(evt);
        else newWebhookEvents.Remove(evt);
    }

    private async Task CreateWebhook()
    {
        if (selectedHarbor?.Config is null || selectedProject is null) return;
        if (string.IsNullOrWhiteSpace(newWebhookName) || string.IsNullOrWhiteSpace(newWebhookUrl)) return;

        savingWebhook = true;
        webhookError = null;
        try
        {
            IEnumerable<string> events = newWebhookEvents.Count > 0
                ? newWebhookEvents
                : WebhookEventTypes;

            await HarborService.CreateWebhookAsync(
                TenantId, selectedHarbor.Config,
                selectedProject.Name,
                newWebhookName.Trim(),
                newWebhookUrl.Trim(),
                events,
                enabled: true,
                string.IsNullOrWhiteSpace(newWebhookAuthHeader) ? null : newWebhookAuthHeader.Trim(),
                newWebhookSkipCert);

            webhooks = await HarborService.GetWebhooksAsync(TenantId, selectedHarbor.Config, selectedProject.Name);
            showCreateWebhook = false;
            newWebhookName = "";
            newWebhookUrl = "";
            newWebhookAuthHeader = "";
            newWebhookSkipCert = false;
            newWebhookEvents = [];
        }
        catch (Exception ex) { webhookError = ex.Message; }
        finally { savingWebhook = false; }
    }

    private async Task DeleteWebhook(long webhookId)
    {
