    // ── Registries ────────────────────────────────────────────────────────────

    private void OnRegistryTypeChanged()
    {
        if (RegistryDefaultUrls.TryGetValue(newRegistryType, out string? url))
            newRegistryUrl = url;
        else if (!RegistryHasFixedUrl(newRegistryType))
            newRegistryUrl = "";
    }

    private static bool RegistryHasFixedUrl(string type) =>
        RegistryDefaultUrls.ContainsKey(type);

    private static string RegistryTypeIcon(string type) => type switch
    {
        "docker-hub"      => "bi-boxes",
        "quay"            => "bi-shield-check",
        "ghcr"            => "bi-github",
        "gcr"             => "bi-google",
        "harbor"          => "bi-archive",
        "aws-ecr"         => "bi-cloud",
        "gitlab"          => "bi-git",
        _                 => "bi-box-seam"
    };

    private async Task CreateRegistry()
    {
        if (selectedHarbor?.Config is null || string.IsNullOrWhiteSpace(newRegistryName)) return;
        savingRegistry = true;
        registryError = null;
        try
        {
            await HarborService.CreateRegistryAsync(
                TenantId, selectedHarbor.Config,
                newRegistryName.Trim(), newRegistryType,
                string.IsNullOrWhiteSpace(newRegistryUrl) ? null : newRegistryUrl.Trim(),
                string.IsNullOrWhiteSpace(newRegistryAccessKey) ? null : newRegistryAccessKey,
                string.IsNullOrWhiteSpace(newRegistryAccessSecret) ? null : newRegistryAccessSecret,
                newRegistryInsecure);

            registries = await HarborService.GetRegistriesAsync(TenantId, selectedHarbor.Config);
            showCreateRegistry = false;
            newRegistryName = "";
            newRegistryType = "docker-hub";
            newRegistryUrl = "https://hub.docker.com";
            newRegistryAccessKey = "";
            newRegistryAccessSecret = "";
            newRegistryInsecure = false;
        }
        catch (Exception ex) { registryError = ex.Message; }
        finally { savingRegistry = false; }
    }

