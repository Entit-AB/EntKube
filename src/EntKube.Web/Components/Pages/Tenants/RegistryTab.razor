    }

    private void BackToProjects()
    {
        selectedProject = null;
        repos = null;
        artifacts = null;
        expandedRepo = null;
        webhooks = null;
        projectSubTab = "repos";
    }

    private async Task SwitchTab(string tab)
    {
        instanceTab = tab;
        projectError = null;
        robotError = null;
        robotListError = null;
        infoError = null;
        registryError = null;
        registryListError = null;
        replicationError = null;
        replicationListError = null;

        switch (tab)
        {
            case "projects":
                await Task.WhenAll(LoadProjects(), EnsureRegistriesLoaded());
                break;
            case "registries":
                await LoadRegistries();
                break;
            case "replication":
                await Task.WhenAll(LoadReplications(), EnsureRegistriesLoaded());
                break;
            case "robots":
                await LoadRobots();
                break;
            case "info":
                await LoadInfo();
                break;
        }
    }

    private async Task SwitchProjectTab(string tab)
    {
        projectSubTab = tab;
        if (tab == "webhooks" && webhooks is null)
            await LoadWebhooks();
    }

    private async Task LoadProjects()
    {
        if (selectedHarbor?.Config is null) return;
        loadingProjects = true;
        projectError = null;
        StateHasChanged();
        try
        {
            projects = await HarborService.GetProjectsAsync(TenantId, selectedHarbor.Config);
        }
        catch (Exception ex) { projectError = ex.Message; }
        finally { loadingProjects = false; }
    }

    private async Task EnsureRegistriesLoaded()
    {
        if (registries is not null) return;
        if (selectedHarbor?.Config is null) return;
        try { registries = await HarborService.GetRegistriesAsync(TenantId, selectedHarbor.Config); }
        catch { /* non-fatal; registries selector will just be empty */ }
