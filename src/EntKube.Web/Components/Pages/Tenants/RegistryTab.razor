        pingResults.Remove(registryId);
        StateHasChanged();
        try
        {
            string result = await HarborService.PingRegistryAsync(TenantId, selectedHarbor.Config, registryId);
            pingResults[registryId] = result;
        }
        catch (Exception ex)
        {
            pingResults[registryId] = ex.Message;
        }
        finally { pingingRegistryId = null; }
    }

