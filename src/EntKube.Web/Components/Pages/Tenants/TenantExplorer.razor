@page "/tenants/{Slug}"
@page "/tenants/{Slug}/explore"
@using EntKube.Web.Data
@using EntKube.Web.Services
@using Microsoft.AspNetCore.Components.Rendering
@rendermode InteractiveServer
@inject TenantService TenantService
@inject UserAccessService UserAccessService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

@* ═══════════════════════════════════════════════════════════════════
   TenantExplorer — resource-tree navigation (default tenant view).
   Environment (auto-expanded) → Customer (collapsed) → App, plus the
   environment's Clusters. Services / Operations / Manage are tenant-
   scoped sections. Every level has an inline "+" to add/register.
   Existing detail/tab components are reused as the right-hand pane;
   selection deep-links via the URL.
   ═══════════════════════════════════════════════════════════════════ *@

<PageTitle>@(tenant?.Name ?? "Tenant")</PageTitle>

@if (tenant is null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="text-muted mt-2">Loading tenant…</p>
    </div>
}
else
{
    <div class="explorer">
        <aside class="tree-side">
            <div class="tree-head">
                <div class="tree-tenant"><i class="bi bi-building"></i> @tenant.Name</div>
                <div class="tree-filter">
                    <i class="bi bi-search text-muted small" aria-hidden="true"></i>
                    <input type="search" placeholder="Filter resources…" aria-label="Filter resources"
                           value="@filter" @oninput="OnFilterInput" />
                </div>
            </div>

            <div class="tree-scroll" role="tree" aria-label="Tenant resources">

                @* ── Environments → Customers → Apps, and Clusters ── *@
                <div class="tree-section-head">
                    <span class="tree-section-label">Environments</span>
                    <button type="button" class="tree-add" title="Add environment" aria-label="Add environment"
                            @onclick="() => addingEnv = !addingEnv"><i class="bi bi-plus-lg"></i></button>
                </div>
                @if (addingEnv)
                {
                    <div class="tree-add-row indent-1">
                        <input placeholder="New environment name" @bind="newEnvName" @bind:event="oninput"
                               @onkeydown="e => OnAddKey(e, AddEnvironment)" />
                        <button type="button" class="tree-add-ok" @onclick="AddEnvironment" aria-label="Create"><i class="bi bi-check-lg"></i></button>
                    </div>
                }
                @if (VisibleEnvironments().Count == 0 && !addingEnv)
                {
                    <div class="tree-empty">@(HasFilter ? "No matches" : "No environments yet")</div>
                }
                @foreach (Data.Environment env in VisibleEnvironments())
                {
                    bool open = EnvOpen(env);
                    <div class="node-row indent-1">
                        <button type="button" class="node group" @onclick="() => ToggleEnv(env.Id)" aria-expanded="@open">
                            <span class="caret">@(open ? "▾" : "▸")</span>
                            <i class="ico bi bi-diagram-3-fill" aria-hidden="true"></i>
                            <span class="label">@env.Name</span>
                            <span class="badge-count">@ClustersInEnv(env).Count</span>
                        </button>
                    </div>
                    @if (open)
                    {
                        @* Customers under this environment *@
                        <div class="tree-subhead indent-2">
                            <span class="tree-sub">Customers</span>
                            <button type="button" class="tree-add" title="Add customer" aria-label="Add customer"
                                    @onclick="() => StartAddCustomer(env.Id)"><i class="bi bi-plus-lg"></i></button>
                        </div>
                        @if (addingCustomerEnv == env.Id)
                        {
                            <div class="tree-add-row indent-3">
                                <input placeholder="New customer name" @bind="newCustomerName" @bind:event="oninput"
                                       @onkeydown="e => OnAddKey(e, AddCustomer)" />
                                <button type="button" class="tree-add-ok" @onclick="AddCustomer" aria-label="Create"><i class="bi bi-check-lg"></i></button>
                            </div>
                        }
                        @foreach (Customer c in VisibleCustomersInEnv(env))
                        {
                            bool copen = EnvCustomerOpen(env.Id, c.Id);
                            List<Data.App> capps = VisibleAppsOfInEnv(c, env);
                            <div class="node-row indent-2">
                                <button type="button" class="node group" @onclick="() => ToggleEnvCustomer(env.Id, c.Id)" aria-expanded="@copen">
                                    <span class="caret">@(copen ? "▾" : "▸")</span>
                                    <i class="ico bi bi-person-badge" aria-hidden="true"></i>
                                    <span class="label">@c.Name</span>
                                    <span class="badge-count">@AppsOfInEnv(c, env).Count</span>
                                </button>
                                <button type="button" class="tree-add" title="Add app to @c.Name" aria-label="Add app"
                                        @onclick="() => StartAddApp(env.Id, c.Id)"><i class="bi bi-plus-lg"></i></button>
                            </div>
                            @if (copen)
                            {
                                @if (IsAddingApp(env.Id, c.Id))
                                {
                                    <div class="tree-add-row indent-3">
                                        <input placeholder="New app name" @bind="newAppName" @bind:event="oninput"
                                               @onkeydown="e => OnAddKey(e, () => AddApp(env.Id, c.Id))" />
                                        <button type="button" class="tree-add-ok" @onclick="() => AddApp(env.Id, c.Id)" aria-label="Create"><i class="bi bi-check-lg"></i></button>
                                    </div>
                                }
                                @if (capps.Count == 0 && !IsAddingApp(env.Id, c.Id))
                                {
                                    <div class="tree-empty" style="padding-left:3.2rem">@(HasFilter ? "—" : "No apps here")</div>
                                }
                                @foreach (Data.App app in capps)
                                {
                                    <button type="button" class="node leaf indent-3 @(selectedApp?.Id == app.Id && selectedAppEnvId == env.Id ? "selected" : "")"
                                            @onclick="() => SelectApp(c, app, env)">
                                        <span class="caret"></span>
                                        <i class="ico bi bi-box-seam" aria-hidden="true"></i>
                                        <span class="label">@app.Name</span>
                                    </button>
                                }
                            }
                        }

                        @* Services in this environment *@
                        <div class="tree-subhead indent-2"><span class="tree-sub">Services</span></div>
                        @foreach (SectionItem svc in VisibleEnvServices())
                        {
                            <button type="button" class="node leaf indent-3 @(selectedSection == svc.Key && selectedServiceEnvId == env.Id ? "selected" : "")"
                                    @onclick="() => SelectEnvService(env.Id, svc.Key)">
                                <span class="caret"></span>
                                <i class="ico bi @svc.Icon" aria-hidden="true"></i>
                                <span class="label">@svc.Label</span>
                            </button>
                        }

                        @* Clusters under this environment *@
                        <div class="tree-subhead indent-2">
                            <span class="tree-sub">Clusters</span>
                            <button type="button" class="tree-add" title="New cluster in @env.Name" aria-label="New cluster"
                                    @onclick="() => RegisterClusterInEnv(env.Id)"><i class="bi bi-plus-lg"></i></button>
                        </div>
                        @if (VisibleClustersInEnv(env).Count == 0)
                        {
                            @if (HasFilter)
                            {
                                <div class="tree-empty" style="padding-left:2.3rem">—</div>
                            }
                            else
                            {
                                <button type="button" class="tree-empty btn btn-link btn-sm text-decoration-none p-0" style="padding-left:2.3rem !important"
                                        @onclick="() => RegisterClusterInEnv(env.Id)">
                                    <i class="bi bi-plus-circle me-1"></i>New cluster
                                </button>
                            }
                        }
                        @foreach (KubernetesCluster cl in VisibleClustersInEnv(env))
                        {
                            <button type="button" class="node leaf indent-3 @(selectedCluster?.Id == cl.Id ? "selected" : "")"
                                    @onclick="() => SelectCluster(cl)">
                                <span class="caret"></span>
                                <i class="ico bi bi-hexagon-fill" aria-hidden="true"></i>
                                <span class="label">@cl.Name</span>
                            </button>
                        }
                    }
                }

                @* ── Platform (tenant-wide) ── *@
                <div class="tree-section-head"><span class="tree-section-label">Platform</span></div>
                @foreach (SectionItem item in VisiblePlatform())
                {
                    <button type="button" class="node leaf indent-1 @(selectedSection == item.Key && selectedServiceEnvId == null ? "selected" : "")" @onclick="() => SelectSection(item.Key)">
                        <span class="caret"></span>
                        <i class="ico bi @item.Icon" aria-hidden="true"></i>
                        <span class="label">@item.Label</span>
                    </button>
                }

                @* ── Operations ── *@
                <div class="tree-section-head"><span class="tree-section-label">Operations</span></div>
                @foreach (TreeGroup g in OpsGroups)
                {
                    List<SectionItem> gi = VisibleGroupItems(g);
                    if (HasFilter && gi.Count == 0) { continue; }
                    bool gopen = GroupOpen(g.Name);
                    <button type="button" class="node group indent-1" @onclick="() => ToggleGroup(g.Name)" aria-expanded="@gopen">
                        <span class="caret">@(gopen ? "▾" : "▸")</span>
                        <i class="ico bi @g.Icon" aria-hidden="true"></i>
                        <span class="label">@g.Name</span>
                        <span class="badge-count">@g.Items.Length</span>
                    </button>
                    @if (gopen)
                    {
                        @foreach (SectionItem item in gi)
                        {
                            <button type="button" class="node leaf indent-2 @(selectedSection == item.Key ? "selected" : "")" @onclick="() => SelectSection(item.Key)">
                                <span class="caret"></span>
                                <i class="ico bi @item.Icon" aria-hidden="true"></i>
                                <span class="label">@item.Label</span>
                            </button>
                        }
                    }
                }

                @* ── Manage ── *@
                <div class="tree-section-head"><span class="tree-section-label">Manage</span></div>
                @foreach (SectionItem item in VisibleManage())
                {
                    <button type="button" class="node leaf indent-1 @(selectedSection == item.Key ? "selected" : "")" @onclick="() => SelectSection(item.Key)">
                        <span class="caret"></span>
                        <i class="ico bi @item.Icon" aria-hidden="true"></i>
                        <span class="label">@item.Label</span>
                    </button>
                }
            </div>
        </aside>

        <section class="detail-pane">
            @if (selectedApp is not null && selectedAppCustomer is not null)
            {
                <AppDetail App="selectedApp" TenantId="tenant.Id" CustomerName="@selectedAppCustomer.Name"
                           InitialEnvironmentId="selectedAppEnvId" ShowBackLink="false"
                           OnBack="ClearSelection" OnDeleted="OnAppDeleted" @key="(selectedApp.Id, selectedAppEnvId)" />
            }
            else if (selectedCluster is not null)
            {
                <ClusterDetail Cluster="selectedCluster" TenantId="tenant.Id" ShowBackLink="false"
                               InitialTab="@TabParam"
                               OnBack="ClearSelection" OnDeleted="OnClusterDeleted" @key="selectedCluster.Id" />
            }
            else if (selectedSection is not null)
            {
                @RenderTenantSection(selectedSection)
            }
            else
            {
                <div class="pane-placeholder">
                    <i class="bi bi-diagram-3" aria-hidden="true"></i>
                    <div class="fw-semibold">Select a resource</div>
                    <div class="small">Pick an app or cluster, open a service, or use “+” to add one.</div>
                </div>
            }
        </section>
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    [SupplyParameterFromQuery(Name = "app")] private Guid? AppParam { get; set; }
    [SupplyParameterFromQuery(Name = "cluster")] private Guid? ClusterParam { get; set; }
    [SupplyParameterFromQuery(Name = "section")] private string? SectionParam { get; set; }
    [SupplyParameterFromQuery(Name = "env")] private Guid? EnvParam { get; set; }
    [SupplyParameterFromQuery(Name = "incident")] private Guid? IncidentParam { get; set; }
    [SupplyParameterFromQuery(Name = "tab")] private string? TabParam { get; set; }
    // Trace deep-link (from a resource-view log line): open the Traces section preselecting this
    // cluster + trace. Uses a dedicated `tcluster` rather than `cluster` because a top-level
    // `cluster` param selects the ClusterDetail pane (which has no Traces tab), short-circuiting
    // the section branch below.
    [SupplyParameterFromQuery(Name = "tcluster")] private Guid? TraceClusterParam { get; set; }
    [SupplyParameterFromQuery(Name = "trace")] private string? TraceParam { get; set; }

    private sealed record SectionItem(string Key, string Label, string Icon);
    private sealed record TreeGroup(string Name, string Icon, SectionItem[] Items);

    // Environment-scoped services — rendered under each environment, opened with that EnvironmentId.
    private static readonly SectionItem[] EnvServiceItems =
    [
        new("databases", "Databases", "bi-hdd-stack"),
        new("cache", "Cache", "bi-lightning-charge"),
        new("storage", "Storage", "bi-bucket"),
        new("messaging", "RabbitMQ", "bi-collection"),
        new("kafka", "Kafka", "bi-diagram-3"),
        new("registry", "Registry", "bi-box-seam"),
        new("identity", "Identity", "bi-person-badge"),
    ];
    // Tenant-scoped (shared) services.
    private static readonly SectionItem[] PlatformItems =
    [
        new("vault", "Vault", "bi-safe2"),
    ];
    private static readonly TreeGroup[] OpsGroups =
    [
        new("Advisor", "bi-lightbulb",
        [ new("advisor", "Priorities", "bi-lightbulb") ]),
        new("Monitoring", "bi-speedometer2",
        [ new("overview", "Overview", "bi-speedometer2"), new("logs", "Logs", "bi-journal-text"), new("traces", "Traces", "bi-diagram-3"), new("metrics", "Metrics", "bi-graph-up-arrow"), new("infrastructure", "Infrastructure", "bi-hdd-network"), new("dashboards", "Dashboards", "bi-grid-1x2"), new("rum", "RUM", "bi-browser-chrome"), new("analytics", "Analytics", "bi-graph-up"), new("telemetry-storage", "Telemetry storage", "bi-hdd-stack") ]),
        new("Alerting", "bi-bell",
        [ new("alerts", "Alerts", "bi-bell"), new("alert-rules", "Alert rules", "bi-sliders"), new("telemetry-alerts", "Telemetry alerts", "bi-bell-fill"), new("alert-routing", "Alert routing", "bi-signpost-split"), new("notifications", "Notifications", "bi-broadcast"), new("notification-providers", "Notification providers", "bi-key") ]),
        new("Incidents", "bi-exclamation-octagon",
        [ new("on-call", "On-call", "bi-person-workspace"), new("incidents", "Incidents", "bi-exclamation-octagon") ]),
        new("Reliability", "bi-check2-square",
        [ new("sla", "SLA", "bi-check2-square"), new("maintenance", "Maintenance", "bi-tools"), new("secret-expiry", "Secret expiry", "bi-clock-history") ]),
    ];
    private static readonly SectionItem[] ManageItems =
    [
        new("customers", "Customers", "bi-people"),
        new("groups", "Groups", "bi-diagram-2"),
        new("blueprints", "Blueprints", "bi-diagram-2-fill"),
    ];

    private Tenant? tenant;
    private List<Data.Environment> environments = [];
    private List<Customer> customers = [];
    private readonly Dictionary<Guid, List<Data.App>> appsByCustomer = [];
    private readonly Dictionary<Guid, Customer> customerByAppId = [];
    private List<Data.App> allApps = [];
    private List<KubernetesCluster> clusters = [];

    // The whole tree starts collapsed for easier navigation: environments, customers, and
    // service/ops groups are all collapsed unless the user opens them (or a deep link /
    // filter reveals the relevant node). Each set holds the ids the user has expanded.
    private readonly HashSet<Guid> expandedEnvs = [];               // environments (collapsed by default)
    private readonly HashSet<string> expandedEnvCustomers = [];     // "env:customer" (collapsed by default)
    private readonly HashSet<string> expandedGroups = [];           // service/ops groups (collapsed by default)
    private string filter = "";

    private bool addingEnv;
    private string newEnvName = "";
    private Guid? addingCustomerEnv;
    private string newCustomerName = "";
    private (Guid Env, Guid Cust)? addingApp;
    private string newAppName = "";

    private Data.App? selectedApp;
    private Customer? selectedAppCustomer;
    private KubernetesCluster? selectedCluster;
    private string? selectedSection;
    private Guid? selectedServiceEnvId;   // environment a per-env service was opened under
    private Guid? selectedAppEnvId;       // environment an app was opened under (from its tree path)
    private Guid? registerEnvId;

    private string? _loadedSlug;                              // tenant whose data is currently loaded
    private (Guid?, Guid?, string?, Guid?, Guid?)? _appliedQuery;   // last (app, cluster, section, env, incident) applied

    private bool HasFilter => !string.IsNullOrWhiteSpace(filter);

    protected override async Task OnParametersSetAsync()
    {
        // Load a tenant's data once per slug — in OnParametersSetAsync (not OnInitializedAsync)
        // so switching tenants via the top-nav mega menu, which changes the {Slug} route param
        // on the same component instance, reloads instead of showing the previous tenant.
        if (_loadedSlug != Slug)
        {
            _loadedSlug = Slug;
            _appliedQuery = null;
            if (!await LoadTenantAsync()) return;   // navigated away (unauth / missing / no access)
        }

        if (tenant is null) return;

        // Re-derive the open pane from the query string whenever it changes. This is what makes
        // the mega menu's ?section=… / ?app=… links act when you're already on a tenant page:
        // those change only the query, which never re-runs OnInitializedAsync.
        (Guid?, Guid?, string?, Guid?, Guid?) sig = (AppParam, ClusterParam, SectionParam, EnvParam, IncidentParam);
        if (_appliedQuery is not { } applied || applied != sig)
        {
            _appliedQuery = sig;
            RestoreSelectionFromQuery();
        }
    }

    private async Task<bool> LoadTenantAsync()
    {
        AuthenticationState authState = await AuthStateProvider.GetAuthenticationStateAsync();
        System.Security.Claims.ClaimsPrincipal user = authState.User;
        if (user.Identity?.IsAuthenticated != true) { Nav.NavigateTo("/Account/Login", forceLoad: true); return false; }

        string? userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (userId is null) { Nav.NavigateTo("/Account/Login", forceLoad: true); return false; }

        Tenant? t = await TenantService.GetTenantBySlugAsync(Slug);
        if (t is null) { Nav.NavigateTo("/tenants"); return false; }
        if (!await UserAccessService.HasTenantAccessAsync(userId, t.Id)) { Nav.NavigateTo("/tenants"); return false; }

        // Clear any previous tenant's tree/selection state before loading the new one.
        expandedEnvs.Clear();
        expandedEnvCustomers.Clear();
        expandedGroups.Clear();
        appsByCustomer.Clear();
        filter = "";
        selectedApp = null; selectedAppCustomer = null; selectedCluster = null;
        selectedSection = null; selectedServiceEnvId = null; registerEnvId = null;

        environments = await TenantService.GetEnvironmentsAsync(t.Id);
        customers = await TenantService.GetCustomersAsync(t.Id);
        foreach (Customer c in customers)
            appsByCustomer[c.Id] = await TenantService.GetAppsAsync(c.Id);
        clusters = await TenantService.GetClustersAsync(t.Id);
        RebuildAppIndex();

        tenant = t;
        return true;
    }

    private void RebuildAppIndex()
    {
        customerByAppId.Clear();
        foreach (Customer c in customers)
            foreach (Data.App a in appsByCustomer.GetValueOrDefault(c.Id, []))
                customerByAppId[a.Id] = c;
        allApps = appsByCustomer.Values.SelectMany(x => x).ToList();
    }

    private void RestoreSelectionFromQuery()
    {
        // Derive the open pane entirely from the query string. Reset the URL-backed selections
        // first so switching (e.g. app → section via the mega menu) clears the previous pane.
        // registerEnvId is transient UI state not encoded in the URL, so it is left untouched.
        selectedApp = null; selectedAppCustomer = null; selectedAppEnvId = null; selectedCluster = null;
        selectedSection = null; selectedServiceEnvId = null;

        if (AppParam is Guid appId)
        {
            selectedApp = allApps.FirstOrDefault(a => a.Id == appId);
            if (selectedApp is not null)
            {
                // The env the app was opened under drives which environment's detail shows.
                selectedAppEnvId = EnvParam;
                selectedAppCustomer = customerByAppId.GetValueOrDefault(selectedApp.Id);
                if (selectedAppCustomer is not null)
                    foreach (AppEnvironment ae in selectedApp.AppEnvironments)
                    {
                        expandedEnvs.Add(ae.EnvironmentId);
                        expandedEnvCustomers.Add($"{ae.EnvironmentId}:{selectedAppCustomer.Id}");
                    }
            }
        }
        else if (ClusterParam is Guid clusterId)
        {
            selectedCluster = clusters.FirstOrDefault(c => c.Id == clusterId);
        }
        else if (!string.IsNullOrEmpty(SectionParam))
        {
            selectedSection = SectionParam;
            if (EnvParam is Guid svcEnv)
            {
                selectedServiceEnvId = svcEnv;
                expandedEnvs.Add(svcEnv);
            }
        }
    }

    // ── Tree data helpers ──
    private List<Data.App> AppsOf(Customer c) => appsByCustomer.GetValueOrDefault(c.Id, []);
    private List<Data.App> AppsOfInEnv(Customer c, Data.Environment env) =>
        AppsOf(c).Where(a => a.AppEnvironments.Any(ae => ae.EnvironmentId == env.Id)).ToList();
    private List<KubernetesCluster> ClustersInEnv(Data.Environment env) => clusters.Where(c => c.EnvironmentId == env.Id).ToList();
    private bool Match(string? s) => s is not null && s.Contains(filter.Trim(), StringComparison.OrdinalIgnoreCase);

    private bool EnvHasMatch(Data.Environment env) =>
        Match(env.Name)
        || ClustersInEnv(env).Any(c => Match(c.Name))
        || customers.Any(c => AppsOfInEnv(c, env).Any(a => Match(a.Name)));

    private List<Data.Environment> VisibleEnvironments() =>
        HasFilter ? environments.Where(EnvHasMatch).ToList() : environments;

    private List<Customer> VisibleCustomersInEnv(Data.Environment env)
    {
        if (!HasFilter || Match(env.Name)) return customers;
        return customers.Where(c => Match(c.Name) || AppsOfInEnv(c, env).Any(a => Match(a.Name))).ToList();
    }
    private List<Data.App> VisibleAppsOfInEnv(Customer c, Data.Environment env)
    {
        List<Data.App> apps = AppsOfInEnv(c, env);
        if (!HasFilter || Match(env.Name) || Match(c.Name)) return apps;
        return apps.Where(a => Match(a.Name)).ToList();
    }
    private List<KubernetesCluster> VisibleClustersInEnv(Data.Environment env)
    {
        List<KubernetesCluster> cl = ClustersInEnv(env);
        if (!HasFilter || Match(env.Name)) return cl;
        return cl.Where(c => Match(c.Name)).ToList();
    }
    private List<SectionItem> VisibleGroupItems(TreeGroup g) =>
        HasFilter ? g.Items.Where(i => Match(i.Label) || Match(g.Name)).ToList() : g.Items.ToList();
    private List<SectionItem> VisibleManage() =>
        HasFilter ? ManageItems.Where(i => Match(i.Label)).ToList() : ManageItems.ToList();
    private List<SectionItem> VisibleEnvServices() =>
        HasFilter ? EnvServiceItems.Where(i => Match(i.Label)).ToList() : EnvServiceItems.ToList();
    private List<SectionItem> VisiblePlatform() =>
        HasFilter ? PlatformItems.Where(i => Match(i.Label)).ToList() : PlatformItems.ToList();

    private bool EnvOpen(Data.Environment env) => HasFilter || expandedEnvs.Contains(env.Id);
    private void ToggleEnv(Guid id) { if (!expandedEnvs.Remove(id)) expandedEnvs.Add(id); }
    private bool EnvCustomerOpen(Guid envId, Guid custId) => HasFilter || expandedEnvCustomers.Contains($"{envId}:{custId}");
    private void ToggleEnvCustomer(Guid envId, Guid custId) { string k = $"{envId}:{custId}"; if (!expandedEnvCustomers.Remove(k)) expandedEnvCustomers.Add(k); }
    private bool GroupOpen(string name) => HasFilter || expandedGroups.Contains(name);
    private void ToggleGroup(string name) { if (!expandedGroups.Remove(name)) expandedGroups.Add(name); }
    private void OnFilterInput(ChangeEventArgs e) => filter = e.Value?.ToString() ?? "";

    // ── Inline add ──
    private bool IsAddingApp(Guid envId, Guid custId) => addingApp is { } a && a.Env == envId && a.Cust == custId;
    private void StartAddCustomer(Guid envId) { addingCustomerEnv = addingCustomerEnv == envId ? null : envId; newCustomerName = ""; }
    private void StartAddApp(Guid envId, Guid custId)
    {
        addingApp = IsAddingApp(envId, custId) ? null : (envId, custId);
        expandedEnvCustomers.Add($"{envId}:{custId}");
        newAppName = "";
    }
    private async Task OnAddKey(KeyboardEventArgs e, Func<Task> submit) { if (e.Key == "Enter") await submit(); }

    private async Task AddEnvironment()
    {
        string name = newEnvName.Trim();
        if (name.Length == 0 || tenant is null) return;
        await TenantService.CreateEnvironmentAsync(tenant.Id, name);
        environments = await TenantService.GetEnvironmentsAsync(tenant.Id);
        newEnvName = ""; addingEnv = false;
    }

    private async Task AddCustomer()
    {
        string name = newCustomerName.Trim();
        if (name.Length == 0 || tenant is null) return;
        Customer c = await TenantService.CreateCustomerAsync(tenant.Id, name);
        customers = await TenantService.GetCustomersAsync(tenant.Id);
        appsByCustomer[c.Id] = await TenantService.GetAppsAsync(c.Id);
        RebuildAppIndex();
        newCustomerName = ""; addingCustomerEnv = null;
    }

    private async Task AddApp(Guid envId, Guid custId)
    {
        string name = newAppName.Trim();
        if (name.Length == 0) return;
        Data.App app = await TenantService.CreateAppAsync(custId, name);
        await TenantService.LinkAppToEnvironmentAsync(app.Id, envId);
        appsByCustomer[custId] = await TenantService.GetAppsAsync(custId);
        RebuildAppIndex();
        newAppName = ""; addingApp = null;
    }

    // ── Selection + deep-linking ──
    private void SelectApp(Customer c, Data.App app, Data.Environment env)
    {
        selectedApp = app; selectedAppCustomer = c; selectedAppEnvId = env.Id;
        selectedCluster = null; selectedSection = null; selectedServiceEnvId = null; registerEnvId = null;
        UpdateUrl(app: app.Id, cluster: null, section: null, env: env.Id);
    }
    private void SelectCluster(KubernetesCluster cl)
    {
        selectedCluster = cl; selectedApp = null; selectedAppCustomer = null; selectedAppEnvId = null; selectedSection = null; selectedServiceEnvId = null; registerEnvId = null;
        UpdateUrl(app: null, cluster: cl.Id, section: null, env: null);
    }
    private void SelectSection(string key)
    {
        selectedSection = key; selectedApp = null; selectedAppCustomer = null; selectedAppEnvId = null; selectedCluster = null; selectedServiceEnvId = null; registerEnvId = null;
        UpdateUrl(app: null, cluster: null, section: key, env: null);
    }
    private void SelectEnvService(Guid envId, string key)
    {
        selectedSection = key; selectedServiceEnvId = envId;
        selectedApp = null; selectedAppCustomer = null; selectedAppEnvId = null; selectedCluster = null; registerEnvId = null;
        UpdateUrl(app: null, cluster: null, section: key, env: envId);
    }
    private void RegisterClusterInEnv(Guid envId)
    {
        registerEnvId = envId;
        selectedApp = null; selectedAppCustomer = null; selectedAppEnvId = null; selectedCluster = null; selectedServiceEnvId = null;
        selectedSection = "new-cluster";
        UpdateUrl(app: null, cluster: null, section: "new-cluster", env: envId);
    }
    private void ClearSelection()
    {
        selectedApp = null; selectedAppCustomer = null; selectedAppEnvId = null; selectedCluster = null; selectedSection = null; selectedServiceEnvId = null; registerEnvId = null;
        UpdateUrl(null, null, null, null);
    }
    private void UpdateUrl(Guid? app, Guid? cluster, string? section, Guid? env)
    {
        string uri = Nav.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["app"] = app, ["cluster"] = cluster, ["section"] = section, ["env"] = env,
        });
        Nav.NavigateTo(uri, forceLoad: false, replace: true);
    }

    private async Task OnAppDeleted()
    {
        if (selectedAppCustomer is not null)
        {
            appsByCustomer[selectedAppCustomer.Id] = await TenantService.GetAppsAsync(selectedAppCustomer.Id);
            RebuildAppIndex();
        }
        ClearSelection();
    }
    private async Task OnClusterDeleted()
    {
        if (tenant is not null) clusters = await TenantService.GetClustersAsync(tenant.Id);
        ClearSelection();
    }

    private void NavigateToSection(string key) => SelectSection(key);

    // Opens an environment-scoped service tab (TenantId + EnvironmentId), re-init per env via key.
    private void OpenEnvScoped<T>(RenderTreeBuilder builder, Guid tid) where T : IComponent
    {
        builder.OpenComponent<T>(0);
        builder.SetKey(selectedServiceEnvId);
        builder.AddComponentParameter(1, "TenantId", tid);
        builder.AddComponentParameter(2, "EnvironmentId", selectedServiceEnvId);
        builder.CloseComponent();
    }

    // ── Detail pane: reuse the existing tab components ──
    private RenderFragment RenderTenantSection(string key) => builder =>
    {
        Guid tid = tenant!.Id;
        switch (key)
        {
            case "environments":
                builder.OpenComponent<EnvironmentTab>(0);
                builder.SetKey(registerEnvId);
                builder.AddComponentParameter(1, "TenantId", tid);
                builder.AddComponentParameter(2, "InitialEnvironmentId", registerEnvId);
                builder.CloseComponent();
                break;
            case "customers": builder.OpenComponent<CustomerTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "groups": builder.OpenComponent<GroupTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "networking": builder.OpenComponent<NetworkingTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "blueprints": builder.OpenComponent<BlueprintsTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "new-cluster":
                builder.OpenComponent<NewClusterWizard>(0);
                builder.AddComponentParameter(1, "TenantId", tid);
                builder.AddComponentParameter(2, "TenantSlug", tenant!.Slug);
                builder.AddComponentParameter(3, "InitialEnvironmentId", EnvParam);
                builder.CloseComponent();
                break;
            case "databases": OpenEnvScoped<DatabaseTab>(builder, tid); break;
            case "cache": OpenEnvScoped<CacheTab>(builder, tid); break;
            case "messaging": OpenEnvScoped<MessagingTab>(builder, tid); break;
            case "kafka": OpenEnvScoped<KafkaTab>(builder, tid); break;
            case "storage": OpenEnvScoped<StorageTab>(builder, tid); break;
            case "identity": OpenEnvScoped<IdentityTab>(builder, tid); break;
            case "registry": OpenEnvScoped<RegistryTab>(builder, tid); break;
            case "vault": builder.OpenComponent<VaultTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "overview":
                builder.OpenComponent<TenantMonitoringOverview>(0);
                builder.AddComponentParameter(1, "TenantId", tid);
                builder.AddComponentParameter(2, "TenantSlug", tenant!.Slug);
                builder.AddComponentParameter(3, "OnNavigateTab", EventCallback.Factory.Create<string>(this, NavigateToSection));
                builder.CloseComponent();
                break;
            case "alerts": builder.OpenComponent<TenantAlertsTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "alert-rules": builder.OpenComponent<TenantAlertRulesTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "alert-routing": builder.OpenComponent<AlertRoutingTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "notifications": builder.OpenComponent<NotificationChannels>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "notification-providers": builder.OpenComponent<NotificationProviders>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "on-call": builder.OpenComponent<OnCallTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "incidents":
                builder.OpenComponent<IncidentManagement>(0);
                builder.AddComponentParameter(1, "TenantId", tid);
                builder.AddComponentParameter(2, "FocusIncidentId", IncidentParam);
                builder.CloseComponent();
                break;
            case "logs": builder.OpenComponent<TenantLogsTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "traces":
                builder.OpenComponent<TenantTracesTab>(0);
                builder.AddComponentParameter(1, "TenantId", tid);
                builder.AddComponentParameter(2, "PresetClusterId", (TraceClusterParam ?? ClusterParam)?.ToString());
                builder.AddComponentParameter(3, "PresetTraceId", TraceParam);
                builder.CloseComponent();
                break;
            case "metrics": builder.OpenComponent<TenantMetricsTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "infrastructure": builder.OpenComponent<TenantInfraMetricsTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "dashboards": builder.OpenComponent<TenantDashboardsTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "rum": builder.OpenComponent<TenantRumTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "telemetry-alerts": builder.OpenComponent<TelemetryAlertRulesTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "telemetry-storage": builder.OpenComponent<TenantTelemetrySettings>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "analytics": builder.OpenComponent<TenantOpsAnalyticsTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "sla": builder.OpenComponent<SlaTargetManager>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "maintenance": builder.OpenComponent<MaintenanceWindows>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "secret-expiry":
                builder.OpenComponent<SecretExpiryTab>(0);
                builder.AddComponentParameter(1, "TenantId", tid);
                builder.AddComponentParameter(2, "OnNavigateTab", EventCallback.Factory.Create<string>(this, NavigateToSection));
                builder.CloseComponent();
                break;
            case "advisor":
                builder.OpenComponent<OperationsAdvisorTab>(0);
                builder.AddComponentParameter(1, "TenantId", tid);
                builder.AddComponentParameter(2, "OnNavigateTab", EventCallback.Factory.Create<string>(this, NavigateToSection));
                builder.CloseComponent();
                break;
        }
    };
}
