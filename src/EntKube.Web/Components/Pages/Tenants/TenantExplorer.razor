@page "/tenants/{Slug}/explore"
@using EntKube.Web.Data
@using EntKube.Web.Services
@rendermode InteractiveServer
@inject TenantService TenantService
@inject UserAccessService UserAccessService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

@* ═══════════════════════════════════════════════════════════════════
   TenantExplorer — resource-tree navigation (Phase 2).
   Environment-first tree: each Environment (auto-expanded) groups its
   Apps and Clusters. Tenant-scoped Services / Operations / Manage
   sections sit below. The existing detail + tab components are reused
   verbatim as the right-hand pane. Selection deep-links via the URL.
   Non-destructive: the classic /tenants/{slug} page is unchanged.
   ═══════════════════════════════════════════════════════════════════ *@

<PageTitle>@(tenant?.Name ?? "Tenant") — Explore</PageTitle>

@if (tenant is null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="text-muted mt-2">Loading tenant…</p>
    </div>
}
else
{
    <div class="explorer">
        <aside class="tree-side">
            <div class="tree-head">
                <div class="tree-tenant"><i class="bi bi-building"></i> @tenant.Name</div>
                <div class="tree-filter">
                    <i class="bi bi-search text-muted small" aria-hidden="true"></i>
                    <input type="search" placeholder="Filter resources…" aria-label="Filter resources"
                           value="@filter" @oninput="OnFilterInput" />
                </div>
            </div>

            <div class="tree-scroll" role="tree" aria-label="Tenant resources">

                @* ── Environments → Apps + Clusters ── *@
                <div class="tree-section-label">Environments</div>
                @if (VisibleEnvironments().Count == 0 && UnlinkedApps().Count == 0)
                {
                    <div class="tree-empty">@(HasFilter ? "No matches" : "No environments yet")</div>
                }
                @foreach (Data.Environment env in VisibleEnvironments())
                {
                    bool open = EnvOpen(env);
                    List<Data.App> envApps = VisibleAppsInEnv(env);
                    List<KubernetesCluster> envClusters = VisibleClustersInEnv(env);
                    <button type="button" class="node group indent-1" @onclick="() => ToggleEnv(env.Id)" aria-expanded="@open">
                        <span class="caret">@(open ? "▾" : "▸")</span>
                        <i class="ico bi bi-diagram-3-fill" aria-hidden="true"></i>
                        <span class="label">@env.Name</span>
                        <span class="badge-count">@(AppsInEnv(env).Count + ClustersInEnv(env).Count)</span>
                    </button>
                    @if (open)
                    {
                        <div class="tree-sub indent-2">Apps</div>
                        @if (envApps.Count == 0)
                        {
                            <div class="tree-empty" style="padding-left:2.3rem">@(HasFilter ? "—" : "No apps")</div>
                        }
                        @foreach (Data.App app in envApps)
                        {
                            <button type="button"
                                    class="node leaf indent-3 @(IsAppSelected(app.Id, env.Id) ? "selected" : "")"
                                    @onclick="() => SelectApp(env, app)">
                                <span class="caret"></span>
                                <i class="ico bi bi-box-seam" aria-hidden="true"></i>
                                <span class="label">@app.Name <span class="sub">@CustomerNameOf(app)</span></span>
                            </button>
                        }
                        <div class="tree-sub indent-2">Clusters</div>
                        @if (envClusters.Count == 0)
                        {
                            <div class="tree-empty" style="padding-left:2.3rem">@(HasFilter ? "—" : "No clusters")</div>
                        }
                        @foreach (KubernetesCluster cl in envClusters)
                        {
                            <button type="button"
                                    class="node leaf indent-3 @(selectedCluster?.Id == cl.Id ? "selected" : "")"
                                    @onclick="() => SelectCluster(cl)">
                                <span class="caret"></span>
                                <i class="ico bi bi-hexagon-fill" aria-hidden="true"></i>
                                <span class="label">@cl.Name</span>
                            </button>
                        }
                    }
                }
                @{ List<Data.App> unlinked = VisibleUnlinkedApps(); }
                @if (unlinked.Count > 0)
                {
                    <div class="tree-sub indent-1">No environment</div>
                    @foreach (Data.App app in unlinked)
                    {
                        <button type="button"
                                class="node leaf indent-2 @(IsAppSelected(app.Id, null) ? "selected" : "")"
                                @onclick="() => SelectApp(null, app)">
                            <span class="caret"></span>
                            <i class="ico bi bi-box-seam" aria-hidden="true"></i>
                            <span class="label">@app.Name <span class="sub">@CustomerNameOf(app)</span></span>
                        </button>
                    }
                }

                @* ── tenant-scoped sections ── *@
                @RenderSection("Services", "bi-hdd-stack", ServiceItems, servicesOpen, () => servicesOpen = !servicesOpen)
                @RenderSection("Operations", "bi-speedometer2", OpsItems, opsOpen, () => opsOpen = !opsOpen)
                @RenderSection("Manage", "bi-sliders", ManageItems, manageOpen, () => manageOpen = !manageOpen)
            </div>

            <div class="tree-foot">
                <a href="/tenants/@Slug" class="small text-decoration-none text-muted">
                    <i class="bi bi-arrow-left me-1"></i>Classic view
                </a>
            </div>
        </aside>

        <section class="detail-pane">
            @if (selectedApp is not null && selectedAppCustomer is not null)
            {
                <AppDetail App="selectedApp"
                           TenantId="tenant.Id"
                           CustomerName="@selectedAppCustomer.Name"
                           InitialEnvironmentId="selectedAppEnvId"
                           OnBack="ClearSelection"
                           OnDeleted="OnAppDeleted"
                           @key="@($"{selectedApp.Id}:{selectedAppEnvId}")" />
            }
            else if (selectedCluster is not null)
            {
                <ClusterDetail Cluster="selectedCluster"
                               TenantId="tenant.Id"
                               OnBack="ClearSelection"
                               OnDeleted="OnClusterDeleted"
                               @key="selectedCluster.Id" />
            }
            else if (selectedSection is not null)
            {
                @RenderTenantSection(selectedSection)
            }
            else
            {
                <div class="pane-placeholder">
                    <i class="bi bi-diagram-3" aria-hidden="true"></i>
                    <div class="fw-semibold">Select a resource</div>
                    <div class="small">Pick an app or cluster under an environment, open a service, or type to filter.</div>
                </div>
            }
        </section>
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    [SupplyParameterFromQuery(Name = "app")] private Guid? AppParam { get; set; }
    [SupplyParameterFromQuery(Name = "env")] private Guid? EnvParam { get; set; }
    [SupplyParameterFromQuery(Name = "cluster")] private Guid? ClusterParam { get; set; }
    [SupplyParameterFromQuery(Name = "section")] private string? SectionParam { get; set; }

    private sealed record SectionItem(string Key, string Label, string Icon);

    private static readonly SectionItem[] ServiceItems =
    [
        new("databases", "Databases", "bi-hdd-stack"),
        new("cache", "Cache", "bi-lightning-charge"),
        new("messaging", "RabbitMQ", "bi-collection"),
        new("kafka", "Kafka", "bi-diagram-3"),
        new("storage", "Storage", "bi-bucket"),
        new("identity", "Identity", "bi-person-badge"),
        new("registry", "Registry", "bi-box-seam"),
        new("vault", "Vault", "bi-safe2"),
    ];
    private static readonly SectionItem[] OpsItems =
    [
        new("overview", "Monitoring", "bi-speedometer2"),
        new("alerts", "Alerts", "bi-bell"),
        new("alert-rules", "Alert rules", "bi-sliders"),
        new("alert-routing", "Alert routing", "bi-signpost-split"),
        new("notifications", "Notifications", "bi-broadcast"),
        new("on-call", "On-call", "bi-person-workspace"),
        new("incidents", "Incidents", "bi-exclamation-octagon"),
        new("logs", "Logs", "bi-journal-text"),
        new("analytics", "Analytics", "bi-graph-up"),
        new("sla", "SLA", "bi-check2-square"),
        new("maintenance", "Maintenance", "bi-tools"),
        new("secret-expiry", "Secret expiry", "bi-clock-history"),
    ];
    private static readonly SectionItem[] ManageItems =
    [
        new("customers", "Customers", "bi-people"),
        new("groups", "Groups", "bi-diagram-2"),
        new("networking", "Networking", "bi-hdd-network"),
        new("blueprints", "Blueprints", "bi-diagram-2-fill"),
    ];

    private Tenant? tenant;
    private List<Data.Environment> environments = [];
    private List<Customer> customers = [];
    private readonly Dictionary<Guid, List<Data.App>> appsByCustomer = [];
    private readonly Dictionary<Guid, Customer> customerByAppId = [];
    private List<Data.App> allApps = [];
    private List<KubernetesCluster> clusters = [];

    private readonly HashSet<Guid> collapsedEnvs = [];
    private bool servicesOpen = true;
    private bool opsOpen;
    private bool manageOpen;
    private string filter = "";

    private Data.App? selectedApp;
    private Customer? selectedAppCustomer;
    private Guid? selectedAppEnvId;
    private KubernetesCluster? selectedCluster;
    private string? selectedSection;

    private bool HasFilter => !string.IsNullOrWhiteSpace(filter);

    protected override async Task OnInitializedAsync()
    {
        AuthenticationState authState = await AuthStateProvider.GetAuthenticationStateAsync();
        System.Security.Claims.ClaimsPrincipal user = authState.User;
        if (user.Identity?.IsAuthenticated != true) { Nav.NavigateTo("/Account/Login", forceLoad: true); return; }

        string? userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (userId is null) { Nav.NavigateTo("/Account/Login", forceLoad: true); return; }

        Tenant? t = await TenantService.GetTenantBySlugAsync(Slug);
        if (t is null) { Nav.NavigateTo("/tenants"); return; }
        if (!await UserAccessService.HasTenantAccessAsync(userId, t.Id)) { Nav.NavigateTo("/tenants"); return; }

        environments = await TenantService.GetEnvironmentsAsync(t.Id);
        customers = await TenantService.GetCustomersAsync(t.Id);
        foreach (Customer c in customers)
        {
            List<Data.App> apps = await TenantService.GetAppsAsync(c.Id);
            appsByCustomer[c.Id] = apps;
            foreach (Data.App a in apps)
                customerByAppId[a.Id] = c;
        }
        allApps = appsByCustomer.Values.SelectMany(x => x).ToList();
        clusters = await TenantService.GetClustersAsync(t.Id);

        tenant = t;
        RestoreSelectionFromQuery();
    }

    private void RestoreSelectionFromQuery()
    {
        if (AppParam is Guid appId)
        {
            selectedApp = allApps.FirstOrDefault(a => a.Id == appId);
            if (selectedApp is not null)
            {
                selectedAppCustomer = customerByAppId.GetValueOrDefault(selectedApp.Id);
                selectedAppEnvId = EnvParam;
                if (EnvParam is Guid e) collapsedEnvs.Remove(e);
            }
        }
        else if (ClusterParam is Guid clusterId)
        {
            selectedCluster = clusters.FirstOrDefault(c => c.Id == clusterId);
        }
        else if (!string.IsNullOrEmpty(SectionParam))
        {
            selectedSection = SectionParam;
        }
    }

    // ── Tree data helpers ──
    private Customer? CustomerObjOf(Data.App a) => customerByAppId.GetValueOrDefault(a.Id);
    private string CustomerNameOf(Data.App a) => CustomerObjOf(a)?.Name ?? "";

    private List<Data.App> AppsInEnv(Data.Environment env) =>
        allApps.Where(a => a.AppEnvironments.Any(ae => ae.EnvironmentId == env.Id)).ToList();
    private List<KubernetesCluster> ClustersInEnv(Data.Environment env) =>
        clusters.Where(c => c.EnvironmentId == env.Id).ToList();
    private List<Data.App> UnlinkedApps() =>
        allApps.Where(a => a.AppEnvironments.Count == 0).ToList();

    private bool Match(string? s) =>
        s is not null && s.Contains(filter.Trim(), StringComparison.OrdinalIgnoreCase);

    private bool EnvHasMatch(Data.Environment env) =>
        Match(env.Name)
        || AppsInEnv(env).Any(a => Match(a.Name) || Match(CustomerNameOf(a)))
        || ClustersInEnv(env).Any(c => Match(c.Name));

    private List<Data.Environment> VisibleEnvironments() =>
        HasFilter ? environments.Where(EnvHasMatch).ToList() : environments;

    private List<Data.App> VisibleAppsInEnv(Data.Environment env)
    {
        List<Data.App> apps = AppsInEnv(env);
        if (!HasFilter || Match(env.Name)) return apps;
        return apps.Where(a => Match(a.Name) || Match(CustomerNameOf(a))).ToList();
    }
    private List<KubernetesCluster> VisibleClustersInEnv(Data.Environment env)
    {
        List<KubernetesCluster> cl = ClustersInEnv(env);
        if (!HasFilter || Match(env.Name)) return cl;
        return cl.Where(c => Match(c.Name)).ToList();
    }
    private List<Data.App> VisibleUnlinkedApps()
    {
        List<Data.App> apps = UnlinkedApps();
        if (!HasFilter) return apps;
        return apps.Where(a => Match(a.Name) || Match(CustomerNameOf(a))).ToList();
    }

    private bool EnvOpen(Data.Environment env) => HasFilter || !collapsedEnvs.Contains(env.Id);
    private void ToggleEnv(Guid id) { if (!collapsedEnvs.Remove(id)) collapsedEnvs.Add(id); }
    private void OnFilterInput(ChangeEventArgs e) => filter = e.Value?.ToString() ?? "";

    private bool IsAppSelected(Guid appId, Guid? envId) =>
        selectedApp?.Id == appId && selectedAppEnvId == envId;

    // ── Selection + deep-linking ──
    private void SelectApp(Data.Environment? env, Data.App app)
    {
        selectedApp = app;
        selectedAppCustomer = CustomerObjOf(app);
        selectedAppEnvId = env?.Id;
        selectedCluster = null;
        selectedSection = null;
        UpdateUrl(app: app.Id, env: env?.Id, cluster: null, section: null);
    }

    private void SelectCluster(KubernetesCluster cl)
    {
        selectedCluster = cl;
        selectedApp = null; selectedAppCustomer = null; selectedAppEnvId = null;
        selectedSection = null;
        UpdateUrl(app: null, env: null, cluster: cl.Id, section: null);
    }

    private void SelectSection(string key)
    {
        selectedSection = key;
        selectedApp = null; selectedAppCustomer = null; selectedAppEnvId = null;
        selectedCluster = null;
        UpdateUrl(app: null, env: null, cluster: null, section: key);
    }

    private void ClearSelection()
    {
        selectedApp = null; selectedAppCustomer = null; selectedAppEnvId = null;
        selectedCluster = null; selectedSection = null;
        UpdateUrl(null, null, null, null);
    }

    private void UpdateUrl(Guid? app, Guid? env, Guid? cluster, string? section)
    {
        string uri = Nav.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["app"] = app,
            ["env"] = env,
            ["cluster"] = cluster,
            ["section"] = section,
        });
        Nav.NavigateTo(uri, forceLoad: false, replace: true);
    }

    private async Task OnAppDeleted()
    {
        if (selectedAppCustomer is not null)
        {
            List<Data.App> apps = await TenantService.GetAppsAsync(selectedAppCustomer.Id);
            appsByCustomer[selectedAppCustomer.Id] = apps;
            allApps = appsByCustomer.Values.SelectMany(x => x).ToList();
        }
        ClearSelection();
    }

    private async Task OnClusterDeleted()
    {
        if (tenant is not null)
            clusters = await TenantService.GetClustersAsync(tenant.Id);
        ClearSelection();
    }

    // ── Tenant-scoped section rendering (reuses the existing tab components) ──
    private RenderFragment RenderSection(string title, string icon, SectionItem[] items, bool open, Action toggle) => builder =>
    {
        List<SectionItem> vis = HasFilter ? items.Where(i => Match(i.Label)).ToList() : items.ToList();
        if (HasFilter && vis.Count == 0) return;

        int seq = 0;
        builder.OpenElement(seq++, "button");
        builder.AddAttribute(seq++, "type", "button");
        builder.AddAttribute(seq++, "class", "node group indent-1 mt-1");
        builder.AddAttribute(seq++, "aria-expanded", (open || HasFilter) ? "true" : "false");
        builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, toggle));
        builder.AddMarkupContent(seq++, $"<span class=\"caret\">{((open || HasFilter) ? "▾" : "▸")}</span><i class=\"ico bi {icon}\" aria-hidden=\"true\"></i>");
        builder.OpenElement(seq++, "span");
        builder.AddAttribute(seq++, "class", "label");
        builder.AddContent(seq++, title);
        builder.CloseElement();
        builder.CloseElement();

        if (open || HasFilter)
        {
            foreach (SectionItem item in vis)
            {
                builder.OpenElement(seq++, "button");
                builder.AddAttribute(seq++, "type", "button");
                builder.AddAttribute(seq++, "class", $"node leaf indent-2 {(selectedSection == item.Key ? "selected" : "")}");
                builder.SetKey(item.Key);
                builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => SelectSection(item.Key)));
                builder.AddMarkupContent(seq++, $"<span class=\"caret\"></span><i class=\"ico bi {item.Icon}\" aria-hidden=\"true\"></i>");
                builder.OpenElement(seq++, "span");
                builder.AddAttribute(seq++, "class", "label");
                builder.AddContent(seq++, item.Label);
                builder.CloseElement();
                builder.CloseElement();
            }
        }
    };

    private void NavigateToSection(string key) => SelectSection(key);

    private RenderFragment RenderTenantSection(string key) => builder =>
    {
        Guid tid = tenant!.Id;
        switch (key)
        {
            case "customers": builder.OpenComponent<CustomerTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "groups": builder.OpenComponent<GroupTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "networking": builder.OpenComponent<NetworkingTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "blueprints": builder.OpenComponent<BlueprintsTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "databases": builder.OpenComponent<DatabaseTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "cache": builder.OpenComponent<CacheTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "messaging": builder.OpenComponent<MessagingTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "kafka": builder.OpenComponent<KafkaTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "storage": builder.OpenComponent<StorageTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "identity": builder.OpenComponent<IdentityTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "registry": builder.OpenComponent<RegistryTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "vault": builder.OpenComponent<VaultTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "overview":
                builder.OpenComponent<TenantMonitoringOverview>(0);
                builder.AddComponentParameter(1, "TenantId", tid);
                builder.AddComponentParameter(2, "TenantSlug", tenant!.Slug);
                builder.AddComponentParameter(3, "OnNavigateTab", EventCallback.Factory.Create<string>(this, NavigateToSection));
                builder.CloseComponent();
                break;
            case "alerts": builder.OpenComponent<TenantAlertsTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "alert-rules": builder.OpenComponent<TenantAlertRulesTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "alert-routing": builder.OpenComponent<AlertRoutingTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "notifications": builder.OpenComponent<NotificationChannels>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "on-call": builder.OpenComponent<OnCallTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "incidents": builder.OpenComponent<IncidentManagement>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "logs": builder.OpenComponent<TenantLogsTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "analytics": builder.OpenComponent<TenantOpsAnalyticsTab>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "sla": builder.OpenComponent<SlaTargetManager>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "maintenance": builder.OpenComponent<MaintenanceWindows>(0); builder.AddComponentParameter(1, "TenantId", tid); builder.CloseComponent(); break;
            case "secret-expiry":
                builder.OpenComponent<SecretExpiryTab>(0);
                builder.AddComponentParameter(1, "TenantId", tid);
                builder.AddComponentParameter(2, "OnNavigateTab", EventCallback.Factory.Create<string>(this, NavigateToSection));
                builder.CloseComponent();
                break;
        }
    };
}
