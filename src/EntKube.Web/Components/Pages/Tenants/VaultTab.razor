    private async Task DeleteSecret(Guid secretId)
    {
        errorMessage = null;

        try
        {
            // Check if deletion is blocked by active storage bindings.

            (bool canDelete, string? reason) = await VaultService.CanDeleteSecretAsync(secretId);

            if (!canDelete)
            {
                errorMessage = reason;
                Toasts.Warning(reason ?? "This secret cannot be deleted right now.");
                return;
            }

            await VaultService.DeleteSecretAsync(secretId);
            revealedSecretId = null;
            editSecretId = null;
            await LoadSecrets();
            Toasts.Success("Secret deleted.");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Toasts.Error($"Failed to delete secret: {ex.Message}");
        }
    }

    private async Task RevealSecret(VaultSecret secret)
    {
        // Toggle off if already revealed.

        if (revealedSecretId == secret.Id)
        {
            revealedSecretId = null;
            revealedValue = null;
            revealedBundle = null;
            revealedOAuthBundle = null;
            return;
        }

        // Decrypt and reveal the value (or certificate / OAuth bundle).

        revealedValue = null;
        revealedBundle = null;
        revealedOAuthBundle = null;
        if (secret.SecretType == VaultSecretType.Certificate)
        {
            revealedBundle = await VaultService.GetCertificateBundleByIdAsync(secret.Id);
        }
        else if (secret.SecretType == VaultSecretType.OAuthClient)
        {
            revealedOAuthBundle = await VaultService.GetOAuthClientBundleByIdAsync(secret.Id);
        }
        else
        {
            revealedValue = await VaultService.GetSecretValueByIdAsync(secret.Id);
        }
        revealedSecretId = secret.Id;
    }

    private async Task StartEdit(VaultSecret secret)
    {
        editSecretId = secret.Id;
        editSecretValue = "";
        editCertBundle = null;
        editOAuthBundle = null;
        revealedSecretId = null;
        revealedValue = null;
        revealedBundle = null;
        revealedOAuthBundle = null;

        if (secret.SecretType == VaultSecretType.Certificate)
        {
            editCertBundle = await VaultService.GetCertificateBundleByIdAsync(secret.Id) ?? new CertificateBundle();
        }
        else if (secret.SecretType == VaultSecretType.OAuthClient)
        {
            editOAuthBundle = await VaultService.GetOAuthClientBundleByIdAsync(secret.Id) ?? new OAuthClientBundle();
        }
    }

    private void CancelEdit()
    {
        editSecretId = null;
        editSecretValue = "";
        editCertBundle = null;
        editOAuthBundle = null;
    }

    private async Task SaveEdit()
    {
        if (editSecretId is null || string.IsNullOrWhiteSpace(editSecretValue))
        {
            return;
        }

        errorMessage = null;

        bool updated = await VaultService.UpdateSecretValueAsync(editSecretId.Value, editSecretValue.Trim());

        if (updated)
        {
            successMessage = "Secret value updated.";
        }
        else
        {
            errorMessage = "Failed to update secret.";
        }

        editSecretId = null;
        editSecretValue = "";
        await LoadSecrets();
    }

