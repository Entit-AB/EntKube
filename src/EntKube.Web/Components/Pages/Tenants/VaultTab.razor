        try
        {
            if (scope == "app")
            {
                Guid? environmentId = newSecretEnvironmentId != Guid.Empty ? newSecretEnvironmentId : null;
                await VaultService.SetAppSecretAsync(TenantId, selectedAppId, newSecretName.Trim(), newSecretValue.Trim(), environmentId: environmentId);
            }
            else if (scope == "component")
