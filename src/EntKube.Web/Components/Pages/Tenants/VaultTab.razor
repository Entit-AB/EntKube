@using EntKube.Web.Data
@using EntKube.Web.Services
@using Microsoft.EntityFrameworkCore
@using EntKube.Web.Components.Pages.Shared
@inject VaultService VaultService
@inject TenantService TenantService
@inject StorageService StorageService
@inject CnpgService CnpgService
@inject MongoService MongoService
@inject RegisteredPostgresService RegisteredPostgresService
@inject AppGovernanceService AppGovernanceService
@inject AuthenticationStateProvider AuthStateProvider
@inject ToastService Toasts

<div class="d-flex align-items-center mb-2">
    <i class="bi bi-shield-lock fs-4 me-2 text-primary"></i>
    <h4 class="mb-0">Secrets Vault</h4>
</div>
<p class="text-muted small mb-3">Encrypted secrets for apps and cluster components. Per-tenant AES-256-GCM envelope encryption with auto-unseal.</p>

@if (!vaultInitialized)
{
    <div class="card border-warning shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-shield-exclamation text-warning" style="font-size: 3rem;"></i>
            <h5 class="mt-3">Vault Not Initialized</h5>
            <p class="text-muted mb-3">A per-tenant encryption key will be generated and sealed with the platform root key.</p>
            <button class="btn btn-primary" @onclick="InitializeVault">
                <i class="bi bi-key me-1"></i>Initialize Vault
            </button>
        </div>
    </div>
}
else
{
    @* --- Scope Toggle --- *@
    <div class="d-flex align-items-center gap-3 mb-3">
        <span class="text-muted small fw-medium">Scope:</span>
        <div class="btn-group" role="group">
            <button class="btn btn-sm @(scope == "app" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SwitchScope("app")'>
                <i class="bi bi-app-indicator me-1"></i>App Secrets
            </button>
            <button class="btn btn-sm @(scope == "component" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SwitchScope("component")'>
                <i class="bi bi-puzzle me-1"></i>Component Secrets
            </button>
            <button class="btn btn-sm @(scope == "storage" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SwitchScope("storage")'>
                <i class="bi bi-hdd me-1"></i>Storage Secrets
            </button>
            <button class="btn btn-sm @(scope == "cnpg" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SwitchScope("cnpg")'>
                <i class="bi bi-database me-1"></i>PostgreSQL
            </button>
            <button class="btn btn-sm @(scope == "mongodb" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SwitchScope("mongodb")'>
                <i class="bi bi-database me-1"></i>MongoDB
            </button>
            <button class="btn btn-sm @(scope == "regpostgres" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SwitchScope("regpostgres")'>
                <i class="bi bi-database me-1"></i>Registered DB
            </button>
            <button class="btn btn-sm @(scope == "docker" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SwitchScope("docker")'>
                <i class="bi bi-box-seam me-1"></i>Docker Registries
            </button>
            <button class="btn btn-sm @(scope == "kubeconfig" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SwitchScope("kubeconfig")'>
                <i class="bi bi-file-earmark-lock me-1"></i>Cluster Kubeconfigs
            </button>
        </div>
    </div>

    @* --- Selector Dropdown --- *@
    @if (scope == "app")
    {
        @if (appOptions is not null && appOptions.Count > 0)
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body py-2">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent"><i class="bi bi-app"></i></span>
                        <select class="form-select" @bind="selectedAppId" @bind:after="LoadSecrets">
                            <option value="@Guid.Empty">Select an app...</option>
                            @foreach ((string label, Guid id) in appOptions)
                            {
                                <option value="@id">@label</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        }
        else
        {
            <EmptyState Icon="bi-app"
                        Message="Create a customer and app first to store app secrets." />
        }
    }
    else if (scope == "component")
    {
        @if (componentOptions is not null && componentOptions.Count > 0)
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body py-2">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent"><i class="bi bi-puzzle"></i></span>
                        <select class="form-select" @bind="selectedComponentId" @bind:after="LoadSecrets">
                            <option value="@Guid.Empty">Select a component...</option>
                            @foreach ((string label, Guid id) in componentOptions)
                            {
                                <option value="@id">@label</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        }
        else
        {
            <EmptyState Icon="bi-puzzle"
                        Message="Create an environment, cluster, and component first to store component secrets." />
        }
    }
    else if (scope == "storage")
    {
        @if (storageLinkOptions is not null && storageLinkOptions.Count > 0)
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body py-2">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent"><i class="bi bi-hdd"></i></span>
                        <select class="form-select" @bind="selectedStorageLinkId" @bind:after="LoadSecrets">
                            <option value="@Guid.Empty">Select a storage link...</option>
                            @foreach ((string label, Guid id) in storageLinkOptions)
                            {
                                <option value="@id">@label</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        }
        else
        {
            <EmptyState Icon="bi-hdd"
                        Message="Create a storage link first to view its secrets." />
        }
    }

    else if (scope == "cnpg")
    {
        @if (cnpgClusterOptions is not null && cnpgClusterOptions.Count > 0)
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body py-2">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent"><i class="bi bi-database"></i></span>
                        <select class="form-select" @bind="selectedCnpgClusterId" @bind:after="LoadSecrets">
                            <option value="@Guid.Empty">Select a CNPG cluster...</option>
                            @foreach ((string label, Guid id) in cnpgClusterOptions)
                            {
                                <option value="@id">@label</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        }
        else
        {
            <EmptyState Icon="bi-database"
                        Message="No CNPG clusters found for this tenant." />
        }
    }

    else if (scope == "mongodb")
    {
        @if (mongoClusterOptions is not null && mongoClusterOptions.Count > 0)
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body py-2">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent"><i class="bi bi-database"></i></span>
                        <select class="form-select" @bind="selectedMongoClusterId" @bind:after="LoadSecrets">
                            <option value="@Guid.Empty">Select a MongoDB cluster...</option>
                            @foreach ((string label, Guid id) in mongoClusterOptions)
                            {
                                <option value="@id">@label</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        }
        else
        {
            <EmptyState Icon="bi-database"
                        Message="No MongoDB clusters found for this tenant." />
        }
    }

    else if (scope == "regpostgres")
    {
        @if (regPostgresOptions is not null && regPostgresOptions.Count > 0)
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body py-2">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent"><i class="bi bi-database"></i></span>
                        <select class="form-select" @bind="selectedRegPostgresInstanceId" @bind:after="LoadSecrets">
                            <option value="@Guid.Empty">Select a registered Postgres instance...</option>
                            @foreach ((string label, Guid id) in regPostgresOptions)
                            {
                                <option value="@id">@label</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        }
        else
        {
            <EmptyState Icon="bi-database"
                        Message="No registered Postgres instances found for this tenant." />
        }
    }

    @* --- Docker Registries Panel --- *@
    @if (scope == "docker")
    {
        @* Scope registry credentials to an app (and its environments), like other secrets,
           or leave tenant-wide (shared across all apps). *@
        @if (appOptions is not null && appOptions.Count > 0)
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body py-2">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent"><i class="bi bi-app"></i></span>
                        <select class="form-select" @bind="dockerAppId">
                            <option value="@Guid.Empty">Tenant-wide (all apps)</option>
                            @foreach ((string label, Guid id) in appOptions)
                            {
                                <option value="@id">@label</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        }
        <DockerRegistriesPanel
            TenantId="TenantId"
            AppId="dockerAppId"
            IsAdmin="true" />
    }

    @* --- Cluster Kubeconfigs Panel --- *@
    @if (scope == "kubeconfig")
    {
        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex align-items-center py-2">
                <i class="bi bi-file-earmark-lock me-2 text-primary"></i>
                <strong>Cluster Kubeconfigs</strong>
                <span class="text-muted small ms-2">Encrypted credentials EntKube uses to connect to registered clusters. Rotate one from its cluster's Kubeconfig panel.</span>
            </div>
            <div class="card-body">
                @if (kubeconfigSecrets is null)
                {
                    <p class="mb-0"><em>Loading…</em></p>
                }
                else if (kubeconfigSecrets.Count == 0)
                {
                    <p class="text-muted mb-0">No cluster kubeconfigs are stored in the vault yet.</p>
                }
                else
                {
                    @if (!string.IsNullOrEmpty(kubeconfigError))
                    {
                        <div class="alert alert-danger py-2 small">@kubeconfigError</div>
                    }
                    @if (!string.IsNullOrEmpty(kubeconfigSuccess))
                    {
                        <div class="alert alert-success py-2 small">@kubeconfigSuccess</div>
                    }
                    <table class="table table-sm align-middle mb-0" style="table-layout: fixed; width: 100%;">
                        <thead>
                            <tr>
                                <th>Cluster</th>
                                <th>Expiry</th>
                                <th>Updated</th>
                                <th>By</th>
                                <th class="text-end" style="width: 130px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (VaultSecret kc in kubeconfigSecrets)
                            {
                                <tr>
                                    <td class="text-truncate">@(kc.OwnerCluster?.Name ?? "—")</td>
                                    <td>
                                        @{ (string css, string text) = KubeconfigStatus(kc.Id); }
                                        <span class="badge @css">@text</span>
                                    </td>
                                    <td><small class="text-muted">@kc.UpdatedAt.ToString("MMM d, HH:mm")</small></td>
                                    <td class="text-truncate"><small class="text-muted">@(kc.UpdatedBy ?? "—")</small></td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => RevealKubeconfig(kc)"
                                                disabled="@kubeconfigRevealLoading"
                                                title="@(revealedKubeconfigId == kc.Id ? "Hide kubeconfig" : "Reveal kubeconfig")"
                                                aria-label="@($"{(revealedKubeconfigId == kc.Id ? "Hide" : "Reveal")} kubeconfig for cluster {kc.OwnerCluster?.Name ?? "unknown"}")">
                                            <i class="bi @(revealedKubeconfigId == kc.Id ? "bi-eye-slash" : "bi-eye")"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-warning" @onclick="() => StartKubeconfigUpdate(kc)"
                                                title="Update kubeconfig"
                                                aria-label="@($"Update kubeconfig for cluster {kc.OwnerCluster?.Name ?? "unknown"}")">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    </td>
                                </tr>
                                @if (revealedKubeconfigId == kc.Id)
                                {
                                    <tr>
                                        <td colspan="5" class="bg-light">
                                            <pre class="mb-0 small user-select-all" style="white-space: pre-wrap; word-break: break-all; max-height: 320px; overflow: auto;">@revealedKubeconfigYaml</pre>
                                        </td>
                                    </tr>
                                }
                                @if (updateKubeconfigId == kc.Id)
                                {
                                    <tr>
                                        <td colspan="5" class="bg-light">
                                            <div class="p-1">
                                                <label class="form-label small mb-1">Replacement kubeconfig</label>
                                                <KubeconfigPicker OnSelectionChanged="OnUpdateKubeconfigSelected" />
                                                <div class="row g-2 align-items-end mt-2">
                                                    <div class="col-auto" style="max-width: 220px;">
                                                        <label class="form-label small mb-1">Expiry <span class="text-muted">(optional)</span></label>
                                                        <input type="date" class="form-control form-control-sm" @bind="updateKubeconfigExpiry" />
                                                    </div>
                                                    <div class="col-auto">
                                                        <button class="btn btn-sm btn-primary" @onclick="() => SaveKubeconfigUpdate(kc)"
                                                                disabled="@(updateKubeconfigSelection is null || savingKubeconfig)">
                                                            <i class="bi bi-save me-1"></i>@(savingKubeconfig ? "Saving…" : "Update")
                                                        </button>
                                                        <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="CancelKubeconfigUpdate">Cancel</button>
                                                    </div>
                                                </div>
                                                <div class="form-text">Archives the current version and refreshes the expiry used for warnings. Never synced to Kubernetes.</div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }

    @* --- Secrets Panel --- *@
    @if (HasSelection())
    {
        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex align-items-center py-2">
                <i class="bi bi-lock me-2 text-primary"></i>
                <strong>Secrets</strong>
                @if (scope == "app" && secrets?.Any(s => s.SyncToKubernetes) == true)
                {
                    <button class="btn btn-sm btn-outline-success ms-auto" @onclick="SyncAllAppSecrets" disabled="@syncingSecrets">
                        @if (syncingSecrets) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        else { <i class="bi bi-cloud-arrow-up me-1"></i> }
                        Sync All to K8s
                    </button>
                }
            </div>
            <div class="card-body">
                <ConfirmDialog Visible="@(pendingConfirm is not null)"
                               Message="@(pendingConfirm?.Message ?? "")"
                               ConfirmText="@(pendingConfirm?.ConfirmText ?? "Delete")"
                               IsBusy="confirmBusy"
                               OnConfirm="RunPendingConfirmAsync"
                               OnCancel="() => pendingConfirm = null" />
                @* Add secret form — hidden for read-only DB scopes *@
                @if (scope is not "mongodb" and not "regpostgres")
                {
                    @* Certificates and OAuth clients are only meaningful for app secrets. *@
                    @if (scope == "app")
                    {
                        <div class="btn-group btn-group-sm mb-2">
                            <button type="button" class="btn @(addMode == "opaque" ? "btn-primary" : "btn-outline-primary")"
                                    @onclick='() => addMode = "opaque"'>
                                <i class="bi bi-key me-1"></i>Opaque value
                            </button>
                            <button type="button" class="btn @(addMode == "certificate" ? "btn-primary" : "btn-outline-primary")"
                                    @onclick='() => addMode = "certificate"'>
                                <i class="bi bi-patch-check me-1"></i>Certificate
                            </button>
                            <button type="button" class="btn @(addMode == "oauth" ? "btn-primary" : "btn-outline-primary")"
                                    @onclick='() => addMode = "oauth"'>
                                <i class="bi bi-shield-lock me-1"></i>OAuth / OIDC
                            </button>
                        </div>
                    }

                    @if (scope == "app" && addMode == "certificate")
                    {
                        <div class="row g-2 mb-2">
                            <div class="col-md-4">
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text"><i class="bi bi-tag"></i></span>
                                    <input type="text" class="form-control" placeholder="PROD_TLS, ingress-cert"
                                           @bind="newSecretName" @bind:event="oninput" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="input-group input-group-sm" title="Bind this certificate to a single environment, or leave shared across all of the app's environments.">
                                    <span class="input-group-text"><i class="bi bi-diagram-3"></i></span>
                                    <select class="form-select" @bind="newSecretEnvironmentId">
                                        <option value="@Guid.Empty">Shared (all environments)</option>
                                        @foreach ((string label, Guid id) in appEnvironmentOptions)
                                        {
                                            <option value="@id">@label</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                        <CertificateFields Bundle="newCertBundle" />
                        <div class="mb-3 mt-2">
                            <button class="btn btn-sm btn-primary" @onclick="AddCertificate"
                                    disabled="@(string.IsNullOrWhiteSpace(newSecretName) || string.IsNullOrWhiteSpace(newCertBundle.Certificate) || savingCertificate)">
                                @if (savingCertificate) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                <i class="bi bi-plus-lg me-1"></i>Save Certificate
                            </button>
                        </div>
                    }
                    else if (scope == "app" && addMode == "oauth")
                    {
                        <div class="row g-2 mb-2">
                            <div class="col-md-4">
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text"><i class="bi bi-tag"></i></span>
                                    <input type="text" class="form-control" placeholder="ENTRA_APP, google-oidc"
                                           @bind="newSecretName" @bind:event="oninput" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="input-group input-group-sm" title="Bind this credential to a single environment, or leave shared across all of the app's environments.">
                                    <span class="input-group-text"><i class="bi bi-diagram-3"></i></span>
                                    <select class="form-select" @bind="newSecretEnvironmentId">
                                        <option value="@Guid.Empty">Shared (all environments)</option>
                                        @foreach ((string label, Guid id) in appEnvironmentOptions)
                                        {
                                            <option value="@id">@label</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                        <OAuthClientFields Bundle="newOAuthBundle" />
                        <div class="mb-3 mt-2">
                            <button class="btn btn-sm btn-primary" @onclick="AddOAuthClient"
                                    disabled="@(string.IsNullOrWhiteSpace(newSecretName) || string.IsNullOrWhiteSpace(newOAuthBundle.ClientSecret) || savingCertificate)">
                                @if (savingCertificate) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                <i class="bi bi-plus-lg me-1"></i>Save OAuth Client
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="row g-2 mb-3">
                            <div class="col-md-3">
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text"><i class="bi bi-tag"></i></span>
                                    <input type="text" class="form-control" placeholder="SECRET_NAME"
                                           @bind="newSecretName" @bind:event="oninput" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text"><i class="bi bi-key"></i></span>
                                    <input type="password" class="form-control" placeholder="Secret value"
                                           @bind="newSecretValue" @bind:event="oninput" />
                                </div>
                            </div>
                            @if (scope == "app")
                            {
                                <div class="col-md-3">
                                    <div class="input-group input-group-sm" title="Bind this secret to a single environment, or leave shared across all of the app's environments.">
                                        <span class="input-group-text"><i class="bi bi-diagram-3"></i></span>
                                        <select class="form-select" @bind="newSecretEnvironmentId">
                                            <option value="@Guid.Empty">Shared (all environments)</option>
                                            @foreach ((string label, Guid id) in appEnvironmentOptions)
                                            {
                                                <option value="@id">@label</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            }
                            <div class="col-md-auto">
                                <button class="btn btn-sm btn-primary" @onclick="AddSecret"
                                        disabled="@(string.IsNullOrWhiteSpace(newSecretName) || string.IsNullOrWhiteSpace(newSecretValue))">
                                    <i class="bi bi-plus-lg me-1"></i>Set Secret
                                </button>
                            </div>
                        </div>
                    }
                }

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger py-1 small mb-2">
                        <i class="bi bi-exclamation-triangle me-1"></i>@errorMessage
                    </div>
                }

                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="alert alert-success py-1 small mb-2">
                        <i class="bi bi-check-circle me-1"></i>@successMessage
                    </div>
                }

                @* Secrets table *@
                <LoadingPanel Loading="@(secrets is null)">
                @if (secrets is not null && secrets.Count == 0)
                {
                    <EmptyState Icon="bi-lock"
                                Message="No secrets stored yet. Add one above." />
                }
                else if (secrets is not null)
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Name</th>
                                    @if (scope is "cnpg" or "mongodb" or "regpostgres")
                                    {
                                        <th>Database</th>
                                    }
                                    <th>K8s Sync</th>
                                    <th>K8s Secret</th>
                                    <th>Namespace</th>
                                    <th>Updated</th>
                                    <th class="text-end" style="width: 150px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (VaultSecret secret in secrets)
                                {
                                    <tr>
                                        <td>
                                            <code>@secret.Name</code>
                                            @if (secret.SecretType == VaultSecretType.Certificate)
                                            {
                                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle ms-2" title="TLS certificate"><i class="bi bi-patch-check me-1"></i>TLS</span>
                                            }
                                            else if (secret.SecretType == VaultSecretType.OAuthClient)
                                            {
                                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle ms-2" title="OAuth / OIDC client"><i class="bi bi-shield-lock me-1"></i>OAuth</span>
                                            }
                                            @if (scope == "app")
                                            {
                                                @if (secret.EnvironmentId is null)
                                                {
                                                    <span class="badge bg-light text-dark border ms-2" title="Visible in every environment of this app"><i class="bi bi-globe me-1"></i>Shared</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle ms-2" title="Bound to a single environment"><i class="bi bi-diagram-3 me-1"></i>@environmentNames.GetValueOrDefault(secret.EnvironmentId.Value, "Unknown env")</span>
                                                }
                                            }
                                            @if (secret.SecretType == VaultSecretType.Certificate)
                                            {
                                                <div class="mt-1">
                                                    <CertificateInfoDisplay Info="@certInfos.GetValueOrDefault(secret.Id)" Compact="true" />
                                                </div>
                                            }
                                            else if (secret.SecretType == VaultSecretType.OAuthClient)
                                            {
                                                <div class="mt-1">
                                                    <OAuthClientDisplay Info="@oauthInfos.GetValueOrDefault(secret.Id)" Compact="true" />
                                                </div>
                                            }
                                        </td>
                                        @if (scope is "cnpg" or "mongodb" or "regpostgres")
                                        {
                                            <td>
                                                @if (secret.CnpgDatabase is not null)
                                                {
                                                    <span class="badge bg-info-subtle text-info border border-info-subtle">@secret.CnpgDatabase.Name</span>
                                                }
                                                else if (secret.MongoDatabase is not null)
                                                {
                                                    <span class="badge bg-success-subtle text-success border border-success-subtle">@secret.MongoDatabase.Name</span>
                                                }
                                                else if (secret.RegisteredPostgresDatabase is not null)
                                                {
                                                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle">@secret.RegisteredPostgresDatabase.Name</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">cluster</span>
                                                }
                                            </td>
                                        }
                                        <td>
                                            @if (secret.SyncToKubernetes)
                                            {
                                                <span class="badge bg-success"><i class="bi bi-cloud-check me-1"></i>Synced</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Off</span>
                                            }
                                        </td>
                                        <td><small class="text-muted">@(secret.KubernetesSecretName ?? "—")</small></td>
                                        <td><small class="text-muted">@(secret.KubernetesNamespace ?? "—")</small></td>
                                        <td><small class="text-muted">@secret.UpdatedAt.ToString("MMM d, HH:mm")</small></td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => RevealSecret(secret)"
                                                    title="@(revealedSecretId == secret.Id ? "Hide value" : "Reveal value")"
                                                    aria-label="@($"{(revealedSecretId == secret.Id ? "Hide" : "Reveal")} value of secret {secret.Name}")">
                                                <i class="bi @(revealedSecretId == secret.Id ? "bi-eye-slash" : "bi-eye")"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-warning me-1" @onclick="() => StartEdit(secret)" title="Edit value"
                                                    aria-label="@($"Edit value of secret {secret.Name}")">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            @if (scope == "app")
                                            {
                                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => StartScopeEdit(secret)" title="Change scope"
                                                        aria-label="@($"Change scope of secret {secret.Name}")">
                                                    <i class="bi bi-diagram-3"></i>
                                                </button>
                                            }
                                            <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => ToggleHistory(secret.Id)" title="Version history"
                                                    aria-label="@($"Version history of secret {secret.Name}")">
                                                <i class="bi bi-clock-history"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-info me-1" @onclick="() => ToggleSync(secret)"
                                                    title="@(secret.SyncToKubernetes ? "Disable K8s sync" : "Enable K8s sync")"
                                                    aria-label="@($"{(secret.SyncToKubernetes ? "Disable" : "Enable")} Kubernetes sync for secret {secret.Name}")">
                                                <i class="bi @(secret.SyncToKubernetes ? "bi-cloud-slash" : "bi-cloud-arrow-up")"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" title="Delete secret"
                                                    aria-label="@($"Delete secret {secret.Name}")"
                                                    @onclick='() => pendingConfirm = new PendingConfirm($"Delete secret \"{secret.Name}\"? This permanently removes it from the vault and cannot be undone.", "Delete secret", () => DeleteSecret(secret.Id))'>
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>

                                    @* Reveal value row *@
                                    @if (revealedSecretId == secret.Id)
                                    {
                                        <tr>
                                            <td colspan="6" class="bg-light">
                                                @if (secret.SecretType == VaultSecretType.Certificate && revealedBundle is not null)
                                                {
                                                    <div class="p-2">
                                                        <CertificateInfoDisplay Info="@certInfos.GetValueOrDefault(secret.Id)" />
                                                        <div class="mt-2">
                                                            <PemBlock Label="Certificate" Pem="@revealedBundle.Certificate" />
                                                            <PemBlock Label="Private key" Pem="@revealedBundle.PrivateKey" />
                                                            <PemBlock Label="CA certificate" Pem="@revealedBundle.CaCertificate" />
                                                            <PemBlock Label="Chain" Pem="@revealedBundle.Chain" />
                                                            <PemBlock Label="Full chain (synced as fullchain.crt)" Pem="@revealedBundle.FullChain" />
                                                        </div>
                                                    </div>
                                                }
                                                else if (secret.SecretType == VaultSecretType.OAuthClient && revealedOAuthBundle is not null)
                                                {
                                                    <div class="p-2">
                                                        <OAuthClientDisplay Info="@revealedOAuthBundle.ToInfo()" ClientSecret="@revealedOAuthBundle.ClientSecret" />
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="p-2">
                                                        <span class="text-muted small me-2">Value:</span>
                                                        <code class="user-select-all">@revealedValue</code>
                                                    </div>
                                                }
                                            </td>
                                        </tr>
                                    }

                                    @* Edit value row *@
                                    @if (editSecretId == secret.Id)
                                    {
                                        <tr>
                                            <td colspan="6" class="bg-light">
                                                @if (secret.SecretType == VaultSecretType.Certificate && editCertBundle is not null)
                                                {
                                                    <div class="p-2">
                                                        <CertificateFields Bundle="editCertBundle" />
                                                        <div class="mt-2">
                                                            <button class="btn btn-sm btn-success" @onclick="() => SaveCertEdit(secret)"
                                                                    disabled="@(string.IsNullOrWhiteSpace(editCertBundle.Certificate) || savingCertificate)">
                                                                @if (savingCertificate) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                                <i class="bi bi-check-lg me-1"></i>Update Certificate
                                                            </button>
                                                            <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="CancelEdit">
                                                                Cancel
                                                            </button>
                                                        </div>
                                                    </div>
                                                }
                                                else if (secret.SecretType == VaultSecretType.OAuthClient && editOAuthBundle is not null)
                                                {
                                                    <div class="p-2">
                                                        <OAuthClientFields Bundle="editOAuthBundle" />
                                                        <div class="mt-2">
                                                            <button class="btn btn-sm btn-success" @onclick="() => SaveOAuthEdit(secret)"
                                                                    disabled="@(string.IsNullOrWhiteSpace(editOAuthBundle.ClientSecret) || savingCertificate)">
                                                                @if (savingCertificate) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                                <i class="bi bi-check-lg me-1"></i>Update OAuth Client
                                                            </button>
                                                            <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="CancelEdit">
                                                                Cancel
                                                            </button>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="row g-2 p-2 align-items-center">
                                                        <div class="col-md-6">
                                                            <input type="password" class="form-control form-control-sm"
                                                                   placeholder="New secret value" @bind="editSecretValue" />
                                                        </div>
                                                        <div class="col-auto">
                                                            <button class="btn btn-sm btn-success" @onclick="SaveEdit"
                                                                    disabled="@string.IsNullOrWhiteSpace(editSecretValue)">
                                                                <i class="bi bi-check-lg me-1"></i>Update
                                                            </button>
                                                            <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="CancelEdit">
                                                                Cancel
                                                            </button>
                                                        </div>
                                                    </div>
                                                }
                                            </td>
                                        </tr>
                                    }

                                    @* Change scope row *@
                                    @if (scopeEditSecretId == secret.Id)
                                    {
                                        <tr>
                                            <td colspan="6" class="bg-light">
                                                <div class="row g-2 p-2 align-items-center">
                                                    <div class="col-auto">
                                                        <label class="form-label small mb-0">Scope</label>
                                                    </div>
                                                    <div class="col-md-5">
                                                        <select class="form-select form-select-sm" @bind="scopeEditValue">
                                                            <option value="">Shared across all environments</option>
                                                            @foreach ((string Label, Guid Id) opt in appEnvironmentOptions)
                                                            {
                                                                <option value="@opt.Id">@opt.Label (this environment only)</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="col-auto">
                                                        <button class="btn btn-sm btn-success" @onclick="() => SaveScopeEdit(secret)" disabled="@savingScope">
                                                            @if (savingScope) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                            <i class="bi bi-check-lg me-1"></i>Save
                                                        </button>
                                                        <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="CancelScopeEdit">
                                                            Cancel
                                                        </button>
                                                    </div>
                                                </div>
                                                @if (secret.SyncToKubernetes)
                                                {
                                                    <div class="px-2 pb-1">
                                                        <small class="text-muted"><i class="bi bi-info-circle me-1"></i>If the new environment doesn't match this secret's sync target cluster, K8s sync will be turned off.</small>
                                                    </div>
                                                }
                                            </td>
                                        </tr>
                                    }

                                    @* Version history row *@
                                    @if (historySecretId == secret.Id)
                                    {
                                        <tr>
                                            <td colspan="7" class="bg-light p-0">
                                                <div class="p-3">
                                                    <div class="d-flex align-items-center mb-2">
                                                        <i class="bi bi-clock-history me-2 text-secondary"></i>
                                                        <strong class="small">Version History</strong>
                                                        <span class="badge bg-secondary ms-2">@(secretVersions?.Count ?? 0)</span>
                                                    </div>
                                                    @if (secretVersions is null)
                                                    {
                                                        <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
                                                    }
                                                    else if (secretVersions.Count == 0)
                                                    {
                                                        <p class="text-muted small mb-0">No previous versions recorded.</p>
                                                    }
                                                    else
                                                    {
                                                        <table class="table table-sm table-bordered mb-0">
                                                            <thead class="table-secondary">
                                                                <tr>
                                                                    <th style="width: 60px;">#</th>
                                                                    <th>Set by</th>
                                                                    <th>Date</th>
                                                                    <th class="text-end" style="width: 160px;">Actions</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (VaultSecretVersion ver in secretVersions)
                                                                {
                                                                    <tr>
                                                                        <td><span class="badge bg-secondary">v@ver.VersionNumber</span></td>
                                                                        <td><small class="text-muted">@(ver.CreatedBy ?? "—")</small></td>
                                                                        <td><small class="text-muted">@ver.CreatedAt.ToString("MMM d, HH:mm")</small></td>
                                                                        <td class="text-end">
                                                                            <button class="btn btn-xs btn-outline-secondary me-1"
                                                                                    @onclick="() => RevealVersion(secret.Id, ver)"
                                                                                    title="@(revealedVersionId == ver.Id ? "Hide" : "Reveal value")">
                                                                                <i class="bi @(revealedVersionId == ver.Id ? "bi-eye-slash" : "bi-eye")"></i>
                                                                            </button>
                                                                            <button class="btn btn-xs btn-outline-warning"
                                                                                    @onclick="() => RollbackToVersion(secret.Id, ver.Id)"
                                                                                    title="Restore this value">
                                                                                <i class="bi bi-arrow-counterclockwise me-1"></i>Restore
                                                                            </button>
                                                                        </td>
                                                                    </tr>
                                                                    @if (revealedVersionId == ver.Id)
                                                                    {
                                                                        <tr class="table-light">
                                                                            <td colspan="4" class="px-2 py-1">
                                                                                <span class="text-muted small me-2">Value:</span>
                                                                                @if (versionRevealLoading)
                                                                                {
                                                                                    <span class="spinner-border spinner-border-sm"></span>
                                                                                }
                                                                                else
                                                                                {
                                                                                    <code class="user-select-all">@revealedVersionValue</code>
                                                                                }
                                                                            </td>
                                                                        </tr>
                                                                    }
                                                                }
                                                            </tbody>
                                                        </table>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }

                                    @if (syncConfigSecretId == secret.Id)
                                    {
                                        <tr>
                                            <td colspan="6" class="bg-light">
                                                <div class="row g-2 p-2 align-items-center">
                                                    @if (scope == "app" && clusterOptions is not null)
                                                    {
                                                        <div class="col-md-3">
                                                            <select class="form-select form-select-sm" @bind="syncClusterId">
                                                                <option value="@Guid.Empty">Target cluster…</option>
                                                                @foreach ((string label, Guid id) in clusterOptions)
                                                                {
                                                                    <option value="@id">@label</option>
                                                                }
                                                            </select>
                                                        </div>
                                                    }
                                                    <div class="col-md-3">
                                                        <input type="text" class="form-control form-control-sm"
                                                               placeholder="K8s Secret name (e.g. my-app-secrets)" @bind="syncSecretName" />
                                                    </div>
                                                    <div class="col-md-3">
                                                        <input type="text" class="form-control form-control-sm"
                                                               placeholder="Namespace (e.g. default)" @bind="syncNamespace" />
                                                    </div>
                                                    <div class="col-auto">
                                                        <button class="btn btn-sm btn-success" @onclick="SaveSync">
                                                            <i class="bi bi-check-lg me-1"></i>Save
                                                        </button>
                                                        <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="() => syncConfigSecretId = null">
                                                            Cancel
                                                        </button>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
                </LoadingPanel>
                @if (syncOutput is not null)
                {
                    <div class="mt-3 p-2 bg-dark text-white rounded font-monospace small" style="white-space: pre-wrap; max-height: 200px; overflow-y: auto;">@syncOutput</div>
                }
            </div>
        </div>
    }
}

@code {
    [Parameter] public Guid TenantId { get; set; }

    // A destructive action awaiting user confirmation.
    private sealed record PendingConfirm(string Message, string ConfirmText, Func<Task> Action);
    private PendingConfirm? pendingConfirm;
    private bool confirmBusy;

    private async Task RunPendingConfirmAsync()
    {
        if (pendingConfirm is null) return;
        confirmBusy = true;
        try { await pendingConfirm.Action(); }
        finally { confirmBusy = false; pendingConfirm = null; }
    }

    private bool vaultInitialized;
    private string scope = "app";

    // App scope
    private List<(string Label, Guid Id)>? appOptions;
    private Guid selectedAppId;

    // Component scope
    private List<(string Label, Guid Id)>? componentOptions;
    private Guid selectedComponentId;

    // Storage scope
    private List<(string Label, Guid Id)>? storageLinkOptions;
    private Guid selectedStorageLinkId;

    // CNPG cluster scope
    private List<(string Label, Guid Id)>? cnpgClusterOptions;
    private Guid selectedCnpgClusterId;

    // MongoDB cluster scope
    private List<(string Label, Guid Id)>? mongoClusterOptions;
    private Guid selectedMongoClusterId;

    // Registered Postgres scope
    private List<(string Label, Guid Id)>? regPostgresOptions;
    private Guid selectedRegPostgresInstanceId;

    // Cluster options (used in app-scope sync config)
    private List<(string Label, Guid Id)>? clusterOptions;

    // Environment scoping (app scope): names for badges + per-app options for the
    // add form. newSecretEnvironmentId == Guid.Empty means "shared across envs".
    private Dictionary<Guid, string> environmentNames = new();
    private List<(string Label, Guid Id)> appEnvironmentOptions = [];
    private Guid newSecretEnvironmentId;

    // Secrets
    private List<VaultSecret>? secrets;
    private string newSecretName = "";
    private string newSecretValue = "";
    private string? errorMessage;
    private string? successMessage;
    private Guid? syncConfigSecretId;
    private string syncSecretName = "";
    private string syncNamespace = "";
    private Guid syncClusterId;

    // Change-scope state (app secrets). scopeEditValue == "" means "shared".
    private Guid? scopeEditSecretId;
    private string scopeEditValue = "";
    private bool savingScope;

    // Docker registries scope: which app the admin is scoping credentials to (Empty = tenant-wide).
    private Guid dockerAppId;

    // Cluster kubeconfig scope state.
    private List<VaultSecret>? kubeconfigSecrets;
    private Dictionary<Guid, KubeconfigInfo?> kubeconfigInfos = new();
    private Guid? revealedKubeconfigId;
    private string? revealedKubeconfigYaml;
    private bool kubeconfigRevealLoading;
    private Guid? updateKubeconfigId;
    private KubeconfigSelection? updateKubeconfigSelection;
    private DateTime? updateKubeconfigExpiry;
    private bool savingKubeconfig;
    private string? kubeconfigError;
    private string? kubeconfigSuccess;

    // Add-form mode for app secrets: "opaque" | "certificate" | "oauth".
    private string addMode = "opaque";
    // Shared busy flag for saving a structured (certificate/oauth) secret.
    private bool savingCertificate;

    // Certificate state (app secrets only).
    private CertificateBundle newCertBundle = new();
    private CertificateBundle? revealedBundle;
    private CertificateBundle? editCertBundle;
    private Dictionary<Guid, CertificateInfo?> certInfos = new();

    // OAuth/OIDC client state (app secrets only).
    private OAuthClientBundle newOAuthBundle = new();
    private OAuthClientBundle? revealedOAuthBundle;
    private OAuthClientBundle? editOAuthBundle;
    private Dictionary<Guid, OAuthClientInfo?> oauthInfos = new();

    // Sync-to-K8s state (app scope)
    private bool syncingSecrets;
    private string? syncOutput;

    // Reveal/Edit state
    private Guid? revealedSecretId;
    private string? revealedValue;
    private Guid? editSecretId;
    private string editSecretValue = "";

    // Version history state
    private Guid? historySecretId;
    private List<VaultSecretVersion>? secretVersions;
    private Guid? revealedVersionId;
    private string? revealedVersionValue;
    private bool versionRevealLoading;

    protected override async Task OnInitializedAsync()
    {
        SecretVault? vault = await VaultService.GetVaultAsync(TenantId);
        vaultInitialized = vault is not null;

        if (vaultInitialized)
        {
            await LoadOptions();
        }
    }

    private async Task InitializeVault()
    {
        await VaultService.InitializeVaultAsync(TenantId);
        vaultInitialized = true;
        await LoadOptions();
    }

    private async Task LoadOptions()
    {
        List<Customer> customers = await TenantService.GetCustomersAsync(TenantId);
        appOptions = [];

        foreach (Customer customer in customers)
        {
            List<Data.App> apps = await TenantService.GetAppsAsync(customer.Id);

            foreach (Data.App app in apps)
            {
                appOptions.Add(($"{customer.Name} / {app.Name}", app.Id));
            }
        }

        environmentNames = (await TenantService.GetEnvironmentsAsync(TenantId))
            .ToDictionary(e => e.Id, e => e.Name);

        List<KubernetesCluster> clusters = await TenantService.GetClustersAsync(TenantId);
        clusterOptions = clusters.Select(c => (c.Name, c.Id)).ToList();
        componentOptions = [];

        foreach (KubernetesCluster cluster in clusters)
        {
            List<ClusterComponent> components = await VaultService.GetComponentsAsync(cluster.Id);

            foreach (ClusterComponent comp in components)
            {
                componentOptions.Add(($"{cluster.Name} / {comp.Name}", comp.Id));
            }
        }

        // Load storage links for the storage secrets scope.

        List<StorageLink> links = await StorageService.GetStorageLinksAsync(TenantId);
        storageLinkOptions = links
            .Select(l => ($"{l.Environment.Name} / {l.Name} ({l.Provider})", l.Id))
            .ToList();

        // Load CNPG clusters for the database secrets scope.

        List<CnpgCluster> cnpgClusters = await CnpgService.GetClustersAsync(TenantId);
        cnpgClusterOptions = cnpgClusters
            .Select(c => ($"{c.KubernetesCluster.Name} / {c.Name}", c.Id))
            .ToList();

        // MongoDB clusters
        List<MongoCluster> mongoClusters = await MongoService.GetClustersAsync(TenantId);
        mongoClusterOptions = mongoClusters
            .Select(c => ($"{c.KubernetesCluster.Name} / {c.Name}", c.Id))
            .ToList();

        // Registered Postgres instances
        List<RegisteredPostgresInstance> regInstances = await RegisteredPostgresService.GetInstancesAsync(TenantId);
        regPostgresOptions = regInstances
            .Select(i => (i.Name, i.Id))
            .ToList();
    }

    private async Task SwitchScope(string newScope)
    {
        scope = newScope;
        secrets = null;
        selectedAppId = Guid.Empty;
        newSecretEnvironmentId = Guid.Empty;
        appEnvironmentOptions = [];
        selectedComponentId = Guid.Empty;
        selectedStorageLinkId = Guid.Empty;
        selectedCnpgClusterId = Guid.Empty;
        selectedMongoClusterId = Guid.Empty;
        selectedRegPostgresInstanceId = Guid.Empty;
        errorMessage = null;
        successMessage = null;
        syncClusterId = Guid.Empty;
        syncOutput = null;
        addMode = "opaque";
        newCertBundle = new();
        newOAuthBundle = new();
        dockerAppId = Guid.Empty;
        revealedKubeconfigId = null;
        revealedKubeconfigYaml = null;
        CancelKubeconfigUpdate();
        kubeconfigError = null;
        kubeconfigSuccess = null;
        // Docker registries panel manages its own state; no reset needed here.

        // Cluster kubeconfigs have no per-owner selector, so load them on scope switch.
        kubeconfigSecrets = null;
        if (newScope == "kubeconfig")
        {
            await LoadKubeconfigSecrets();
        }
    }

    private async Task LoadKubeconfigSecrets()
    {
        kubeconfigSecrets = await VaultService.GetClusterKubeconfigSecretsAsync(TenantId);

        kubeconfigInfos = new();
        foreach (VaultSecret kc in kubeconfigSecrets)
        {
            kubeconfigInfos[kc.Id] = await VaultService.GetKubeconfigInfoByIdAsync(kc.Id);
        }
    }

    private async Task RevealKubeconfig(VaultSecret secret)
    {
        if (revealedKubeconfigId == secret.Id)
        {
            revealedKubeconfigId = null;
            revealedKubeconfigYaml = null;
            return;
        }

        kubeconfigRevealLoading = true;
        try
        {
            KubeconfigBundle? bundle = await VaultService.GetKubeconfigBundleByIdAsync(secret.Id);
            revealedKubeconfigYaml = bundle?.ConfigYaml;
            revealedKubeconfigId = secret.Id;
        }
        finally
        {
            kubeconfigRevealLoading = false;
        }
    }

    private void StartKubeconfigUpdate(VaultSecret secret)
    {
        kubeconfigError = null;
        kubeconfigSuccess = null;
        if (updateKubeconfigId == secret.Id)
        {
            CancelKubeconfigUpdate();
            return;
        }

        updateKubeconfigId = secret.Id;
        updateKubeconfigSelection = null;
        // Seed the expiry with the current value so the admin can keep or adjust it.
        updateKubeconfigExpiry = kubeconfigInfos.GetValueOrDefault(secret.Id)?.ExpiresAt;
    }

    private void CancelKubeconfigUpdate()
    {
        updateKubeconfigId = null;
        updateKubeconfigSelection = null;
        updateKubeconfigExpiry = null;
    }

    private void OnUpdateKubeconfigSelected(KubeconfigSelection? selection)
    {
        updateKubeconfigSelection = selection;
    }

    private async Task SaveKubeconfigUpdate(VaultSecret secret)
    {
        if (secret.OwnerClusterId is not Guid clusterId)
        {
            kubeconfigError = "This kubeconfig is not linked to a cluster.";
            return;
        }

        if (updateKubeconfigSelection is null)
        {
            return;
        }

        kubeconfigError = null;
        kubeconfigSuccess = null;
        savingKubeconfig = true;

        try
        {
            AuthenticationState authState = await AuthStateProvider.GetAuthenticationStateAsync();

            KubeconfigBundle bundle = new()
            {
                ConfigYaml = updateKubeconfigSelection.Yaml,
                ContextName = updateKubeconfigSelection.ContextName,
                ApiServerUrl = updateKubeconfigSelection.ServerUrl,
                ExpiresAt = updateKubeconfigExpiry,
            };

            (bool ok, string? error, _) = await VaultService.SetClusterKubeconfigAsync(
                TenantId, clusterId, bundle, authState.User.Identity?.Name);

            if (!ok)
            {
                kubeconfigError = error ?? "Failed to update the kubeconfig.";
                return;
            }

            kubeconfigSuccess = $"Kubeconfig for '{secret.OwnerCluster?.Name}' updated.";
            CancelKubeconfigUpdate();
            revealedKubeconfigId = null;
            revealedKubeconfigYaml = null;
            await LoadKubeconfigSecrets();
        }
        finally
        {
            savingKubeconfig = false;
        }
    }

    private (string Css, string Text) KubeconfigStatus(Guid secretId)
    {
        KubeconfigInfo? info = kubeconfigInfos.GetValueOrDefault(secretId);
        if (info?.ExpiresAt is null)
        {
            return ("bg-light text-dark border", "No expiry");
        }

        int days = (int)Math.Floor((info.ExpiresAt.Value - DateTime.UtcNow).TotalDays);
        if (days < 0)
        {
            return ("bg-danger", "Expired");
        }
        if (days <= 30)
        {
            return ("bg-warning text-dark", $"Expires in {days} d");
        }

        return ("bg-success", "Valid");
    }

    private bool HasSelection()
    {
        return (scope == "app" && selectedAppId != Guid.Empty)
            || (scope == "component" && selectedComponentId != Guid.Empty)
            || (scope == "storage" && selectedStorageLinkId != Guid.Empty)
            || (scope == "cnpg" && selectedCnpgClusterId != Guid.Empty)
            || (scope == "mongodb" && selectedMongoClusterId != Guid.Empty)
            || (scope == "regpostgres" && selectedRegPostgresInstanceId != Guid.Empty);
    }

    private async Task LoadSecrets()
    {
        errorMessage = null;
        successMessage = null;

        if (scope == "app" && selectedAppId != Guid.Empty)
        {
            secrets = await VaultService.GetAppSecretsAsync(TenantId, selectedAppId);

            // Offer only the environments this app is linked to (plus "shared").
            List<AppEnvironment> appEnvs = await AppGovernanceService.GetAppEnvironmentsAsync(selectedAppId);
            appEnvironmentOptions = appEnvs
                .Select(ae => (environmentNames.GetValueOrDefault(ae.EnvironmentId, "Unknown env"), ae.EnvironmentId))
                .ToList();
            // Reset the add-form scope if the previously selected env isn't valid here.
            if (newSecretEnvironmentId != Guid.Empty && appEnvironmentOptions.All(o => o.Item2 != newSecretEnvironmentId))
                newSecretEnvironmentId = Guid.Empty;
        }
        else if (scope == "component" && selectedComponentId != Guid.Empty)
        {
            secrets = await VaultService.GetComponentSecretsAsync(TenantId, selectedComponentId);
        }
        else if (scope == "storage" && selectedStorageLinkId != Guid.Empty)
        {
            secrets = await VaultService.GetStorageLinkSecretsAsync(TenantId, selectedStorageLinkId);
        }
        else if (scope == "cnpg" && selectedCnpgClusterId != Guid.Empty)
        {
            secrets = await VaultService.GetAllCnpgSecretsForClusterAsync(TenantId, selectedCnpgClusterId);
        }
        else if (scope == "mongodb" && selectedMongoClusterId != Guid.Empty)
        {
            secrets = await VaultService.GetAllMongoSecretsForClusterAsync(TenantId, selectedMongoClusterId);
        }
        else if (scope == "regpostgres" && selectedRegPostgresInstanceId != Guid.Empty)
        {
            secrets = await VaultService.GetAllRegisteredPostgresSecretsForInstanceAsync(TenantId, selectedRegPostgresInstanceId);
        }
        else
        {
            secrets = null;
        }

        // Parse certificate / OAuth rows so the list can show metadata + expiry status.
        certInfos = new();
        oauthInfos = new();
        if (secrets is not null)
        {
            foreach (VaultSecret cert in secrets.Where(s => s.SecretType == VaultSecretType.Certificate))
            {
                certInfos[cert.Id] = await VaultService.GetCertificateInfoByIdAsync(cert.Id);
            }
            foreach (VaultSecret oauth in secrets.Where(s => s.SecretType == VaultSecretType.OAuthClient))
            {
                oauthInfos[oauth.Id] = await VaultService.GetOAuthClientInfoByIdAsync(oauth.Id);
            }
        }
    }

    private async Task AddCertificate()
    {
        errorMessage = null;
        successMessage = null;
        savingCertificate = true;

        try
        {
            Guid? environmentId = newSecretEnvironmentId != Guid.Empty ? newSecretEnvironmentId : null;
            (bool ok, string? error) = await VaultService.SetAppCertificateAsync(
                TenantId, selectedAppId, newSecretName.Trim(), newCertBundle, environmentId);

            if (!ok)
            {
                errorMessage = error;
                return;
            }

            successMessage = $"Certificate '{newSecretName.Trim()}' saved.";
            newSecretName = "";
            newCertBundle = new();
            await LoadSecrets();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally { savingCertificate = false; }
    }

