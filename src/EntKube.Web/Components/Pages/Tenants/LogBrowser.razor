@using EntKube.Web.Data
@using EntKube.Web.Services
@inject LogQueryService Logs
@inject NavigationManager Nav
@implements IAsyncDisposable

@if (!lokiAvailable && !isLoading)
{
    <div class="alert alert-light border text-muted small py-2">
        <span class="bi bi-journal-x me-1"></span>
        No log backend is available for this cluster. Deploy the EntKube telemetry collector (or a Loki component) to enable log browsing.
    </div>
}
else
{
    @if (!string.IsNullOrEmpty(loadError))
    {
        <div class="alert alert-warning small py-2">
            <span class="bi bi-exclamation-triangle me-1"></span>
            Could not reach Loki: @loadError
        </div>
    }

    @* ── Controls ── *@
    <div class="row g-2 mb-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label small text-muted mb-1">Namespace</label>
            <select class="form-select form-select-sm" @bind="selectedNamespace" @bind:after="OnNamespaceChanged"
                    disabled="@(namespaces.Count == 0)">
                <option value="">— select namespace —</option>
                @foreach (string ns in namespaces)
                {
                    <option value="@ns">@ns</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted mb-1">Pod</label>
            <select class="form-select form-select-sm" @bind="selectedPod"
                    disabled="@(string.IsNullOrEmpty(selectedNamespace))">
                <option value="">All pods</option>
                @foreach (string pod in pods)
                {
                    <option value="@pod">@pod</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted mb-1">Time range</label>
            <select class="form-select form-select-sm" @bind="timeRangeMinutes">
                <option value="15">Last 15 minutes</option>
                <option value="60">Last 1 hour</option>
                <option value="180">Last 3 hours</option>
                <option value="720">Last 12 hours</option>
                <option value="1440">Last 24 hours</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted mb-1">Lines</label>
            <select class="form-select form-select-sm" @bind="limit">
                <option value="100">100</option>
                <option value="200">200</option>
                <option value="500">500</option>
                <option value="1000">1000</option>
            </select>
        </div>
        <div class="col-12 col-md-3">
            <label class="form-label small text-muted mb-1">Filter text</label>
            <input class="form-control form-control-sm font-monospace" @bind="textFilter"
                   placeholder="e.g. error, refused" />
        </div>
        <div class="col-6 col-md-3">
            <label class="form-label small text-muted mb-1">Attribute key</label>
            <input class="form-control form-control-sm font-monospace" @bind="attrKey"
                   placeholder="e.g. http.status_code" />
        </div>
        <div class="col-6 col-md-3">
            <label class="form-label small text-muted mb-1">Attribute value</label>
            <input class="form-control form-control-sm font-monospace" @bind="attrValue"
                   placeholder="exact (blank = has key)" />
            @if (!string.IsNullOrEmpty(attrKey))
            {
                <div class="form-text small"><span class="bi bi-info-circle me-1"></span>Native store only — no effect on Loki clusters.</div>
            }
        </div>
        <div class="col-12 col-md-3">
            <button class="btn btn-sm btn-primary w-100" @onclick="Search"
                    disabled="@(isQuerying || string.IsNullOrEmpty(selectedNamespace))">
                @if (isQuerying) { <span class="spinner-border spinner-border-sm me-1"></span> }
                <span class="bi bi-search me-1"></span>Search
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(queryError))
    {
        <div class="alert alert-warning small py-2">
            <span class="bi bi-exclamation-triangle me-1"></span>@queryError
        </div>
    }

    @* ── Log output ── *@
    @* Render the results shell whenever a query has run — so the level dropdown stays available even
       when the current filter yields zero rows (otherwise it vanishes and the filter can't be cleared). *@
    @if (hasQueried && !isQuerying)
    {
        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted small">@allEntries.Count entries · @queried.ToLocalTime().ToString("HH:mm:ss")</span>
            <div class="d-flex gap-2 align-items-center">
                @* Level change re-queries so the filter is applied server-side within the line limit,
                   not just to the already-fetched slice. *@
                <select class="form-select form-select-sm" style="width:auto" @bind="levelFilter" @bind:after="Search">
                    <option value="">All levels</option>
                    <option value="Error">Error + Fatal</option>
                    <option value="Warn">Warn+</option>
                    <option value="Info">Info+</option>
                </select>
                <button class="btn btn-sm @(follow ? "btn-success" : "btn-outline-secondary")" @onclick="ToggleFollow"
                        title="Live-tail new log lines">
                    <span class="bi @(follow ? "bi-pause-fill" : "bi-play-fill") me-1"></span>@(follow ? "Following" : "Follow")
                </button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => { allEntries = []; histogram = []; hasQueried = false; }">
                    <span class="bi bi-x-lg"></span>
                </button>
            </div>
        </div>

        @* Log-volume histogram: one bar per time bucket, height ∝ count, error+fatal portion in red. *@
        @if (histogram.Count > 0)
        {
            <div class="d-flex align-items-end gap-1 mb-2 px-1" style="height:44px">
                @{ long maxTotal = histogram.Max(b => b.Total); }
                @foreach (LogHistogramBucket b in histogram)
                {
                    int barPx = maxTotal > 0 ? (int)Math.Round(b.Total * 40.0 / maxTotal) : 0;
                    int errPx = b.Total > 0 ? (int)Math.Round(b.Errors * (double)barPx / b.Total) : 0;
                    <div style="flex:1 1 0;display:flex;flex-direction:column;justify-content:flex-end;height:44px"
                         title="@b.Start.ToLocalTime().ToString("HH:mm:ss") · @b.Total logs (@b.Errors err)">
                        <div style="background:#f48771;height:@(errPx)px"></div>
                        <div style="background:#4a90d9;height:@(barPx - errPx)px"></div>
                    </div>
                }
            </div>
        }

        @if (allEntries.Count > 0)
        {
            <div class="border rounded font-monospace" style="background:#1e1e1e;max-height:500px;overflow-y:auto">
                @foreach (LokiLogEntry entry in FilteredEntries)
                {
                    <div class="px-3 py-0" style="line-height:1.4;border-bottom:1px solid #2d2d2d">
                        <span style="color:#888;font-size:0.72rem;user-select:none">
                            @entry.Timestamp.ToLocalTime().ToString("HH:mm:ss.fff")
                        </span>
                        <span class="ms-2" style="@LineStyle(entry.DetectedLevel); font-size:0.8rem; white-space:pre-wrap; word-break:break-all">@entry.Line</span>
                        @if (entry.TraceId is not null)
                        {
                            <a class="ms-2 badge bg-primary text-decoration-none align-middle" style="font-size:.58rem;cursor:pointer"
                               @onclick="() => OpenTrace(entry.TraceId)" title="Open trace @entry.TraceId">trace</a>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-4 text-muted">
                <span class="bi bi-journal display-4 d-block mb-2"></span>
                No logs found for the selected criteria.
            </div>
        }
    }
}

@code {
    [Parameter] public required Guid ClusterId { get; set; }
    [Parameter] public string? PresetNamespace { get; set; }
    [Parameter] public string? PresetPod { get; set; }

    private List<string> namespaces = [];
    private List<string> pods = [];
    private List<LokiLogEntry> allEntries = [];
    private List<LogHistogramBucket> histogram = [];
    private bool follow;
    private CancellationTokenSource? followCts;
    private DateTime lastTs = DateTime.MinValue;
    private string selectedNamespace = "";
    private string selectedPod = "";
    private string textFilter = "";
    private string attrKey = "";
    private string attrValue = "";
    private string levelFilter = "";
    private int timeRangeMinutes = 60;
    private int limit = 200;
    private bool lokiAvailable;
    private bool isLoading = true;
    private bool isQuerying;
    private bool hasQueried;
    private string? queryError;
    private string? loadError;
    private DateTime queried;

    private IEnumerable<LokiLogEntry> FilteredEntries => allEntries.Where(e => levelFilter switch
    {
        "Error" => e.DetectedLevel >= LogLevel.Error,
        "Warn"  => e.DetectedLevel >= LogLevel.Warn,
        "Info"  => e.DetectedLevel >= LogLevel.Info,
        _ => true
    });

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        lokiAvailable = await Logs.IsAvailableAsync(ClusterId);

        loadError = null;
        if (lokiAvailable)
        {
            KubernetesOperationResult<List<string>> nsResult = await Logs.GetNamespacesAsync(ClusterId);
            if (nsResult.IsSuccess)
                namespaces = nsResult.Data ?? [];
            else
                loadError = nsResult.Error;

            if (!string.IsNullOrEmpty(PresetNamespace))
            {
                selectedNamespace = PresetNamespace;
                await OnNamespaceChanged();
            }
            if (!string.IsNullOrEmpty(PresetPod))
                selectedPod = PresetPod;
        }
        isLoading = false;
    }

    private async Task OnNamespaceChanged()
    {
        pods = [];
        selectedPod = "";
        if (string.IsNullOrEmpty(selectedNamespace)) return;

        KubernetesOperationResult<List<string>> podResult =
            await Logs.GetPodsAsync(ClusterId, selectedNamespace);
        if (podResult.IsSuccess) pods = podResult.Data ?? [];
    }

    private async Task Search()
    {
        if (string.IsNullOrEmpty(selectedNamespace)) return;
        isQuerying = true;
        queryError = null;
        allEntries = [];
        StateHasChanged();

        DateTime to   = DateTime.UtcNow;
        DateTime from = to.AddMinutes(-timeRangeMinutes);
        LogQueryFilter filter = BuildFilter();

        KubernetesOperationResult<List<LokiLogStream>> result = await Logs.QueryAsync(ClusterId, filter, from, to, limit);
        if (result.IsSuccess && result.Data is not null)
        {
            allEntries = result.Data
                .SelectMany(s => s.Entries)
                .OrderBy(e => e.Timestamp)
                .ToList();
        }
        else
        {
            queryError = result.Error;
        }

        // Volume histogram over the same filters (native store only; empty otherwise → strip hidden).
        KubernetesOperationResult<List<LogHistogramBucket>> hist = await Logs.GetHistogramAsync(ClusterId, filter, from, to);
        histogram = hist.IsSuccess && hist.Data is not null ? hist.Data : [];

        if (allEntries.Count > 0) lastTs = allEntries.Max(e => e.Timestamp);
        queried = DateTime.UtcNow;
        hasQueried = true;
        isQuerying = false;
    }

    private LogQueryFilter BuildFilter() => new()
    {
        Namespaces = [selectedNamespace],
        Pod = string.IsNullOrEmpty(selectedPod) ? null : selectedPod,
        Text = string.IsNullOrEmpty(textFilter) ? null : textFilter,
        MinLevel = MinLevel,
        AttrKey = string.IsNullOrEmpty(attrKey) ? null : attrKey.Trim(),
        AttrValue = string.IsNullOrEmpty(attrValue) ? null : attrValue.Trim()
    };

    // ── Live tail: poll for logs newer than the cursor (lastTs) and append. ──
    private async Task ToggleFollow()
    {
        follow = !follow;
        if (follow)
        {
            if (!hasQueried) await Search();
            lastTs = allEntries.Count > 0 ? allEntries.Max(e => e.Timestamp) : DateTime.UtcNow;
            followCts = new CancellationTokenSource();
            _ = FollowLoopAsync(followCts.Token);
        }
        else
        {
            followCts?.Cancel();
            followCts?.Dispose();
            followCts = null;
        }
    }

    private async Task FollowLoopAsync(CancellationToken ct)
    {
        try
        {
            using PeriodicTimer timer = new(TimeSpan.FromSeconds(3));
            while (await timer.WaitForNextTickAsync(ct))
            {
                DateTime now = DateTime.UtcNow;
                // Query just past the cursor; a 1s overlap tolerates clock skew, de-duped by ts.
                KubernetesOperationResult<List<LokiLogStream>> result =
                    await Logs.QueryAsync(ClusterId, BuildFilter(), lastTs.AddSeconds(-1), now, limit, ct);
                if (!result.IsSuccess || result.Data is null) continue;

                List<LokiLogEntry> newer = result.Data
                    .SelectMany(s => s.Entries).Where(e => e.Timestamp > lastTs)
                    .OrderBy(e => e.Timestamp).ToList();
                if (newer.Count == 0) continue;

                allEntries.AddRange(newer);
                if (allEntries.Count > 2000)
                    allEntries = allEntries.Skip(allEntries.Count - 2000).ToList();
                lastTs = newer[^1].Timestamp;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { /* stopped */ }
        catch (Exception ex) { queryError = ex.Message; }
    }

    public async ValueTask DisposeAsync()
    {
        if (followCts is not null)
        {
            await followCts.CancelAsync();
            followCts.Dispose();
        }
    }

    // Cross-links a log line to its distributed trace: opens the Traces tab with this trace preselected.
    private void OpenTrace(string? traceId)
    {
        if (string.IsNullOrEmpty(traceId)) return;
        Nav.NavigateTo(Nav.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["category"] = "ops",
            ["tab"] = "traces",
            ["cluster"] = ClusterId.ToString(),
            ["trace"] = traceId
        }));
    }

    // Maps the level dropdown to a minimum severity pushed into the query.
    private LogLevel MinLevel => levelFilter switch
    {
        "Error" => LogLevel.Error,
        "Warn"  => LogLevel.Warn,
        "Info"  => LogLevel.Info,
        _ => LogLevel.None
    };

    private static string LineStyle(LogLevel level) => level switch
    {
        LogLevel.Fatal or LogLevel.Error => "color:#f48771",
        LogLevel.Warn  => "color:#cca700",
        LogLevel.Info  => "color:#9cdcfe",
        LogLevel.Debug => "color:#808080",
        _ => "color:#d4d4d4"
    };
}
