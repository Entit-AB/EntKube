@using EntKube.Web.Data
@using EntKube.Web.Services
@inject TenantService TenantService
@inject KubernetesOperationsService K8sOps
@inject ToastService Toasts

@* ═══════════════════════════════════════════════════════════════════
   App Detail — app-level header + environment cards.
   All per-environment content (deployments, resources, governance,
   metrics, external access) is handled by AppEnvironmentDetail.
   ═══════════════════════════════════════════════════════════════════ *@

@* --- Back button (hidden where a persistent nav — e.g. the resource tree — already
       provides the way back). --- *@
@if (ShowBackLink)
{
    <nav class="mb-3">
        <button class="btn btn-sm btn-link text-decoration-none p-0" @onclick="OnBack">
            <i class="bi bi-arrow-left me-1"></i>Back to @CustomerName
        </button>
    </nav>
}

@* --- App header (kept visible above the per-environment detail so app-level
       actions — Import / Rename / Delete — stay reachable). --- *@
<div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex align-items-start justify-content-between">
                <div class="d-flex align-items-start">
                    <i class="bi bi-app-indicator fs-3 me-3 text-primary"></i>
                    <div>
                        @if (renaming)
                        {
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <input class="form-control form-control-sm" style="max-width:20rem" @bind="renameValue"
                                       @bind:event="oninput" @onkeydown="OnRenameKeyDown" placeholder="App name" />
                                <button class="btn btn-sm btn-primary" @onclick="SaveRename"
                                        disabled="@(savingRename || string.IsNullOrWhiteSpace(renameValue) || renameValue.Trim() == App.Name)">
                                    @if (savingRename)
                                    {
                                        <span class="spinner-border spinner-border-sm"></span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-check-lg"></i>
                                    }
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => renaming = false" disabled="@savingRename">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                            @if (!string.IsNullOrEmpty(renameError))
                            {
                                <div class="text-danger small mb-1">@renameError</div>
                            }
                        }
                        else
                        {
                            <h4 class="mb-1 d-flex align-items-center gap-2">
                                @App.Name
                                <button class="btn btn-sm btn-link p-0 text-muted" title="Rename app" @onclick="BeginRename">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            </h4>
                        }
                        <div class="d-flex flex-wrap gap-2 text-muted small">
                            <span><i class="bi bi-person me-1"></i>@CustomerName</span>
                            <span><i class="bi bi-calendar me-1"></i>Created @App.CreatedAt.ToString("MMM d, yyyy")</span>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-sm @(showLinkPanel ? "btn-secondary" : "btn-outline-secondary")"
                            @onclick="() => showLinkPanel = !showLinkPanel"
                            title="Link or unlink environments for this app">
                        <i class="bi @(showLinkPanel ? "bi-chevron-up" : "bi-link-45deg") me-1"></i>Link / Unlink
                    </button>
                    <button class="btn btn-sm btn-outline-primary" @onclick="() => showImportWizard = true"
                            title="Adopt a running workload into this app">
                        <i class="bi bi-box-arrow-in-down me-1"></i>Import Deployment
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => confirmUnregister = true"
                            title="Remove this app from EntKube. Any deployed workloads keep running in the cluster.">
                        <i class="bi bi-box-arrow-right me-1"></i>Unregister
                    </button>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => confirmClusterDelete = true"
                            title="Delete this app's workloads from the cluster, then remove it from EntKube.">
                        <i class="bi bi-trash me-1"></i>Delete from cluster
                    </button>
                </div>
            </div>

            @* Unregister: pure EntKube-side removal — the cluster is never touched. *@
            <ConfirmDialog Visible="confirmUnregister"
                           Message="@($"Unregister {App.Name} from EntKube? This removes it from EntKube only — any workloads it deployed keep running in the cluster.")"
                           ConfirmText="Unregister"
                           Variant="secondary"
                           IsBusy="deleting"
                           OnConfirm="UnregisterApp"
                           OnCancel="() => confirmUnregister = false" />

            @* Delete from cluster: destructive. This confirms intent; the change-ack dialog then
               shows the exact dry-run of what will be removed from the cluster before it happens. *@
            <ConfirmDialog Visible="confirmClusterDelete"
                           Message="@($"Delete {App.Name}'s resources from the cluster? You will review the exact changes before they are applied. This also unregisters the app from EntKube.")"
                           ConfirmText="Delete from cluster"
                           IsBusy="deleting"
                           OnConfirm="DeleteAppFromCluster"
                           OnCancel="() => confirmClusterDelete = false" />
        </div>
    </div>

    @if (showImportWizard)
    {
        <ImportDeploymentWizard TenantId="TenantId"
                                TargetApp="App"
                                OnClose="OnImportClosed" />
    }

    @* --- Link / Unlink environments — opened from the header, available whether or
       not an environment is currently selected (so it survives the tree dropping the
       env-cards view). --- *@
    @if (showLinkPanel)
    {
        <div class="card mb-3">
            <div class="card-header bg-white py-2">
                <small class="text-muted">Select which environments this app is deployed in.</small>
            </div>
            <div class="card-body py-2">
                <LoadingPanel Loading="@(allEnvironments is null)">
                @if (allEnvironments is not null && allEnvironments.Count == 0)
                {
                    <EmptyState Icon="bi-layers"
                                Message="No environments exist for this tenant yet. Create environments first." />
                }
                else if (allEnvironments is not null)
                {
                    <div class="row row-cols-1 row-cols-md-3 g-2">
                        @foreach (Data.Environment env in allEnvironments)
                        {
                            bool isLinked = linkedEnvIds.Contains(env.Id);
                            <div class="col">
                                <div class="card @(isLinked ? "border-success bg-success bg-opacity-10" : "border-light")"
                                     role="button" style="cursor: pointer;"
                                     @onclick="() => ToggleEnvironment(env.Id, isLinked)">
                                    <div class="card-body py-2 d-flex align-items-center">
                                        <i class="bi @(isLinked ? "bi-check-circle-fill text-success" : "bi-circle text-muted") me-2 fs-5"></i>
                                        <span class="fw-medium">@env.Name</span>
                                        @if (isLinked) { <span class="badge bg-success ms-auto">Active</span> }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                </LoadingPanel>
            </div>
        </div>
    }

    @* When an environment is selected (from the resource tree, or a card below),
       show its deployment detail right here under the app header — no second click. *@
    @if (selectedEnvironment is not null)
    {
        <AppEnvironmentDetail App="App"
                              Environment="selectedEnvironment"
                              TenantId="TenantId"
                              IsPortalView="false"
                              ShowBackLink="ShowBackLink"
                              OnBack="() => selectedEnvironment = null"
                              @key="selectedEnvironment.Id" />
    }
    else
    {

    @* --- Linked environments (clickable cards → per-env detail) --- *@
    <div class="d-flex align-items-center mb-3">
        <h6 class="mb-0 fw-semibold">
            <i class="bi bi-layers me-2 text-primary"></i>Environments
        </h6>
    </div>

    <LoadingPanel Loading="@(linkedEnvironments is null)">
    @if (linkedEnvironments is not null && linkedEnvironments.Count == 0)
    {
        <div class="card border-dashed">
            <div class="card-body">
                <EmptyState Icon="bi-layers"
                            Title="No environments linked yet"
                            Message="Use the Link / Unlink button above to connect this app to an environment." />
            </div>
        </div>
    }
    else if (linkedEnvironments is not null)
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
            @foreach (Data.Environment env in linkedEnvironments)
            {
                int deployCount = deployCountByEnv.GetValueOrDefault(env.Id, 0);

                <div class="col">
                    <div class="card shadow-sm border-light h-100 env-card" role="button" style="cursor: pointer;"
                         @onclick="() => selectedEnvironment = env">
                        <div class="card-body">
                            <div class="d-flex align-items-start justify-content-between mb-2">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-layers fs-4 text-primary"></i>
                                    <h6 class="mb-0 fw-semibold">@env.Name</h6>
                                </div>
                                <i class="bi bi-chevron-right text-muted small mt-1"></i>
                            </div>
                            <div class="d-flex flex-wrap gap-2 small text-muted">
                                @if (deployCount > 0)
                                {
                                    <span><i class="bi bi-rocket-takeoff me-1"></i>@deployCount deployment@(deployCount == 1 ? "" : "s")</span>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">No deployments</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    </LoadingPanel>
}

<style>
    .env-card { transition: box-shadow .14s, transform .1s; }
    .env-card:hover { box-shadow: 0 4px 14px rgba(0,0,0,.13) !important; transform: translateY(-1px); }
    .border-dashed { border-style: dashed !important; }
</style>

@code {
    [Parameter] public required Data.App App { get; set; }
    [Parameter] public Guid TenantId { get; set; }
    [Parameter] public string CustomerName { get; set; } = "";
    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback OnDeleted { get; set; }

    /// <summary>Show the "Back to {customer}" link. Off when a persistent navigation
    /// (the resource tree) already handles going back, so it isn't a redundant step.</summary>
    [Parameter] public bool ShowBackLink { get; set; } = true;

    /// <summary>When set (e.g. opened from the resource tree under an environment),
    /// jump straight into that environment's detail instead of the env-cards list.</summary>
    [Parameter] public Guid? InitialEnvironmentId { get; set; }

    private bool confirmUnregister;
    private bool confirmClusterDelete;
    private bool deleting;
    private bool showLinkPanel;
    private bool showImportWizard;

    private bool renaming;
    private bool savingRename;
    private string renameValue = "";
    private string? renameError;

    private List<Data.Environment>? allEnvironments;
    private List<Data.Environment>? linkedEnvironments;
    private HashSet<Guid> linkedEnvIds = new();
    private Dictionary<Guid, int> deployCountByEnv = new();

    private Data.Environment? selectedEnvironment;

    protected override async Task OnInitializedAsync()
    {
        await LoadEnvironments();
    }

    private async Task OnImportClosed()
    {
        showImportWizard = false;
        await LoadEnvironments();
    }

    private void BeginRename()
    {
        renameValue = App.Name;
        renameError = null;
        renaming = true;
    }

    private async Task OnRenameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SaveRename();
        }
        else if (e.Key == "Escape")
        {
            renaming = false;
        }
    }

    private async Task SaveRename()
    {
        string newName = renameValue.Trim();
        if (string.IsNullOrWhiteSpace(newName) || newName == App.Name)
        {
            renaming = false;
            return;
        }

        savingRename = true;
        renameError = null;
        try
        {
            bool ok = await TenantService.RenameAppAsync(App.Id, newName);
            if (ok)
            {
                App.Name = newName;
                renaming = false;
            }
            else
            {
                renameError = "Could not rename the app.";
            }
        }
        catch (Exception ex)
        {
            renameError = ex.Message;
        }
        finally
        {
            savingRename = false;
        }
    }

    // Unregister — remove from EntKube only. The cluster is never contacted; any
    // workloads the app deployed keep running under their current owner.
    private async Task UnregisterApp()
    {
        deleting = true;
        try
        {
            await TenantService.DeleteAppAsync(App.Id);
            Toasts.Success($"Unregistered {App.Name} from EntKube. Cluster workloads were left running.");
            confirmUnregister = false;
            await OnDeleted.InvokeAsync();
        }
        catch (Exception ex)
        {
            Toasts.Error($"Failed to unregister {App.Name}: {ex.Message}");
        }
        finally
        {
            deleting = false;
        }
    }

    // Delete from cluster — destructive. Removes the app's resources from the cluster
    // (each removal is reviewed in the change-ack dialog), then unregisters it from EntKube.
    private async Task DeleteAppFromCluster()
    {
        deleting = true;
        try
        {
            List<string> errors = await K8sOps.DeleteAppFromClusterAsync(App.Id, performedBy: null);
            if (errors.Count > 0)
            {
                // Cluster cleanup hit problems — surface them and keep the app registered so
                // the operator can retry rather than losing track of orphaned resources.
                Toasts.Error($"Some cluster resources could not be removed: {string.Join("; ", errors)}");
                return;
            }

            await TenantService.DeleteAppAsync(App.Id);
            Toasts.Success($"Deleted {App.Name} from the cluster and unregistered it from EntKube.");
            confirmClusterDelete = false;
            await OnDeleted.InvokeAsync();
        }
        catch (OperationCanceledException)
        {
            // Operator cancelled at the change-ack dialog — nothing was applied.
            Toasts.Info($"Cluster deletion of {App.Name} was cancelled. Nothing was changed.");
        }
        catch (Exception ex)
        {
            Toasts.Error($"Failed to delete {App.Name} from the cluster: {ex.Message}");
        }
        finally
        {
            deleting = false;
        }
    }

    private async Task LoadEnvironments()
    {
        allEnvironments = await TenantService.GetEnvironmentsAsync(TenantId);

        List<Data.App> apps = await TenantService.GetAppsAsync(App.CustomerId);
        Data.App? freshApp = apps.FirstOrDefault(a => a.Id == App.Id);
        linkedEnvIds = freshApp?.AppEnvironments.Select(ae => ae.EnvironmentId).ToHashSet() ?? new();

        linkedEnvironments = allEnvironments.Where(e => linkedEnvIds.Contains(e.Id)).ToList();

        if (InitialEnvironmentId is Guid envId && selectedEnvironment is null)
            selectedEnvironment = linkedEnvironments.FirstOrDefault(e => e.Id == envId);

        deployCountByEnv = (freshApp?.Deployments ?? [])
            .GroupBy(d => d.EnvironmentId)
            .ToDictionary(g => g.Key, g => g.Count());
    }

    private async Task ToggleEnvironment(Guid envId, bool currentlyLinked)
    {
        if (currentlyLinked)
            await TenantService.UnlinkAppFromEnvironmentAsync(App.Id, envId);
        else
            await TenantService.LinkAppToEnvironmentAsync(App.Id, envId);

        await LoadEnvironments();
    }
}
