@using EntKube.Web.Data
@using EntKube.Web.Services
@using Microsoft.EntityFrameworkCore
@inject TenantService TenantService
@inject VaultService VaultService
@inject AuthenticationStateProvider AuthStateProvider
@inject ToastService Toasts

<ConfirmDialog Visible="@(pendingConfirm is not null)"
               Message="@(pendingConfirm?.Message ?? "")"
               ConfirmText="@(pendingConfirm?.ConfirmText ?? "Delete")"
               IsBusy="confirmBusy"
               OnConfirm="RunPendingConfirmAsync"
               OnCancel="() => pendingConfirm = null" />

<h4>Kubernetes Clusters</h4>
<p class="text-muted">Clusters registered in this tenant, each assigned to an environment.</p>

@if (environments is not null && environments.Count > 0)
{
    <div class="row g-2 mb-3" style="max-width: 700px;">
        <div class="col">
            <input type="text" class="form-control" placeholder="Cluster name" @bind="newName" @bind:event="oninput" />
        </div>
        <div class="col">
            <input type="text" class="form-control" placeholder="API server URL" @bind="newApiUrl" @bind:event="oninput" />
        </div>
        <div class="col-auto">
            <select class="form-select" @bind="selectedEnvironmentId">
                <option value="">Environment...</option>
                @foreach (Data.Environment env in environments)
                {
                    <option value="@env.Id">@env.Name</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <button class="btn btn-primary" @onclick="Create"
                    disabled="@(string.IsNullOrWhiteSpace(newName) || string.IsNullOrWhiteSpace(newApiUrl) || selectedEnvironmentId == Guid.Empty)">
                Add
            </button>
        </div>
    </div>
    <p class="form-text mt-0 mb-3">
        Adding a cluster here registers it without a kubeconfig. Register from an environment (with a kubeconfig
        upload) or use the <strong>Kubeconfig</strong> action below to store one in the vault.
    </p>
}
else
{
    <div class="alert alert-info">Create at least one environment before adding clusters.</div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="text-danger mb-2">@errorMessage</div>
}

@if (clusters is null)
{
    <p><em>Loading...</em></p>
}
else if (clusters.Count == 0)
{
    <p class="text-muted">No clusters registered yet.</p>
}
else
{
    <table class="table table-sm table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Environment</th>
                <th>API Server</th>
                <th>Kubeconfig</th>
                <th style="width: 360px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (KubernetesCluster cluster in clusters)
            {
                <tr>
                    <td>@cluster.Name</td>
                    <td><span class="badge bg-secondary">@cluster.Environment.Name</span></td>
                    <td class="text-truncate" style="max-width: 300px;">@cluster.ApiServerUrl</td>
                    <td>@KubeconfigBadge(cluster)</td>
                    <td>
                        <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => ToggleKubeconfig(cluster.Id)">
                            <i class="bi bi-file-earmark-lock"></i> Kubeconfig
                        </button>
                        <button class="btn btn-sm btn-outline-success me-1" @onclick="() => ToggleHealth(cluster.Id)">
                            <i class="bi bi-heart-pulse"></i> Health
                        </button>
                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ToggleComponents(cluster.Id)">
                            Components
                        </button>
                        <button class="btn btn-sm btn-outline-danger" @onclick='() => pendingConfirm = new PendingConfirm($"Delete cluster \"{cluster.Name}\"? It will be unregistered from this tenant. This cannot be undone.", "Delete", () => Delete(cluster.Id, cluster.Name))'>Delete</button>
                    </td>
                </tr>

                @if (kubeconfigClusterId == cluster.Id)
                {
                    <tr>
                        <td colspan="5">
                            <div class="card card-body bg-light">
                                <h6 class="mb-2"><i class="bi bi-file-earmark-lock me-1"></i>Manage kubeconfig — @cluster.Name</h6>

                                @{
                                    KubeconfigInfo? info = kubeconfigInfos.GetValueOrDefault(cluster.Id);
                                }
                                <p class="small mb-2">
                                    Current status: @KubeconfigBadge(cluster)
                                    @if (info?.ExpiresAt is not null)
                                    {
                                        <span class="text-muted ms-2">Expires @info.ExpiresAt.Value.ToString("yyyy-MM-dd")</span>
                                    }
                                </p>

                                <div class="mb-2">
                                    <label class="form-label small mb-1">Replacement kubeconfig</label>
                                    <KubeconfigPicker OnSelectionChanged="OnKubeconfigSelected" />
                                </div>
                                <div class="row g-2 align-items-end">
                                    <div class="col-auto" style="max-width: 220px;">
                                        <label class="form-label small mb-1">Expiry <span class="text-muted">(optional)</span></label>
                                        <input type="date" class="form-control form-control-sm" @bind="updateExpiry" />
                                    </div>
                                    <div class="col-auto">
                                        <button class="btn btn-sm btn-primary" @onclick="() => SaveKubeconfig(cluster)"
                                                disabled="@(updateSelection is null || savingKubeconfig)">
                                            <i class="bi bi-save me-1"></i>@(savingKubeconfig ? "Saving..." : "Update kubeconfig")
                                        </button>
                                        <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="() => kubeconfigClusterId = null">Cancel</button>
                                    </div>
                                </div>

                                @if (!string.IsNullOrEmpty(kubeconfigError))
                                {
                                    <div class="text-danger small mt-2">@kubeconfigError</div>
                                }
                                @if (!string.IsNullOrEmpty(kubeconfigSuccess))
                                {
                                    <div class="text-success small mt-2">@kubeconfigSuccess</div>
                                }
                                <div class="form-text mt-2">
                                    The kubeconfig is stored encrypted in the tenant vault. Updating it archives the previous
                                    version and refreshes the expiry used for warnings. It is never synced to Kubernetes.
                                </div>
                            </div>
                        </td>
                    </tr>
                }

                @if (expandedClusterId == cluster.Id)
                {
                    <tr>
                        <td colspan="5">
                            <ComponentPanel ClusterId="cluster.Id" TenantId="TenantId" OnClose="() => expandedClusterId = null" />
                        </td>
                    </tr>
                }

                @if (healthClusterId == cluster.Id)
                {
                    <tr>
                        <td colspan="5">
                            <ClusterHealthPanel ClusterId="cluster.Id" OnClose="() => healthClusterId = null" />
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {
    [Parameter] public Guid TenantId { get; set; }

    private List<KubernetesCluster>? clusters;
    private List<Data.Environment>? environments;
    private readonly Dictionary<Guid, KubeconfigInfo?> kubeconfigInfos = [];
    private string newName = "";
    private string newApiUrl = "";
    private Guid selectedEnvironmentId;
    private string? errorMessage;
    private Guid? expandedClusterId;
    private Guid? healthClusterId;

    // Kubeconfig management panel state.
    private Guid? kubeconfigClusterId;
    private KubeconfigSelection? updateSelection;
    private DateTime? updateExpiry;
    private bool savingKubeconfig;
    private string? kubeconfigError;
    private string? kubeconfigSuccess;

    // A destructive action awaiting user confirmation.
    private sealed record PendingConfirm(string Message, string ConfirmText, Func<Task> Action);
    private PendingConfirm? pendingConfirm;
    private bool confirmBusy;

    private async Task RunPendingConfirmAsync()
    {
        if (pendingConfirm is null) return;
        confirmBusy = true;
        try { await pendingConfirm.Action(); }
        finally { confirmBusy = false; pendingConfirm = null; }
    }

    protected override async Task OnInitializedAsync()
    {
        await Load();
        environments = await TenantService.GetEnvironmentsAsync(TenantId);
    }

    private async Task Load()
    {
        clusters = await TenantService.GetClustersAsync(TenantId);

        kubeconfigInfos.Clear();
        foreach (KubernetesCluster cluster in clusters)
        {
            kubeconfigInfos[cluster.Id] = cluster.KubeconfigSecretId is Guid secretId
                ? await VaultService.GetKubeconfigInfoByIdAsync(secretId)
                : null;
        }
    }

    private RenderFragment KubeconfigBadge(KubernetesCluster cluster) => builder =>
    {
        (string css, string text) = KubeconfigStatus(cluster);
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", $"badge {css}");
        builder.AddContent(2, text);
        builder.CloseElement();
    };

    private (string Css, string Text) KubeconfigStatus(KubernetesCluster cluster)
    {
        if (cluster.KubeconfigSecretId is null)
        {
            return ("bg-secondary", "Not in vault");
        }

        KubeconfigInfo? info = kubeconfigInfos.GetValueOrDefault(cluster.Id);
        if (info?.ExpiresAt is null)
        {
            return ("bg-light text-dark border", "No expiry");
        }

        int days = (int)Math.Floor((info.ExpiresAt.Value - DateTime.UtcNow).TotalDays);
        if (days < 0)
        {
            return ("bg-danger", "Expired");
        }
        if (days <= 30)
        {
            return ("bg-warning text-dark", $"Expires in {days} d");
        }

        return ("bg-success", "Valid");
    }

    private void ToggleKubeconfig(Guid clusterId)
    {
        kubeconfigError = null;
        kubeconfigSuccess = null;
        if (kubeconfigClusterId == clusterId)
        {
            kubeconfigClusterId = null;
            return;
        }

        kubeconfigClusterId = clusterId;
        expandedClusterId = null;
        healthClusterId = null;

        // Seed the expiry field with the current value so the admin can keep or adjust it.
        updateSelection = null;
        updateExpiry = kubeconfigInfos.GetValueOrDefault(clusterId)?.ExpiresAt;
    }

    private void OnKubeconfigSelected(KubeconfigSelection? selection)
    {
        updateSelection = selection;
    }

    private async Task SaveKubeconfig(KubernetesCluster cluster)
    {
        if (updateSelection is null)
        {
            return;
        }

        kubeconfigError = null;
        kubeconfigSuccess = null;
        savingKubeconfig = true;

        try
        {
            AuthenticationState authState = await AuthStateProvider.GetAuthenticationStateAsync();

            KubeconfigBundle bundle = new()
            {
                ConfigYaml = updateSelection.Yaml,
                ContextName = updateSelection.ContextName,
                ApiServerUrl = updateSelection.ServerUrl,
                ExpiresAt = updateExpiry,
            };

            (bool ok, string? error, _) = await VaultService.SetClusterKubeconfigAsync(
                TenantId, cluster.Id, bundle, authState.User.Identity?.Name);

            if (!ok)
            {
                kubeconfigError = error ?? "Failed to store the kubeconfig.";
                return;
            }

            kubeconfigSuccess = "Kubeconfig updated.";
            updateSelection = null;
            kubeconfigClusterId = null;
            await Load();
        }
        finally
        {
            savingKubeconfig = false;
        }
    }

    private async Task Create()
    {
        errorMessage = null;

        try
        {
            await TenantService.CreateClusterAsync(TenantId, selectedEnvironmentId, newName.Trim(), newApiUrl.Trim());
            newName = "";
            newApiUrl = "";
            selectedEnvironmentId = Guid.Empty;
            await Load();
        }
        catch (DbUpdateException)
        {
            errorMessage = "A cluster with that name already exists in this tenant.";
        }
    }

    private void ToggleComponents(Guid clusterId)
    {
        expandedClusterId = expandedClusterId == clusterId ? null : clusterId;
        if (expandedClusterId is not null)
        {
            healthClusterId = null;
            kubeconfigClusterId = null;
        }
    }

    private void ToggleHealth(Guid clusterId)
    {
        healthClusterId = healthClusterId == clusterId ? null : clusterId;
        if (healthClusterId is not null)
        {
            expandedClusterId = null;
            kubeconfigClusterId = null;
        }
    }

    private async Task Delete(Guid id, string name)
    {
        try
        {
            await TenantService.DeleteClusterAsync(id);
            await Load();
            Toasts.Success($"Deleted cluster \"{name}\".");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Toasts.Error($"Failed to delete cluster \"{name}\": {ex.Message}");
        }
    }
}
