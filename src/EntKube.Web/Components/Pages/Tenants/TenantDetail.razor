        else if (activeCategory == "services")
        {
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "databases" ? "active" : "")" @onclick='() => SetTab("databases")' role="tab" aria-selected="@(activeTab == "databases")" tabindex="@(activeTab == "databases" ? 0 : -1)" id="@($"tab-databases")">
                    <i class="bi bi-database me-1"></i>Databases
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "storage" ? "active" : "")" @onclick='() => SetTab("storage")' role="tab" aria-selected="@(activeTab == "storage")" tabindex="@(activeTab == "storage" ? 0 : -1)" id="@($"tab-storage")">
                    <i class="bi bi-bucket me-1"></i>Storage
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "messaging" ? "active" : "")" @onclick='() => SetTab("messaging")' role="tab" aria-selected="@(activeTab == "messaging")" tabindex="@(activeTab == "messaging" ? 0 : -1)" id="@($"tab-messaging")">
                    <i class="bi bi-collection me-1"></i>Messaging
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "cache" ? "active" : "")" @onclick='() => SetTab("cache")' role="tab" aria-selected="@(activeTab == "cache")" tabindex="@(activeTab == "cache" ? 0 : -1)" id="@($"tab-cache")">
                    <i class="bi bi-lightning-charge me-1"></i>Cache
                </button>
