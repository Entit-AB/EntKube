                    <i class="bi bi-graph-up me-1"></i>Metrics
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "incidents" ? "active" : "")" @onclick='() => SetTab("incidents")' role="tab" aria-selected="@(activeTab == "incidents")" tabindex="@(activeTab == "incidents" ? 0 : -1)" id="@($"tab-incidents")">
                    <i class="bi bi-bell-fill me-1"></i>Incidents
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "notifications" ? "active" : "")" @onclick='() => SetTab("notifications")' role="tab" aria-selected="@(activeTab == "notifications")" tabindex="@(activeTab == "notifications" ? 0 : -1)" id="@($"tab-notifications")">
                    <i class="bi bi-send-fill me-1"></i>Notifications
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "secret-expiry" ? "active" : "")" @onclick='() => SetTab("secret-expiry")' role="tab" aria-selected="@(activeTab == "secret-expiry")" tabindex="@(activeTab == "secret-expiry" ? 0 : -1)" id="@($"tab-secret-expiry")">
                    <i class="bi bi-shield-exclamation me-1"></i>Secret Expiry
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "maintenance" ? "active" : "")" @onclick='() => SetTab("maintenance")' role="tab" aria-selected="@(activeTab == "maintenance")" tabindex="@(activeTab == "maintenance" ? 0 : -1)" id="@($"tab-maintenance")">
                    <i class="bi bi-tools me-1"></i>Maintenance
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "on-call" ? "active" : "")" @onclick='() => SetTab("on-call")' role="tab" aria-selected="@(activeTab == "on-call")" tabindex="@(activeTab == "on-call" ? 0 : -1)" id="@($"tab-on-call")">
                    <i class="bi bi-person-badge me-1"></i>On-Call
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "alert-routing" ? "active" : "")" @onclick='() => SetTab("alert-routing")' role="tab" aria-selected="@(activeTab == "alert-routing")" tabindex="@(activeTab == "alert-routing" ? 0 : -1)" id="@($"tab-alert-routing")">
                    <i class="bi bi-funnel me-1"></i>Alert Routing
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "analytics" ? "active" : "")" @onclick='() => SetTab("analytics")' role="tab" aria-selected="@(activeTab == "analytics")" tabindex="@(activeTab == "analytics" ? 0 : -1)" id="@($"tab-analytics")">
                    <i class="bi bi-bar-chart-line me-1"></i>Analytics
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "sla" ? "active" : "")" @onclick='() => SetTab("sla")' role="tab" aria-selected="@(activeTab == "sla")" tabindex="@(activeTab == "sla" ? 0 : -1)" id="@($"tab-sla")">
                    <i class="bi bi-shield-check me-1"></i>SLA
