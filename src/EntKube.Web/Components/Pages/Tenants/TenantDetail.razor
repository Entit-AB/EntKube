                <button class="nav-link @(activeTab == "environments" ? "active" : "")" @onclick='() => SetTab("environments")' role="tab" aria-selected="@(activeTab == "environments")" tabindex="@(activeTab == "environments" ? 0 : -1)" id="@($"tab-environments")">
                    <i class="bi bi-layers me-1"></i>Environments
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "networking" ? "active" : "")" @onclick='() => SetTab("networking")' role="tab" aria-selected="@(activeTab == "networking")" tabindex="@(activeTab == "networking" ? 0 : -1)" id="@($"tab-networking")">
                    <i class="bi bi-diagram-2 me-1"></i>Networking
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "blueprints" ? "active" : "")" @onclick='() => SetTab("blueprints")' role="tab" aria-selected="@(activeTab == "blueprints")" tabindex="@(activeTab == "blueprints" ? 0 : -1)" id="@($"tab-blueprints")">
                    <i class="bi bi-diagram-3 me-1"></i>Blueprints
                </button>
            </li>
