            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "identity" ? "active" : "")" @onclick='() => SetTab("identity")' role="tab" aria-selected="@(activeTab == "identity")" tabindex="@(activeTab == "identity" ? 0 : -1)" id="@($"tab-identity")">
                    <i class="bi bi-person-badge me-1"></i>Identity
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "registry" ? "active" : "")" @onclick='() => SetTab("registry")' role="tab" aria-selected="@(activeTab == "registry")" tabindex="@(activeTab == "registry" ? 0 : -1)" id="@($"tab-registry")">
                    <i class="bi bi-archive me-1"></i>Registry
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "vault" ? "active" : "")" @onclick='() => SetTab("vault")' role="tab" aria-selected="@(activeTab == "vault")" tabindex="@(activeTab == "vault" ? 0 : -1)" id="@($"tab-vault")">
                    <i class="bi bi-shield-lock me-1"></i>Vault
                </button>
            </li>
        }
        else if (activeCategory == "ops")
        {
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "overview" ? "active" : "")" @onclick='() => SetTab("overview")' role="tab" aria-selected="@(activeTab == "overview")" tabindex="@(activeTab == "overview" ? 0 : -1)" id="@($"tab-overview")">
                    <i class="bi bi-speedometer2 me-1"></i>Overview
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "alerts" ? "active" : "")" @onclick='() => SetTab("alerts")' role="tab" aria-selected="@(activeTab == "alerts")" tabindex="@(activeTab == "alerts" ? 0 : -1)" id="@($"tab-alerts")">
                    <i class="bi bi-bell me-1"></i>Alerts
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "alert-rules" ? "active" : "")" @onclick='() => SetTab("alert-rules")' role="tab" aria-selected="@(activeTab == "alert-rules")" tabindex="@(activeTab == "alert-rules" ? 0 : -1)" id="@($"tab-alert-rules")">
                    <i class="bi bi-list-check me-1"></i>Alert Rules
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "telemetry-alerts" ? "active" : "")" @onclick='() => SetTab("telemetry-alerts")' role="tab" aria-selected="@(activeTab == "telemetry-alerts")" tabindex="@(activeTab == "telemetry-alerts" ? 0 : -1)" id="@($"tab-telemetry-alerts")">
                    <i class="bi bi-bell me-1"></i>Telemetry Alerts
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "logs" ? "active" : "")" @onclick='() => SetTab("logs")' role="tab" aria-selected="@(activeTab == "logs")" tabindex="@(activeTab == "logs" ? 0 : -1)" id="@($"tab-logs")">
                    <i class="bi bi-journal-text me-1"></i>Logs
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "traces" ? "active" : "")" @onclick='() => SetTab("traces")' role="tab" aria-selected="@(activeTab == "traces")" tabindex="@(activeTab == "traces" ? 0 : -1)" id="@($"tab-traces")">
                    <i class="bi bi-diagram-3 me-1"></i>Traces
