    <div class="tab-content" role="tabpanel" tabindex="0" aria-labelledby="@($"tab-{activeTab}")">
        @if (tabLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
            </div>
        }
        else @switch (activeTab)
        {
            case "environments":
                <EnvironmentTab TenantId="tenant.Id" />
                break;
            case "customers":
                <CustomerTab TenantId="tenant.Id" />
                break;
            case "vault":
                <VaultTab TenantId="tenant.Id" />
                break;
            case "groups":
                <GroupTab TenantId="tenant.Id" />
                break;
            case "databases":
                <DatabaseTab TenantId="tenant.Id" />
                break;
            case "storage":
                <StorageTab TenantId="tenant.Id" />
                break;
            case "identity":
                <IdentityTab TenantId="tenant.Id" />
                break;
            case "blueprints":
                <BlueprintsTab TenantId="tenant.Id" />
                break;
            case "registry":
                <RegistryTab TenantId="tenant.Id" />
                break;
            case "messaging":
                <ul class="nav nav-pills mb-3" role="tablist" aria-label="Messaging tabs">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(messagingSubTab == "rabbitmq" ? "active" : "")"
                                @onclick='() => messagingSubTab = "rabbitmq"' role="tab" aria-selected="@(messagingSubTab == "rabbitmq")" tabindex="@(messagingSubTab == "rabbitmq" ? 0 : -1)">
                            <i class="bi bi-collection me-1"></i>RabbitMQ
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(messagingSubTab == "kafka" ? "active" : "")"
                                @onclick='() => messagingSubTab = "kafka"' role="tab" aria-selected="@(messagingSubTab == "kafka")" tabindex="@(messagingSubTab == "kafka" ? 0 : -1)">
                            <i class="bi bi-hdd-stack me-1"></i>Kafka
                        </button>
                    </li>
                </ul>
                @if (messagingSubTab == "kafka")
                {
                    <KafkaTab TenantId="tenant.Id" />
                }
                else
                {
                    <MessagingTab TenantId="tenant.Id" />
                }
                break;
            case "cache":
                <CacheTab TenantId="tenant.Id" />
                break;
            case "overview":
                <TenantMonitoringOverview TenantId="tenant.Id" TenantSlug="tenant.Slug" OnNavigateTab="SetTab" />
                break;
            case "alerts":
                <TenantAlertsTab TenantId="tenant.Id" />
                break;
            case "alert-rules":
                <TenantAlertRulesTab TenantId="tenant.Id" />
                break;
            case "logs":
                <TenantLogsTab TenantId="tenant.Id" />
                break;
            case "traces":
                <TenantTracesTab TenantId="tenant.Id" PresetClusterId="@ClusterParam" PresetTraceId="@TraceParam" />
                break;
            case "metrics":
                <TenantMetricsTab TenantId="tenant.Id" />
                break;
            case "telemetry-alerts":
                <TelemetryAlertRulesTab TenantId="tenant.Id" />
                break;
            case "incidents":
                <IncidentManagement TenantId="tenant.Id" />
                break;
            case "notifications":
                <NotificationChannels TenantId="tenant.Id" />
                break;
            case "secret-expiry":
                <SecretExpiryTab TenantId="tenant.Id" OnNavigateTab="SetTab" />
                break;
            case "maintenance":
                <MaintenanceWindows TenantId="tenant.Id" />
                break;
            case "on-call":
                <OnCallTab TenantId="tenant.Id" />
                break;
            case "alert-routing":
                <AlertRoutingTab TenantId="tenant.Id" />
                break;
            case "analytics":
                <TenantOpsAnalyticsTab TenantId="tenant.Id" />
                break;
            case "sla":
                <SlaTargetManager TenantId="tenant.Id" />
                break;
            case "networking":
                <NetworkingTab TenantId="tenant.Id" />
                break;
        }
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = "";

    // Tab state is mirrored to the URL (?category=&tab=) so a deep view is
    // bookmarkable, shareable, and survives a refresh or Blazor reconnect.
    [SupplyParameterFromQuery(Name = "category")] private string? CategoryParam { get; set; }
    [SupplyParameterFromQuery(Name = "tab")] private string? TabParam { get; set; }
    // Deep-link a specific trace (from a log line's "trace" badge) into the Traces tab.
    [SupplyParameterFromQuery(Name = "cluster")] private string? ClusterParam { get; set; }
    [SupplyParameterFromQuery(Name = "trace")] private string? TraceParam { get; set; }

    private Tenant? tenant;
    private string activeCategory = "apps";
    private string activeTab = "customers";
    private string messagingSubTab = "rabbitmq";
    private bool tabLoading;

    private static readonly Dictionary<string, string> CategoryDefaults = new()
    {
        ["apps"] = "customers",
        ["infra"] = "environments",
        ["services"] = "databases",
        ["ops"] = "overview",
    };

    // Re-apply tab/category from the query string on every navigation. OnInitializedAsync runs only
    // once, so a same-page deep-link (e.g. the log→trace badge navigating to ?tab=traces) would not
    // otherwise switch tabs — OnParametersSet fires on each query-string change and covers that.
    protected override void OnParametersSet() => ApplyTabFromQuery();

    // Restore tab state from the query string on load / navigation.
    private void ApplyTabFromQuery()
    {
        activeCategory = CategoryParam is not null && CategoryDefaults.ContainsKey(CategoryParam)
            ? CategoryParam
            : "apps";
        activeTab = string.IsNullOrWhiteSpace(TabParam)
            ? CategoryDefaults[activeCategory]
            : TabParam;
    }

    private void SyncUrl()
    {
        string uri = Navigation.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["category"] = activeCategory,
            ["tab"] = activeTab,
        });
        Navigation.NavigateTo(uri, forceLoad: false, replace: true);
    }

    private async Task SetCategory(string category)
    {
        tabLoading = true;
        activeCategory = category;
        activeTab = CategoryDefaults[category];
        SyncUrl();
        StateHasChanged();
        await Task.Yield();
        tabLoading = false;
    }

    private async Task SetTab(string tab)
    {
        tabLoading = true;
        activeTab = tab;
        SyncUrl();
        StateHasChanged();
        await Task.Yield();
        tabLoading = false;
    }

    protected override async Task OnInitializedAsync()
    {
        AuthenticationState authState = await AuthStateProvider.GetAuthenticationStateAsync();
        System.Security.Claims.ClaimsPrincipal user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo("/Account/Login", forceLoad: true);
            return;
        }

        string? userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (userId is null)
        {
            Navigation.NavigateTo("/Account/Login", forceLoad: true);
            return;
        }

        tenant = await TenantService.GetTenantBySlugAsync(Slug);

        if (tenant is null)
        {
            Navigation.NavigateTo("/tenants");
            return;
        }

        bool canAccess = await UserAccessService.HasTenantAccessAsync(userId, tenant.Id);
        if (!canAccess)
        {
            bool hasMembership = await UserAccessService.HasAnyTenantMembershipAsync(userId);
            Navigation.NavigateTo(hasMembership ? "/tenants" : "/portal");
            return;
        }
        // Tab is applied in OnParametersSet (runs after this on first render and on every navigation).
    }
}