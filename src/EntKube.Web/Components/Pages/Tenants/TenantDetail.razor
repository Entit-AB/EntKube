@page "/tenants/{Slug}/classic"
@using EntKube.Web.Data
@using EntKube.Web.Services
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer
@inject TenantService TenantService
@inject UserAccessService UserAccessService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>@(tenant?.Name ?? "Tenant")</PageTitle>

@if (tenant is null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="text-muted mt-2">Loading tenant...</p>
    </div>
}
else
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb small">
            <li class="breadcrumb-item"><a href="/tenants" class="text-decoration-none"><i class="bi bi-building me-1"></i>Tenants</a></li>
            <li class="breadcrumb-item active">@tenant.Name</li>
        </ol>
    </nav>

    <div class="d-flex align-items-center mb-4">
        <i class="bi bi-building fs-3 me-2 text-primary"></i>
        <div>
            <h2 class="mb-0">@tenant.Name</h2>
            <small class="text-muted"><code>@tenant.Slug</code></small>
        </div>
        <a href="/tenants/@tenant.Slug" class="btn btn-sm btn-outline-primary ms-auto">
            <i class="bi bi-diagram-3 me-1"></i>Switch to new navigation
        </a>
    </div>

    @* ── Category (top-level) nav ── *@
    <ul class="nav nav-pills mb-2 gap-1 tenant-category-nav" role="tablist" aria-label="Tenant sections">
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeCategory == "apps" ? "active" : "")" @onclick='() => SetCategory("apps")' disabled="@tabLoading" role="tab" aria-selected="@(activeCategory == "apps")" tabindex="@(activeCategory == "apps" ? 0 : -1)">
                <i class="bi bi-people me-1"></i>Applications
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeCategory == "infra" ? "active" : "")" @onclick='() => SetCategory("infra")' disabled="@tabLoading" role="tab" aria-selected="@(activeCategory == "infra")" tabindex="@(activeCategory == "infra" ? 0 : -1)">
                <i class="bi bi-layers me-1"></i>Infrastructure
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeCategory == "services" ? "active" : "")" @onclick='() => SetCategory("services")' disabled="@tabLoading" role="tab" aria-selected="@(activeCategory == "services")" tabindex="@(activeCategory == "services" ? 0 : -1)">
                <i class="bi bi-box-seam me-1"></i>Services
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeCategory == "ops" ? "active" : "")" @onclick='() => SetCategory("ops")' disabled="@tabLoading" role="tab" aria-selected="@(activeCategory == "ops")" tabindex="@(activeCategory == "ops" ? 0 : -1)">
                <i class="bi bi-speedometer2 me-1"></i>Operations
            </button>
        </li>
    </ul>

    @* ── Sub-tab strip for the active category ── *@
    <ul class="nav nav-tabs mb-4" role="tablist" aria-label="Section tabs">
        @if (activeCategory == "apps")
        {
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "customers" ? "active" : "")" @onclick='() => SetTab("customers")' role="tab" aria-selected="@(activeTab == "customers")" tabindex="@(activeTab == "customers" ? 0 : -1)" id="@($"tab-customers")">
                    <i class="bi bi-people me-1"></i>Customers
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "groups" ? "active" : "")" @onclick='() => SetTab("groups")' role="tab" aria-selected="@(activeTab == "groups")" tabindex="@(activeTab == "groups" ? 0 : -1)" id="@($"tab-groups")">
                    <i class="bi bi-diagram-3 me-1"></i>Groups
                </button>
            </li>
        }
        else if (activeCategory == "infra")
        {
