    private async Task PushFullPreviewUpdate()
    {
        if (_jsModule is null) return;
        string? logoDataUri = null;
        if (_vars.ShowLogo && !string.IsNullOrEmpty(_vars.LogoResourceName))
            logoDataUri = _resourcePreviews.GetValueOrDefault(_vars.LogoResourceName);
        string? bgDataUri = null;
        if (_vars.UseBackgroundImage && !string.IsNullOrEmpty(_vars.BackgroundImageResourceName))
            bgDataUri = _resourcePreviews.GetValueOrDefault(_vars.BackgroundImageResourceName);

        // Object with camelCase property names to match the JS interface
        await _jsModule.InvokeVoidAsync("updatePreview", _previewId, new
        {
            primaryColor = _vars.PrimaryColor,
            primaryColorDark = _vars.PrimaryColorDark,
            pageBackground = _vars.PageBackground,
            cardBackground = _vars.CardBackground,
            textColor = _vars.TextColor,
            mutedTextColor = _vars.MutedTextColor,
            linkColor = _vars.LinkColor,
            inputBorderColor = _vars.InputBorderColor,
            inputBackground = _vars.InputBackground,
            inputTextColor = _vars.InputTextColor,
            buttonTextColor = _vars.ButtonTextColor,
            errorColor = _vars.ErrorColor,
            headerBackground = _vars.HeaderBackground,
            headerTextColor = _vars.HeaderTextColor,
            fontFamily = _vars.FontFamily,
            fontSizePx = _vars.FontSizePx,
            buttonRadiusPx = _vars.ButtonRadiusPx,
            inputRadiusPx = _vars.InputRadiusPx,
            cardRadiusPx = _vars.CardRadiusPx,
            logoHeightPx = _vars.LogoHeightPx,
            showLogo = _vars.ShowLogo,
            logoExternalUrl = _vars.LogoExternalUrl ?? "",
            useBackgroundImage = _vars.UseBackgroundImage,
            showFooter = _vars.ShowFooter,
            footerText = _vars.FooterText,
            extraCss = _vars.ExtraCss,
        }, logoDataUri, bgDataUri);
    }

    // ── Presets ───────────────────────────────────────────────────────────────

    private async Task ApplyPreset((string Name, string Primary, string PrimaryDark, string HeaderBg, string PageBg, string CardBg, string Text, string InputBorder) p)
    {
        _vars.PrimaryColor    = p.Primary;
        _vars.PrimaryColorDark = p.PrimaryDark;
        _vars.HeaderBackground = p.HeaderBg;
        _vars.PageBackground  = p.PageBg;
        _vars.CardBackground  = p.CardBg;
        _vars.TextColor       = p.Text;
        _vars.InputTextColor  = p.Text;
        _vars.MutedTextColor  = AdjustAlpha(p.Text, 0.55);
        _vars.InputBorderColor = p.InputBorder;
        _vars.LinkColor       = p.Primary;
        _vars.ButtonTextColor = IsLight(p.Primary) ? "#000000" : "#ffffff";
        _vars.HeaderTextColor = IsLight(p.HeaderBg) ? "#151515" : "#ffffff";
        await PushFullPreviewUpdate();
    }

