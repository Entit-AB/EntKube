    private async Task AutoDarken()
    {
        string darkened = DarkenHex(_vars.PrimaryColor, 0.80);
        _vars.PrimaryColorDark = darkened;
        await SetVar("--ek-primary-dark", darkened);
    }

    private static string DarkenHex(string hex, double factor)
    {
        try
        {
            string h = hex.TrimStart('#');
            if (h.Length < 6) return hex;
            int r = (int)(Convert.ToInt32(h[0..2], 16) * factor);
            int g = (int)(Convert.ToInt32(h[2..4], 16) * factor);
            int b = (int)(Convert.ToInt32(h[4..6], 16) * factor);
            return $"#{Math.Clamp(r, 0, 255):X2}{Math.Clamp(g, 0, 255):X2}{Math.Clamp(b, 0, 255):X2}";
        }
        catch { return hex; }
    }

    // ── WCAG contrast helpers ─────────────────────────────────────────────────

    private static double SrgbLinearize(double c)
        => c <= 0.04045 ? c / 12.92 : Math.Pow((c + 0.055) / 1.055, 2.4);

    private static double RelativeLuminance(string hex)
    {
        try
        {
            string h = hex.TrimStart('#');
            if (h.Length < 6) return 0;
            return 0.2126 * SrgbLinearize(Convert.ToInt32(h[0..2], 16) / 255.0)
                 + 0.7152 * SrgbLinearize(Convert.ToInt32(h[2..4], 16) / 255.0)
                 + 0.0722 * SrgbLinearize(Convert.ToInt32(h[4..6], 16) / 255.0);
        }
        catch { return 0; }
    }

    private static double ContrastRatio(string fg, string bg)
    {
        double l1 = RelativeLuminance(fg);
        double l2 = RelativeLuminance(bg);
        double lighter = Math.Max(l1, l2);
        double darker  = Math.Min(l1, l2);
        return (lighter + 0.05) / (darker + 0.05);
    }

    // ── WCAG render helper ────────────────────────────────────────────────────

    private RenderFragment A11yRow(string label, string fg, string bg) =>
        __builder =>
        {
            double ratio = ContrastRatio(fg, bg);
            bool passAAA  = ratio >= 7.0;
            bool passAA   = ratio >= 4.5;
            bool passLarge = ratio >= 3.0;
            string level  = passAAA ? "AAA" : (passAA ? "AA" : (passLarge ? "AA Large" : "Fail"));
            string color  = passAA  ? "success" : (passLarge ? "warning" : "danger");
            string icon   = passAA  ? "bi-check-circle-fill" : "bi-x-circle-fill";
            <div class="te-a11y-row">
                <span class="te-a11y-label">@label</span>
                <span class="te-a11y-swatch" aria-hidden="true">
                    <span style="background:@bg;color:@fg;padding:1px 7px;border-radius:3px;font-size:.68rem;font-weight:700;border:1px solid rgba(0,0,0,.08)">Aa</span>
                </span>
                <span class="te-a11y-ratio">@ratio.ToString("F1"):1</span>
                <span class="badge bg-@(color)-subtle text-@color border" style="font-size:.65rem;white-space:nowrap">
                    <i class="bi @icon me-1"></i>@level
                </span>
            </div>
        };

    // rough luminance check — "is this hex colour light?"
    private static bool IsLight(string hex)
    {
        try
        {
            string h = hex.TrimStart('#');
            if (h.Length < 6) return true;
            int r = Convert.ToInt32(h[0..2], 16);
            int g = Convert.ToInt32(h[2..4], 16);
            int b = Convert.ToInt32(h[4..6], 16);
            return (r * 299 + g * 587 + b * 114) / 1000 > 128;
        }
        catch { return true; }
    }

    private static string AdjustAlpha(string hex, double opacity)
    {
        try
        {
            string h = hex.TrimStart('#');
            if (h.Length < 6) return hex;
            int r = (int)(Convert.ToInt32(h[0..2], 16) * opacity + 255 * (1 - opacity));
            int g = (int)(Convert.ToInt32(h[2..4], 16) * opacity + 255 * (1 - opacity));
            int b = (int)(Convert.ToInt32(h[4..6], 16) * opacity + 255 * (1 - opacity));
            return $"#{r:X2}{g:X2}{b:X2}";
        }
        catch { return hex; }
    }

    // ── Section dialogs ───────────────────────────────────────────────────────

    private async Task OpenDialog(string key)
    {
        _activeDialog = key;
        // Version history is loaded lazily the first time its dialog is opened.
        if (key == "history" && _history is null)
            await LoadHistoryAsync();
    }

    private void CloseDialog() => _activeDialog = null;

    // ── Version history ───────────────────────────────────────────────────────

    private async Task LoadHistoryAsync()
    {
        _loadingHistory = true;
        StateHasChanged();
        _history = await KeycloakService.GetThemeHistoryAsync(TenantId, ComponentId, Theme.Id);
        _loadingHistory = false;
    }

    private async Task RestoreHistoryEntry(ThemeHistoryEntry entry)
    {
        _vars = entry.Variables;
        // Close the history dialog so the restored values are visible in the live preview.
        _activeDialog = null;
        await PushFullPreviewUpdate();
    }

    private static string RelativeTime(DateTimeOffset dt)
    {
        TimeSpan elapsed = DateTimeOffset.UtcNow - dt;
        if (elapsed.TotalSeconds < 90)  return "just now";
        if (elapsed.TotalMinutes < 60)  return $"{(int)elapsed.TotalMinutes} min ago";
        if (elapsed.TotalHours < 24)    return $"{(int)elapsed.TotalHours} hr ago";
        if (elapsed.TotalDays < 7)
        {
            int d = (int)elapsed.TotalDays;
            return $"{d} day{(d > 1 ? "s" : "")} ago";
        }
        return dt.ToLocalTime().ToString("MMM d");
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private static bool IsImage(string filename) =>
        new[] { ".png", ".jpg", ".jpeg", ".gif", ".svg", ".webp", ".ico" }
            .Contains(Path.GetExtension(filename).ToLowerInvariant());

    private static string SanitiseFilename(string name)
    {
        string clean = System.Text.RegularExpressions.Regex.Replace(
            Path.GetFileNameWithoutExtension(name), @"[^a-zA-Z0-9_\-]", "_");
        string ext = Path.GetExtension(name).ToLowerInvariant();
        return $"{clean}{ext}";
    }

    // ── Render helper for colour rows ─────────────────────────────────────────

    private RenderFragment ColorRow(string label, string currentValue, Action<string> onChange) =>
        __builder =>
        {
            <div class="te-row te-color-row">
                <label>@label</label>
                <div class="d-flex align-items-center gap-2">
                    <input type="color" class="form-control form-control-color te-color-input"
                           value="@currentValue"
                           @oninput="e => onChange(e.Value?.ToString() ?? currentValue)" />
                    <input type="text" class="form-control form-control-sm te-color-hex"
                           value="@currentValue"
                           @oninput="e => onChange(e.Value?.ToString() ?? currentValue)"
                           maxlength="9" spellcheck="false" />
                </div>
            </div>
        };

    public async ValueTask DisposeAsync()
    {
        if (_jsModule is not null)
        {
            try { await _jsModule.InvokeVoidAsync("destroyPreview", _previewId); } catch { }
            await _jsModule.DisposeAsync();
        }
    }
}

