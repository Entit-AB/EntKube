@using EntKube.Web.Data
@using EntKube.Web.Services
@inject SecretExpiryService SecretExpiry

<div class="card shadow-sm mb-3 mt-4">
    <div class="card-header bg-white py-2 d-flex align-items-center justify-content-between">
        <span><i class="bi bi-shield-exclamation me-2 text-primary"></i><strong>Expiry notifications</strong></span>
    </div>
    <div class="card-body pt-3">
        <p class="text-muted small mb-3">
            Notify operations before certificates and OAuth/OIDC client secrets expire. Notices are sent
            through this tenant's <a href="#" @onclick:preventDefault @onclick='() => Navigate("notifications")'>notification channels</a>,
            honoring your <a href="#" @onclick:preventDefault @onclick='() => Navigate("alert-routing")'>alert routing rules</a>.
        </p>

        <div class="row g-3 align-items-end">
            <div class="col-auto">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="expiryEnabled" @bind="enabled" />
                    <label class="form-check-label" for="expiryEnabled">Enable automatic notifications</label>
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label small mb-1">Lead times (days before expiry)</label>
                <input class="form-control form-control-sm" @bind="thresholdsCsv" placeholder="30,14,7,1" />
                <div class="form-text">Comma-separated. A notice fires once per band as a secret nears expiry; expired secrets always notify.</div>
            </div>
            <div class="col-auto">
                <button class="btn btn-sm btn-primary" @onclick="SaveConfigAsync" disabled="@saving">
                    @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Save
                </button>
            </div>
            @if (saveMessage is not null)
            {
                <div class="col-auto">
                    <span class="small @(saveOk ? "text-success" : "text-danger")">@saveMessage</span>
                </div>
            }
        </div>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header bg-white py-2 d-flex align-items-center justify-content-between">
        <span><i class="bi bi-clock-history me-2 text-primary"></i><strong>Secrets with an expiry</strong></span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="ReloadAsync" disabled="@loading">
            <i class="bi bi-arrow-clockwise me-1"></i>Refresh
        </button>
    </div>
    <div class="card-body pt-2">
        @if (loading)
        {
            <div class="text-center py-3"><span class="spinner-border spinner-border-sm text-primary"></span></div>
        }
        else if (loadError is not null)
        {
            <div class="alert alert-danger mb-0">Failed to load: @loadError</div>
        }
        else if (secrets.Count == 0)
        {
            <p class="text-muted small mb-0">No certificates or OAuth client secrets found for this tenant.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr class="text-muted small">
                            <th>Secret</th>
                            <th>Type</th>
                            <th>Scope</th>
                            <th>Expires</th>
                            <th>Status</th>
                            <th>Last notified</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (ExpiringSecretInfo s in secrets)
                        {
                            SecretExpiryNotification? last = LastNotified(s.SecretId);
                            <tr>
                                <td>
                                    <div class="fw-semibold">@s.Name</div>
                                    @if (!string.IsNullOrEmpty(s.Detail))
                                    {
                                        <div class="text-muted small text-truncate" style="max-width: 22rem;">@s.Detail</div>
                                    }
                                </td>
                                <td class="small">@s.TypeLabel</td>
                                <td class="small">@s.ScopeLabel</td>
                                <td class="small">
                                    @if (s.ExpiresAt.HasValue)
                                    {
                                        @s.ExpiresAt.Value.ToString("yyyy-MM-dd")
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge @StatusBadgeClass(s)">@StatusText(s)</span>
                                </td>
                                <td class="small">
                                    @if (last is not null)
                                    {
                                        <span title="@last.SentAt.ToString("u")">
                                            @last.SentAt.ToString("yyyy-MM-dd")
                                            @if (!last.Success)
                                            {
                                                <i class="bi bi-exclamation-triangle-fill text-danger ms-1" title="@last.Error"></i>
                                            }
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">never</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => SendNowAsync(s)"
                                            disabled="@(sendingId == s.SecretId)">
                                        @if (sendingId == s.SecretId)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        <i class="bi bi-send me-1"></i>Send now
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (sendMessage is not null)
            {
                <div class="small mt-2 @(sendOk ? "text-success" : "text-danger")">@sendMessage</div>
            }
        }
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header bg-white py-2">
        <span><i class="bi bi-journal-text me-2 text-primary"></i><strong>Recent notifications</strong></span>
    </div>
    <div class="card-body pt-2">
        @if (history.Count == 0)
        {
            <p class="text-muted small mb-0">No notifications have been sent yet.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr class="text-muted small">
                            <th>Sent</th>
                            <th>Secret</th>
                            <th>Band</th>
                            <th>Channels</th>
                            <th>Result</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (SecretExpiryNotification n in history)
                        {
                            <tr>
                                <td class="small" title="@n.SentAt.ToString("u")">@n.SentAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="small">@n.SecretName</td>
                                <td class="small">
                                    @(n.ThresholdDays == 0 ? "expired" : $"{n.ThresholdDays}d")
                                    @if (n.Manual) { <span class="badge bg-secondary ms-1">manual</span> }
                                </td>
                                <td class="small">@n.ChannelsNotified</td>
                                <td class="small">
                                    @if (n.Success)
                                    {
                                        <span class="text-success"><i class="bi bi-check-circle me-1"></i>sent</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger" title="@n.Error"><i class="bi bi-x-circle me-1"></i>failed</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public Guid TenantId { get; set; }
    [Parameter] public EventCallback<string> OnNavigateTab { get; set; }

    private bool enabled;
    private string thresholdsCsv = "30,14,7,1";

    private List<ExpiringSecretInfo> secrets = [];
    private List<SecretExpiryNotification> history = [];

    private bool loading = true;
    private string? loadError;
    private bool saving;
    private string? saveMessage;
    private bool saveOk;
    private Guid? sendingId;
    private string? sendMessage;
    private bool sendOk;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        loading = true;
        loadError = null;
        try
        {
            SecretExpiryNotificationConfig config = await SecretExpiry.GetConfigAsync(TenantId);
            enabled = config.IsEnabled;
            thresholdsCsv = config.ThresholdDaysCsv;
            secrets = await SecretExpiry.GetExpiringSecretsAsync(TenantId);
            history = await SecretExpiry.GetHistoryAsync(TenantId);
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task SaveConfigAsync()
    {
        saving = true;
        saveMessage = null;
        try
        {
            await SecretExpiry.SaveConfigAsync(TenantId, null, enabled, thresholdsCsv);
            saveOk = true;
            saveMessage = "Saved";
        }
        catch (Exception ex)
        {
            saveOk = false;
            saveMessage = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private async Task SendNowAsync(ExpiringSecretInfo secret)
    {
        sendingId = secret.SecretId;
        sendMessage = null;
        try
        {
            (int notified, bool success, string? error) = await SecretExpiry.SendNowAsync(TenantId, secret.SecretId);
            sendOk = success;
            sendMessage = success
                ? $"Sent \"{secret.Name}\" to {notified} channel(s)."
                : $"Failed to send \"{secret.Name}\": {error}";
            history = await SecretExpiry.GetHistoryAsync(TenantId);
        }
        catch (Exception ex)
        {
            sendOk = false;
            sendMessage = ex.Message;
        }
        finally
        {
            sendingId = null;
        }
    }

    private SecretExpiryNotification? LastNotified(Guid secretId) =>
        history.Where(n => n.SecretId == secretId).MaxBy(n => n.SentAt);

    private async Task Navigate(string tab)
    {
        if (OnNavigateTab.HasDelegate)
            await OnNavigateTab.InvokeAsync(tab);
    }

    private static string StatusText(ExpiringSecretInfo s)
    {
        if (!s.ExpiresAt.HasValue) return "No expiry set";
        int days = s.DaysUntilExpiry ?? 0;
        if (s.IsExpired) return $"Expired {Math.Abs(days)}d ago";
        return $"{days}d left";
    }

    private static string StatusBadgeClass(ExpiringSecretInfo s)
    {
        if (!s.ExpiresAt.HasValue) return "bg-secondary";
        int days = s.DaysUntilExpiry ?? 0;
        if (s.IsExpired || days <= 7) return "bg-danger";
        if (days <= 30) return "bg-warning text-dark";
        return "bg-success";
    }
}
