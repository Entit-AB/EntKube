@using System.ComponentModel.DataAnnotations
@using System.Text.Json
@using EntKube.Web.Data
@using EntKube.Web.Services
@inject IncidentService IncidentService
@inject OnCallService OnCallService
@inject NotificationService NotificationService
@inject ToastService Toasts
@inject AuthenticationStateProvider AuthStateProvider

@* ── On-call banner ── *@
@if (currentOnCall is not null)
{
    <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-3">
        <span class="bi bi-person-check-fill"></span>
        <span class="small">
            On call now: <strong>@currentOnCall.AssigneeName</strong>
            @if (!string.IsNullOrEmpty(currentOnCall.AssigneeEmail))
            {
                <a href="mailto:@currentOnCall.AssigneeEmail" class="ms-1">@currentOnCall.AssigneeEmail</a>
            }
            — until @currentOnCall.EndsAt.ToLocalTime().ToString("MMM d HH:mm")
        </span>
    </div>
}

@if (stats is not null)
{
    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
        <span class="badge rounded-pill @(stats.Active > 0 ? "bg-danger" : "bg-success")">@stats.Active active</span>
        @if (stats.Acknowledged > 0)
        {
            <span class="badge rounded-pill bg-warning text-dark">@stats.Acknowledged ack</span>
        }
        @if (stats.Critical > 0)
        {
            <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle">@stats.Critical critical</span>
        }
        @if (UnassignedActiveCount > 0)
        {
            <span class="badge rounded-pill bg-warning-subtle text-warning-emphasis border border-warning-subtle"
                  style="cursor:pointer" title="Show unassigned only"
                  @onclick="() => { filterUnassigned = true; showFilters = true; _ = LoadIncidents(); }">@UnassignedActiveCount unassigned</span>
        }
        <span class="text-muted small ms-1">MTTR @stats.FormatMttr() · MTTA @stats.FormatMtta() · @stats.Total in @(stats.WindowDays)d</span>
    </div>
}

@* Compact control bar — only the most-used controls; everything else lives behind "Filters". *@
<div class="mb-2 d-flex flex-wrap gap-2 align-items-center">
    <select class="form-select form-select-sm" style="width:auto" @bind="filterStatus" @bind:after="LoadIncidents">
        <option value="Open">Open (Active + Acknowledged)</option>
        <option value="Active">Active</option>
        <option value="Acknowledged">Acknowledged</option>
        <option value="">All (including resolved)</option>
        <option value="Resolved">Resolved only</option>
    </select>
    <input class="form-control form-control-sm" style="max-width:200px"
           @bind="searchText" @bind:after="LoadIncidents" placeholder="Search alerts…" />
    <button class="btn btn-sm @(showFilters ? "btn-secondary" : "btn-outline-secondary")" @onclick="() => showFilters = !showFilters">
        <span class="bi bi-funnel me-1"></span>Filters@(ActiveFilterCount() > 0 ? $" ({ActiveFilterCount()})" : "")
    </button>
    <button class="btn btn-sm btn-outline-secondary" @onclick="LoadIncidents" title="Refresh">
        <span class="bi bi-arrow-clockwise"></span>
    </button>
    <span class="ms-auto text-muted small">@incidents.Count incident@(incidents.Count == 1 ? "" : "s")</span>
</div>

@if (showFilters)
{
    <div class="d-flex flex-wrap align-items-center gap-2 mb-3 p-2 bg-light rounded border">
        <select class="form-select form-select-sm" style="width:auto" @bind="filterSeverity" @bind:after="LoadIncidents">
            <option value="">All severities</option>
            <option value="critical">Critical</option>
            <option value="warning">Warning</option>
            <option value="info">Info</option>
        </select>
        <select class="form-select form-select-sm" style="width:auto" @bind="filterClusterId" @bind:after="LoadIncidents">
            <option value="">All clusters</option>
            @foreach (var c in clusters)
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>
        <select class="form-select form-select-sm" style="width:auto" @bind="filterDays" @bind:after="LoadIncidents">
            <option value="1">Last 24 hours</option>
            <option value="7">Last 7 days</option>
            <option value="30">Last 30 days</option>
            <option value="90">Last 90 days</option>
        </select>
        <div class="form-check ms-1">
            <input class="form-check-input" type="checkbox" id="chkUnassigned" @bind="filterUnassigned" @bind:after="LoadIncidents" />
            <label class="form-check-label small" for="chkUnassigned">Unassigned only</label>
        </div>
        @if (stats is not null && stats.Daily.Count > 1)
        {
            int maxCount = stats.Daily.Max(d => d.Count);
            <div class="ms-auto d-flex align-items-center gap-2">
                <span class="text-muted small">Alert volume (30d)</span>
                <div class="d-flex align-items-end" style="height:28px;gap:2px">
                    @foreach (DailyAlertCount day in stats.Daily)
                    {
                        int h = maxCount > 0 ? (int)Math.Max(2, day.Count * 28.0 / maxCount) : 2;
                        string color = day.Count == 0 ? "#dee2e6" : "#dc3545";
                        <div style="width:4px;height:@(h)px;background:@color;border-radius:1px"
                             title="@day.Date.ToString("MMM d"): @day.Count alert@(day.Count == 1 ? "" : "s")"></div>
                    }
                </div>
            </div>
        }
    </div>
}

@* ── One list: incidents grouped by environment, then collapsed by correlation. A storm
      (same alert firing N times — the reason we don't send 26 notifications) is a single
      expandable row; uncorrelated incidents are ordinary rows. ── *@
<LoadingPanel Loading="@isLoading" LoadingText="Loading incidents…">
@if (!isLoading && displayEnv.Count == 0)
{
    <EmptyState Icon="bi-check-circle"
                Title="No incidents found"
                Message="No incidents match the selected filters." />
}
else if (!isLoading)
{
    @foreach (EnvGroup env in displayEnv)
    {
        <div class="d-flex align-items-center gap-2 mt-3 mb-2 pb-1 border-bottom">
            <i class="bi bi-layers text-primary"></i>
            <span class="fw-semibold">@env.EnvironmentName</span>
            <span class="text-muted small">@env.AlertCount alert@(env.AlertCount == 1 ? "" : "s")</span>
            @if (env.CriticalCount > 0)
            {
                <span class="badge bg-danger">@env.CriticalCount critical</span>
            }
        </div>

        <div class="list-group mb-2">
            @foreach (IncidentGroup g in env.Groups)
            {
                @if (g.Count > 1)
                {
                    bool sopen = expandedStormKey == g.Key;
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start gap-3" style="cursor:pointer"
                             @onclick="() => ToggleStorm(g.Key)">
                            <div>
                                <i class="bi @(sopen ? "bi-chevron-down" : "bi-chevron-right") small text-muted me-1"></i>
                                <i class="bi bi-tornado text-warning me-1" title="Correlated — @g.Count alerts, one root cause"></i>
                                <span class="badge @StormSevBadge(g.Severity) me-1">@g.Severity</span>
                                <span class="fw-semibold">@g.AlertName</span>
                                <span class="badge bg-secondary ms-1">×@g.Count</span>
                                @if (g.AnyAcknowledged)
                                {
                                    <span class="badge bg-warning text-dark ms-1">some ack’d</span>
                                }
                                <div class="small text-muted mt-1 ms-4">
                                    <i class="bi bi-hdd-network me-1"></i>@g.ClusterName
                                    @if (g.Namespaces.Count > 0)
                                    {
                                        <span class="ms-2"><i class="bi bi-diagram-2 me-1"></i>@string.Join(", ", g.Namespaces)</span>
                                    }
                                    <span class="ms-2"><i class="bi bi-clock-history me-1"></i>since @g.EarliestStartsAt.ToLocalTime().ToString("MMM d HH:mm")</span>
                                </div>
                            </div>
                            <div class="d-flex gap-1 flex-shrink-0" @onclick:stopPropagation="true">
                                <button class="btn btn-sm btn-outline-warning" @onclick="() => AckStorm(g)"
                                        title="Acknowledge all @g.Count alerts in this storm">Ack all</button>
                                <button class="btn btn-sm btn-outline-success" @onclick="() => ResolveStorm(g)"
                                        title="Resolve all @g.Count alerts in this storm">Resolve all</button>
                            </div>
                        </div>
                        @if (sopen)
                        {
                            <div class="mt-2 ms-4 ps-2 border-start">
                                @foreach (AlertIncident m in MembersOf(g))
                                {
                                    <div class="py-1 border-top">
                                        @RenderIncidentRow(m, true)
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="list-group-item">
                        @RenderIncidentRow(MembersOf(g).FirstOrDefault(), false)
                    </div>
                }
            }
        </div>
    }
}
</LoadingPanel>

@code {
    [Parameter] public required Guid TenantId { get; set; }

    /// <summary>When set (via a deep link, e.g. from the Fleet/Operations Advisor), the incident
    /// whose detail should open automatically on load — no drill-down required.</summary>
    [Parameter] public Guid? FocusIncidentId { get; set; }

    private List<AlertIncident> incidents = [];
    private Dictionary<Guid, AlertIncident> incidentsById = [];
    private List<EnvGroup> displayEnv = [];
    private string? expandedStormKey;
    private bool initialized;
    private Guid? focusApplied;

    /// <summary>A tenant's environment with its correlated incident groups, for the grouped list.</summary>
    private sealed record EnvGroup(
        Guid? EnvironmentId, string EnvironmentName, List<IncidentGroup> Groups, int AlertCount, int CriticalCount);

    private void ToggleStorm(string key) => expandedStormKey = expandedStormKey == key ? null : key;

    // A group's member incidents, resolved from the loaded list (which was itself correlated).
    private List<AlertIncident> MembersOf(IncidentGroup g) =>
        g.IncidentIds
            .Select(id => incidentsById.GetValueOrDefault(id))
            .Where(i => i is not null).Select(i => i!)
            .OrderBy(i => SeverityRank(i.Severity)).ThenBy(i => i.StartsAt)
            .ToList();

    private static int SeverityRank(string? severity) => severity?.ToLowerInvariant() switch
    {
        "critical" => 0,
        "warning" => 1,
        _ => 2,
    };

    // The distinguishing resource within a group (members share the alert name): namespace / pod.
    private static string ResourceLabel(AlertIncident i)
    {
        try
        {
            using JsonDocument doc = JsonDocument.Parse(i.LabelsJson);
            JsonElement root = doc.RootElement;
            string? ns = root.TryGetProperty("namespace", out JsonElement n) ? n.GetString() : null;
            string? pod = root.TryGetProperty("pod", out JsonElement p) ? p.GetString()
                        : root.TryGetProperty("instance", out JsonElement inst) ? inst.GetString() : null;
            string label = string.Join(" / ", new[] { ns, pod }.Where(x => !string.IsNullOrEmpty(x)));
            if (!string.IsNullOrEmpty(label)) return label;
        }
        catch { /* fall through to summary */ }
        return string.IsNullOrWhiteSpace(i.Summary) ? "—" : i.Summary;
    }

    private async Task AckStorm(IncidentGroup g)
    {
        await IncidentService.BulkAcknowledgeAsync(g.IncidentIds, currentUser!);
        await Task.WhenAll(LoadIncidents(), LoadStats());
    }

    private async Task ResolveStorm(IncidentGroup g)
    {
        await IncidentService.BulkResolveAsync(g.IncidentIds);
        await Task.WhenAll(LoadIncidents(), LoadStats());
    }

    private static string StormSevBadge(string? severity) => severity?.ToLowerInvariant() switch
    {
        "critical" => "bg-danger",
        "warning" => "bg-warning text-dark",
        _ => "bg-secondary",
    };

    private List<KubernetesCluster> clusters = [];
    private AlertStats? stats;
    private Guid? expandedId;
    private string filterStatus = "Open";
    private string filterSeverity = "";
    private string filterClusterId = "";
    private int filterDays = 7;
    private NoteForm noteForm = new();
    private bool isLoading = true;
    private string? currentUser;

    private Guid? assigningId;
    private AssignForm assignForm = new();
    private bool filterUnassigned;
    private bool showFilters;
    private string searchText = "";

    private int UnassignedActiveCount =>
        incidents.Count(i => i.AssignedTo is null && i.Status != IncidentStatus.Resolved);

    // Count of advanced filters set away from their defaults — surfaced on the collapsed
    // "Filters" button so hidden filtering is discoverable.
    private int ActiveFilterCount()
    {
        int n = 0;
        if (!string.IsNullOrEmpty(filterSeverity)) n++;
        if (!string.IsNullOrEmpty(filterClusterId)) n++;
        if (filterDays != 7) n++;
        if (filterUnassigned) n++;
        return n;
    }

    private OnCallShift? currentOnCall;
    private Dictionary<Guid, List<NotificationDelivery>> deliveriesByIncident = new();
    private Guid? reNotifyingId;
    private Dictionary<Guid, string> reNotifyResults = new();

    protected override async Task OnInitializedAsync()
    {
        AuthenticationState authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUser = authState.User.Identity?.Name ?? "Unknown";
        await Task.WhenAll(LoadIncidents(), LoadStats(), LoadOnCall());
        initialized = true;
        if (FocusIncidentId is Guid fid) await ApplyFocusAsync(fid);
    }

    // Fires when the deep link's ?incident= changes while the component is already mounted
    // (e.g. opening a different incident from the advisor without a full reload).
    protected override async Task OnParametersSetAsync()
    {
        if (initialized && FocusIncidentId is Guid fid && fid != focusApplied)
        {
            await ApplyFocusAsync(fid);
        }
    }

    // Expand the targeted incident's detail. If the default "Open" filter would hide it
    // (e.g. it was resolved since the advisor computed the finding), widen the filters and
    // reload so the row is still there to open. If it lives inside a correlated storm,
    // open that storm too so the row is visible.
    private async Task ApplyFocusAsync(Guid id)
    {
        focusApplied = id;
        if (!incidents.Any(i => i.Id == id))
        {
            filterStatus = "";
            filterSeverity = "";
            filterClusterId = "";
            searchText = "";
            filterUnassigned = false;
            await LoadIncidents();
        }
        if (incidents.Any(i => i.Id == id))
        {
            IncidentGroup? group = displayEnv.SelectMany(e => e.Groups)
                .FirstOrDefault(g => g.IncidentIds.Contains(id));
            if (group is { Count: > 1 }) expandedStormKey = group.Key;
            expandedId = id;
            await LoadDeliveriesAsync(id);
        }
        StateHasChanged();
    }

    private async Task LoadOnCall()
    {
        currentOnCall = await OnCallService.GetCurrentOnCallAsync(TenantId);
    }

    private async Task LoadStats()
    {
        stats = await IncidentService.GetStatsForTenantAsync(TenantId, windowDays: 30);
    }

    private async Task LoadIncidents()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            IncidentStatus? status = filterStatus switch
            {
                "Active" => IncidentStatus.Active,
                "Acknowledged" => IncidentStatus.Acknowledged,
                "Resolved" => IncidentStatus.Resolved,
                _ => null  // "Open" and "" both pass null — post-filter handles "Open"
            };

            Guid? clusterId = Guid.TryParse(filterClusterId, out Guid cid) ? cid : null;

            // Open incidents are ongoing — don't cut them off by start date.
            // Apply the time window only when browsing resolved history.
            bool isOpenFilter = filterStatus is "Open" or "Active" or "Acknowledged";
            DateTime? fromDate = isOpenFilter ? null : DateTime.UtcNow.AddDays(-filterDays);

            incidents = await IncidentService.GetIncidentsForTenantAsync(
                TenantId,
                status: status,
                severity: string.IsNullOrEmpty(filterSeverity) ? null : filterSeverity,
                clusterId: clusterId,
                from: fromDate,
                to: null);

            // "Open" means Active + Acknowledged — exclude resolved
            if (filterStatus == "Open")
                incidents = incidents.Where(i => i.Status != IncidentStatus.Resolved).ToList();

            if (filterUnassigned)
                incidents = incidents.Where(i => i.AssignedTo is null).ToList();

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                string q = searchText.Trim();
                incidents = incidents.Where(i =>
                    i.AlertName.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                    i.Summary.Contains(q, StringComparison.OrdinalIgnoreCase)).ToList();
            }

            deliveriesByIncident.Clear();

            clusters = incidents
                .Where(i => i.Cluster is not null)
                .Select(i => i.Cluster!)
                .DistinctBy(c => c.Id)
                .OrderBy(c => c.Name)
                .ToList();

            // Correlate the displayed incidents (same alert firing many times → one group) and
            // arrange them by environment for the single grouped list.
            incidentsById = incidents.ToDictionary(i => i.Id);
            displayEnv = IncidentCorrelationService.Correlate(incidents)
                .GroupBy(g => new { g.EnvironmentId, g.EnvironmentName })
                .Select(envG => new EnvGroup(
                    envG.Key.EnvironmentId,
                    envG.Key.EnvironmentName,
                    envG.OrderBy(g => SeverityRank(g.Severity))
                        .ThenByDescending(g => g.Count)
                        .ThenByDescending(g => g.LatestStartsAt)
                        .ToList(),
                    envG.Sum(g => g.Count),
                    envG.SelectMany(g => g.IncidentIds)
                        .Select(id => incidentsById.GetValueOrDefault(id))
                        .Count(i => i is not null && i.Severity == "critical")))
                .OrderByDescending(e => e.CriticalCount)
                .ThenByDescending(e => e.AlertCount)
                .ThenBy(e => e.EnvironmentName)
                .ToList();
        }
        catch
        {
            incidents = [];
            incidentsById = [];
            displayEnv = [];
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleExpand(Guid id)
    {
        if (expandedId == id)
        {
            expandedId = null;
        }
        else
        {
            expandedId = id;
            _ = LoadDeliveriesAsync(id);
        }
        noteForm = new NoteForm();
        if (assigningId != id) assigningId = null;
    }

    private async Task LoadDeliveriesAsync(Guid incidentId)
    {
        List<NotificationDelivery> deliveries = await IncidentService.GetDeliveriesAsync(incidentId);
        deliveriesByIncident[incidentId] = deliveries;
        StateHasChanged();
    }

    private async Task ReNotify(AlertIncident incident)
    {
        reNotifyingId = incident.Id;
        reNotifyResults.Remove(incident.Id);
        StateHasChanged();

        try
        {
            int count = await NotificationService.ReNotifyAsync(incident.Id, incident.Cluster!.TenantId);
            reNotifyResults[incident.Id] = count > 0
                ? $"✓ Notified {count} channel{(count == 1 ? "" : "s")}"
                : "✓ No channels to notify";

            // Refresh deliveries so the new entry appears
            await LoadDeliveriesAsync(incident.Id);
        }
        catch (Exception ex)
        {
            reNotifyResults[incident.Id] = $"✗ {ex.Message}";
        }
        finally
        {
            reNotifyingId = null;
        }
    }

    private void StartAssign(AlertIncident incident)
    {
        assigningId = incident.Id;
        assignForm = new AssignForm { Assignee = incident.AssignedTo ?? "" };
    }

    private async Task SubmitAssign(AlertIncident incident)
    {
        try
        {
            string assignee = assignForm.Assignee.Trim();
            await IncidentService.AssignAsync(incident.Id, assignee);
            assigningId = null;
            await Task.WhenAll(LoadIncidents(), LoadStats());
            expandedId = incident.Id;
            Toasts.Success($"Incident assigned to {assignee}.");
        }
        catch (Exception ex)
        {
            Toasts.Error(ex.Message, "Failed to assign incident");
        }
    }

    private async Task Acknowledge(AlertIncident incident)
    {
        await IncidentService.AcknowledgeAsync(incident.Id, currentUser!);
        await Task.WhenAll(LoadIncidents(), LoadStats());
    }

    private async Task Resolve(AlertIncident incident)
    {
        await IncidentService.ResolveAsync(incident.Id, currentUser!);
        await Task.WhenAll(LoadIncidents(), LoadStats());
    }

    private async Task AddNote(AlertIncident incident)
    {
        try
        {
            await IncidentService.AddNoteAsync(incident.Id, currentUser!, noteForm.Content.Trim());
            noteForm = new NoteForm();
            await LoadIncidents();
            expandedId = incident.Id;
            Toasts.Success("Note added.");
        }
        catch (Exception ex)
        {
            Toasts.Error(ex.Message, "Failed to add note");
        }
    }

    private sealed class AssignForm
    {
        [Required(ErrorMessage = "Enter an assignee name or email.")]
        [StringLength(200)]
        public string Assignee { get; set; } = "";
    }

    private sealed class NoteForm
    {
        [Required(ErrorMessage = "Note cannot be empty.")]
        [StringLength(2000)]
        public string Content { get; set; } = "";
    }

    private record TimelineEvent(DateTime At, string Icon, string IconColor, string Label, string Detail);

    private static List<TimelineEvent> BuildTimeline(AlertIncident incident)
    {
        List<TimelineEvent> events = [];

        events.Add(new(incident.StartsAt, "bi-bell-fill", "text-danger", "Alert fired", ""));

        if (incident.EscalatedAt.HasValue)
            events.Add(new(incident.EscalatedAt.Value, "bi-exclamation-triangle-fill", "text-danger",
                "Escalated", "No acknowledgement within threshold"));

        if (incident.AssignedAt.HasValue && incident.AssignedTo is not null)
            events.Add(new(incident.AssignedAt.Value, "bi-person-fill", "text-primary",
                $"Assigned to {incident.AssignedTo}", ""));

        if (incident.AcknowledgedAt.HasValue)
            events.Add(new(incident.AcknowledgedAt.Value, "bi-check-circle-fill", "text-warning",
                $"Acknowledged{(incident.AcknowledgedBy is not null ? $" by {incident.AcknowledgedBy}" : "")}", ""));

        foreach (IncidentNote note in incident.Notes)
            events.Add(new(note.CreatedAt, "bi-chat-left-text-fill", "text-secondary",
                $"Note by {note.Author}", note.Content));

        if (incident.ResolvedAt.HasValue)
            events.Add(new(incident.ResolvedAt.Value, "bi-check2-circle", "text-success", "Resolved", ""));

        return [.. events.OrderBy(e => e.At)];
    }

    private static string FormatDuration(AlertIncident incident)
    {
        DateTime end = incident.EndsAt ?? DateTime.UtcNow;
        TimeSpan duration = end - incident.StartsAt;
        if (duration.TotalDays >= 1) return $"{(int)duration.TotalDays}d {duration.Hours}h";
        if (duration.TotalHours >= 1) return $"{(int)duration.TotalHours}h {duration.Minutes}m";
        return $"{(int)duration.TotalMinutes}m";
    }

    private static RenderFragment SeverityBadge(string severity) => severity switch
    {
        "critical" => @<span class="badge bg-danger">Critical</span>,
        "warning"  => @<span class="badge bg-warning text-dark">Warning</span>,
        "info"     => @<span class="badge bg-info text-dark">Info</span>,
        _          => @<span class="badge bg-secondary">@severity</span>
    };

    private static RenderFragment StatusBadge(IncidentStatus status) => status switch
    {
        IncidentStatus.Active       => @<span class="badge bg-danger">Active</span>,
        IncidentStatus.Acknowledged => @<span class="badge bg-warning text-dark">Acknowledged</span>,
        IncidentStatus.Resolved     => @<span class="badge bg-success">Resolved</span>,
        _                           => @<span class="badge bg-secondary">@status</span>
    };

    // One incident's summary row + (when expanded) its full detail. Reused for uncorrelated
    // incidents and for the members inside a correlated storm.
    private RenderFragment RenderIncidentRow(AlertIncident? incident, bool nested) => incident is null ? @<text></text> : @<div>
        <div class="d-flex justify-content-between align-items-start gap-3" style="cursor:pointer"
             @onclick="() => ToggleExpand(incident.Id)">
            <div>
                <i class="bi @(expandedId == incident.Id ? "bi-chevron-down" : "bi-chevron-right") small text-muted me-1"></i>
                @SeverityBadge(incident.Severity)
                <span class="fw-semibold ms-1 @(nested ? "small" : "")">@(nested ? ResourceLabel(incident) : incident.AlertName)</span>
                @if (incident.EscalatedAt.HasValue)
                {
                    <span class="badge bg-danger-subtle text-danger border border-danger small ms-1">Escalated</span>
                }
                <div class="small text-muted mt-1 ms-4">
                    @if (!nested)
                    {
                        <span><i class="bi bi-hdd-network me-1"></i>@incident.Cluster?.Name</span>
                    }
                    <span class="@(nested ? "" : "ms-2")"><i class="bi bi-clock-history me-1"></i>@incident.StartsAt.ToLocalTime().ToString("MMM d HH:mm") · @FormatDuration(incident)</span>
                    @if (incident.AssignedTo is not null)
                    {
                        <span class="ms-2"><i class="bi bi-person me-1"></i>@incident.AssignedTo</span>
                    }
                </div>
            </div>
            <div class="d-flex align-items-center gap-1 flex-shrink-0" @onclick:stopPropagation="true">
                @StatusBadge(incident.Status)
                @if (incident.Status == IncidentStatus.Active)
                {
                    <button class="btn btn-sm btn-outline-warning" @onclick="() => Acknowledge(incident)">Ack</button>
                }
                @if (incident.Status != IncidentStatus.Resolved)
                {
                    <button class="btn btn-sm btn-outline-success" @onclick="() => Resolve(incident)">Resolve</button>
                }
            </div>
        </div>
        @if (expandedId == incident.Id)
        {
            <div class="mt-2 mb-1 p-2 bg-light rounded">
                @RenderIncidentDetail(incident)
            </div>
        }
    </div>;

    // The expanded incident detail: summary, timeline, assignment, notification history, notes.
    private RenderFragment RenderIncidentDetail(AlertIncident incident) => @<div class="row g-4">

        @* ── Left: Timeline ── *@
        <div class="col-12 col-lg-5">
            @if (!string.IsNullOrEmpty(incident.Summary))
            {
                <p class="mb-1 small"><strong>Summary:</strong> @incident.Summary</p>
            }
            @if (!string.IsNullOrEmpty(incident.Description))
            {
                <p class="mb-2 small text-muted">@incident.Description</p>
            }
            @if (!string.IsNullOrEmpty(incident.RunbookUrl))
            {
                <p class="mb-3">
                    <a href="@incident.RunbookUrl" target="_blank" rel="noopener noreferrer"
                       class="btn btn-sm btn-outline-secondary">
                        <span class="bi bi-book me-1"></span>Runbook
                    </a>
                </p>
            }

            <strong class="small d-block mb-2">Timeline</strong>
            <div style="position:relative;padding-left:28px">
                <div style="position:absolute;left:9px;top:0;bottom:0;width:2px;background:#dee2e6"></div>
                @foreach (TimelineEvent ev in BuildTimeline(incident))
                {
                    <div style="position:relative;margin-bottom:14px">
                        <span style="position:absolute;left:-19px;top:2px;width:20px;height:20px;border-radius:50%;background:white;border:2px solid #dee2e6;display:flex;align-items:center;justify-content:center;font-size:.72rem"
                              class="@ev.IconColor">
                            <i class="bi @ev.Icon"></i>
                        </span>
                        <div class="d-flex gap-2 align-items-baseline">
                            <span class="small fw-semibold">@ev.Label</span>
                            <span class="text-muted" style="font-size:.72rem">@ev.At.ToLocalTime().ToString("MMM d HH:mm")</span>
                        </div>
                        @if (!string.IsNullOrEmpty(ev.Detail))
                        {
                            <div class="text-muted small mt-1">@ev.Detail</div>
                        }
                    </div>
                }
            </div>
        </div>

        @* ── Right: Actions ── *@
        <div class="col-12 col-lg-7">

            @* Assignment *@
            <div class="mb-3">
                <strong class="small d-block mb-2">Assignment</strong>
                @if (incident.AssignedTo is not null)
                {
                    <p class="mb-1 small text-muted">
                        <span class="bi bi-person-check me-1"></span>
                        Assigned to <strong>@incident.AssignedTo</strong>
                        @if (incident.AssignedAt.HasValue)
                        {
                            <span>at @incident.AssignedAt.Value.ToLocalTime().ToString("MMM d HH:mm")</span>
                        }
                    </p>
                }
                @if (assigningId == incident.Id)
                {
                    <EditForm Model="assignForm" OnValidSubmit="() => SubmitAssign(incident)" class="mt-1">
                        <DataAnnotationsValidator />
                        <div class="d-flex gap-2 align-items-center">
                            <div>
                                <InputText class="form-control form-control-sm" style="max-width:220px"
                                           @bind-Value="assignForm.Assignee" placeholder="Assignee name or email" />
                                <ValidationMessage For="() => assignForm.Assignee" class="text-danger small" />
                            </div>
                            <button type="submit" class="btn btn-sm btn-primary">Assign</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => assigningId = null">Cancel</button>
                        </div>
                    </EditForm>
                }
                else
                {
                    <button class="btn btn-sm btn-outline-secondary mt-1"
                            @onclick="() => StartAssign(incident)">
                        <span class="bi bi-person-plus me-1"></span>
                        @(incident.AssignedTo is null ? "Assign" : "Reassign")
                    </button>
                }
            </div>

            @* Notification delivery history *@
            @if (deliveriesByIncident.TryGetValue(incident.Id, out List<NotificationDelivery>? deliveries) && deliveries.Count > 0)
            {
                <div class="mb-3">
                    <strong class="small d-block mb-1">Notification history</strong>
                    <div class="table-responsive">
                        <table class="table table-sm table-borderless mb-0" style="font-size:.77rem">
                            <tbody>
                                @foreach (NotificationDelivery d in deliveries)
                                {
                                    <tr>
                                        <td class="py-0 text-muted">@d.SentAt.ToLocalTime().ToString("MMM d HH:mm")</td>
                                        <td class="py-0">@d.Channel?.Name</td>
                                        <td class="py-0 text-muted">@(d.IsFiring ? "FIRING" : "RESOLVED")</td>
                                        <td class="py-0">
                                            @if (d.Success)
                                            {
                                                <span class="text-success"><span class="bi bi-check-circle me-1"></span>Sent</span>
                                            }
                                            else
                                            {
                                                <span class="text-danger" title="@d.Error"><span class="bi bi-x-circle me-1"></span>Failed</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @* Re-notify *@
            <div class="mb-3 d-flex gap-2 align-items-center">
                <button class="btn btn-sm btn-outline-info"
                        @onclick="() => ReNotify(incident)"
                        disabled="@(reNotifyingId == incident.Id)">
                    @if (reNotifyingId == incident.Id)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    <span class="bi bi-send me-1"></span>Re-notify
                </button>
                @if (reNotifyResults.TryGetValue(incident.Id, out string? reNotifyMsg))
                {
                    <span class="small @(reNotifyMsg.StartsWith("✓") ? "text-success" : "text-danger")">@reNotifyMsg</span>
                }
            </div>

            @* Add note *@
            <strong class="small d-block mb-1">Add note</strong>
            <EditForm Model="noteForm" OnValidSubmit="() => AddNote(incident)">
                <DataAnnotationsValidator />
                <div class="d-flex gap-2">
                    <div style="max-width:360px">
                        <InputTextArea class="form-control form-control-sm" rows="2"
                                       placeholder="Add a note…"
                                       @bind-Value="noteForm.Content" />
                        <ValidationMessage For="() => noteForm.Content" class="text-danger small" />
                    </div>
                    <button type="submit" class="btn btn-sm btn-primary align-self-end">Add</button>
                </div>
            </EditForm>
        </div>

    </div>;
}
