@using System.ComponentModel.DataAnnotations
@using EntKube.Web.Data
@using EntKube.Web.Services
@inject RabbitMQService RabbitMQService
@inject StorageService StorageService
@inject TenantService TenantService
@inject ToastService Toasts

@* ===========================================================================
   Messaging Tab — RabbitMQ cluster management and topology.
   Full lifecycle for clusters plus topology management via the K8s Topology
   Operator (vhosts, queues, exchanges, routing bindings, users, permissions).
   App linkage syncs AMQP connection details into app namespace K8s Secrets.
   =========================================================================== *@

<LoadingPanel Loading="@loading" LoadingText="Loading RabbitMQ clusters…">
@if (!loading)
{
    @* ── Operator availability badges ── *@
    <div class="d-flex gap-2 mb-4 flex-wrap">
        @if (clusterOperatorAvailable)
        {
            <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2">
                <i class="bi bi-collection me-1"></i>RabbitMQ Cluster Operator
                @if (operatorStatus?.ClusterOperatorClusterName is not null)
                {
                    <small class="ms-1 opacity-75">on @operatorStatus.ClusterOperatorClusterName</small>
                }
            </span>
        }
        else
        {
            <span class="badge bg-secondary-subtle text-secondary border px-3 py-2">
                <i class="bi bi-collection me-1"></i>RabbitMQ Cluster Operator — not installed
            </span>
        }

        @if (topologyOperatorAvailable)
        {
            <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2">
                <i class="bi bi-diagram-3 me-1"></i>Topology Operator
                @if (operatorStatus?.TopologyOperatorClusterName is not null)
                {
                    <small class="ms-1 opacity-75">on @operatorStatus.TopologyOperatorClusterName</small>
                }
            </span>
        }
        else
        {
            <span class="badge bg-secondary-subtle text-secondary border px-3 py-2">
                <i class="bi bi-diagram-3 me-1"></i>Topology Operator — not installed
            </span>
        }
    </div>

    @* ── Cluster list ── *@
    <div class="mb-4">
        <h5 class="d-flex align-items-center gap-2 mb-3">
            <i class="bi bi-collection text-primary"></i>RabbitMQ Clusters
            <span class="badge bg-secondary rounded-pill">@clusters.Count</span>
            <button class="btn btn-sm btn-outline-secondary ms-auto" @onclick="DiscoverClusters" disabled="@(discovering || showCreateForm)">
                @if (discovering) { <span class="spinner-border spinner-border-sm me-1"></span> }
                else { <i class="bi bi-search me-1"></i> }
                Discover existing
            </button>
            <button class="btn btn-sm btn-secondary" @onclick="ShowCreateForm" disabled="@showCreateForm">
                <i class="bi bi-plus-lg me-1"></i>Create Cluster
            </button>
        </h5>

        @if (discoverMessage is not null)
        {
            <div class="alert @(discoverIsError ? "alert-danger" : "alert-info") py-2 small d-flex align-items-center">
                <i class="bi @(discoverIsError ? "bi-exclamation-triangle" : "bi-info-circle") me-2"></i>
                <span>@discoverMessage</span>
                <button type="button" class="btn-close btn-close-sm ms-auto" aria-label="Close" @onclick="() => discoverMessage = null"></button>
            </div>
        }

        @if (showCreateForm)
        {
            <div class="card shadow-sm mb-3 border-secondary">
                <div class="card-header bg-secondary bg-opacity-10 d-flex align-items-center justify-content-between">
                    <h6 class="mb-0"><i class="bi bi-plus-circle me-2"></i>New RabbitMQ Cluster</h6>
                    <button class="btn btn-sm btn-outline-secondary border-0" aria-label="Close" @onclick="CancelCreate"><i class="bi bi-x-lg"></i></button>
                </div>
                <div class="card-body">
                    <EditForm Model="createModel" OnValidSubmit="CreateCluster">
                        <DataAnnotationsValidator />
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small">Cluster Name</label>
                                <InputText class="form-control form-control-sm" @bind-Value="createModel.Name" placeholder="rabbitmq-prod" />
                                <div class="form-text small">DNS-safe, max 63 chars.</div>
                                <ValidationMessage For="() => createModel.Name" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small">Kubernetes Cluster</label>
                                <InputSelect class="form-select form-select-sm" @bind-Value="createModel.K8sClusterId">
                                    <option value="">Select cluster...</option>
                                    @foreach (KubernetesCluster k in allK8sClusters)
                                    {
                                        <option value="@k.Id">@k.Name (@k.Environment.Name)</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="() => createModel.K8sClusterId" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small">Namespace</label>
                                <InputText class="form-control form-control-sm" @bind-Value="createModel.Namespace" placeholder="rabbitmq" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small">RabbitMQ Version</label>
                                <InputText class="form-control form-control-sm" @bind-Value="createModel.Version" placeholder="3.13" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Replicas</label>
                                <InputNumber class="form-control form-control-sm" @bind-Value="createModel.Replicas" min="1" max="9" />
                                <ValidationMessage For="() => createModel.Replicas" class="text-danger small" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Storage Size</label>
                                <InputText class="form-control form-control-sm" @bind-Value="createModel.StorageSize" placeholder="10Gi" />
                                <ValidationMessage For="() => createModel.StorageSize" class="text-danger small" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Storage Class <span class="text-muted">(optional)</span></label>
                                <InputText class="form-control form-control-sm" @bind-Value="createModel.StorageClass" placeholder="default" />
                            </div>
                            <div class="col-md-8">
                                <label class="form-label small">S3 Storage Link <span class="text-muted">(optional, for backups)</span></label>
                                <InputSelect class="form-select form-select-sm" @bind-Value="createModel.StorageLinkId">
                                    <option value="">No backup storage</option>
                                    @foreach (StorageLink sl in storageLinks)
                                    {
                                        <option value="@sl.Id">@sl.Name (@sl.BucketName)</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(createError))
                        {
                            <div class="alert alert-danger mt-3 mb-0 py-2 small">@createError</div>
                        }
                        <div class="mt-3 d-flex gap-2">
                            <button type="submit" class="btn btn-sm btn-primary" disabled="@creating">
                                @if (creating) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Create
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CancelCreate">Cancel</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        }

        @if (clusters.Count == 0)
        {
            <EmptyState Icon="bi-collection" Title="No clusters yet"
                        Message="No RabbitMQ clusters provisioned for this tenant."
                        ActionLabel="Create cluster" OnAction="ShowCreateForm" />
        }
        else
        {
            @foreach (RabbitMQCluster cluster in clusters)
            {
                bool expanded = expandedClusterId == cluster.Id;

                <div class="card shadow-sm mb-3 @(expanded ? "border-primary" : "")">
                    <div class="card-header d-flex align-items-center gap-2 @(expanded ? "bg-primary bg-opacity-10" : "bg-light")"
                         style="cursor:pointer" @onclick="() => ToggleCluster(cluster.Id)">
                        <i class="bi bi-collection @(expanded ? "text-primary" : "text-secondary")"></i>
                        <span class="fw-semibold">@cluster.Name</span>
                        <small class="text-muted">@cluster.Namespace</small>
                        <span class="badge @StatusBadgeClass(cluster.Status) ms-1">@cluster.Status</span>
                        <small class="text-muted ms-2">
                            <i class="bi bi-server me-1"></i>@cluster.KubernetesCluster.Name
                            <span class="ms-2"><i class="bi bi-layers me-1"></i>@cluster.KubernetesCluster.Environment.Name</span>
                        </small>
                        <small class="text-muted ms-2">v@cluster.RabbitMQVersion &bull; @cluster.Replicas nodes &bull; @cluster.StorageSize</small>
                        @if (cluster.StorageLinkId.HasValue)
                        {
                            <span class="badge bg-info-subtle text-info border border-info-subtle ms-1">
                                <i class="bi bi-cloud me-1"></i>Backups
                            </span>
                        }
                        <button class="btn btn-sm btn-link text-warning p-0 ms-auto" title="Edit cluster" aria-label="Edit cluster"
                                @onclick="() => ShowClusterEdit(cluster)" @onclick:stopPropagation="true">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <i class="bi @(expanded ? "bi-chevron-up" : "bi-chevron-down") ms-2 text-muted"></i>
                    </div>

                    @if (!string.IsNullOrEmpty(cluster.LastError) && cluster.Status == RabbitMQClusterStatus.Failed)
                    {
                        <div class="px-3 py-2 bg-danger-subtle text-danger small border-bottom">
                            <i class="bi bi-exclamation-triangle me-1"></i>@cluster.LastError
                        </div>
                    }

                    @if (expanded)
                    {
                        <div class="card-body pt-3">
                            <ul class="nav nav-pills mb-3 gap-1 flex-wrap" role="tablist" aria-label="RabbitMQ cluster sections">
                                @foreach (string tab in new[] { "vhosts", "queues", "exchanges", "routing", "users", "app-links", "backup", "credentials", "metrics" })
                                {
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link @(clusterTab == tab ? "active" : "")"
                                                @onclick="() => SetClusterTab(tab, cluster.Id)"
                                                role="tab" aria-selected="@(clusterTab == tab)" tabindex="@(clusterTab == tab ? 0 : -1)">
                                            @TabLabel(tab)
                                        </button>
                                    </li>
                                }
                            </ul>

                            @if (!string.IsNullOrEmpty(topologyError))
                            {
                                <div class="alert alert-danger py-2 small mb-3">
                                    <i class="bi bi-exclamation-triangle me-1"></i>@topologyError
                                    <button type="button" class="btn-close float-end" aria-label="Close" @onclick="() => topologyError = null"></button>
                                </div>
                            }

                            @* ── Vhosts ── *@
                            @if (clusterTab == "vhosts")
                            {
                                <div class="d-flex align-items-center mb-2">
                                    <h6 class="mb-0 me-2"><i class="bi bi-hdd-rack me-1 text-primary"></i>Virtual Hosts</h6>
                                    <button class="btn btn-sm btn-secondary ms-auto" @onclick="() => showVhostForm = !showVhostForm">
                                        <i class="bi bi-plus-lg me-1"></i>Add Vhost
                                    </button>
                                </div>

                                @if (showVhostForm)
                                {
                                    <div class="card border-secondary mb-3">
                                        <div class="card-body py-2">
                                            <EditForm Model="vhostModel" OnValidSubmit="() => CreateVhost(cluster)">
                                                <DataAnnotationsValidator />
                                                <div class="row g-2 align-items-end">
                                                    <div class="col">
                                                        <label class="form-label small">Vhost Path</label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="vhostModel.Name" placeholder="/my-app" />
                                                        <div class="form-text small">Use "/" for the default vhost or "/path" for a named vhost.</div>
                                                        <ValidationMessage For="() => vhostModel.Name" class="text-danger small" />
                                                    </div>
                                                    <div class="col-auto">
                                                        <button type="submit" class="btn btn-sm btn-primary" disabled="@submitting">
                                                            @if (submitting) { <span class="spinner-border spinner-border-sm me-1"></span> }Create
                                                        </button>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary ms-1" @onclick="() => showVhostForm = false">Cancel</button>
                                                    </div>
                                                </div>
                                            </EditForm>
                                        </div>
                                    </div>
                                }

                                @if (loadingTopology)
                                {
                                    <div class="text-center py-3"><span class="spinner-border spinner-border-sm text-primary"></span></div>
                                }
                                else if (vhosts.Count == 0)
                                {
                                    <EmptyState Icon="bi-hdd-rack" Title="No vhosts" Message="No vhosts managed via the topology operator yet." />
                                }
                                else
                                {
                                    <table class="table table-sm table-hover small">
                                        <thead><tr><th>Vhost</th><th>K8s Name</th><th></th></tr></thead>
                                        <tbody>
                                            @foreach (RabbitMQVhostInfo v in vhosts)
                                            {
                                                <tr>
                                                    <td class="align-middle fw-semibold">@v.VhostName</td>
                                                    <td class="align-middle text-muted font-monospace">@v.K8sName</td>
                                                    <td class="align-middle text-end">
                                                        <button class="btn btn-sm btn-outline-danger" title="Delete" aria-label="@($"Delete vhost {v.VhostName}")"
                                                                @onclick='() => PrepareCascadeDelete(cluster, "vhost", v.K8sName, v.VhostName, v.VhostName)'>
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                            }

                            @* ── Queues ── *@
                            @if (clusterTab == "queues")
                            {
                                <div class="d-flex align-items-center mb-2">
                                    <h6 class="mb-0"><i class="bi bi-stack me-1 text-primary"></i>Queues</h6>
                                    <button class="btn btn-sm btn-secondary ms-auto" @onclick="() => showQueueForm = !showQueueForm">
                                        <i class="bi bi-plus-lg me-1"></i>Add Queue
                                    </button>
                                </div>

                                @if (showQueueForm)
                                {
                                    <div class="card border-secondary mb-3">
                                        <div class="card-body py-2">
                                            <EditForm Model="queueModel" OnValidSubmit="() => CreateQueue(cluster)">
                                                <DataAnnotationsValidator />
                                                <div class="row g-2">
                                                    <div class="col-md-5">
                                                        <label class="form-label small">Queue Name</label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="queueModel.Name" placeholder="orders.created" />
                                                        <ValidationMessage For="() => queueModel.Name" class="text-danger small" />
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="form-label small">Vhost</label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="queueModel.Vhost" placeholder="/" />
                                                        <ValidationMessage For="() => queueModel.Vhost" class="text-danger small" />
                                                    </div>
                                                    <div class="col-md-2">
                                                        <label class="form-label small">Type</label>
                                                        <InputSelect class="form-select form-select-sm" @bind-Value="queueModel.QueueType">
                                                            <option value="quorum">Quorum</option>
                                                            <option value="classic">Classic</option>
                                                            <option value="stream">Stream</option>
                                                        </InputSelect>
                                                    </div>
                                                    <div class="col-md-2 d-flex align-items-end gap-2">
                                                        <div class="form-check form-check-inline">
                                                            <InputCheckbox class="form-check-input" @bind-Value="queueModel.Durable" />
                                                            <label class="form-check-label small">Durable</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-12 d-flex gap-2">
                                                        <button type="submit" class="btn btn-sm btn-primary" disabled="@submitting">
                                                            @if (submitting) { <span class="spinner-border spinner-border-sm me-1"></span> }Create
                                                        </button>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => showQueueForm = false">Cancel</button>
                                                    </div>
                                                </div>
                                            </EditForm>
                                        </div>
                                    </div>
                                }

                                @if (loadingTopology) { <div class="text-center py-3"><span class="spinner-border spinner-border-sm text-primary"></span></div> }
                                else if (queues.Count == 0) { <EmptyState Icon="bi-stack" Title="No queues" Message="No queues yet." /> }
                                else
                                {
                                    <table class="table table-sm table-hover small">
                                        <thead><tr><th>Name</th><th>Vhost</th><th>Type</th><th>Durable</th><th></th></tr></thead>
                                        <tbody>
                                            @foreach (RabbitMQQueueInfo q in queues)
                                            {
                                                <tr>
                                                    <td class="align-middle fw-semibold">@q.QueueName</td>
                                                    <td class="align-middle text-muted">@q.Vhost</td>
                                                    <td class="align-middle"><span class="badge bg-secondary-subtle text-secondary border">@q.QueueType</span></td>
                                                    <td class="align-middle">@(q.Durable ? "✓" : "—")</td>
                                                    <td class="align-middle text-end">
                                                        <button class="btn btn-sm btn-outline-info me-1"
                                                                @onclick="() => PrepareAppLink(cluster, q.QueueName, null, q.Vhost)">
                                                            <i class="bi bi-link-45deg me-1"></i>Link to App
                                                        </button>
                                                        <button class="btn btn-sm btn-outline-danger" title="Delete" aria-label="@($"Delete queue {q.QueueName}")"
                                                                @onclick='() => PrepareCascadeDelete(cluster, "queue", q.K8sName, q.QueueName, q.Vhost)'>
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                            }

                            @* ── Exchanges ── *@
                            @if (clusterTab == "exchanges")
                            {
                                <div class="d-flex align-items-center mb-2">
                                    <h6 class="mb-0"><i class="bi bi-arrow-left-right me-1 text-primary"></i>Exchanges</h6>
                                    <button class="btn btn-sm btn-secondary ms-auto" @onclick="() => showExchangeForm = !showExchangeForm">
                                        <i class="bi bi-plus-lg me-1"></i>Add Exchange
                                    </button>
                                </div>

                                @if (showExchangeForm)
                                {
                                    <div class="card border-secondary mb-3">
                                        <div class="card-body py-2">
                                            <EditForm Model="exchangeModel" OnValidSubmit="() => CreateExchange(cluster)">
                                                <DataAnnotationsValidator />
                                                <div class="row g-2">
                                                    <div class="col-md-5">
                                                        <label class="form-label small">Exchange Name</label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="exchangeModel.Name" placeholder="orders" />
                                                        <ValidationMessage For="() => exchangeModel.Name" class="text-danger small" />
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="form-label small">Vhost</label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="exchangeModel.Vhost" placeholder="/" />
                                                        <ValidationMessage For="() => exchangeModel.Vhost" class="text-danger small" />
                                                    </div>
                                                    <div class="col-md-2">
                                                        <label class="form-label small">Type</label>
                                                        <InputSelect class="form-select form-select-sm" @bind-Value="exchangeModel.ExchangeType">
                                                            <option value="direct">Direct</option>
                                                            <option value="fanout">Fanout</option>
                                                            <option value="topic">Topic</option>
                                                            <option value="headers">Headers</option>
                                                        </InputSelect>
                                                    </div>
                                                    <div class="col-md-2 d-flex align-items-end">
                                                        <div class="form-check">
                                                            <InputCheckbox class="form-check-input" @bind-Value="exchangeModel.Durable" />
                                                            <label class="form-check-label small">Durable</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-12 d-flex gap-2">
                                                        <button type="submit" class="btn btn-sm btn-primary" disabled="@submitting">
                                                            @if (submitting) { <span class="spinner-border spinner-border-sm me-1"></span> }Create
                                                        </button>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => showExchangeForm = false">Cancel</button>
                                                    </div>
                                                </div>
                                            </EditForm>
                                        </div>
                                    </div>
                                }

                                @if (loadingTopology) { <div class="text-center py-3"><span class="spinner-border spinner-border-sm text-primary"></span></div> }
                                else if (exchanges.Count == 0) { <EmptyState Icon="bi-arrow-left-right" Title="No exchanges" Message="No exchanges yet." /> }
                                else
                                {
                                    <table class="table table-sm table-hover small">
                                        <thead><tr><th>Name</th><th>Vhost</th><th>Type</th><th>Durable</th><th></th></tr></thead>
                                        <tbody>
                                            @foreach (RabbitMQExchangeInfo ex in exchanges)
                                            {
                                                <tr>
                                                    <td class="align-middle fw-semibold">@ex.ExchangeName</td>
                                                    <td class="align-middle text-muted">@ex.Vhost</td>
                                                    <td class="align-middle"><span class="badge bg-secondary-subtle text-secondary border">@ex.ExchangeType</span></td>
                                                    <td class="align-middle">@(ex.Durable ? "✓" : "—")</td>
                                                    <td class="align-middle text-end">
                                                        <button class="btn btn-sm btn-outline-info me-1"
                                                                @onclick="() => PrepareAppLink(cluster, null, ex.ExchangeName, ex.Vhost)">
                                                            <i class="bi bi-link-45deg me-1"></i>Link to App
                                                        </button>
                                                        <button class="btn btn-sm btn-outline-danger" title="Delete" aria-label="@($"Delete exchange {ex.ExchangeName}")"
                                                                @onclick='() => PrepareCascadeDelete(cluster, "exchange", ex.K8sName, ex.ExchangeName, ex.Vhost)'>
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                            }

                            @* ── Routing Bindings ── *@
                            @if (clusterTab == "routing")
                            {
                                <div class="d-flex align-items-center mb-2">
                                    <h6 class="mb-0"><i class="bi bi-signpost-split me-1 text-primary"></i>Routing Bindings</h6>
                                    <button class="btn btn-sm btn-secondary ms-auto" @onclick="() => showRoutingForm = !showRoutingForm">
                                        <i class="bi bi-plus-lg me-1"></i>Add Binding
                                    </button>
                                </div>

                                @if (showRoutingForm)
                                {
                                    <div class="card border-secondary mb-3">
                                        <div class="card-body py-2">
                                            <EditForm Model="bindingModel" OnValidSubmit="() => CreateRoutingBinding(cluster)">
                                                <DataAnnotationsValidator />
                                                <div class="row g-2">
                                                    <div class="col-md-3">
                                                        <label class="form-label small">Vhost</label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="bindingModel.Vhost" placeholder="/" />
                                                        <ValidationMessage For="() => bindingModel.Vhost" class="text-danger small" />
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="form-label small">Source Exchange</label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="bindingModel.Source" placeholder="orders" />
                                                        <ValidationMessage For="() => bindingModel.Source" class="text-danger small" />
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="form-label small">Destination</label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="bindingModel.Destination" placeholder="orders.created" />
                                                        <ValidationMessage For="() => bindingModel.Destination" class="text-danger small" />
                                                    </div>
                                                    <div class="col-md-1">
                                                        <label class="form-label small">Type</label>
                                                        <InputSelect class="form-select form-select-sm" @bind-Value="bindingModel.DestinationType">
                                                            <option value="queue">Queue</option>
                                                            <option value="exchange">Exchange</option>
                                                        </InputSelect>
                                                    </div>
                                                    <div class="col-md-2">
                                                        <label class="form-label small">Routing Key</label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="bindingModel.RoutingKey" placeholder="created" />
                                                    </div>
                                                    <div class="col-12 d-flex gap-2">
                                                        <button type="submit" class="btn btn-sm btn-primary" disabled="@submitting">
                                                            @if (submitting) { <span class="spinner-border spinner-border-sm me-1"></span> }Create
                                                        </button>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => showRoutingForm = false">Cancel</button>
                                                    </div>
                                                </div>
                                            </EditForm>
                                        </div>
                                    </div>
                                }

                                @if (loadingTopology) { <div class="text-center py-3"><span class="spinner-border spinner-border-sm text-primary"></span></div> }
                                else if (routingBindings.Count == 0) { <EmptyState Icon="bi-signpost-split" Title="No bindings" Message="No routing bindings yet." /> }
                                else
                                {
                                    <table class="table table-sm table-hover small">
                                        <thead><tr><th>Source</th><th>→</th><th>Destination</th><th>Type</th><th>Routing Key</th><th>Vhost</th><th></th></tr></thead>
                                        <tbody>
                                            @foreach (RabbitMQRoutingBindingInfo rb in routingBindings)
                                            {
                                                <tr>
                                                    <td class="align-middle">@rb.Source</td>
                                                    <td class="align-middle text-muted">→</td>
                                                    <td class="align-middle fw-semibold">@rb.Destination</td>
                                                    <td class="align-middle"><span class="badge bg-secondary-subtle text-secondary border">@rb.DestinationType</span></td>
                                                    <td class="align-middle font-monospace text-muted">@rb.RoutingKey</td>
                                                    <td class="align-middle text-muted">@rb.Vhost</td>
                                                    <td class="align-middle text-end">
                                                        <button class="btn btn-sm btn-outline-danger" title="Delete" aria-label="Delete binding"
                                                                @onclick='() => PrepareCascadeDelete(cluster, "binding", rb.K8sName, $"{rb.Source} → {rb.Destination}", rb.Vhost)'>
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                            }

                            @* ── Users ── *@
                            @if (clusterTab == "users")
                            {
                                <div class="d-flex align-items-center mb-2">
                                    <h6 class="mb-0"><i class="bi bi-person-badge me-1 text-primary"></i>Users</h6>
                                    <button class="btn btn-sm btn-secondary ms-auto" @onclick="() => showUserForm = !showUserForm">
                                        <i class="bi bi-plus-lg me-1"></i>Add User
                                    </button>
                                </div>

                                @if (showUserForm)
                                {
                                    <div class="card border-secondary mb-3">
                                        <div class="card-body py-2">
                                            <EditForm Model="userModel" OnValidSubmit="() => CreateUser(cluster)">
                                                <DataAnnotationsValidator />
                                                <div class="row g-2">
                                                    <div class="col-md-4">
                                                        <label class="form-label small">Username</label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="userModel.Username" placeholder="app-user" />
                                                        <ValidationMessage For="() => userModel.Username" class="text-danger small" />
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label class="form-label small">Password</label>
                                                        <InputText type="password" class="form-control form-control-sm" @bind-Value="userModel.Password" />
                                                        <ValidationMessage For="() => userModel.Password" class="text-danger small" />
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label class="form-label small">Tags (comma-separated)</label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="userModel.Tags" placeholder="monitoring,management" />
                                                        <div class="form-text small">management, monitoring, administrator, policymaker</div>
                                                    </div>
                                                    <div class="col-12 d-flex gap-2">
                                                        <button type="submit" class="btn btn-sm btn-primary" disabled="@submitting">
                                                            @if (submitting) { <span class="spinner-border spinner-border-sm me-1"></span> }Create
                                                        </button>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => showUserForm = false">Cancel</button>
                                                    </div>
                                                </div>
                                            </EditForm>
                                        </div>
                                    </div>
                                }

                                @if (loadingTopology) { <div class="text-center py-3"><span class="spinner-border spinner-border-sm text-primary"></span></div> }
                                else if (users.Count == 0) { <EmptyState Icon="bi-person-badge" Title="No users" Message="No topology-managed users yet." /> }
                                else
                                {
                                    <table class="table table-sm table-hover small">
                                        <thead><tr><th>Username</th><th>Tags</th><th>K8s Name</th><th></th></tr></thead>
                                        <tbody>
                                            @foreach (RabbitMQUserInfo u in users)
                                            {
                                                <tr>
                                                    <td class="align-middle fw-semibold">@u.Username</td>
                                                    <td class="align-middle">
                                                        @foreach (string tag in u.Tags)
                                                        {
                                                            <span class="badge bg-secondary-subtle text-secondary border me-1">@tag</span>
                                                        }
                                                    </td>
                                                    <td class="align-middle text-muted font-monospace">@u.K8sName</td>
                                                    <td class="align-middle text-end">
                                                        <button class="btn btn-sm btn-outline-warning me-1"
                                                                @onclick="() => PreparePermission(cluster, u.Username)">
                                                            <i class="bi bi-shield-check me-1"></i>Permissions
                                                        </button>
                                                        @TopoDeleteBtn($"user:{u.K8sName}", () => DeleteUser(cluster, u.K8sName))
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }

                                @if (showPermissionForm && permissionTargetUser is not null)
                                {
                                    <div class="card border-warning mt-3">
                                        <div class="card-header bg-warning bg-opacity-10 small fw-semibold">
                                            <i class="bi bi-shield-check me-1"></i>Set Permissions — @permissionTargetUser
                                        </div>
                                        <div class="card-body py-2">
                                            <EditForm Model="permissionModel" OnValidSubmit="() => SetPermission(cluster)">
                                                <DataAnnotationsValidator />
                                                <div class="row g-2">
                                                    <div class="col-md-3">
                                                        <label class="form-label small">Vhost</label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="permissionModel.Vhost" placeholder="/" />
                                                        <ValidationMessage For="() => permissionModel.Vhost" class="text-danger small" />
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="form-label small">Configure (regex)</label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="permissionModel.Configure" placeholder=".*" />
                                                        <ValidationMessage For="() => permissionModel.Configure" class="text-danger small" />
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="form-label small">Write (regex)</label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="permissionModel.Write" placeholder=".*" />
                                                        <ValidationMessage For="() => permissionModel.Write" class="text-danger small" />
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="form-label small">Read (regex)</label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="permissionModel.Read" placeholder=".*" />
                                                        <ValidationMessage For="() => permissionModel.Read" class="text-danger small" />
                                                    </div>
                                                    <div class="col-12 d-flex gap-2">
                                                        <button type="submit" class="btn btn-sm btn-warning" disabled="@submitting">
                                                            @if (submitting) { <span class="spinner-border spinner-border-sm me-1"></span> }Apply
                                                        </button>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => { showPermissionForm = false; }">Cancel</button>
                                                    </div>
                                                </div>
                                            </EditForm>
                                        </div>
                                    </div>
                                }
                            }

                            @* ── App Links ── *@
                            @if (clusterTab == "app-links")
                            {
                                <div class="d-flex align-items-center mb-2">
                                    <h6 class="mb-0"><i class="bi bi-link-45deg me-1 text-primary"></i>App Links</h6>
                                    <button class="btn btn-sm btn-secondary ms-auto" @onclick="() => showAppLinkForm = !showAppLinkForm">
                                        <i class="bi bi-plus-lg me-1"></i>Link App
                                    </button>
                                </div>

                                <p class="text-muted small mb-3">
                                    Each link provisions a dedicated RabbitMQ user for the app and syncs the connection details
                                    (host, port, vhost, credentials, queue/exchange) into a Kubernetes Secret in the app's namespace.
                                </p>

                                @if (showAppLinkForm)
                                {
                                    <div class="card border-secondary mb-3">
                                        <div class="card-body py-2">
                                            <div class="alert alert-info py-2 small mb-3">
                                                <i class="bi bi-person-plus me-1"></i>
                                                A dedicated RabbitMQ user with full access to the chosen vhost will be automatically
                                                created and its credentials stored in the vault, then synced into the K8s secret below.
                                            </div>
                                            <EditForm Model="appLinkModel" OnValidSubmit="() => CreateAppLink(cluster)">
                                                <DataAnnotationsValidator />
                                                <div class="row g-2">
                                                    <div class="col-md-4">
                                                        <label class="form-label small">App Deployment</label>
                                                        <InputSelect class="form-select form-select-sm" @bind-Value="appLinkModel.DeploymentId">
                                                            <option value="">Select deployment...</option>
                                                            @foreach (AppDeployment dep in allDeployments)
                                                            {
                                                                <option value="@dep.Id">@dep.App.Customer.Name / @dep.App.Name / @dep.Name (@dep.Cluster.Name)</option>
                                                            }
                                                        </InputSelect>
                                                        <ValidationMessage For="() => appLinkModel.DeploymentId" class="text-danger small" />
                                                    </div>
                                                    <div class="col-md-2">
                                                        <label class="form-label small">Vhost</label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="appLinkModel.Vhost" placeholder="/" />
                                                        <ValidationMessage For="() => appLinkModel.Vhost" class="text-danger small" />
                                                    </div>
                                                    <div class="col-md-2">
                                                        <label class="form-label small">Queue <span class="text-muted">(optional)</span></label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="appLinkModel.Queue" placeholder="orders.created" />
                                                    </div>
                                                    <div class="col-md-2">
                                                        <label class="form-label small">Exchange <span class="text-muted">(optional)</span></label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="appLinkModel.Exchange" placeholder="orders" />
                                                    </div>
                                                    <div class="col-md-2">
                                                        <label class="form-label small">K8s Secret Name</label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="appLinkModel.SecretName" placeholder="rabbitmq" />
                                                        <ValidationMessage For="() => appLinkModel.SecretName" class="text-danger small" />
                                                    </div>
                                                    <div class="col-12 d-flex gap-2">
                                                        <button type="submit" class="btn btn-sm btn-primary" disabled="@submitting">
                                                            @if (submitting) { <span class="spinner-border spinner-border-sm me-1"></span> }Link &amp; Sync
                                                        </button>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => showAppLinkForm = false">Cancel</button>
                                                    </div>
                                                </div>
                                            </EditForm>
                                        </div>
                                    </div>
                                }

                                @if (loadingTopology) { <div class="text-center py-3"><span class="spinner-border spinner-border-sm text-primary"></span></div> }
                                else if (messagingBindings.Count == 0) { <EmptyState Icon="bi-link-45deg" Title="No app links" Message="No app links yet." /> }
                                else
                                {
                                    <table class="table table-sm table-hover small">
                                        <thead>
                                            <tr><th>App / Deployment</th><th>Vhost</th><th>Queue</th><th>Exchange</th><th>Secret</th><th>Last Synced</th><th></th></tr>
                                        </thead>
                                        <tbody>
                                            @foreach (MessagingBinding mb in messagingBindings)
                                            {
                                                <tr>
                                                    <td class="align-middle">
                                                        <div class="fw-semibold">@mb.AppDeployment.App.Customer.Name / @mb.AppDeployment.App.Name</div>
                                                        <small class="text-muted">@mb.AppDeployment.Name (@mb.AppDeployment.Cluster.Name)</small>
                                                    </td>
                                                    <td class="align-middle">@mb.Vhost</td>
                                                    <td class="align-middle text-muted">@(mb.QueueName ?? "—")</td>
                                                    <td class="align-middle text-muted">@(mb.ExchangeName ?? "—")</td>
                                                    <td class="align-middle font-monospace">@mb.KubernetesSecretName</td>
                                                    <td class="align-middle text-muted">
                                                        @if (mb.LastSyncedAt.HasValue)
                                                        {
                                                            @mb.LastSyncedAt.Value.ToLocalTime().ToString("MM-dd HH:mm")
                                                        }
                                                        else
                                                        {
                                                            <span class="text-warning">Not synced</span>
                                                        }
                                                    </td>
                                                    <td class="align-middle text-end">
                                                        <button class="btn btn-sm btn-outline-primary me-1" aria-label="Sync app link"
                                                                @onclick="() => SyncAppLink(mb)" disabled="@(syncingLinkId == mb.Id)">
                                                            @if (syncingLinkId == mb.Id)
                                                            {
                                                                <span class="spinner-border spinner-border-sm"></span>
                                                            }
                                                            else
                                                            {
                                                                <i class="bi bi-arrow-clockwise"></i>
                                                            }
                                                        </button>
                                                        <button class="btn btn-sm btn-outline-danger" aria-label="Delete app link" @onclick="() => DeleteAppLink(cluster, mb)">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                            }

                            @* ── Backup & Restore ── *@
                            @if (clusterTab == "backup")
                            {
                                @if (!cluster.StorageLinkId.HasValue)
                                {
                                    <div class="alert alert-secondary py-2 small">
                                        <i class="bi bi-info-circle me-1"></i>
                                        No S3 storage link is attached to this cluster. Edit the cluster to add one before creating backups.
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex align-items-center gap-2 mb-3">
                                        <span class="small text-muted">
                                            Definitions exported via <code>rabbitmqctl export_definitions</code> and stored as JSON in S3.
                                        </span>
                                        <button class="btn btn-sm btn-primary ms-auto" @onclick="() => TriggerBackup(cluster)"
                                                disabled="@(backingUp == cluster.Id)">
                                            @if (backingUp == cluster.Id) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                            <i class="bi bi-cloud-arrow-up me-1"></i>Export Now
                                        </button>
                                    </div>

                                    @* ── Scheduled backups ── *@
                                    <div class="card border-secondary mb-3">
                                        <div class="card-body py-2">
                                            <EditForm Model="scheduleModel" OnValidSubmit="() => SaveSchedule(cluster)">
                                                <DataAnnotationsValidator />
                                                <div class="row g-2 align-items-end">
                                                    <div class="col-md-5">
                                                        <label class="form-label small mb-1">Backup Schedule (cron)</label>
                                                        <InputText class="form-control form-control-sm" @bind-Value="scheduleModel.Schedule"
                                                                   placeholder="0 2 * * *  (empty = disabled)" />
                                                        <div class="form-text small">Deploys a CronJob that exports definitions to S3. 5-field cron.</div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="form-label small mb-1">Keep last</label>
                                                        <InputNumber class="form-control form-control-sm" @bind-Value="scheduleModel.MaxBackups" min="1" />
                                                        <ValidationMessage For="() => scheduleModel.MaxBackups" class="text-danger small" />
                                                    </div>
                                                    <div class="col-md-4">
                                                        <button type="submit" class="btn btn-sm btn-secondary" disabled="@savingSchedule">
                                                            @if (savingSchedule) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                            <i class="bi bi-clock me-1"></i>Save Schedule
                                                        </button>
                                                        @if (!string.IsNullOrEmpty(cluster.BackupSchedule))
                                                        {
                                                            <span class="badge bg-info-subtle text-info border border-info-subtle ms-2">@cluster.BackupSchedule</span>
                                                        }
                                                    </div>
                                                </div>
                                                @if (!string.IsNullOrEmpty(scheduleError)) { <div class="alert alert-danger py-1 small mt-2 mb-0">@scheduleError</div> }
                                            </EditForm>
                                        </div>
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(backupError))
                                {
                                    <div class="alert alert-danger py-2 small mb-3">@backupError</div>
                                }

                                @if (showRestoreForm && restoreBackupId.HasValue)
                                {
                                    <div class="card border-warning mb-3">
                                        <div class="card-header bg-warning bg-opacity-10 small fw-semibold">
                                            <i class="bi bi-cloud-arrow-down me-1"></i>Restore Definitions
                                        </div>
                                        <div class="card-body py-2">
                                            <div class="mb-2">
                                                <label class="form-label small">Target Cluster</label>
                                                <select class="form-select form-select-sm" @bind="restoreTargetClusterId">
                                                    <option value="@cluster.Id">This cluster — @cluster.Name</option>
                                                    @foreach (RabbitMQCluster other in clusters.Where(c => c.Id != cluster.Id))
                                                    {
                                                        <option value="@other.Id">@other.Name (@other.KubernetesCluster.Name)</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-sm btn-warning" @onclick="ExecuteRestore" disabled="@restoring">
                                                    @if (restoring) { <span class="spinner-border spinner-border-sm me-1"></span> }Restore
                                                </button>
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        @onclick="() => { showRestoreForm = false; restoreBackupId = null; }">Cancel</button>
                                            </div>
                                        </div>
                                    </div>
                                }

                                @if (loadingBackups) { <div class="text-center py-3"><span class="spinner-border spinner-border-sm text-primary"></span></div> }
                                else if (clusterBackups.Count == 0) { <EmptyState Icon="bi-clock-history" Title="No backups" Message="No backups yet." /> }
                                else
                                {
                                    <table class="table table-sm table-hover small">
                                        <thead><tr><th>Created</th><th>Size</th><th>Status</th><th></th></tr></thead>
                                        <tbody>
                                            @foreach (RabbitMQBackup backup in clusterBackups)
                                            {
                                                <tr>
                                                    <td class="align-middle">@backup.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                                    <td class="align-middle text-muted">@FormatBytes(backup.SizeBytes)</td>
                                                    <td class="align-middle">
                                                        <span class="badge @BackupBadgeClass(backup.Status)">@backup.Status</span>
                                                    </td>
                                                    <td class="align-middle text-end">
                                                        @if (backup.Status == RabbitMQBackupStatus.Ready)
                                                        {
                                                            <button class="btn btn-sm btn-outline-warning me-1" @onclick="() => PrepareRestore(backup)">
                                                                <i class="bi bi-cloud-arrow-down me-1"></i>Restore
                                                            </button>
                                                        }
                                                        <button class="btn btn-sm btn-outline-danger" aria-label="Delete backup" @onclick="() => DeleteBackup(backup)">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                            }

                            @* ── Credentials ── *@
                            @if (clusterTab == "credentials")
                            {
                                <p class="small text-muted mb-2">
                                    Admin credentials generated by the Cluster Operator, stored encrypted in the tenant vault.
                                    Source: K8s Secret <code>@(cluster.Name)-default-user</code> in <code>@cluster.Namespace</code>.
                                </p>

                                @if (loadingCredentials) { <div class="text-center py-3"><span class="spinner-border spinner-border-sm text-primary"></span></div> }
                                else if (adminUsername is not null)
                                {
                                    <div class="row g-2 mb-2">
                                        <div class="col-md-6">
                                            <label class="form-label small text-muted">Username</label>
                                            <input type="text" class="form-control form-control-sm font-monospace" value="@adminUsername" readonly />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small text-muted">Password</label>
                                            <div class="input-group input-group-sm">
                                                <input type="@(showPassword ? "text" : "password")"
                                                       class="form-control form-control-sm font-monospace" value="@adminPassword" readonly />
                                                <button class="btn btn-outline-secondary" aria-label="Toggle password visibility" @onclick="() => showPassword = !showPassword">
                                                    <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    <span class="badge bg-success-subtle text-success border border-success-subtle">
                                        <i class="bi bi-shield-lock me-1"></i>Stored in vault
                                    </span>
                                }
                                else
                                {
                                    <div class="alert alert-secondary py-2 small">
                                        <i class="bi bi-info-circle me-1"></i>
                                        Credentials not yet in vault. Click <strong>Sync from K8s</strong> once the cluster is running.
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(credentialError))
                                {
                                    <div class="alert alert-danger py-2 small mt-2">@credentialError</div>
                                }

                                <div class="mt-2 d-flex gap-2">
                                    <button class="btn btn-sm btn-primary" @onclick="() => SyncCredentials(cluster)" disabled="@syncingCredentials">
                                        @if (syncingCredentials) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                        <i class="bi bi-cloud-download me-1"></i>Sync from K8s
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => LoadCredentials(cluster)">
                                        <i class="bi bi-arrow-clockwise me-1"></i>Refresh
                                    </button>
                                </div>

                                <hr class="my-3" />

                                <div class="d-flex gap-2">
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => RefreshClusterStatus(cluster)"
                                            disabled="@(refreshingStatus == cluster.Id)">
                                        @if (refreshingStatus == cluster.Id) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                        <i class="bi bi-arrow-repeat me-1"></i>Refresh Status
                                    </button>
                                    <button class="btn btn-sm btn-outline-warning" @onclick="() => ShowClusterEdit(cluster)">
                                        <i class="bi bi-pencil me-1"></i>Edit Cluster
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger ms-auto" @onclick="() => ConfirmDeleteCluster(cluster)">
                                        <i class="bi bi-trash me-1"></i>Delete Cluster
                                    </button>
                                </div>
                            }

                            @if (clusterTab == "metrics")
                            {
                                <RabbitMQMonitoringPanel ClusterId="cluster.KubernetesClusterId" />
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>

    @* ── Delete confirmation modal ── *@
    @if (deleteTarget is not null)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title text-danger"><i class="bi bi-trash me-2"></i>Delete RabbitMQ Cluster</h5>
                    </div>
                    <div class="modal-body">
                        <p>Delete <strong>@deleteTarget.Name</strong> from Kubernetes?</p>
                        <p class="text-danger small">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            This deletes the RabbitmqCluster CRD and associated PVCs. Messages in non-durable queues are lost.
                            S3 backups are not affected.
                        </p>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-outline-secondary" @onclick="() => deleteTarget = null">Cancel</button>
                        <button class="btn btn-danger" @onclick="DeleteCluster" disabled="@deleting">
                            @if (deleting) { <span class="spinner-border spinner-border-sm me-1"></span> }Delete
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @* ── Cluster edit modal ── *@
    @if (editClusterId is not null)
    {
        RabbitMQCluster? editCluster = clusters.FirstOrDefault(c => c.Id == editClusterId);
        if (editCluster is not null)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title"><i class="bi bi-pencil me-2 text-warning"></i>Edit Cluster — @editCluster.Name</h5>
                            <button type="button" class="btn-close" aria-label="Close" @onclick="() => editClusterId = null"></button>
                        </div>
                        <EditForm Model="editModel" OnValidSubmit="() => SaveClusterEdit(editCluster)">
                            <DataAnnotationsValidator />
                            <div class="modal-body">
                                <div class="row g-2">
                                    <div class="col-md-3">
                                        <label class="form-label small mb-1">Version</label>
                                        <InputText class="form-control form-control-sm" @bind-Value="editModel.Version" />
                                        <ValidationMessage For="() => editModel.Version" class="text-danger small" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small mb-1">Replicas</label>
                                        <InputNumber class="form-control form-control-sm" @bind-Value="editModel.Replicas" min="1" max="9" />
                                        <ValidationMessage For="() => editModel.Replicas" class="text-danger small" />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label small mb-1">Storage Size</label>
                                        <InputText class="form-control form-control-sm" @bind-Value="editModel.StorageSize" />
                                        <ValidationMessage For="() => editModel.StorageSize" class="text-danger small" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small mb-1">Storage Class</label>
                                        <InputText class="form-control form-control-sm" @bind-Value="editModel.StorageClass" />
                                    </div>
                                </div>
                                <div class="form-text small mt-1">Storage can only grow; the operator applies a rolling update.</div>
                                @if (!string.IsNullOrEmpty(editError)) { <div class="alert alert-danger py-1 small mt-2 mb-0">@editError</div> }
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-outline-secondary" @onclick="() => editClusterId = null">Cancel</button>
                                <button type="submit" class="btn btn-warning" disabled="@savingEdit">
                                    @if (savingEdit) { <span class="spinner-border spinner-border-sm me-1"></span> }Save Changes
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        }
    }

    @* ── Cascade delete modal (vhost / queue / exchange / binding) ── *@
    @if (cascadeCluster is not null && cascadeKind is not null)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title text-danger"><i class="bi bi-trash me-2"></i>Delete @cascadeKind</h5>
                        <button type="button" class="btn-close" aria-label="Close" @onclick="CancelCascadeDelete" disabled="@cascadeDeleting"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-2">Delete <strong>@cascadeDisplay</strong>?</p>
                        @if (cascadeLoading)
                        {
                            <div class="text-muted small"><span class="spinner-border spinner-border-sm me-1"></span>Checking dependents…</div>
                        }
                        else if (cascadeDependents.Count == 0)
                        {
                            <p class="text-muted small mb-0">No dependent topology objects.</p>
                        }
                        else
                        {
                            <p class="text-danger small mb-1">
                                <i class="bi bi-exclamation-triangle me-1"></i>
                                The following @cascadeDependents.Count dependent object(s) will also be deleted:
                            </p>
                            <ul class="small mb-0" style="max-height:14rem;overflow-y:auto">
                                @foreach (RabbitMQCascadeItem dep in cascadeDependents)
                                {
                                    <li><span class="badge bg-secondary-subtle text-secondary border me-1">@dep.Kind</span>@dep.Display</li>
                                }
                            </ul>
                        }
                        @if (!string.IsNullOrEmpty(cascadeError)) { <div class="alert alert-danger py-1 small mt-2 mb-0">@cascadeError</div> }
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-outline-secondary" @onclick="CancelCascadeDelete" disabled="@cascadeDeleting">Cancel</button>
                        <button class="btn btn-danger" @onclick="ConfirmCascadeDelete" disabled="@(cascadeDeleting || cascadeLoading)">
                            @if (cascadeDeleting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Delete@(cascadeDependents.Count > 0 ? $" + {cascadeDependents.Count} dependent(s)" : "")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
}
</LoadingPanel>

