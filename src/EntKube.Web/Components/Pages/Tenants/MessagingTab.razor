    private async Task PreparePermission(RabbitMQCluster cluster, string username)
    {
        permissionTargetUser = username;
        permVhost = "/"; permConfigure = ".*"; permWrite = ".*"; permRead = ".*";
        showPermissionForm = true;

        // Pre-populate from an existing Permission CRD for this user, if any.
        try
        {
            List<RabbitMQPermissionInfo> perms = await RabbitMQService.GetPermissionsAsync(TenantId, cluster.Id);
            RabbitMQPermissionInfo? existing = perms.FirstOrDefault(p => p.User == username);
            if (existing is not null)
            {
                permVhost = existing.Vhost;
                permConfigure = existing.Configure;
                permWrite = existing.Write;
                permRead = existing.Read;
            }
        }
        catch { /* fall back to defaults */ }
    }

    private async Task SetPermission(RabbitMQCluster cluster)
    {
        if (permissionTargetUser is null) return;
        submitting = true; topologyError = null;
        try
        {
            await RabbitMQService.SetPermissionAsync(TenantId, cluster.Id,
                permVhost, permissionTargetUser, permConfigure, permWrite, permRead);
            showPermissionForm = false;
        }
        catch (Exception ex) { topologyError = ex.Message; }
        finally { submitting = false; }
    }

