    // ── Cascade delete (vhost / queue / exchange / binding) ─────────────────────

    private async Task PrepareCascadeDelete(
        RabbitMQCluster cluster, string kind, string k8sName, string display, string vhost)
    {
        cascadeCluster = cluster;
        cascadeKind = kind;
        cascadeK8sName = k8sName;
        cascadeDisplay = display;
        cascadeVhost = vhost;
        cascadeDependents = [];
        cascadeError = null;
        cascadeDeleting = false;
        cascadeLoading = kind != "binding";

        if (cascadeLoading)
        {
            try
            {
                // For vhost the resource name is the vhost path itself.
                cascadeDependents = await RabbitMQService.GetCascadeDependentsAsync(
                    TenantId, cluster.Id, kind, vhost, display);
