    {
        savingSchedule = true;
        scheduleError = null;
        try
        {
            await RabbitMQService.UpdateBackupScheduleAsync(
                TenantId, cluster.Id,
                string.IsNullOrWhiteSpace(scheduleModel.Schedule) ? null : scheduleModel.Schedule.Trim(),
                scheduleModel.MaxBackups);
            await LoadAsync();
            Toasts.Success("Backup schedule saved.");
        }
        catch (Exception ex) { scheduleError = ex.Message; }
        finally { savingSchedule = false; }
