    private async Task ConfirmCascadeDelete()
    {
        if (cascadeCluster is null || cascadeKind is null || cascadeK8sName is null) return;
        cascadeDeleting = true;
        cascadeError = null;
        try
        {
            Guid clusterId = cascadeCluster.Id;
            await RabbitMQService.DeleteTopologyCascadeAsync(
                TenantId, clusterId, cascadeKind, cascadeK8sName, cascadeDependents);
            CancelCascadeDelete();
            await LoadTopologyTab(clusterId);
        }
        catch (Exception ex) { cascadeError = ex.Message; cascadeDeleting = false; }
    }

    private void CancelCascadeDelete()
    {
        cascadeCluster = null;
        cascadeKind = null;
        cascadeK8sName = null;
        cascadeDisplay = null;
        cascadeVhost = "";
        cascadeDependents = [];
        cascadeError = null;
        cascadeDeleting = false;
        cascadeLoading = false;
    }

