{
  "DatabaseProvider": "Sqlite",
  "Auth": {
    "AllowRegistration": true
  },
  "Presence": {
    "//": "Live 'online now' backend for the admin users page. 'InMemory' (default) is process-local; set Provider to 'Redis' with ConnectionStrings:Redis for cross-instance presence.",
    "Provider": "InMemory",
    "StaleAfterSeconds": 30,
    "RefreshSeconds": 10
  },
  "ClusterChanges": {
    "//": "When true (default), every human-triggered change to Kubernetes cluster state pauses to show a server-side dry-run diff that an operator must acknowledge before it is applied. Automated/background flows are never gated. Set false to disable the gate.",
    "RequireAcknowledgment": true
  },
  "ConnectionStrings": {
    "DefaultConnection": "DataSource=Data/app.db;Cache=Shared"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient.RouteHealth": "Warning"
    }
  },
  "AllowedHosts": "*"
}
